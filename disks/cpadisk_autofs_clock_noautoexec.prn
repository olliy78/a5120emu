  D40C    FA D3E7        C      	jp	m,kbdwin	;ja, keine Dauerfunktion
  D40F    CD D3C2        C      	call	kbdput		;sonst puffern
  D412    18 0A          C      	jr	kbdinn		;und aeltestes Pufferzeichen uebergeben
  D414    CD D34F        C      kbdwb:	call	kbdst		;abwarten tastendruck
  D417    28 FB          C      	jr	z,kbdwb
  D419    21 D3F0        C      kbdwe:	ld	hl,kbdwt	;bei neuer taste
  D41C    36 64          C      	ld	(hl),100	;100*0.01 sec warten
