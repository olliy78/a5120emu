                                  IF cdtdc1 or cdtdtr
                         C      	include BIOSCSIO
                         C      ;===================================================================
                         C      ; SIO-Treiber, DTR- und DC1/DC3-Protokoll
                         C      ;===================================================================
                         C      ;
                         C      ; Aenderungen:
                         C      ; - Statusabfrage jedesmal, auch wenn zuvor frei gemeldet
                         C      ; - Pufferueberlauf bei UC1-Puffer kontrolliert
                         C      ; - bei DC1/DC3 nach Initialisierung 7fh an Drucker und max. 30 sec auf
                         C      ;  Antwort gewartet (sonst Fehler am SD1157, wenn zu frueh gesendet wird)
                         C      ; 29.6.88:
                         C      ; - bei DC1/3 Protokoll wird neu initialisiert, wenn DC4 vom Drucker kommt
                         C      ;  (Probleme bei K6314)
                         C      ; 20.09.88
                         C      ; - Neben DTR-Statusabfrage ueber Kanal B, Bit 3 (Treiber 1, Standard)
                         C      ;  auch DTR-Statusabfrage ueber Kanal A, Bit 5 (Treiber 3) unterstuetzt
                         C      ; 23.03.89
                         C      ; - CTS-Zusammenspiel bei K6311 u.ae. funktioniert nur, wenn bis zum
                         C      ;   Verlassen aller Bits aus dem Sender gewartet wird und nicht nur auf
                         C      ;   das Freiwerden des Sendepuffers - sonst Zeichenverlust!
                         C      ; - wenn UC1 am Kanal A wird WR1 Bit2 und WR2 im Kanal B gesetzt
                         C       IF cpu eq c1715
                         C       ENDIF
                         C      ; 04.04.89
                         C      ; - nach Drucker-Init 'set 0,(ix+ltpst)' statt 'ld (ix+ltpst),11h'
                         C      ; 06.07.89
                         C      ; - wegen K6314-Problemen wird nach Initialisierung DC1 angenommen
                         C      ; - bei UC1-Kopplung ueber DTR ohne Warten auf Senderegister leer,
                         C      ;   nur Warten auf Sendepuffer leer
                         C      ;   (Aenderung 23.03.89 daher nur fuer Drucker wirksam, sonst zu langsam)
                         C      ; 15.09.89
                         C      ; - bei UC1-Kopplung ueber DC1/DC3 nicht 7fh zu Beginn gesendet, sondern DC1
                         C      ;**************************************************************************
                         C      
  D32F                   C      cdsioi	equ	dumi		;keine Zeicheneingabe unterstuetzt
                         C      
                         C      ; Einzelzeichenausgabe Reg. A
  D9D4    DD 4E 02       C      cdsioo:	ld	c,(ix+ltpsd)	;Datenport
  D9D7    ED 79          C      	out	(c),a
  D9D9    C9             C      	ret
                         C      
                         C      ;------------------------------------
                         C      
                         C      ; Statusabfrage
  D9DA    DD 7E 00       C      cdsios:	ld	a,(ix+ltpst)	;Status
  D9DD    CB 4F          C      	bit	1,a		;senderseitig blockiert?
  D9DF    20 3F          C      	jr	nz,lstsr	;ja, frei rueckmelden
  D9E1    B7             C      	or	a		;initialisiert?
  D9E2    CC DA47        C      	call	z,cdsins	;nein
  D9E5    DD CB 0A 7E    C      	bit	7,(ix+ltpw5)	;Prozedur DTR?
  D9E9    28 3A          C      	JR	Z,lstsdc	;nein
  D9EB    DD 4E 03       C      	ld	c,(ix+ltpsc)	;SIO Kommando
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-55


                         C       IF iobuc1
  D9EE    DD CB 01 7E    C      	bit	7,(ix+ltpdc)	;Warten auf Senderegister leer?
  D9F2    28 0C          C      	jr	z,lstse0	;ja
  D9F4    3E 10          C      	ld	a,00010000b	;Reset Ext/Status-Interrupt, Lesereg. 0
  D9F6    ED 79          C      	out	(c),a		;Status abspeichern
  D9F8    ED 78          C      	in	a,(c)		;Lesereg. 0
  D9FA    CB 57          C      	bit	2,a		;Sendepuffer leer?
  D9FC    20 0C          C      	jr	nz,lstse1	;ja
  D9FE    18 20          C      	jr	lstsr		;nein, Drucker besetzt
  DA00                   C      lstse0:
                         C       ENDIF
                         C       IF cpu eq c1715 ;wegen evtl. parallelem Tastaturpolling am gleichen SIO-Kanal
                         C       ENDIF
  DA00    3E 11          C      	LD	a,00010001b	;Reset Ext/Status-Interrupt, Lesereg. 1
  DA02    ED 79          C      	OUT	(C),a		;Status abspeichern
  DA04    ED 78          C      	IN	a,(C)		;Leseregister 1
                         C       IF cpu eq c1715 ;wegen evtl. parallelem Tastaturpolling am gleichen SIO-Kanal
                         C       ENDIF
  DA06    CB 47          C      	bit	0,a		;alle Bits gesendet?
                         C      				; Sendepuffer frei reicht nicht, da
                         C      				; K6311 u.ae. nicht korrekt arbeiten
  DA08    28 16          C      	jr	z,lstsr		;nein, Drucker besetzt
  DA0A    DD CB 01 5E    C      lstse1:	bit	3,(ix+ltpdc)	;Abfrage DTR ueber DCD im Kanal B?
  DA0E    20 06          C      	jr	nz,lstsb3	;ja
  DA10    ED 78          C      	in	a,(c)		;Leseregister 0
  DA12    CB 6F          C      	bit	5,a		;CTS?
  DA14    18 0A          C      	jr	lstsr		;nz bei ja
  DA16    0C             C      lstsb3:	inc	c
  DA17    0C             C      	inc	c		;auf Kanal B
  DA18    3E 10          C      	LD	a,00010000b	;Reset Ext/Status-Interrupt, Lesereg. 0
  DA1A    ED 79          C      	out	(c),a		;DCD in RR0 Kanal B abspeichern
  DA1C    ED 78          C      	in	a,(c)		;Leseregister 0 des Kanal B
  DA1E    CB 5F          C      	bit	3,a		;DCD im Kanal B (ist DTR-Bit vom Kanal A)
                         C      ; Ausgang Senderstatus
  DA20                   C      lstsr:
  DA20    3E FF          C      lstsr1:	ld	a,0ffh
  DA22    C0             C      	ret	nz		;senderseitig frei
  DA23    3C             C      	inc	a		;A=00, ret z
  DA24    C9             C      	RET			;senderseitig besetzt
                         C      ;-----------------------
                         C      ; DC1/DC3 und XON/XOFF
  DA25    DD 4E 02       C      lstsdc:	LD	C,(ix+ltpsd)	;SIO Daten
  DA28    ED 78          C      	IN	A,(C)		;Status lesen (SIO speichert letzten Status)
  DA2A    DD 77 01       C      	LD	(ix+ltpdc),A	;zuletzt empf. Zeichen fuer Fehlersuche merken
  DA2D    E6 7F          C      	and	7fh		;evtl. Paritaet ignorieren
  DA2F    FE 13          C      	cp	13h		;DC3?
  DA31    28 12          C      	jr	z,lstsd2	;ja, besetzt
  DA33    FE 14          C      	cp	14h		;DC4 (Status)?
  DA35    20 05          C      	jr	nz,lstsd1	;nein (DC1 angenommen)
  DA37    CD DA7B        C      	call	cdsini		;statt Status abzuholen neu initialisieren
  DA3A    18 E9          C      	jr	lstsdc		;und Status neu abfragen
  DA3C    DD 4E 03       C      lstsd1:	ld	c,(ix+ltpsc)	;SIO Kommando
  DA3F    ED 78          C      	in	a,(c)
  DA41    CB 57          C      	bit	2,a		;Sendepuffer leer? (nz bei ja)
  DA43    18 DB          C      	jr	lstsr
  DA45    AF             C      lstsd2:	xor	a		;A=00, ret z
  DA46    C9             C      	ret			;senderseitig besetzt
                         C      
                         C      ;-----------------------
                         C      
                         C      ; (Re-)Initialisierung
                         C      ; IX auf Steuertabelle
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-56


                         C      ; ret: C zeigt auf Kommandoport
                         C      
                         C      ; Sender initialisieren
  DA47                   C      cdsins:
  DA47    DD CB 00 C6    C      	set	0,(ix+ltpst)	;Sender ist initialisiert
  DA4B    CD DA7B        C      	call	cdsini
  DA4E    DD CB 0A 7E    C      	bit	7,(ix+ltpw5)	;Prozedur DC1/DC3?
  DA52    C0             C      	ret	nz		;nein
  DA53    41             C      	ld	b,c
  DA54    DD 4E 02       C      	ld	c,(ix+ltpsd)	;Datenport
                         C       IF iobuc1
  DA57    DD CB 01 7E    C       	bit	7,(ix+ltpdc)	;Warten auf Senderegister leer?
  DA5B    28 06          C      	jr	z,cdsind	;ja, Drucker
  DA5D    3E 11          C      	ld	a,11h		;bei UC1: mit DC1/DC3-Protokoll DC1 senden
  DA5F    ED 79          C      	out	(c),a
  DA61    48             C      	ld	c,b
  DA62    C9             C      	ret
                         C       ENDIF
  DA63    3E 7F          C      cdsind:	ld	a,7fh		;nach Initialisierung RESET senden
  DA65    ED 79          C      	out	(c),a
  DA67    48             C      	ld	c,b
  DA68    11 0BB8        C      	ld	de,30*100	;max. Wartezeit ca. 30 sec (SD1157!)
  DA6B    ED 78          C      cdsinw:	in	a,(c)
  DA6D    CB 47          C      	bit	0,a		;Antwort da?
  DA6F    C0             C      	ret	nz		;ja
  DA70    06 01          C      	ld	b,1
  DA72    CD E7F3        C      	call	wait10		;10ms warten
  DA75    1B             C      	dec	de
  DA76    7A             C      	ld	a,d
  DA77    B3             C      	or	e		;max. Wartezeit abgelaufen?
  DA78    20 F1          C      	jr	nz,cdsinw	;nein
  DA7A    C9             C      	ret			;sonst Drucker wohl nicht bereit
                         C      
                         C      
                         C      ; gem. UP fuer Sender und Empf. initialisieren
  DA7B                   C      cdsini:
  DA7B    DD E5          C      	push	ix
  DA7D    E1             C      	pop	hl
  DA7E    01 000B        C      	ld	bc,ltpini
  DA81    09             C      	add	hl,bc
                         C       IF cpu eq c1715 ;wegen evtl. parallelem Tastaturpolling am gleichen SIO-Kanal
                         C       ENDIF
  DA82    CD D973        C      	call	portpr		;CTC, WR0, WR4, WR1, WR3
                         C       IF cpu eq c1715 ;wegen evtl. parallelem Tastaturpolling am gleichen SIO-Kanal
                         C       ENDIF
  DA85    DD 5E 0A       C      ltpow5:	LD	e,(ix+ltpw5)	;Prozedurtyp/Bitanzahl
                         C      ; Stellen Schreibregister 5
                         C      ; Reg. B,HL bleiben erhalten
  DA88    3E 05          C      ltpot5:	ld	a,5
  DA8A    DD 4E 03       C      	ld	c,(ix+ltpsc)
                         C       IF cpu eq c1715 ;wegen evtl. parallelem Tastaturpolling am gleichen SIO-Kanal
                         C       ENDIF
  DA8D    ED 79          C      	OUT	(C),A
  DA8F    ED 59          C      	OUT	(C),e
                         C       IF cpu eq c1715 ;wegen evtl. parallelem Tastaturpolling am gleichen SIO-Kanal
                         C       ENDIF
  DA91    C9             C      	RET
                         C      
                         C      ;-------------------------------------
                         C       if iobuc1
                         C      
                         C      ; UC1-Routinen (ausser Senden)
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-57


                         C      
                         C      ; UC1: Empf.-Status
                         C      ;==================
                         C      ; o A=0, ret z	: kein Zeichen empfangen
                         C      ; o A=ff,ret nz	: Zeichen da
  DA92    DD 21 D9B7     C      uc1st:	ld	ix,lstuc1	;Stellen IX auf Steuertabelle
  DA96                   C      uc1si:	;interner Aufruf mit gestelltem IX
  DA96    DD CB 00 66    C      	bit	4,(ix+ltpst)	;initialisiert?
  DA9A    20 19          C      	jr	nz,uc1si1	;ja
  DA9C    AF             C      	xor	a
  DA9D    32 DB63        C      	ld	(uc1bfp),a	;Puffer leeren
  DAA0    CD DA7B        C      	call	cdsini		;Initialisierung
  DAA3    DD CB 00 E6    C      	set	4,(ix+ltpst)	;Empfaenger ist initialisiert
  DAA7    F3             C      	di
                         C       IF (uc1dat xor uc1sta) eq 01b	;Kanal-Nr ist Bit 1 (bei Buerocomp und OEM)
                         C        IF (uc1sta and 10b) eq 00b	;UC1 ist an Kanal A
  DAA8    CB C9          C      	set	1,c		;Kanal B erzwingen
                         C        ENDIF
                         C       ENDIF
  DAAA    21 DABD        C      	ld	hl,uc1i2	;WR1,WR2 programmieren
  DAAD    06 04          C       	ld	b,uc1il
  DAAF    ED B3          C      	otir
  DAB1    FB             C      	ei
  DAB2    CD DAEC        C      	call	uc1ird		;DTR bzw. DC1 senden
  DAB5    3A DB63        C      uc1si1:	ld	a,(uc1bfp)	;Zeichen im Empfpuffer?
  DAB8    B7             C      	or	a
  DAB9    C8             C      	ret	z		;nein
  DABA    3E FF          C      	ld	a,0ffh
  DABC    C9             C      	ret
                         C      
  DABD                   C      uc1i2: ;zusaetzliche Initialisierung fuer WR1/Bit2 und WR2 (beide nur Kanal B)
                         C       IF (uc1dat xor uc1sta) eq 01b	;Kanal-Nr ist Bit 1 (bei Buerocomp und OEM)
                         C        IF (uc1sta and 10b) eq 00b	;UC1 ist an Kanal A
  DABD    01 04          C      	db	1,00000100b	;WR1, Kanal B: Intv.modif. setzen
                         C        ENDIF
                         C       ENDIF
  DABF    02 D0          C      	db	2,ivsio0	;WR2, Kanal B: Interruptvektor
  0004                   C      uc1il	equ	$-uc1i2
                         C      ; UC1: empf. Zeichen an Nutzer
                         C      ;=============================
                         C      ; o A:	aeltestes empf. Zeichen
                         C      
  DAC1    DD 21 D9B7     C      uc1i:	ld	ix,lstuc1	;Stellen IX auf Steuertabelle
                         C      
  DAC5                   C      uc1ii:	;interner Aufruf mit gestelltem IX
  DAC5    FB             C      uc1iw:	ei			;UC1:-Interrupt zulassen
  DAC6    CD DA96        C      	call	uc1si		;Zeichen da?
  DAC9    28 FA          C      	jr	z,uc1iw		;nein ***keine Zeitueberwachung!***
  DACB    21 DB63        C      	ld	hl,uc1bfp
  DACE    F3             C      	di
  DACF    4E             C      	ld	c,(hl)
  DAD0    35             C      	dec	(hl)		;Pufferlaenge -1
  DAD1    06 00          C      	ld	b,0
  DAD3    23             C      	inc	hl		;^(aeltestes Pufferzeichen)
  DAD4    7E             C      	ld	a,(hl)		;Zeichen nach A
  DAD5    11 DB65        C      	ld	de,uc1buf+1
  DAD8    EB             C      	ex	de,hl
  DAD9    ED B0          C      	ldir			;Puffer aufschieben
  DADB    FB             C      	ei
  DADC    DD CB 00 7E    C      	bit	7,(ix+ltpst)	;war Stopaufforderung?
  DAE0    C8             C      	ret	z		;nein
  DAE1    F5             C      	push	af		;retten Zeichen
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-58


  DAE2    3A DB63        C      	ld	a,(uc1bfp)	;Pufferbelegung
  DAE5    FE 06          C      	cp	1*uc1bfl/3	;unter dem Limit?
  DAE7    DC DAEC        C      	call	c,uc1ird	;ja, Senden wieder erlauben
  DAEA    F1             C      	pop	af
  DAEB    C9             C      	ret
                         C      
                         C      ; Empfangsbereitschaft anzeigen
  DAEC    DD CB 00 BE    C      uc1ird:	res	7,(ix+ltpst)
  DAF0    DD CB 0A 7E    C      	bit	7,(ix+ltpw5)	;Prozedur DC1/DC3?
  DAF4    C2 DA85        C      	jp	nz,ltpow5	;nein, DTR wieder setzen
  DAF7    3E 11          C      	ld	a,11h		;DC1 (Senden wieder erlauben)
  DAF9    DD 4E 02       C      	LD	C,(ix+ltpsd)	;SIO Daten
  DAFC    ED 79          C      	OUT	(C),A
  DAFE    C9             C      	ret
                         C      
                         C      ; UC1: Empf.-Interrupt
                         C      ;=====================
  DAFF    ED 73 E626     C      uc1rin:	ld	(intsp),sp
  DB03    31 F126        C      	ld	sp,intstk
  DB06    F5             C      	push	af
  DB07    E5             C      	push	hl
  DB08    D5             C      	push	de
  DB09    C5             C      	push	bc
  DB0A    DD E5          C      	push	ix
  DB0C    21 DB2C        C      	ld	hl,uc1rir
  DB0F    E5             C      	push	hl
  DB10    DD 21 D9B7     C      	ld	ix,lstuc1	;Stellen IX auf Steuertabelle
  DB14    DD 4E 02       C      	ld	c,(ix+ltpsd)	;SIO Daten
  DB17    ED 40          C      	in	b,(c)		;Zeichen lesen
  DB19    21 DB63        C      	ld	hl,uc1bfp	;Pufferzeiger zum zuletzt empf. Zeichen
  DB1C    7E             C      	ld	a,(hl)
  DB1D    FE 14          C      	cp	uc1bfl		;Puffer voll?
  DB1F    D0             C      	ret	nc		;ja, Zeichen ignorieren
  DB20    FE 0D          C      	cp	2*uc1bfl/3	;Puffer fast voll (SIO-Empf.puffer 3 Byte!)?
  DB22    D4 DB31        C      	call	nc,uc1ri1	;ja, DC3 senden bzw. DTR wegnehmen
  DB25    34             C      	inc	(hl)		;+1
  DB26    5E             C      	ld	e,(hl)
  DB27    16 00          C      	ld	d,0
  DB29    19             C      	add	hl,de		;naechste freie Stelle
  DB2A    70             C      	ld	(hl),b		;Zeichen in Puffer
  DB2B    C9             C      	ret
  DB2C    DD E1          C      uc1rir:	pop	ix
  DB2E    C3 E621        C      	jp	intrbc		;fertig
                         C      
                         C      ; Stopaufforderung senden
                         C      ; B,HL bleibt erhalten
  DB31    DD CB 00 FE    C      uc1ri1:	set	7,(ix+ltpst)	;merken Stopaufforderung
  DB35    DD 5E 0A       C      	ld	e,(ix+ltpw5)
  DB38    CB 7B          C      	bit	7,e		;Prozedur DC1/DC3?
  DB3A    28 05          C      	jr	z,uc1ri2	;ja
  DB3C    CB BB          C      	res	7,e		;DTR loeschen
  DB3E    C3 DA88        C      	jp	ltpot5
  DB41    3E 13          C      uc1ri2:	ld	a,13h		;DC3 an Partner (Senden stopppen)
  DB43    DD 4E 02       C      	LD	C,(ix+ltpsd)	;SIO Daten
  DB46    ED 79          C      	OUT	(C),A
  DB48    C9             C      	ret
                         C      
                         C      ; UC1: Interrupt Empf.-Fehler (Parit., Ueberlauf, Rahmenfehler)
                         C      ;============================
  DB49    ED 73 E626     C      uc1err:	ld	(intsp),sp
  DB4D    31 F126        C      	ld	sp,intstk
  DB50    F5             C      	push	af
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-59


  DB51    E5             C      	push	hl
  DB52    D5             C      	push	de
  DB53    C5             C      	push	bc
  DB54    DD E5          C      	push	ix
  DB56    DD 21 D9B7     C      	ld	ix,lstuc1	;Stellen IX auf Steuertabelle
  DB5A    DD 4E 03       C      	ld	c,(ix+ltpsc)	;SIO Kommando
  DB5D    16 30          C      	ld	d,00110000b	;Reset Fehler-Interrupt
  DB5F    ED 51          C      	out	(c),d
                         C      				;keine Fehlermeldung, da bei
                         C      				;Empf.ueberlauf alles noch
                         C      				;mehr verzoegert wird
  DB61    18 C9          C      	jr	uc1rir
                         C      
                         C      ; UC1: Empfangspuffer
                         C      ;====================
  DB63    00             C      uc1bfp:	db	0
  DB64                   C      uc1buf:	ds	uc1bfl,0
                         C      
                         C       endif	;uc1
                         C      
                                  ENDIF
                                  IF cdtsib
                                  ENDIF
                                  IF cdtpio
                                  ENDIF
                                  IF cdtp54
                                  ENDIF
                                  IF cdth54
                                  ENDIF
                                  IF cdtn56 or cdtp56
                                  ENDIF
                                 ENDIF
                                
                         C      	include BIOSDSK
                         C      
                         C      ;****************************************************
                         C      ;	Diskettentreiber; Umkleidung des phys. Transfers
                         C      ;	Version 04.11.88
                         C      ; Aenderungen:
                         C      ; - Jeder Fehler in Spur 0, Sektor 1 fuehrt zur Annahme von Systemspuren
                         C      ;   (A7100-System mit 5" FM und 8272-Hardware mit 128er Sektorlaenge)
                         C      ; - !!Schnittstelle fuer diskio-Aufruf neu!! (Flags neu, side zusaetzlich)
                         C      ; - Verify nach Schreiben kann laufwerksspezifisch gewaehlt werden
                         C      ; - Laufwerkskapazitaet nach phys. LW-Nr in Statuszeile
                         C      ; - Fehlerkorrektur bei KAYPRO IV fuer C128
                         C      ; 12.06.88
                         C      ; - bei stzaus in synflg keine Pflege der Statuszeile
                         C      ; 06.07.88:
                         C      ; - Spurnummer generell auf 16 bit erweitert
                         C      ; 14.10.88
                         C      ; - Generierung ohne Floppy-Laufwerke moeglich
                         C      ; 26.10.88
                         C      ; - Test der Laufwerksbereitschaft bei Select
                         C      ; 04.11.88
                         C      ; - bei 5" und 512 Sektorlaenge Dir-Groesse 0
                         C      ; 12.03.89
                         C      ; - 'ibmfrm' gestrichen, phys. Formaterkennung fuer SIOS erfolgt immer
                         C      ;****************************************************
                         C      
                         C       if1
                         C       endif
                         C      
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-60


                         C      ; Laufwerksauswahl
                         C      ;=================
                         C      ; i C: Laufw. (0=A:, 1=B: ...)
                         C      ; i E: Bit 0 ist LOGIN-Bit von BDOS (=0, wenn LOGIN)
                         C      
  DB78    CD E8AE        C      seldsk:	call	dgetpb		;HL auf DPH stellen, IX auf DPB
  DB7B    C8             C      	ret	z		;Geraet ex. nicht
  DB7C    79             C      	ld	a,c
  DB7D    32 E0E9        C      	ld	(ddrive),a	;Laufwerk merken
  DB80    CB 43          C      	bit	0,e		;LOGIN von BDOS?
  DB82    C0             C      	ret	nz		;nein
                         C       if ramfl
                         C       endif
  DB83    E5             C      	push	hl		;^DPH merken
                         C      
                         C      	IF	dbufsz gt 7
  DB84    21 E0E0        C      	ld	hl,dbdev
  DB87    BE             C      	cp	(hl)		;LOGIN fuer gepuffertes Device?
  DB88    20 07          C      	jr	nz,dselnb	;nein
  DB8A    36 FF          C      	ld	(hl),0ffh	;Puffer ist ungueltig
  DB8C    21 E0DF        C      	ld	hl,dbflg
  DB8F    CB 96          C      	res	dfbwr,(hl)	;kein veraend. Puffer auszug.!
  DB91                   C      dselnb:
                         C      	ENDIF
                         C      
                         C       IF format
  DB91    DD CB 0F 76    C      	bit	dpbfrm,(ix+dpbflg);Formaterkennung unterdr.?
  DB95    28 1A          C      	jr	z,drdfrm	;nein
                         C       ENDIF
                         C      
                         C      ; Test der Laufwerks-Bereitschaft; nur dann Select Disk ok
                         C      ;---------------------------------------------------------
  DB97    32 E0D2        C      	ld	(drddev),a	;log. LW
  DB9A    DD 6E 0D       C      	ld	l,(ix+dpbofs)
  DB9D    DD 66 0E       C      	ld	h,(ix+dpbofs+1)
  DBA0    22 E0D3        C      	ld	(drdtrk),hl	;auf Beginn des Verzeichnisses
  DBA3    21 E0D1        C      	ld	hl,drdcdb	;Positionieren ohne Fehlerbehandlung
  DBA6    CD DF1E        C      	call	dsktra
  DBA9    CA DD5E        C      	jp	z,selext	;ok
  DBAC    E1             C      	pop	hl		;^DPH wegschmeissen
  DBAD    21 0000        C      	ld	hl,0		;Select Fehler
  DBB0    C9             C      	ret
  DBB1                   C      drdfrm:
                         C      
                         C      	IF	format
                         C      ;++++++++++Automatische Format-Erkennung++++++++++
                         C      ; Reg. C zeigt auf Laufwerk
                         C      
                         C      	IF	dbufsz gt 7
  DBB1    CD DEFE        C       	call	dbtrw		;Puffer freimachen
                         C      				;und auf Lesen schalten
  DBB4    21 E0F6        C      	ld	hl,dbnb
  DBB7    36 FF          C      	ld	(hl),0ffh	;Puffernummer ist ungueltig, obwohl evtl.
                         C      				;alle anderen Pufferparameter stimmen
                         C      				;(da nur 128 Bytes vom Puffer belegt sind)
                         C      	ENDIF
                         C      
  DBB9    79             C      	ld	a,c
  DBBA    32 E0D9        C      	ld	(dfrmdv),a
  DBBD    32 E0E0        C      	ld	(dbdev),a
                         C      
  DBC0    AF             C      	xor	a
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-61


  DBC1    DD 77 0F       C      	ld	(ix+dpbflg),a	;ruecksetzen alle Flags
  DBC4    DD 77 13       C      	ld	(ix+dpbsn0),a	;keine Weiter-Numm. auf Ruecks.
  DBC7    DD 77 0D       C      	ld	(ix+dpbofs),a	;keine Systemspuren
                         C      
  DBCA    32 E0DA        C      	ld	(dfrmtr),a	;Spur 0
  DBCD    32 E0E1        C      	ld	(dbtrk),a
  DBD0    32 E0E2        C      	ld	(dbtrk+1),a
  DBD3    3C             C      	inc	a
  DBD4    32 E0E3        C      	ld	(dbsec),a	;Sektor 1
  DBD7    32 E0E5        C      	ld	(dbsnb),a	;1 phys. Sektor lesen
                         C      
                         C      ; Stellen  Sektor-Translate-Tabelle 1,2,3,...
  DBDA    DD E5          C      	push	ix
  DBDC    06 1A          C      	ld	b,26		;max. Laenge der Tabelle
                         C       IF dsk8mf
                         C       ENDIF
  DBDE    DD 77 19       C      selstz:	ld	(ix+dpbstr),a
  DBE1    DD 23          C      	inc	ix
  DBE3    3C             C      	inc	a
  DBE4    10 F8          C      	djnz	selstz
  DBE6    DD E1          C      	pop	ix
                         C      
                         C      ; Positionieren auf Spur 0 und analysieren Systemspuren
  DBE8    CD DF16        C      	call	dsidtr		;beliebigen Sekt.Id lesen
  DBEB    20 3E          C      	jr	nz,selsys	;Fehler beim Lesen; Systemsp. annehmen
                         C      ;				 (z.B. SCP1700 mit 5"FM in Spur 0!!)
  DBED    7C             C      	ld	a,h
  DBEE    32 E0E4        C      	ld	(dbslc),a	;setzen Spurformat fuer Sp. 0
                         C      	IF	dbufsz le 7
                         C      	ENDIF
  DBF1    21 E0DF        C      	ld	hl,dbflg
                         C       IF dsk8mf
                         C       ENDIF
  DBF4    46             C      	ld	b,(hl)		;merken Fehlerprotokoll-Bit
  DBF5    CB E6          C      	set	dfbtr,(hl)	;kein Fehlerprotokoll
  DBF7    E5             C      	push	hl
  DBF8    CD DF04        C      	call	dbtran		;Lesen Spur 0, Sektor 1
  DBFB    E1             C      	pop	hl
  DBFC    70             C      	ld	(hl),b		;setzen Standard fuer Fehlerprotokoll-Bit
  DBFD    20 2C          C      	jr	nz,selsys	;Fehler, Systemspuren annehmen
  DBFF    FD E5          C      	push	iy
  DC01    FD 2A E0E6     C      	ld	iy,(dbdma)
  DC05    FD 7E 00       C      	ld	a,(iy+0)	;Format-Loeschbyte
  DC08    FE E5          C      	cp	0e5h		;leere Diskette/geloeschter Eintrag?
  DC0A    20 0A          C      	jr	nz,selsy2	;nein, weder/noch
  DC0C    FD BE 01       C      	cp	(iy+1)		;auch danach 0e5h?
  DC0F    20 15          C      	jr	nz,selsy0	;nein, geloeschter Dir-Eintrag
  DC11    DD 35 0D       C      	dec	(ix+dpbofs)	;Flag: leere Disk oder leere Systemsp.
  DC14    18 10          C      	jr	selsy0		;dpbofs auf 254
  DC16                   C      selsy2:
  DC16    FE 40          C      	cp	40h		;IBM-Format (SIOS-Daten-Diskette)?
  DC18    28 0F          C      	jr	z,selsy1	;ja, 0 Systemspuren annehmen
  DC1A    FE 20          C      	cp	20h		;<=31 ? ("S"YL ist groesser!)
  DC1C    30 0B          C      	jr	nc,selsy1	;nein, kann kein Directory sein; 0 Systemsp.
                         C      ;Systemlader fuer PC1715 beginnt mit 02 oder 03
  DC1E    FD 7E 20       C      	ld	a,(iy+20h)	;bei SCP1715-Systemdiskette dort 00h
                         C      				;bei MicroDos dort 10h
  DC21    FD B6 21       C      	or	(iy+21h)	;bei SCP1715-Systemdiskette dort 00h
                         C      				;bei CP/A dort Dir-Eintrag (E5 oder Filename)
  DC24    28 03          C      	jr	z,selsy1	;beides 00h, kein Directory; 0 Systemsp.
  DC26    DD 35 0D       C      selsy0:	dec	(ix+dpbofs)	;=255, wenn Directory; =254 wenn vorn leer
  DC29                   C      selsy1:
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-62


  DC29    FD E1          C      	pop	iy
  DC2B                   C      selsys:
                         C      
                         C      ; Analysieren Datenspur
                         C      
                         C      ; SS/DS-Analyse
  DC2B    DD 36 12 02    C      	ld	(ix+dpbstp),2	;Doppel-Step-Impulse
  DC2F    3E 03          C      	ld	a,dlgint	;auf LOGIN-Spur
  DC31    CD DF13        C      	call	dsidtt		;belieb. SektId Vorderseite lesen
  DC34    20 2B          C      	jr	nz,seldle	;Fehler, unsicheres Format
  DC36    54             C      	ld	d,h		;d:=Sektorlcode, e:=Spur
                         C       IF dsk8mf
                         C       ENDIF
                         C       IF dskds
  DC37    DD CB 18 46    C      	bit	dpbtds,(ix+dpbtyp)	;ist es ein DS-Laufwerk?
  DC3B    28 14          C      	jr	z,selss		;nein, SS
  DC3D    D5             C      	push	de		;merken Sektorlaengencode und Spur
  DC3E    DD CB 0F EE    C      	set	dpbfds,(ix+dpbflg)
  DC42    3E 07          C      	ld	a,1+(dlgint*2)	;Rueckseite der Spur,
                         C      				;ab der Format bei SS konstant
  DC44    CD DF13        C      	call	dsidtt		;beliebigen Sekt.Id Ruecks. lesen
  DC47    7A             C      	ld	a,d		;merken side Ruecks.
  DC48    6B             C      	ld	l,e		;h:=Sektorlcode, l:=Spur Rueckseite
  DC49    D1             C      	pop	de		;wiederherstellen Vorderseite
  DC4A    20 05          C      	jr	nz,selss	;Fehler beim Lesen, SS
  DC4C    B7             C      	or	a
  DC4D    ED 52          C      	sbc	hl,de		;Vorder- gleich Rueckseite?
  DC4F    28 04          C      	jr	z,sel48		;ja; 40 Tr/ 80 Tr unterscheiden
  DC51    DD CB 0F AE    C      selss:	res	dpbfds,(ix+dpbflg)
                         C       ENDIF
                         C      
                         C      ; 40/80 Track Analyse
  DC55    7B             C      sel48:	ld	a,e		;trk
  DC56    D6 03          C      	sub	dlgint		;waren 2 Steps richtig? 
  DC58    28 12          C      	jr	z,seldl1	;ja
  DC5A    DD 35 12       C      	dec	(ix+dpbstp)	;Einzelstep-Impulse
  DC5D    D6 03          C      	sub	dlgint		;waere 1 Step richtig?
  DC5F    28 0B          C      	jr	z,seldl1	;ja
                         C      				;nein, unsicher
  DC61    DD 36 10 FF    C      seldle:	ld	(ix+dpbslc),0ffh;provozieren 'BAD SECTOR'
  DC65    21 0000        C      	ld	hl,0		;erzeugen 'SELECT' Error
  DC68    E3             C      	ex	(sp),hl
