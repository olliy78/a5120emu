                         C      ;===========================================
  D3E7                   C      kbdi:
  D3E7                   C      kbdmd1:		;Modifizierung bei K7634/36/37 mit:
                         C      ;kbdwin:call	kbdst		;Taste im Puffer
                         C      ;	jr	z,kbdwin	;nein, warten
                         C      ;	jp	kbdinn		;sonst aeltestes Pufferzeichen
                         C      
  D3E7    CD D34F        C      kbdwin:	call	kbdst		;Taste im Puffer?
  D3EA    20 32          C      	jr	nz,kbdinn	;ja
