  D80A    E5             C      crt2zs:	push	hl
  D80B    21 D23D        C      	ld	hl,synflg
  D80E    CB D6          C      	set	umlflg,(hl)
  D810    E1             C      	pop	hl
  D811    C9             C      	ret
                         C      ; Umschalten auf 1. Zeichensatz
  D812    E5             C      crt1zs:	push	hl
