  D5AF    E7 02 0F 47    C+     	db	pf7c,2,'O' and 1fh,'G'
  D5B3    E8 01 17       C+     	db	pf8c,1,'W' and 1fh
  D5B6    E9 01 1A       C+     	db	pf9c,1,'Z' and 1fh
