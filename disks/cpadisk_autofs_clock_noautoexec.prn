                                ;$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$
                                ;	Beginn BIOS-Treiber
                                ;$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$
                                
                                ; Dummy-Treiber
  D32C                          dumst:
  D32C    AF                    	xor	a
  D32D    3D                    	dec	a		;Status immer FF (bereit)
                                 IF iobvar
                                 ENDIF
  D32E    C9                    	ret			;Status immer FF (bereit)
                                
                                 IF iobvar
  D32F    3E 1A                 dumi:	ld	a,1ah		;Eingabe-Zeichen immer EOF
  D331    C9                    	ret
  D332    79                    dumo:	ld	a,c
  D333    11 D33F               	ld	de,dumoh
  D336    CD E802               	call	mrecoa		;Zeichen hex aufbereiten
  D339    0E 28                 	ld	c,'('
  D33B    CD D654               	call	crto
  D33E    01 0000               	ld	bc,0
  D33F                          dumoh	equ	$-2
  D341    C5                    	push	bc
  D342    CD D654               	call	crto
  D345    C1                    	pop	bc
  D346    48                    	ld	c,b
  D347    CD D654               	call	crto
  D34A    0E 29                 	ld	c,')'
  D34C    C3 D654               	jp	crto
                                 ENDIF
                                
                         C      	include BIOSKBD
                         C      ;****************************************************
                         C      ;	Tastatur-Eingabe
                         C      ; - Unterstuetzung weiterer Steckplaetze fuer IFSS-Tastatur
                         C      ;   (z.B. Digitalisier-AP)
                         C      ; - freie Belegbarkeit Kursor- und rechter Ziffernblock
                         C      ; 17.07.88
                         C      ; - uebersichtlichere Darstellung phys. -> virtueller Tastencode
                         C      ; 24.09.88
                         C      ; - Anpassung Tastaturpuffer in Statuszeile an umschaltbaren Bildschirmpuffer
                         C      ; 25.09.88
                         C      ; - Fehler in Stop-Tasten-Behandlung korrigiert
                         C      ; 07.11.88
                         C      ; - Erweiterung des virtuellen Tastaturcodes um K7634-spezifische Tasten
                         C      ; 23.12.88
                         C      ; - saemtliche Sondertasten c0..ff liefern mit Control oder Shift einen
                         C      ;   virtuellen Zwischencode 80..bf
                         C      ; 14.01.89
                         C      ; - Variante K7633 (kbdotp eq 3) eingefuehrt
                         C      ; - wenn Tastatur nach RESET gross schreibt, so caps-lock-Test invertiert
                         C      ; 20.01.89
                         C      ; - Abtesten auf ^Q-Prefix ueber virtuellen Tastencode
                         C      ; 22.03.89
                         C      ; - Control-Flag gilt genau fuer das naechste Zeichen
                         C      ; 31.03.89
                         C      ; - Sondertasten >=80h ignoriert, wenn nicht in Tastatur-Tabelle
                         C      ; 25.09.89
                         C      ; - Fehlerkorrektur K7637: CTRL-Ersatztaste brachte kein ^Q-Prefix
                         C      ;****************************************************
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-24


                         C      
                         C       if1
                         C       endif	;if1
                         C      
                         C      ; Tastatur-Status
                         C      ;================
  D34F                   C      kbdst:
                         C      ; vor Pufferabfrage anstehende Zeichen lesen (falls 5ms Takt aus)
  D34F    F3             C      	di			;parallele Abfrage ueber 5ms verhindern
                         C       IF cpastz
                         C       ENDIF
  D350    CD D357        C      	call	kbdsti		;interner Aufruf
  D353    FB             C      	ei
                         C       IF stpvar or monitor
  D354    C3 E72E        C      	jp	chksp		;Test auf Spezialfunktionen
                         C       ENDIF
                         C      
  D357                   C      kbdsti:				;kbdst-Aufruf intern
  D357    CD D433        C      kbdstz:	call	kbdst1		;Taste neu gedrueckt ?
  D35A    28 05          C      	jr	z,kbdsnt	;nein
  D35C    CD D368        C      	call	kbdrdt		;Taste in Puffer ablegen
                         C       IF stpvar
                         C       ENDIF
  D35F    18 F6          C      	jr	kbdstz		;auf neuen Tastendruck testen
                         C      
  D361    3E 00          C      kbdsnt:	ld	a,0		;erstes Pufferzeichen
  D362                   C      kbdbfe	equ	$-1
  D363    B7             C      	or	a		;Puffer leer?
  D364    C8             C      	ret	z		;ja
  D365    3E FF          C      	ld	a,0ffh
  D367    C9             C      	ret
                         C      
                         C      ;------------------------------------------------------------
                         C      
                         C      
                         C      ; Taste umkodieren und im Puffer ablegen
                         C      ;=======================================
                         C      ; Achtung!! Dieses UP wird aus Interruptroutine aufgmrufen
  D368    CD D453        C      kbdrdt:	call	kbdrch		;Zeichen evtl. umkodieren
  D36B    21 D23D        C      	ld	hl,synflg
                         C      
  D36E    FE DF          C      	cp	ctlc		;Ersatz-Control-Taste ?
  D370    20 05          C      	jr	nz,kbdnct	;nein
  D372    7E             C      	ld	a,(hl)
  D373    EE 01          C      	xor	1 shl ctrlst	;CTRL-Status umkehren
  D375    77             C      	ld	(hl),a
  D376    C9             C      	ret			;und Zeichen ignorieren
  D377                   C      kbdnct:
                         C      
                         C       IF stpvar
  D377    CB 7E          C      	bit	phyact,(hl)	;Taste physisch in Puffer?
  D379    C2 D3C2        C      	jp	nz,kbdput	;ja, direkt ablegen
                         C       ENDIF
                         C       IF costu
                         C       ENDIF
  D37C    2A D23B        C      	ld	hl,(kbdsst)	;Adresse der Standardstringtabelle
  D37F    CD D499        C      	call	costr		;Standardstring?
  D382    28 07          C      	jr	z,kbdnco	;nein
  D384    1D             C      kbdco:	dec	e		;String der Laenge 0?
  D385    C8             C      	ret	z		;ja, zu ignorierende Taste
  D386    1D             C      	dec	e		;String exakt ein Zeichen lang?
  D387    C2 D3D9        C      	jp	nz,kbdco1	;nein, kann keine Sondertaste sein
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-25


  D38A    7E             C      	ld	a,(hl)		;holen erstes Stringzeichen
  D38B    21 D23D        C      kbdnco:	ld	hl,synflg
                         C      
                         C      ; Auswertung Sondertasten, die nicht im Puffer abgelegt werden
                         C      ;-------------------------------------------------------------
                         C      
  D38E    FE DE          C      	cp	stpc		;STOP ?
  D390    20 0A          C      	jr	nz,kbdnst
  D392    CB E6          C      	set	stoprq,(hl)	;Stop-Request vermerken
                         C      
                         C      ; Rest des Konsolpuffers streichen
                         C      ;---------------------------------
  D394    AF             C      kbdbcl:	xor	a
                         C       IF cpastz
                         C       ENDIF
  D395    32 FFFF        C      	ld	(0ffffh),a
  D396                   C      crtm36	equ	$-2
                         C       IF cpastz
                         C       ENDIF
  D398    32 D362        C      	ld	(kbdbfe),a
  D39B    C9             C      	ret
                         C      
  D39C                   C      kbdnst:
                         C       IF stpvar
                         C       IF chdvar
  D39C    FE D9          C      	cp	SyLc		;Drucker Synchronisieren?
  D39E    20 03          C      	jr	nz,kbdnsy	;nein
  D3A0    CB DE          C      	set	synlrq,(hl)	;sonst vermerken
  D3A2    C9             C      	ret
  D3A3                   C      kbdnsy:
  D3A3    FE DA          C      	cp	HrLc		;Hardcopy ein/aus ?
  D3A5    20 0C          C      	jr	nz,kbdnhc
  D3A7    21 D20C        C      	ld	hl,conol
  D3AA    7E             C      	ld	a,(hl)
  D3AB    EE 0E          C      	xor	0cdh xor 0c3h	;CALL aus JP u.umgekehrt
  D3AD    77             C      	ld	(hl),a
  D3AE    3E 80          C      	ld	a,1 shl lmphcp	;Hardcopy-Lampe
  D3B0    C3 D4AB        C      	jp	kbdslm
  D3B3                   C      kbdnhc:
                         C       ENDIF
                         C       ENDIF	;stpvar
                         C      
                         C       IF monitor
                         C       ENDIF
                         C      
  D3B3    FE D1          C      	cp	Sel0		;Selector 0?
  D3B5    38 09          C      	jr	c,kbdnsl	;nein
  D3B7    FE D9          C      	cp	Sel3+1		;Selector 0..3?
  D3B9    30 05          C      	jr	nc,kbdnsl	;nein
  D3BB    E6 0F          C      	and	0fh		;Bit 0..3
  D3BD    C3 D4AB        C      	jp	kbdslm
  D3C0                   C      kbdnsl:
  D3C0    B7             C      	or	a		;Taste zu ignorieren?
  D3C1    F8             C      	ret	m		;ja
                         C      
                         C      ; Zeichen im Puffer ablegen
                         C      ;--------------------------
  D3C2                   C      kbdput:
                         C       IF cpastz
                         C       ENDIF
  D3C2    21 FFFF        C      	ld	hl,0ffffh	;Pufferadresse
  D3C3                   C      crtm35	equ	$-2
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-26


  D3C5    01 0014        C      	ld	bc,kbdbl	;Pufferlaenge
  D3C8    5F             C      	ld	e,a		;A retten
  D3C9    AF             C      	xor	a		;Pufferende-Kennzeichen
  D3CA    ED B1          C      	cpir
  D3CC    20 08          C      	jr	nz,kbdpt1	;Puffer voll
  D3CE    77             C      	ld	(hl),a		;neues Pufferende anzeigen
  D3CF    7B             C      	ld	a,e		;A wiederherstellen
  D3D0    2B             C      	dec	hl
  D3D1    77             C      	ld	(hl),a		;Zeichen puffern
                         C      ;um bei Arbeit mit Anzeige des Tastaturpuffers in Statuszeile
                         C      ;Bildschirmflimmern zu vermeiden hinterlegen des gepufferten Zeichens
                         C      ;ausserhalb des Bildschirmbereichs fuer Test, ob ueberhaupt etwas im Puffer
                         C       IF cpastz
