                         C       ENDIF
  D3D6    C3 D7F3        C      	jp	crtclk		;Puffer voll anzeigen
                         C      
                         C      ; Ablegen String im Puffer
                         C      ;-------------------------
                         C      ; i E	Stringlaenge -1
                         C      ; i HL	Stringanfang
  D3D9    1C             C      kbdco1:	inc	e
  D3DA    E5             C      kbdco2:	push	hl
  D3DB    D5             C      	push	de
  D3DC    7E             C      	ld	a,(hl)
  D3DD    CD D3C2        C      	call	kbdput		;Zeichen in Puffer
  D3E0    D1             C      	pop	de
  D3E1    E1             C      	pop	hl
  D3E2    23             C      	inc	hl
  D3E3    1D             C      	dec	e
