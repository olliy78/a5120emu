  D9C8    17             C      	db	17h		;Vorteiler 16
  D9C9    01             C      	db	@l		;Baudrate empf.
                         C      ; SIO-Initialisierung
  D9CA    08             C      	db	7+1
  D9CB    51             C      	db	@ls		;SIO-Komm.
  D9CC    18             C      	db	18h		;WR0
  0044                   C      @l	aset	01000100b	;;Takt*16, ohne P., 1 Stbit, DTR
                         C       if (@lt mod 10) eq 2
                         C       endif
