  D7C1    62             C      	ld	h,d
  D7C2    6B             C      	ld	l,e
  D7C3    18 D5          C      	jr	crtzlr		;freigewordene Zeile loeschen
                         C      ;-----------------------------
  D7C5    CD D749        C      crtdll:	call	crtcr		;Delete Line
  D7C8    E5             C      	push	hl
  D7C9    11 FF30        C      	ld	de,bsend2-bssp2+1	;Anfang letzte Zeile
  D7CA                   C      crtm47	equ	$-2
  D7CC    EB             C      	ex	de,hl
  D7CD    B7             C      	or	a
  D7CE    ED 52          C      	sbc	hl,de		;Laenge
  D7D0    28 08          C      	jr	z,crtdl1	;letzte Zeile
  D7D2    E3             C      	ex	(sp),hl
  D7D3    54             C      	ld	d,h
  D7D4    5D             C      	ld	e,l		;de auf Ziel (Zeilenanfang)
  D7D5    09             C      	add	hl,bc		;hl auf Quelle
  D7D6    C1             C      	pop	bc
  D7D7    D5             C      	push	de
                         C      	setbs
  D7D8    ED B0          C      	ldir			;eine Zeile nach oben schieben
                         C      	setram
  D7DA    21 FF30        C      crtdl1:	ld	hl,bsend2-bssp2+1
  D7DB                   C      crtm48	equ	$-2
  D7DD    54             C      	ld	d,h
  D7DE    5D             C      	ld	e,l
  D7DF    CD D79A        C      	call	crtzlr		;letzte Zeile loeschen
  D7E2    E1             C      	pop	hl
  D7E3    C9             C      	ret
                         C      ;-----------------------------
                         C       ENDIF	;inslin
  D7E4    3E 02          C      crtesc:	ld	a,2		;escape flag setzen
  D7E6    32 D692        C      	ld	(desc),a
                         C      
                         C      	if	costu or adm3a
                         C      	endif
                         C      
  D7E9    C9             C      	ret
                         C      ;-----------------------------
  D7EA    3E 80          C      crtcrt:	ld	a,80h		;cursor an
  D7EC    18 01          C      	jr	crto14
                         C      ;-----------------------------
  D7EE    AF             C      crtcof:	xor	a		;cursor aus
  D7EF    32 D666        C      crto14:	ld	(dcurs),a
  D7F2    C9             C      	ret
                         C      ;-----------------------------
                         C      ; Realisierung 07h
                         C      ; Achtung! Diese Routine wird aus Interruptroutine aufgerufen!
  D7F3    CD D7F6        C      crtclk:	call	crtcl1		;Fehlerlampe umschalten
                         C      
  D7F6    06 19          C      crtcl1:	ld	b,25		;0.25 sec warten
  D7F8    CD E7F3        C      	call	wait10
                         C      				;Fehlerlampe wieder zurueck
                         C      ; Fehlerlampe umschalten
                         C      ; Reg. A, HL bleiben erhalten
  D7FB    F5             C      swilmp:	push	af
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-42


  D7FC    E5             C      	push	hl
  D7FD    21 0040        C      	ld	hl,lampbf
  D800    7E             C      	ld	a,(hl)
  D801    EE 40          C      	xor	1 shl lmperr
  D803    77             C      	ld	(hl),a
  D804    CD D4B0        C      	call	lampen
  D807    E1             C      	pop	hl
  D808    F1             C      	pop	af
  D809    C9             C      	ret
                         C      ;-----------------------------
                         C       IF umlaut
