                         C      	include BIOSNUC
                         C      ;$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$
                         C      ; Zentrale BIOS-Kompenenten
                         C      ; - rst 38h fuehrt bei Monitor zu seinem Aufruf, sonst Warmstart
                         C      ; - Nachladen CCP aus RAM-Floppy vereinheitlicht (unabh. von RAM-Floppy)
                         C      ; - synflg hinter BIOS-Sprungvektor fuer Modifizierung von aussen
                         C      ; - Verwendung der Interruptsaeule in Generierungsteil verlagert
                         C      ; 25.09.88
                         C      ; - Streichen des Tastaturpuffers in Tastaturstatus
                         C      ; 09.10.88
                         C      ; - Pflege der Statuszeile nur bei stzaus=0
                         C      ; 11.01.89
                         C      ; - Variante wbootv=4 (@CCP.COM) eingefuehrt
                         C      ; 17.05.89
                         C      ; - Generierung ohne LW A moeglich
                         C      ; 05.06.89
                         C      ; - Unterstuetzung NANOS-RAF
                         C      ;$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$
                         C      
                         C       IF iobvar
                         C      ;Verteiler fuer die 1-Zeichen-Kanaele entsprechend IOBYTE:
                         C      ;=========================================================
                         C      
  E69A                   C      const:			; iobyte  00 00 00 xx
  E69A    CD E6FA        C      	call	iodisp
  E69D    07             C      	db	7
  E69E    D34F           C      	dw	kbdst		;0 kbd:
  E6A0    D34F           C      	dw	kbdst		;1 kbd:
  E6A2    E6BE           C      	dw	reades		;2 rdr:
  E6A4    DA92           C      	dw	uc1st		;3 uc1: (liefert, ob Z. da)
                         C      
  E6A6                   C      conin:			; iobyte:  00 00 00 xx
  E6A6    CD E6FA        C      	call	iodisp
  E6A9    07             C      	db	7
  E6AA    D3E7           C      	dw	kbdi		;0 kbd:
  E6AC    D3E7           C      	dw	kbdi		;1 kbd:
  E6AE    E6CA           C      	dw	reader		;2 rdr:
  E6B0    DAC1           C      	dw	uc1i		;3 uc1: (wartet, bis Z. da)
                         C      
  E6B2                   C      conout:			; iobyte:  00 00 00 xx
  E6B2    CD E6FA        C      	call	iodisp
  E6B5    07             C      	db	7
  E6B6    D654           C      	dw	crto		;0 crt:
  E6B8    D332           C      	dw	dumo		;1 dum:
  E6BA    E6D6           C      	dw	punch		;2 pun:
  E6BC    D8EB           C      	dw	uc1o		;3 uc1: (wartet, bis frei)
                         C      
  E6BE                   C      reades:			; iobyte:   00 00 xx 00
  E6BE    CD E6FA        C      	call	iodisp
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-101


  E6C1    01             C      	db	1
  E6C2    D34F           C      	dw	kbdst		;0 kbd:
  E6C4    D32C           C      	dw	dumst		;1 dum:
  E6C6    D32C           C      	dw	dumst		;2 dum:
  E6C8    DA92           C      	dw	uc1st		;3 uc1: (liefert, ob Z. da)
                         C      
  E6CA                   C      reader:			; iobyte:   00 00 xx 00
  E6CA    CD E6FA        C      	call	iodisp
  E6CD    01             C      	db	1
  E6CE    D3E7           C      	dw	kbdi		;0 kbd:
  E6D0    D32F           C      	dw	dumi		;1 dum:
  E6D2    D32F           C      	dw	dumi		;2 dum:
  E6D4    DAC1           C      	dw	uc1i		;3 uc1: (wartet, bis Z. da)
                         C      
                         C      
  E6D6                   C      punch:			; iobyte:   00 xx 00 00
  E6D6    CD E6FA        C      	call	iodisp
  E6D9    03             C      	db	3
  E6DA    D654           C      	dw	crto		;0 crt:
  E6DC    D332           C      	dw	dumo		;1 dum:
  E6DE    E6EE           C      	dw	list		;2 lst:
  E6E0    D8EB           C      	dw	uc1o		;3 uc1: (wartet, bis frei)
                         C      
                         C      
  E6E2                   C      listst:			; iobyte:  xx 00 00 00
  E6E2    CD E6FA        C      	call	iodisp
  E6E5    05             C      	db	5
  E6E6    D955           C      	dw	ttyst		;0 tty:
  E6E8    D32C           C      	dw	crtst		;1 crt:
  E6EA    D95B           C      	dw	lptst		;2 lpt:
  E6EC    D32C           C      	dw	dumst		;3 dum:
                         C      
  E6EE                   C      list:			; iobyte:  xx 00 00 00
  E6EE    CD E6FA        C      	call	iodisp
  E6F1    05             C      	db	5
  E6F2    D8DF           C      	dw	ttyo		;0 tty:
  E6F4    D654           C      	dw	crto		;1 crt:
  E6F6    D8E5           C      	dw	lpto		;2 lpt:
  E6F8    D332           C      	dw	dumo		;3 dum:
                         C      
                         C      
                         C      ; IOBYTE-Auswertung - Verteilung auf die physischen Geraete
                         C      ; ---------------------------------------------------------
                         C      ; A,HL werden zerstoert
                         C      ; Anwender-IX wird gerettet, darf von Treiber-Routine zerstoert werden
                         C      ; damit kann Treiber auch aus Interrupt-Routine aufgerufen werden
                         C      
  E6FA                   C      iodisp:
  E6FA    E1             C      	pop	hl
  E6FB    C5             C      	push	bc
  E6FC    46             C      	ld	b,(hl)
  E6FD    23             C      	inc	hl
  E6FE    3A 0003        C      	ld	a,(iobyte)
  E701    0F             C      iodis1: rrca
  E702    10 FD          C      	djnz	iodis1
  E704    E6 06          C      	and	6
  E706    4F             C      	ld	c,a
  E707    09             C      	add	hl,bc
  E708    7E             C      	ld	a,(hl)
  E709    23             C      	inc	hl
  E70A    66             C      	ld	h,(hl)
  E70B    6F             C      	ld	l,a
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-102


  E70C    C1             C      	pop	bc
  E70D    DD E5          C      	push	ix		;retten Anwender-IX
  E70F    CD E7E6        C      	call	callhl
  E712    DD E1          C      	pop	ix		;wiederherstellen Anwender-IX
  E714    C9             C      	ret
                         C      
                         C       ENDIF
