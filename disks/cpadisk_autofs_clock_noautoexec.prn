  03B9    7A             C      	ld	a,d
  03BA    B3             C      	or	e
  03BB    20 F9          C      	jr	nz,ciini2
  03BD    10 F4          C      	djnz	ciini1
                         C      
  03BF    DB 01          C      	in	a,(kbdpcs)	;;Status einer leeren Tastatur
  03C1    E6 08          C      	and	8		;;ist Taste gedrueckt?
  03C3    20 06          C      	jr	nz,ciini3	;;nein
  03C5    32 04CC        C      	ld	(coistc),a	;;sonst cpl -> nop
  03C8    32 D435        C      	ld	(kbdstc),a
  03CB                   C      ciini3:
                         C      
