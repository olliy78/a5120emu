  DE08    32 E0F7        C      	ld	(dwrtyp),a
                         C      
  DE0B                   C      alloc:
                         C        IF @write
  DE0B    AF             C      	xor	a
  DE0C    32 E0F1        C      	ld	(unacnt),a	;Ende unalloc
                         C        ENDIF
                         C      
                         C       ENDIF
                         C      
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-68


                         C      ; gemeinsamer Zweig read/write Floppy
                         C      ;------------------------------------
                         C      
  DE0F    3A E0EC        C      drw:	ld	a,(dsectr)	;Sektornummer in 1..dpbspt ?
  DE12    3D             C      	dec	a		;ab 0 zaehlen
  DE13    FA DDF0        C      	jp	m,drwerr	;<0, Fehler
  DE16    DD BE 00       C      	cp	(ix+dpbspt)	;<dpbspt?
  DE19    30 D5          C      	jr	nc,drwerr	;nein, Fehler
                         C       IF dbufsz gt 7
  DE1B    47             C      	ld	b,a		;retten dsectr-1
                         C       ENDIF
  DE1C    DD 7E 0F       C      	ld	a,(ix+dpbflg)
  DE1F    E6 03          C      	and	dpbfsm		;Anzahl der abweich. 128er Spuren
  DE21    5F             C      	ld	e,a
  DE22    16 00          C      	ld	d,0
  DE24    2A E0EA        C      	ld	hl,(dtrack)	;verlangte Spur
  DE27    B7             C      	or	a
  DE28    ED 52          C      	sbc	hl,de		;im abweichenden Spurformat?
  DE2A    DA DF1B        C      	jp	c,drwsec	;ja, Sektorlaenge 128
                         C      
                         C       IF dbufsz gt 7	;gepufferte Disk E/A
                         C       IF dbufsz lt 12 ;<2**12 =4K Puffer
  DE2D    DD 7E 10       C      	ld	a,(ix+dpbslc)	;phys. Sektorlaenge 128?
  DE30    B7             C      	or	a		;d.h. mit Sektorversatz?
  DE31    CA DF1B        C      	jp	z,drwsec	;ja, keine Pufferung sinnvoll
                         C       ENDIF
  DE34    78             C      	ld	a,b
  DE35    DD 56 11       C      	ld	d,(ix+dpbbfm)	;Puffermaske
  DE38    A2             C      	and	d		;rel. Sekt.nr. des BDOS-Blocks zum Puff.anf.
  DE39    F5             C      	push	af		;merken fuer move
  DE3A    A8             C      	xor	b		;a ist Sektornr. des Puff.anf.
  DE3B    CB 3F          C      drwbnr:	srl	a		;ermitteln Puffernr in Spur
  DE3D    CB 1A          C      	rr	d		;noch Bits in Puffermaske?
  DE3F    20 FA          C      	jr	nz,drwbnr	;ja
                         C      ; Test, ob dieser Puffer da ist
  DE41    F5             C      	push	af		;merken Puffernummer
  DE42    21 E0F6        C      	ld	hl,dbnb
  DE45    BE             C      	cp	(hl)		;richtige Puffernummer?
  DE46    20 12          C      	jr	nz,dbn		;nein
  DE48    2A E0EA        C      	ld	hl,(dtrack)	;geforderte Spur
  DE4B    ED 5B E0E1     C      	ld	de,(dbtrk)
  DE4F    B7             C      	or	a
  DE50    ED 52          C      	sbc	hl,de		;richtige Spur?
  DE52    20 06          C      	jr	nz,dbn
  DE54    3A E0E0        C      	ld	a,(dbdev)	;zum Puffer gehoeriges Geraet
  DE57    B9             C      	cp	c		;richtiges Geraet?
  DE58    28 6C          C      	jr	z,dbmat		;ja, Sektor steht im Puffer
                         C      
  DE5A    C5             C      dbn:	push	bc		;retten ddrive
  DE5B    CD DEFE        C      	call	dbtrw		;veraenderten Puffer ausgeben
  DE5E    C1             C      	pop	bc		;c:=ddrive
  DE5F    21 E0E0        C      	ld	hl,dbdev
  DE62    71             C      	ld	(hl),c
  DE63    2A E0EA        C      	ld	hl,(dtrack)
  DE66    22 E0E1        C      	ld	(dbtrk),hl
  DE69    CD E8AE        C      	call	dgetpb		;ix:=dpb(c)
  DE6C    DD 46 10       C      	ld	b,(ix+dpbslc)
  DE6F    21 E0E4        C      	ld	hl,dbslc
  DE72    70             C      	ld	(hl),b
  DE73    DD 7E 11       C      	ld	a,(ix+dpbbfm)	;Zahl der 128er Sektoren -1
  DE76    3C             C      	inc	a
  DE77    87             C      	add	a,a		;CY:=0
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-69


  DE78    04             C      	inc	b		;fuer djnz, falls dpbslc=0
  DE79    0F             C      dbsnbz:	rrca			;Zahl der phys. Sekt. im Puff.
  DE7A    10 FD          C      	djnz	dbsnbz
  DE7C    57             C      	ld	d,a		;merken
  DE7D    AF             C      	xor	a
  DE7E    C1             C      	pop	bc		;b:=geforderte Puffernr.
  DE7F    C5             C      	push	bc
  DE80    21 E0F6        C      	ld	hl,dbnb
  DE83    70             C      	ld	(hl),b
  DE84    04             C      	inc	b
  DE85    05             C      	dec	b		;Puffernr. 0?
  DE86    28 03          C      	jr	z,dbsec0	;ja
  DE88    82             C      dbsecz:	add	a,d		;0. phys. Sekt. im Puffer
  DE89    10 FD          C      	djnz	dbsecz		;=dbsnb.*Puffernr.
  DE8B    5F             C      dbsec0:	ld	e,a		;merken Pufferanf.-Sektor
  DE8C    DD 46 10       C      	ld	b,(ix+dpbslc)
  DE8F    DD 7E 00       C      	ld	a,(ix+dpbspt)
  DE92    04             C      	inc	b		;wegen djnz
  DE93    87             C      	add	a,a
  DE94    CB 3F          C      dbsecm:	srl	a		;phys. Sektoranzahl
  DE96    10 FC          C      	djnz	dbsecm
  DE98    93             C      	sub	e		;Restsektorzahl auf Spur
  DE99    BA             C      	cp	d		;>= Zahl zu transferierender?
  DE9A    30 01          C      	jr	nc,dbseco	;ja
  DE9C    57             C      	ld	d,a		;sonst nur Restsektorzahl
  DE9D    1C             C      dbseco:	inc	e		;Sektoren zaehlen ab 1
  DE9E    7B             C      	ld	a,e
  DE9F    32 E0E3        C      	ld	(dbsec),a	;Sektor
  DEA2    7A             C      	ld	a,d
  DEA3    32 E0E5        C      	ld	(dbsnb),a	;Sektorzahl
  DEA6    21 E0DF        C      	ld	hl,dbflg
  DEA9    CB 96          C      	res	dfbwr,(hl)
                         C       if @write
  DEAB    CB 46          C      	bit	dfbprr,(hl)	;muss neuer Puffer gel. werden?
  DEAD    20 14          C      	jr	nz,dbprr	;ja
                         C      ; nur dann kein preread, wenn Rest BDOS-Block >= phys. Puff.
                         C      ; und Rest BDOS-Block auf Pufferanfang beginnt
  DEAF    3A E0F1        C      	ld	a,(unacnt)
  DEB2    DD BE 11       C      	cp	(ix+dpbbfm)	;Restzahl-1 >= Puffergr.-1 ?
  DEB5    38 0C          C      	jr	c,dbprr		;nein, preread
  DEB7    3A E0EC        C      	ld	a,(dsectr)	;Sektornr.
  DEBA    3D             C      	dec	a		;ab 0 zaehlen
  DEBB    DD A6 11       C      	and	(ix+dpbbfm)	;rel. Sekt.nr. des
                         C      ;				BDOS-Blocks zum Pufferanfang
  DEBE    20 03          C      	jr	nz,dbprr
  DEC0    32 E0F8        C      	ld	(dberrf),a	;fehlerfrei gel. anzeigen
  DEC3    C4 DF04        C      dbprr:	call	nz,dbtran	;Puffer lesen
                         C       endif
  DEC6                   C      dbmat:	
                         C      
                         C      ; Sektor in/aus Puffer holen
                         C      ;===========================
  DEC6    F1             C      	pop	af		;Puffernr. in Spur wegschm.
  DEC7    F1             C      	pop	af		;128-er Index im Puffer
  DEC8    F5             C      	push	af
  DEC9    1F             C      	rra			;Sektornb*128 berechnen
  DECA    47             C      	ld	b,a
  DECB    0E 00          C      	ld	c,0
  DECD    CB 19          C      	rr	c
  DECF    21 F2FC        C      	ld	hl,dbuf
  DED2    09             C      	add	hl,bc		;Adresse im Puffer
  DED3    ED 5B E0EF     C      	ld	de,(ddma)	;Nutzer-DMA
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-70


  DED7    3A E0E8        C      	ld	a,(dflg)
  DEDA    CB 57          C      	bit	dfwr,a		;Schreiben?
  DEDC    28 09          C      	jr	z,dsmove	;nein
  DEDE    3A E0DF        C      	ld	a,(dbflg)
  DEE1    CB D7          C      	set	dfbwr,a		;anzeigen Puffer beschrieben
  DEE3    32 E0DF        C      	ld	(dbflg),a
  DEE6    EB             C      	ex	de,hl
  DEE7    01 0080        C      dsmove:	ld	bc,128
                         C       IF dev eq cpd
                         C       ELSE
  DEEA    ED B0          C      	ldir
                         C       ENDIF
  DEEC    F1             C      	pop	af		;128-Index im Puffer
  DEED    DD BE 11       C      	cp	(ix+dpbbfm)	;letzter Sektor im Puffer
  DEF0    28 05          C      	jr	z,dmovew	;ja, Puffer ausgeben
  DEF2    3A E0F7        C      	ld	a,(dwrtyp)
  DEF5    FE 01          C      	cp	1		;write to directory?
  DEF7    CC DEFE        C      dmovew:	call	z,dbtrw		;ja, veraend. Puffer ausgeben
  DEFA    3A E0F8        C      	ld	a,(dberrf)	;Ergebnis letztes dbtran
  DEFD    C9             C      	ret
