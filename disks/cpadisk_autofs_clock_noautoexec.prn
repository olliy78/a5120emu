BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-44


                         C      ; Tabelle der Sonderzeichen, SCP kompatibel!
                         C      ;==========================================
                         C      
  D897                   C      dszta:	
  D897    00             C      	db	00h	;nop
  D898    01             C      	db	01h	;home
  D899    02             C      	db	02h	;(auch 82h) cursor an
  D89A    03             C      	db	03h	;(auch 83h) cursor aus
  D89B    04             C      	db	04h	;(auch 84h) normal, nicht inv.
  D89C    05             C      	db	05h	;(auch 85h) normal,       inv.
  D89D    06             C      	db	06h	;(auch 86h) hell  , nicht inv.
                         C      ;			 (nur  87h) hell  ,       inv.
  D89E    07             C      	db	07h	;bell (akustisches zeichen)
  D89F    08             C      	db	08h	;cursor zurueck
  D8A0    0A             C      	db	0ah	;LF
  D8A1    0C             C      	db	0ch	;bs loeschen, cursor links oben
  D8A2    0D             C      	db	0dh	;CR
                         C       if umlaut
  D8A3    0E             C      	db	0eh	;umschalten auf 2. Zeichensatz
  D8A4    0F             C      	db	0fh	;umschalten auf 1. Zeichensatz
                         C       endif
  D8A5    14             C      	db	14h	;rest bs loeschen
  D8A6    15             C      	db	15h	;cursor vorwaerts
  D8A7    16             C      	db	16h	;rest der zeile loeschen
                         C       IF inslin
  D8A8    17             C      	db	17h	;Insert Line
                         C       ENDIF
  D8A9    18             C      	db	18h	;zeile loeschen, cursor an zeilanf.
                         C       IF inslin
  D8AA    19             C      	db	19h	;Delete Line
                         C       ENDIF
  D8AB    1A             C      	db	1ah	;eine zeile hoch
                         C      			;bei ADM3a wie 0ch
  D8AC    1B             C      	db	1bh	;escape
                         C      ;		1b zeile+80h spalte+80h		Kursor posit. SCP
                         C      ;		1b zeile+00h spalte+00h		geht auch bei CP/A
                         C      ;		1b '='/'Y' zeile+20h spalte+20h	Kursor posit. bei ADM3A
                         C      ;		1b 5e xx	Feldattribut setzen (SCP1715 fuer 8275-Contr.)
                         C      ;			mit xx= 01urggbh
                         C      ;				  u		unterstreichen,
                         C      ;				   r		invers,
                         C      ;				    gg		Zeichengenerator-Umschaltung,
                         C      ;				      b		blinken,
                         C      ;				       h	heller 
                         C      ;		1b 5f xx	Spezialzeichen setzen (SCP1715 fuer 8275)
                         C      ;			mit xx= 01ssssbh
                         C      ;				  ssss		Zeichencode (1100 Sonderfkt)
                         C      ;				      b		blinken des Sonderzeichens
                         C      ;				       h	heller des Sonderzeichens
                         C      	if	adm3a
                         C      	endif
                         C       if crt eq dsy5
                         C       endif
  D8AD    7F             C      	db	7fh	;delete
  D8AE    87             C      	db	87h	;(nicht 07h) hell  ,      inv.
  0018                   C       dsztal	equ	$-dszta	;Tabellenlaenge
                         C      
                         C      ; Reaktionsroutinen fuer Sonderzeichen
                         C      
  D8AF    D6F7           C      	dw	crtnop	;00
  D8B1    D786           C      	dw	crthom	;01
  D8B3    D7EA           C      	dw	crtcrt	;02/82
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-45


  D8B5    D7EE           C      	dw	crtcof	;03/83
  D8B7    D6D0           C      	dw	crto84	;04/84
  D8B9    D6D0           C      	dw	crto85	;05/85
  D8BB    D6D0           C      	dw	crto86	;06/86
  D8BD    D7F3           C      	dw	crtclk	;07
  D8BF    D768           C      	dw	crtcl	;08
  D8C1    D75A           C      	dw	crtlf	;0A
  D8C3    D771           C      	dw	crtbsl	;0C
  D8C5    D749           C      	dw	crtcr	;0D
                         C       if umlaut
  D8C7    D80A           C      	dw	crt2zs	;0E
  D8C9    D812           C      	dw	crt1zs	;0F
                         C       endif
  D8CB    D774           C      	dw	crtbsr	;14
