                         C      ;================================
  D46C                   C      kbdrcu:
  D46C    DB 06          C      	in	a,(kbdpci)	;Zeichen lesen
  D46D                   C      kbdmt1	equ	$-1		;auf "kbdsci/kbddci" bei K7637
                         C      
  D46E    21 D51C        C      cocpm1:	ld	hl,kbdcpt
  D471    4E             C      kbdrc3:	ld	c,(hl)		;phys. Tastencode
  D472    0C             C      	inc	c
  D473    0D             C      	dec	c		;TabEnde?
  D474    28 07          C      	jr	z,kbdrc1	;ja
  D476    B9             C      	cp	c		;Umcodieren ?
  D477    23             C      	inc	hl
  D478    28 07          C      	jr	z,kbdrc2	;ja
  D47A    23             C      	inc	hl
  D47B    18 F4          C      	jr	kbdrc3		;weiter in Tab
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-29


  D47D    FE 80          C      kbdrc1:	cp	80h		;Sonderzeichen, das nicht in Tabelle?
  D47F    38 01          C      	jr	c,kbdrc6	;nein; sonst A=00, d.h. Zeichen ignorieren
  D481    7E             C      kbdrc2:	ld	a,(hl)		;virtueller Tastencode
  D482                   C      kbdrc6:	
                         C      
  D482                   C      cocpm2:
  D482    21 D23D        C      	ld	hl,synflg
  D485    FE 20          C      	cp	20h		;Sondertaste?
  D487    38 0D          C      	jr	c,kbdrc5	;<20h, ja
  D489    FE 80          C      	cp	80h		
  D48B    38 04          C      	jr	c,kbdrc4	;nein
                         C      ; virtueller Code 80..ff
  D48D    E6 FF          C      	and	0ffh
  D48E                   C      kbdlcs	equ	$-1		;auf bfh, wenn Taste mit Control/Shift
  D48F    18 05          C      	jr	kbdrc5
                         C      ; normale Taste 20..7f
  D491    CB 46          C      kbdrc4:	bit	ctrlst,(hl)	;norm. Taste mit Control?
  D493    C8             C      	ret	z
  D494    E6 1F          C      	and	1fh		;CTRL realisieren
  D496    CB 86          C      kbdrc5:	res	ctrlst,(hl)
  D498    C9             C      	ret
                         C      
                         C      ; Suchen, ob Taste (A) umzukodieren entspr. Stringtab ab (HL)
                         C      ; ret z:	nicht gefunden, A unveraendert
                         C      ; ret nz:	gefunden, A unveraendert
                         C      ;		E Stringlaenge +1
                         C      ;		HL Stringanfang (nur gueltig falls E>1!)
  D499    16 00          C      costr:	ld	d,0
  D49B    4E             C      costr0:	ld	c,(hl)		;Tastencode o. Tabende
  D49C    0C             C      	inc	c		;Tabende?
  D49D    C8             C      	ret	z		;ja, nicht gefunden
  D49E    23             C      	inc	hl
  D49F    5E             C      	ld	e,(hl)		;Stringlaenge
  D4A0    1C             C      	inc	e		;+1
  D4A1    0D             C      	dec	c		;Tastencode wiederherstellen
  D4A2    B9             C      	cp	c		;Zeichen umkodieren?
  D4A3    28 03          C      	jr	z,costr1	;ja
  D4A5    19             C      	add	hl,de		;String uebergehen
  D4A6    18 F3          C      	jr	costr0
  D4A8                   C      costr1:
  D4A8    23             C      	inc	hl
  D4A9    14             C      	inc	d		;ret nz
  D4AA    C9             C      	ret
                         C      
                         C       IF costu
                         C       ENDIF
                         C      
                         C      ; Tastatur-Lampe umschalten
                         C      ;==========================
  D4AB    21 0040        C      kbdslm:	ld	hl,lampbf
  D4AE    AE             C      	xor	(hl)		;Lampe ein/aus
  D4AF    77             C      	ld	(hl),a
                         C      
                         C      ; Tastatur-Lampen ein/aus
                         C      ;========================
                         C      ; Achtung! Diese Routine wird auch aus Interrupt-Routine
                         C      ; aufgerufen (EI/DI darf hier nicht auftreten!!)
  D4B0                   C      lampen:
                         C      
  D4B0                   C      kbdmd2:		;Routine fuer K7637,
                         C      ;		 wird modifiziert bei K7604/06/34/36
  D4B0    3A 0040        C      lampen:	ld	a,(lampbf)
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-30


  D4B3    EE 00          C      	xor	00h		;ermitteln veraenderte Bits
  D4B4                   C      lamplt	equ	$-1		;Kopie Lampen-Puffer
  D4B5    C8             C      	ret	z		;unveraendert
  D4B6    21 E61E        C      	ld	hl,intkbd
  D4B9    36 21          C      	ld	(hl),21h	;call ... -> ld hl,...
                         C      				;d.h. 5ms Tastaturabfrage verbieten
  D4BB    26 55          C      	ld	h,55h		;Standard-Vorbyte
  D4BD    6F             C      	ld	l,a
  D4BE    CB 7D          C      	bit	7,l		;INS-MODE ?
  D4C0    28 06          C      	jr	z,lampb6	;nein
  D4C2    7C             C      	ld	a,h
  D4C3    D3 5C          C      	out	(kbdsci),a
  D4C4                   C      k37dm3	equ	$-1		;modfiziert bei Digitalisier-AP
  D4C5    CD D50A        C      	call	lmpout
  D4C8    CB 75          C      lampb6:	bit	6,l		;Fehlerlampe ?
  D4CA    28 05          C      	jr	z,lampb3	;nein
  D4CC    3E 20          C      	ld	a,20h
  D4CE    CD D50A        C      	call	lmpout
  D4D1    CB 5D          C      lampb3:	bit	3,l		;Sel3?
  D4D3    28 08          C      	jr	z,lampb2
  D4D5    7C             C      	ld	a,h
  D4D6    D3 5C          C      	out	(kbdsci),a
  D4D7                   C      k37dm4	equ	$-1		;modfiziert bei Digitalisier-AP
  D4D8    3E 52          C      	ld	a,52h
  D4DA    CD D50A        C      	call	lmpout
  D4DD    CB 55          C      lampb2:	bit	2,l		;Sel2?
  D4DF    28 08          C      	jr	z,lampb1
  D4E1    7C             C      	ld	a,h
  D4E2    D3 5C          C      	out	(kbdsci),a
  D4E3                   C      k37dm5	equ	$-1		;modfiziert bei Digitalisier-AP
  D4E4    3E 44          C      	ld	a,44h
  D4E6    CD D50A        C      	call	lmpout
  D4E9    CB 4D          C      lampb1:	bit	1,l
  D4EB    28 08          C      	jr	z,lampb0
  D4ED    7C             C      	ld	a,h
  D4EE    D3 5C          C      	out	(kbdsci),a
  D4EF                   C      k37dm6	equ	$-1		;modfiziert bei Digitalisier-AP
  D4F0    3E 20          C      	ld	a,20h
  D4F2    CD D50A        C      	call	lmpout
  D4F5    CB 45          C      lampb0:	bit	0,l
  D4F7    28 05          C      	jr	z,lampbn
  D4F9    3E 52          C      	ld	a,52h
  D4FB    CD D50A        C      	call	lmpout
  D4FE    3A 0040        C      lampbn:	ld	a,(lampbf)
  D501    32 D4B4        C      	ld	(lamplt),a	;neuen Zustand merken
  D504    21 E61E        C      	ld	hl,intkbd
  D507    36 CC          C      	ld	(hl),0cch	;ld hl,... -> call z,...
  D509    C9             C      	ret
                         C      
  D50A    E5             C      lmpout:	push	hl
  D50B    D3 5C          C      	out	(kbdsci),a
  D50C                   C      k37dm7	equ	$-1		;modfiziert bei Digitalisier-AP
  D50D    CD D433        C      lmpow:	call	kbdst1		;warten auf Antwort
  D510    28 FB          C      	jr	z,lmpow
  D512    DB 5C          C      	in	a,(kbdsci)
  D513                   C      k37dm8	equ	$-1		;modfiziert bei Digitalisier-AP
  D514    E6 F0          C      	and	0f0h
  D516    FE 80          C      	cp	typc37		;Antwort da?
  D518    20 F3          C      	jr	nz,lmpow	;nein
  D51A    E1             C      	pop	hl
  D51B    C9             C      	ret
                         C      
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-31


                         C      ; virtuelle Tastencodes: (unabhaengig von TastaturTyp)
                         C      ;=======================
                         C      
                         C      ; Beim Betaetigen zusammen mit CONTROL/SHIFT wird bei allen folgenden
                         C      ; Tastencodes >=c0h Bit 6 geloescht (d.h. Codes liegen von 80h..bfh)
                         C      
                         C      ; Kursortasten
                         C      ;-------------
  00C1                   C      kcurwl	equ	0c1h
  00C2                   C      kcurup	equ	0c2h
  00C3                   C      kcurwr	equ	0c3h
  00C4                   C      kcurlf	equ	0c4h
  00C5                   C      kcurpu	equ	0c5h
  00C6                   C      kcurri	equ	0c6h
  00C7                   C      kcurpd	equ	0c7h
  00C8                   C      kcurdw	equ	0c8h
                         C      
                         C      ; Sondertasten
                         C      ;-------------
                         C      ;		0c9h		;belegt mit zblb
  00CA                   C      spcclr	equ	0cah		;CLEAR
  00CB                   C      spccnc	equ	0cbh		;CNCL	
  00CC                   C      spcce	equ	0cch		;CE bzw. ERASE INPUT
  00CD                   C      spcins	equ	0cdh		;INS
  00C0                   C      spcdel	equ	0c0h		;DEL
  00CE                   C      spckor	equ	0ceh		;KOR
  00CF                   C      spcrol	equ	0cfh		;ROLL <-
  00D0                   C      spcror	equ	0d0h		;ROLL ->
                         C      
                         C      ; Bei Einfuehrung neuer Sonderzeichen zwischen Sel0..Sel3 muss
                         C      ; Test auf Sel0..3 zuletzt erfolgen, da diese als Gruppe
                         C      ; getestet werden, aber nicht dicht liegen!
  00D1                   C      Sel0	equ	0d1h;!!hintere!!	;LED 0 bei SEL 0
  00D2                   C      Sel1	equ	0d2h;!!Tetrade!!	;LED 1 bei SEL 1
  00D4                   C      Sel2	equ	0d4h;!!=2**LED!!	;LED 2 bei SEL 2
  00D8                   C      Sel3	equ	0d8h;!!	      !!	;LED 3 bei SEL 3
                         C      
  00D9                   C      SyLc	equ	0d9h			; Synch. List
  00DA                   C      HrLc	equ	0dah			; Hardcopy
  00DB                   C      Monc	equ	0dbh			; BIOS-Monitor
  00DC                   C      z00c	equ	0dch			; "00" im Ziffernblock
  00DD                   C      z000	equ	0ddh			; "000" im Ziffernblock
  00DE                   C      stpc	equ	0deh			; allg. STOP
  00DF                   C      ctlc	equ	0dfh			; Control (-Ersatz)
                         C      
                         C      ; Funktionstasten
                         C      ;----------------
  00E0                   C      pf0c	equ	0e0h			;PF0 bzw. S0 bzw. Enter im Ziffernblock
  00E1                   C      pf1c	equ	0e1h			;PF1...
  00E2                   C      pf2c	equ	0e2h
  00E3                   C      pf3c	equ	0e3h
  00E4                   C      pf4c	equ	0e4h
  00E5                   C      pf5c	equ	0e5h
  00E6                   C      pf6c	equ	0e6h
  00E7                   C      pf7c	equ	0e7h
  00E8                   C      pf8c	equ	0e8h
  00E9                   C      pf9c	equ	0e9h
                         C      ;***die folgenden 6 Funktionstasten ex nicht bei allen
                         C      ; Tastaturen, koennen aber durch andere Tasten ersetzt werden!
  00EA                   C      pfac	equ	0eah
  00EB                   C      pfbc	equ	0ebh
  00EC                   C      pfcc	equ	0ech
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-32


  00ED                   C      pfdc	equ	0edh
  00EE                   C      pfec	equ	0eeh		;bei CP/A i.a. Monitor-Taste
  00EF                   C      pffc	equ	0efh		;bei CP/A i.a. Stop-Taste
                         C      
                         C      ;rechter Ziffernblock
                         C      ;--------------------
  00F0                   C      zbl0	equ	0f0h
  00F1                   C      zbl1	equ	0f1h
  00F2                   C      zbl2	equ	0f2h
  00F3                   C      zbl3	equ	0f3h
  00F4                   C      zbl4	equ	0f4h
  00F5                   C      zbl5	equ	0f5h
  00F6                   C      zbl6	equ	0f6h
  00F7                   C      zbl7	equ	0f7h
  00F8                   C      zbl8	equ	0f8h
  00F9                   C      zbl9	equ	0f9h
  00DC                   C      zbl00	equ	z00c
  00DD                   C      zbl000	equ	z000
  00FA                   C      zblkom	equ	0fah		;Komma im Ziffernblock
  00FB                   C      zblmin	equ	0fbh		;Minus im Ziffernblock bei CP/A i.a. HardCopy
                         C      	;Enter im Ziffernblock als "pf0c" behandelt
  00FC                   C      zbla	equ	0fch		;Taste im Ziffernblock ueber der "7"
                         C      ;		0fdh		;belegt wegen TastenUmdefinitionsBegrenzer
  00C9                   C      zblb	equ	0c9h		;dito "8"
  00FE                   C      zblc	equ	0feh		;dito "9"
                         C      
                         C      ; zu ignorierende Tasten
                         C      ;-----------------------
  00FF                   C      cign	equ	0ffh			;Taste ignorieren
                         C      
  0000                   C      kbdcpb	equ	lmpsl0	;0..3, Selectortaste fuer CAPS-Lock
  0001                   C      kbdcal	equ	lmpsl1	;0..3, Selectortaste fuer ALPHA K7633
                         C      
                         C      ; Die folgende Code-Tabelle wird je nach Tastaturtyp beim
                         C      ; Kaltstart modifiziert. Sie dient dazu, um einen virtuellen
                         C      ; Tastaturcode zu erzeugen, der dann durch die String-
                         C      ; umkodierungstabellen unabhaengig von der konkreten Tastatur
                         C      ; zum eigentlichen Tastencode umgesetzt wird.
                         C      
                         C      ; Codetabelle fuer K7606/36
                         C      ;==========================
                         C      ;(Bemerkung: Falls sich K76x4-Tastaturen mit dem Typcode von K76x6 melden,
                         C      ;wurden einige phys. Tastencodes fuer diese mit aufgenommen, um trotzdem
                         C      ;eine notduerftige Arbeit zu erlauben. Gleichzeitig wird fuer die Kaltstart-
                         C      ;Modifizierung von 'kbdcpt' Reserve-Platz freigehalten.)
                         C      
  D51C                   C      kbdcpt:
                         C      ; Kursortasten
                         C      ;-------------
  D51C    0B C1          C      	db	00BH,kcurwl		;|<-
  D51E    04 C2          C      	db	004H,kcurup		;^
  D520    01 C3          C      	DB	001H,kcurwr		;->|
  D522    06 C4          C      	db	006H,kcurlf		;<-
  D524    0C C5          C      	DB	00CH,kcurpu		;'\
  D526    07 C6          C      	db	007H,kcurri		;->
  D528    0A C7          C      	db	00AH,kcurpd		;<-'
  D52A    05 C8          C      	db	005H,kcurdw		;v
                         C      ; Sondertasten
                         C      ;-------------
  D52C    FF 0D          C      	db	0ffh,0dh		;ET1 als CR
  D52E    9D 0D          C      	db	09dh,0dh		;ENTR			K7604/34
  D530    0F 09          C      	db	00FH,009h		;|<-| als Ersatz Tab
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-33


  D532    13 1B          C      	db	013H,01bh		;DELL als Ersatz ESC
  D534    1B C0          C      	db	01BH,spcdel		;DEL
  D536    19 CC          C      	db	019H,spcce		;CE
  D538    09 CC          C      	db	009H,spcce		;ERIN als Ersatz CE	K7604/34
  D53A    03 CD          C      	db	003H,spcins		;INSL
  D53C    1E CD          C          	db	01eH,spcins		;INS			K7604/34
  D53E    A0 D1          C      	DB	0A0H,Sel0		;SEL0
  D540    A1 D2          C      	DB	0A1H,Sel1		;SEL1
  D542    A2 D4          C      	DB	0A2H,Sel2		;SEL2
  D544    A3 D8          C              DB	0A3H,Sel3		;SEL3
  D546    FE DF          C      	db	0feh,ctlc		;ET2 als Control-Taste (Loslassen!)
  D548    1F DF          C      	db	01fH,ctlc		;RESET Control-Taste	K7604/34
                         C      ; num. Tasten
                         C      ;------------
  D54A    14 FF          C      	db	10*2,0ffh		;Reserve fuer rechtes Ziffernfeld
  D54C    11 DC          C      	db	011H,zbl00		;00
  D54E    12 DD          C      	db	012H,zbl000		;000
  D550    A8 FB          C      	DB	0A8H,zblmin		;INSM als Ersatz num. Minus
  D552    02 FB          C      	db	002H,zblmin		;INSM			K7604/34
                         C      ; Funktionstasten
                         C      ;----------------
  D554    C0 E0          C      	db	0c0h,pf0c		;S
  D556    C1 E1          C      	db	0c1h,pf1c		;S1
  D558    C2 E2          C      	db	0c2h,pf2c		;S2
  D55A    C3 E3          C      	db	0c3h,pf3c		;S3
  D55C    C4 E4          C      	db	0c4h,pf4c		;S4
  D55E    C5 E5          C      	db	0c5h,pf5c		;S5
  D560    C6 E6          C      	db	0c6h,pf6c		;S6
  D562    C7 E7          C      	db	0c7h,pf7c		;S7
  D564    C8 E8          C      	db	0c8h,pf8c		;S8
  D566    C9 E9          C      	db	0c9h,pf9c		;S9
  D568    CA EA          C      	db	0cah,pfac		;S10
  D56A    CB EB          C      	db	0cbh,pfbc		;S11
  D56C    CC EC          C      	db	0cch,pfcc		;S12
  D56E    10 EE          C      	db	010H,pfec		;MON als PF14
  D570    08 EE          C      	db	008H,pfec		;EREO als Ersatz PF14	K7604/34
  D572    AF EF          C      	DB	0AFH,pffc		;CI als Ersatz PF15
                         C      
  D574    00             C      	db	0			;Tabellenende
  D575                   C      	ds	12,0			;Reserve fuer K7633, K7637
  0065                   C      kbdcpl	equ	$-kbdcpt		;max. Tabellenlaenge
                         C      ;----------------------------------------------------------
                         C      
                         C      ; String-Umkodierungstabellen
                         C      ;============================
                         C      
                         C      ; Standardstrings:
                         C      
  D581                   C      kbdsts:	costs
  D581    C1 01 01       C+     	db	kcurwl,1,'A' and 1fh
  D584    C2 01 05       C+     	db	kcurup,1,'E' and 1fh
