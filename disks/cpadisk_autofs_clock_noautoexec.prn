  D9C1    EA             C      	db	@l	;WR5
                         C      			;**Portinitialisierung**
                         C      ; CTC Sendetakt
  D9C2    03             C       	db	2+1
  D9C3    0C             C      	db	@lcs		;CTC Senden
                         C       IF (cpu eq c1715) and (@ld eq kbdsci)	;;PC1715, SIO durch Tastatur init.!!
                         C       ELSE
  D9C4    17             C      	db	17h		;Vorteiler 16
