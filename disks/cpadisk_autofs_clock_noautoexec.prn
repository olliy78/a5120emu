  DDFA    28 F4          C      	jr	z,drwerr	;Geraet ex. nicht
                         C       if ramfl
                         C       endif
  DDFC    21 E0E8        C      	ld	hl,dflg
  DDFF    CB 96          C      	res	dfwr,(hl)	;Lesen anzeigen
                         C      
                         C       IF dbufsz gt 7
  DE01    21 E0DF        C      	ld	hl,dbflg
