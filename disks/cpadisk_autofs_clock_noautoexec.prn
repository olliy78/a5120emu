  D99B    00             C      	db	00H	;zuletzt empfangenes Zeichen
                         C       ENDIF
  D99C    5E             C      	db	@ld	;Port fuer Daten
  D99D    5F             C      	DB	@ls	;Port fuer Status/Kommando
                         C       IF (@lt mod 10) lt 5	;;SIO ###########################################
                         C       if ((@lt mod 10) eq 0) or ((@lt mod 10) eq 1) or ((@lt mod 10) eq 3)
  D99E    D9D4           C      	dw	cdsioo	;;Senden
  D9A0    D32F           C      	dw	cdsioi	;;Empfang
  D9A2    D9DA           C      	dw	cdsios	;;Empf.Status
                         C       endif
                         C       if (@lt mod 10) eq 2
                         C       endif
  0008                   C      @l	aset	00001000b	;;DC1/3, 5 Bit
                         C       if ((@lt mod 10) eq 1) or ((@lt mod 10) eq 3)
                         C       endif
                         C       if ((@lt mod 1000)/100) eq 6
                         C       endif
