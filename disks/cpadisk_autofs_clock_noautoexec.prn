                         C       IF	dbufsz le 7
                         C       ELSE
                         C      	IF	dbufsz lt 10	;Test, ob Disk-Puffer ausreicht
                         C      	ENDIF
  DC70    B7             C      	or	a		;Sektorlaenge 128?
  DC71    20 0F          C      	jr	nz,seldxl	;nein, normale Sektorfolge
                         C       ENDIF	;dbufsz gt 7
                         C       IF dsk8mf
                         C       ENDIF
  DC73                   C      seldsv:
