  D692                   C      desc	equ	$-1
  D693    B7             C      	or	a
  D694    20 62          C      	jr	nz,crto04	;ja
  D696    79             C      crto02:	ld	a,c
  D697    32 D896        C      	ld	(crtcch),a	;merken fuer direkte Ausgabe
  D69A    FE 87          C      	cp	87h		;07h ist bell!, daher 87h<>07h
  D69C    28 39          C      	jr	z,crto09
  D69E    CB BF          C      	res	7,a		;sonst 1xxxxxxxB  = 0xxxxxxxB
  D6A0    FE 20          C      	cp	20h		;steuerzeichen?
  D6A2    38 33          C      	jr	c,crto09	;ja
  D6A4    FE 7F          C      	cp	7fh
  D6A6    30 2F          C      	jr	nc,crto09
                         C       IF umlaut
  D6A8    CD D865        C      	call	crtuml		;evtl. Umlaute umkodieren
                         C       ENDIF
  D6AB                   C      crtobs:
  D6AB    EB             C      	ex	de,hl
                         C       IF crt eq dsy5
                         C       ENDIF
  D6AC                   C      crtsbl:
                         C      	setbs
  D6AC    12             C      	ld	(de),a		;Zeichen in Bildschirmpuffer
                         C      	setram
  D6AD    21 0001        C      crtcur:	ld	hl,0-bsend1
  D6AE                   C      crtm01	equ	$-2
  D6B0    19             C      	add	hl,de		;bs voll?
  D6B1    EB             C      	ex	de,hl
  D6B2    23             C      	inc	hl	
  D6B3    D0             C      	ret	nc
  D6B4    11 FFC0        C      	ld	de,bsend1-bssp1+1
  D6B5                   C      crtm02	equ	$-2
  D6B7    D5             C      crto03:	push	de
  D6B8    21 FC40        C      	ld	hl,bsanf1+bssp1	;aufschieben
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-37


  D6B9                   C      crtm03	equ	$-2
  D6BB    11 FC00        C      	ld	de,bsanf1
  D6BC                   C      crtm04	equ	$-2
  D6BE    01 03C0        C      	ld	bc,bsend1-bsanf1-bssp1+1
  D6BF                   C      crtm05	equ	$-2
                         C      	setbs
  D6C1    ED B0          C      	ldir
  D6C3    2B             C      	dec	hl
  D6C4    36 20          C      	ld	(hl),' '	;letzte zeile loeschen
