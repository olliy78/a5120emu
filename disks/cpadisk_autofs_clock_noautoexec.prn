  E653    27             C      	daa
  E654    10 F3          C      	djnz	t1uhr2		;Sec., Min. haben 60
  E656    FE 24          C      	cp	24h		;Std. haben 24
  E658    38 01          C      	jr	c,t1uhre	;kein Uebertrag
