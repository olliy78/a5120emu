  D3F5    C5             C      kbdwa:	push	bc
  D3F6    06 01          C      	ld	b,1		;0,01 sec warten
  D3F8    CD E7F3        C      	call	wait10
  D3FB    C1             C      	pop	bc
  D3FC    CD D433        C      kbdwst:	call	kbdst1		;taste neu gedrueckt?
  D3FF    20 13          C      	jr	nz,kbdwb	;ja, abholen ueber kbdst
  D401    DB 06          C      	in	a,(kbdpci)	;taste noch gedrueckt?
  D403    B7             C      	or	a		;(funktioniert nur bei K760X!)
  D404    28 0E          C      	jr	z,kbdwb		;nein; warten
