  D3EF    06 64          C      	ld	b,100		;fuer dauerfunktion
  D3F0                   C      kbdwt	equ	$-1
  D3F1    36 0A          C      	ld	(hl),10		;auf 10*0,01sec fuer
                         C      				;gleiche taste
