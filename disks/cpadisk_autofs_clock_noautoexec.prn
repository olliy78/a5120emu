  DC7A    EB             C      	ex	de,hl
  DC7B    21 E0A2        C      	ld	hl,xlt
  DC7E    0E 1A          C      	ld	c,26
  DC80    ED B0          C      	ldir
  DC82                   C      seldxl:
                         C      
  DC82    CD E035        C      	call	dtrsla		;stellen hl entspr. Sektorlaenge
  DC85    20 DA          C      	jr	nz,seldle	;unzulaessig
  DC87    01 0005        C      	ld	bc,dsll		;Laenge eines Eintrags
                         C       IF disk8
                         C       ENDIF
  DC8A    DD CB 12 4E    C      	bit	1,(ix+dpbstp)	;40 Tr. auf 80er LW?
  DC8E    20 08          C      	jr	nz,seld40	;ja
  DC90    DD 7E 16       C      	ld	a,(ix+dpbptr)	;40er LW?
  DC93    FE 29          C      	cp	40+1
  DC95    38 01          C      	jr	c,seld40	;ja, 40 Tr. auf 40er LW
  DC97    09             C      	add	hl,bc		;auf 80er Format stellen
  DC98    DD CB 0F 6E    C      seld40:	bit	dpbfds,(ix+dpbflg)	;DS?
  DC9C    28 02          C      	jr	z,seldss	;nein
  DC9E    09             C      	add	hl,bc		;auf DS Format
  DC9F    09             C      	add	hl,bc
  DCA0                   C      seldss:
  DCA0                   C      selset:
                         C      ; DPB modifizieren entsprechend erkanntem Format
  DCA0    4E             C      	ld	c,(hl)		;Zahl der benutzten Spuren
  DCA1    DD 71 14       C      	ld	(ix+dpbtrk),c
  DCA4    23             C      	inc	hl
  DCA5    4E             C      	ld	c,(hl)		;Anzahl 128er Sektoren pro Spur
  DCA6    DD 71 00       C      	ld	(ix+dpbspt),c
  DCA9    23             C      	inc	hl
  DCAA    4E             C      	ld	c,(hl)		;Anzahl der Dir-Eintraege -1
  DCAB    23             C      	inc	hl
  DCAC    7E             C      	ld	a,(hl)		;Anzahl der Systemspuren
  DCAD    CB 3F          C      	srl	a		;feste Anzahl erzwungen?
  DCAF    38 28          C      	jr	c,seldof	;ja
  DCB1    DD CB 0D 7E    C      	bit	7,(ix+dpbofs)	;kann Spur 0 Directory sein?
  DCB5    28 22          C      	jr	z,seldof	;nein, Standardanzahl setzen
  DCB7    DD 34 0D       C      	inc	(ix+dpbofs)	;evtl. leere Systemspur?
  DCBA    28 1C          C      	jr	z,seldo0	;nein, 0 Systemspuren
  DCBC    47             C      	ld	b,a		;retten Anzahl Systemspuren
  DCBD    32 E0E1        C      	ld	(dbtrk),a	;einlesen evtl. moeglicher Datenbeginn
  DCC0    E5             C      	push	hl
  DCC1    CD DF04        C      	call	dbtran		; dauert bei falscher Spur etwas laenger
  DCC4    E1             C      	pop	hl
  DCC5    78             C      	ld	a,b
  DCC6    20 11          C      	jr	nz,seldof	;Fehler, mit Systemspuren annehmen
  DCC8    FD E5          C      	push	iy
  DCCA    FD 2A E0E6     C      	ld	iy,(dbdma)
  DCCE    FD 7E 0E       C      	ld	a,(iy+14)	;falls dort Dir, so Byte 14 von Dir =0
  DCD1    FE E5          C      	cp	0e5h		;Daten auch leer?
  DCD3    FD E1          C      	pop	iy
  DCD5    78             C      	ld	a,b
  DCD6    20 01          C      	jr	nz,seldof	;nein, vorn liegen nichtbelegte Systemspuren
  DCD8    AF             C      seldo0:	xor	a		;sonst ohne Systemspuren
  DCD9    DD 77 0D       C      seldof:	ld	(ix+dpbofs),a
  DCDC    B7             C      	or	a		;0 Systemspuren?
  DCDD    28 07          C      	jr	z,selddr	;ja
  DCDF    79             C      	ld	a,c		;Anzahl Dir-Eintraege -1
  DCE0    FE BF          C      	cp	192-1		;>=192 Dir-Eintraege ?
  DCE2    38 02          C      	jr	c,selddr	;nein
  DCE4    0E 7F          C      	ld	c,128-1		;780k hat 128 Dir-Eintraege
  DCE6    DD 71 07       C      selddr:	ld	(ix+dpbdir),c
