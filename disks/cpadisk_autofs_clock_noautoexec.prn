                         C      
                         C      ; Uebersetzung Sektornummer 
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-66


                         C      ;==========================
                         C      ; Translate-Tab-Adr. in DE, Eingangs-Sektornummer in BC,
                         C      ;			    Ausgangs-Sektornummer in HL
                         C      ; Es wird keine Translate-Tabelle benutzt, da die Sektor-
                         C      ; nummernverwaltung verallgemeinert im nicht-Standard-DPB 
                         C      ; enthalten ist (auch fuer physische Sektorlaenge <>128)
                         C      
  DD7E                   C      sectran:
  DD7E    60             C      	LD	H,B
  DD7F    69             C      	LD	L,C
  DD80    23             C      	inc	hl		;Sektoren zaehlen in CP/A ab 1
  DD81    C9             C      	RET
                         C      ;-----------------------
                         C      
                         C      ; Schreiben Sektor
                         C      ;=================
                         C      ; Register C (vom BDOS gestellt):
                         C      ;	=0, wenn normales write
                         C      ;	=1, wenn directory-write (sofort ausgeben)
                         C      ;	=2, wenn Beginn eines neuen Datenblocks (kein preread)
                         C      
  DD82                   C      write:
                         C       IF @write
  DD82    59             C      	ld	e,c		;retten Reg. C
  DD83    3A E0E9        C      	ld	a,(ddrive)
  DD86    4F             C      	ld	c,a
  DD87    CD E8AE        C      	call	dgetpb		;ix:=dpb(ddrive)
  DD8A    28 64          C      	jr	z,drwerr	;Geraet ex. nicht
                         C       if ramfl
                         C       endif
  DD8C    21 E0E8        C      	ld	hl,dflg
  DD8F    CB D6          C      	set	dfwr,(hl)	;Write-Flag setzen
                         C      
                         C      	IF	dbufsz gt 7	;gepufferte Disk E/A
  DD91    21 E0DF        C      	ld	hl,dbflg
  DD94    CB C6          C      	set	dfbprr,(hl)	;Annahme preread notwendig
  DD96    7B             C      	ld	a,e		;A:= Write-Typ
  DD97    32 E0F7        C      	ld	(dwrtyp),a	;merken Write-Typ
  DD9A    FE 02          C      	cp	2		;write to unallocated?
  DD9C    20 17          C      	jr	nz,chkuna	;nein
  DD9E    DD 7E 03       C      	ld	a,(ix+dpbblm)	;Zahl der 128-Sekt. im Block -1
  DDA1    3C             C      	inc	a
  DDA2    32 E0F1        C      	ld	(unacnt),a	;fuer diese Sekt. kein preread
  DDA5    21 E0F2        C      	ld	hl,unadev
  DDA8    71             C      	ld	(hl),c
  DDA9    2A E0EA        C      	ld	hl,(dtrack)
  DDAC    22 E0F3        C      	ld	(unatrk),hl
  DDAF    3A E0EC        C      	ld	a,(dsectr)
  DDB2    32 E0F5        C      	ld	(unasec),a
  DDB5    21 E0F1        C      chkuna:	ld	hl,unacnt
  DDB8    7E             C      	ld	a,(hl)
  DDB9    B7             C      	or	a		;noch nicht geschr. Sekt. da?
  DDBA    28 4F          C      	jr	z,alloc		;nein
  DDBC    3D             C      	dec	a		;sonst Restzahl -1
  DDBD    77             C      	ld	(hl),a
  DDBE    23             C      	inc	hl
  DDBF    79             C      	ld	a,c
  DDC0    BE             C      	cp	(hl)		;gleiches Geraet?
  DDC1    20 48          C      	jr	nz,alloc	;nein
  DDC3    23             C      	inc	hl
  DDC4    3A E0EA        C      	ld	a,(dtrack)
  DDC7    BE             C      	cp	(hl)		;gleiche Spur?
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-67


  DDC8    20 41          C      	jr	nz,alloc	;nein
  DDCA    23             C      	inc	hl
  DDCB    3A E0EB        C      	ld	a,(dtrack+1)
  DDCE    BE             C      	cp	(hl)
  DDCF    20 3A          C      	jr	nz,alloc
  DDD1    23             C      	inc	hl
  DDD2    3A E0EC        C      	ld	a,(dsectr)
  DDD5    BE             C      	cp	(hl)		;gleicher Sektor?
  DDD6    20 33          C      	jr	nz,alloc	;nein
                         C      ; Vorbereiten naechsten unalloc write-Aufruf
  DDD8    DD BE 00       C      	cp	(ix+dpbspt)	;neue Spur?
  DDDB    38 0A          C      	jr	c,unatr1	;nein
  DDDD    2B             C      	dec	hl
  DDDE    56             C      	ld	d,(hl)
  DDDF    2B             C      	dec	hl
  DDE0    5E             C      	ld	e,(hl)
  DDE1    13             C      	inc	de		;unatrk +1
  DDE2    73             C      	ld	(hl),e
  DDE3    23             C      	inc	hl
  DDE4    72             C      	ld	(hl),d
  DDE5    23             C      	inc	hl
  DDE6    AF             C      	xor	a		;Sektor auf Spuranfang
  DDE7    3C             C      unatr1:	inc	a		;naechster Sektor
  DDE8    77             C      	ld	(hl),a
  DDE9    21 E0DF        C      	ld	hl,dbflg
  DDEC    CB 86          C      	res	dfbprr,(hl)	;anzeigen kein preread notw.
                         C      	ENDIF
  DDEE    18 1F          C      	jr	drw
                         C      
                         C       ENDIF ;@write
                         C      
                         C      ; Abbruch read/write mit E/A-Fehler
  DDF0    3E 01          C      drwerr:	ld	a,1
  DDF2    C9             C      	ret
                         C      
                         C      ; Lesen Sektor
                         C      ;=============
                         C      
  DDF3                   C      read:
