  D308                          cpmx00: IF	monitor
                                	ELSE
  D308    C9                    	ret
  D309    00                    	nop
  D30A    00                    	nop
                                	ENDIF
  D30B    C3 E5E7               cpmx03: jp	tim5on		;5ms Takt an
  D30E    C3 E5EE               cpmx06: jp	tim5of		;5ms Takt aus
  D311    C3 E5F2               cpmx09: jp	tim1on		;1s Takt an
  D314    C3 E5F9               cpmx0c: jp	tim1of		;1s Takt aus
                                	IF	mprot
                                	ELSE
  D317    C9                    	ret
  D318    00                    	nop
  D319    00                    	nop
  D31A    C9                    	ret
  D31B    00                    	nop
  D31C    00                    	nop
  D31D    C9                    	ret
  D31E    00                    	nop
  D31F    00                    	nop
                                	ENDIF
                                 IF stpvar or monitor
  D320    C3 E715               cpmx18: jp	delsps		;verzoegern Sondertasten
  D323    C3 E722               cpmx1b: jp	delspr		;erlauben Sondertasten
                                 ENDIF
                                 IF umlaut
