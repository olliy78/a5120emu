  E61E    CC D357        C      intkbd:	call	z,kbdsti	;ja, Tastatur abfragen und puffern
                         C      				;auf 'ld hl,.. .' waehrend Lampen-Ausgabe
  E621                   C      intrbc:				;allg. Interr.-ausgang
