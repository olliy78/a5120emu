  DF49    0D             C      	dec	c		;Sektornr. ab 0
  DF4A    DD CB 0F 66    C      	bit	dpbf86,(ix+dpbflg)	;Fortsetzung Dsk. auf Ruecks.?
  DF4E    20 0C          C      	jr	nz,diots2	;ja
  DF50    DD CB 0F 6E    C      	bit	dpbfds,(ix+dpbflg)	;ungerade Spuren auf Rueckseite?
  DF54    28 29          C      	jr	z,diotrs	;nein, einseitig
  DF56    CB 3A          C      	srl	d		;Spur halbieren
  DF58    30 25          C      	jr	nc,diotrs	;gerade Spur, Vorderseite
  DF5A    18 12          C      	jr	diots1		;auf Rueckseite
  DF5C    DD 46 14       C      diots2:	ld	b,(ix+dpbtrk)	;log. Spurzahl
  DF5F    CB 38          C      	srl	b		;Spuren auf Vorderseite
  DF61    7A             C      	ld	a,d
  DF62    90             C      	sub	b		;Spur auf Vorderseite?
  DF63    38 1A          C      	jr	c,diotrs	;ja, Spur in d unveraendert lassen
                         C      				;40 ->  0; 41 ->  1; ...; 79 ->  39
                         C      				;77 ->  0; 78 ->  1; ...;153 ->  76
  DF65    DD CB 0F 5E    C      	bit	dpbfsv,(ix+dpbflg)	;Ruecks. von aussen nach innen?
  DF69    20 02          C      	jr	nz,diots4	;ja
  DF6B    2F             C      	cpl			;40 -> -1; 41 -> -2; ...; 79 -> -40
                         C      				;77 -> -1; 78 -> -2; ...;153 -> -77
  DF6C    80             C      	add	a,b		;40 -> 39; 41 -> 38; ...; 79 ->   0
                         C      				;77 -> 76; 78 -> 75; ...;153 ->   0
  DF6D    57             C      diots4:	ld	d,a
  DF6E    3A E0F9        C      diots1:	ld	a,(diocfl)
  DF71    CB FF          C      	set	diofs1,a	;vermerken Rueckseite
  DF73    32 E0F9        C      	ld	(diocfl),a
  DF76    DD 7E 13       C      	ld	a,(ix+dpbsn0)	;Versch. der Sektornr. auf Rueckseite
  DF79    81             C      	add	a,c		;Sektornr. evtl. weiterzaehlen
                         C      ;;;	cp	c		;Weiternummerierung auf Rueckseite?
  DF7A    4F             C      	ld	c,a
                         C      ;;;	jr	nz,diotrs	;ja, dann side:=0
  DF7B    3E 01          C      	ld	a,1		;side:=1
  DF7D    18 01          C      	jr	diotss
  DF7F    AF             C      diotrs:	xor	a		;side:=0
  DF80    32 E0FC        C      diotss:	ld	(diocsi),a	;phys. Seite setzen
  DF83    7A             C      	ld	a,d
  DF84    32 E0FB        C      	ld	(dioctr),a	;phys. Spur setzen
                         C      
  DF87    7B             C      	ld	a,e		;log. Spurnr. zurueck nach A
  DF88    DD E5          C      	push	ix
  DF8A    E1             C      	pop	hl
  DF8B    11 0019        C      	ld	de,dpbstr	;d:=0
  DF8E    19             C      	add	hl,de
  DF8F    DD BE 0D       C      	cp	(ix+dpbofs)	;Systemspur?
  DF92    38 03          C      	jr	c,diossp	;ja, Sektornummern nicht logisch
  DF94    59             C      	ld	e,c
  DF95    19             C      	add	hl,de		;HL entspr. Index in dpbstr
  DF96    4A             C      	ld	c,d		;c:=0
  DF97    79             C      diossp:	ld	a,c		;phys. Sektornr. ab 0
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-73


  DF98    86             C      	add	a,(hl)		;+echte Sektornr.
  DF99    32 E0FD        C      	ld	(diocse),a	;phys. Sektor setzen
  DF9C                   C      diophy:
                         C      
                         C      ; i ret, BC, IX im Stack
                         C      ; i cdb auf diocdb
                         C      ; i IX auf DPB
                         C      
  DF9C                   C      diorty:	;interne Wiederholung diskio
  DF9C    DD E5          C      	push	ix		;retten IX fuer evtl. Wiederholung
  DF9E    21 E0F9        C      	ld	hl,diocdb
  DFA1    E5             C      	push	hl
