                         C      
                         C       IF cpastz or uhrvar
  E667    3A D23D        C      	ld	a,(synflg)
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-99


  E66A    CB 77          C      	bit	stzaus,a	;Pflege der Statuszeile?
  E66C    20 14          C      	jr	nz,nt1stz	;nein
                         C        IF crtbfl eq 0
