  D81A    E5             C      crthrd:	push	hl
  D81B    21 FC00        C      	ld	hl,bsanf1
  D81C                   C      crtm22	equ	$-2
  D81E    0E 11          C      	ld	c,bszl1+1
  D81F                   C      crtm23	equ	$-1
  D820    18 30          C      	jr	crthd3		;zu Beginn neue Zeile
  D822    06 40          C      crthd1:	ld	b,bssp1
  D823                   C      crtm24	equ	$-1
  D824    C5             C      crthd2:	push	bc
                         C      	setbs
  D825    7E             C      	ld	a,(hl)
                         C      	setram
  D826    23             C      	inc	hl
  D827    E5             C      	push	hl
  D828    E6 7F          C      	and	7fh
  D82A    FE 20          C      	cp	20h		;BS-Steuerzeichen?
  D82C    30 1C          C      	jr	nc,crthd4	;nein
                         C       IF umlaut
  D82E    21 D23D        C      	ld	hl,synflg	;Schalterbyte 
  D831    CB 56          C      	bit	umlflg,(hl)	;Umlaute anzeigen ?
  D833    28 13          C      	jr	z,cnuml1	;nein!
  D835    21 D88B        C      	ld	hl,umltb2	;Umlautcodierung ?
  D838    01 000B        C      	ld	bc,umllen
  D83B    ED B1          C      	cpir
  D83D    20 09          C      	jr	nz,cnuml1	;nein !
  D83F    01 000C        C      	ld	bc,umllen+1	;sonst rueckkodieren
  D842    B7             C      	or	a
  D843    ED 42          C      	sbc	hl,bc
  D845    7E             C      	ld	a,(hl)		;rueckkodiertes Zeichen
  D846    18 02          C      	jr	crthd4
  D848                   C      cnuml1:
                         C       ENDIF
  D848    3E 5E          C      	ld	a,'^'		;sonst Sonderzeichen
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-43


  D84A    4F             C      crthd4:	ld	c,a
  D84B    CD D20F        C      	call	BIOS0F		;LIST
  D84E    E1             C      	pop	hl
  D84F    C1             C      	pop	bc
  D850    10 D2          C      	djnz	crthd2		;bis Zeilenende
  D852    C5             C      crthd3:	push	bc
  D853    E5             C      	push	hl
  D854    0E 0D          C      	ld	c,0dh
  D856    CD D20F        C      	call	BIOS0F
  D859    0E 0A          C      	ld	c,0ah
  D85B    CD D20F        C      	call	BIOS0F
  D85E    E1             C      	pop	hl
  D85F    C1             C      	pop	bc
  D860    0D             C      	dec	c		;Bildschirmende?
  D861    20 BF          C      	jr	nz,crthd1	;nein
  D863    E1             C      	pop	hl
  D864    C9             C      	ret
                         C       ENDIF
                         C       ENDIF	;stpvar
                         C      
                         C       IF umlaut
                         C      ; Umlaute umcodieren fuer Anzeige auf BAB1/BAB2 (Sonder-PROM)
  D865                   C      crtuml:	
  D865    E5             C      	push 	hl		;retten wegen evtl. ext. Verwendung
  D866    C5             C      	push 	bc
  D867    21 D23D        C      	ld	hl,synflg	;Schalterbyte
  D86A    CB 56          C      	bit	umlflg,(hl)	;Umlaute anzeigen ?
  D86C    28 0F          C      	jr	z,umlcn1	;nein !
  D86E    21 D880        C      	ld 	hl,umltb1
  D871    01 000B        C      	ld 	bc,umllen
  D874    ED B1          C      	cpir			;in Tabelle suchen
  D876    20 05          C      	jr	nz,umlcn1	;nicht gefunden
  D878    01 000A        C      	ld	bc,umllen-1	;wegen cpir
  D87B    09             C      	add 	hl,bc
  D87C    7E             C      	ld	a,(hl)		;umcodieren
  D87D    C1             C      umlcn1:	pop	bc
  D87E    E1             C      	pop	hl
  D87F    C9             C      	ret
                         C      
                         C      ;------------------------------
                         C      ; Umcodiertabelle fuer Umlautumcodierung
                         C       IF zsuml ;auf freie 7023/24-Steuerzeichen (IH Mittweida, Koll. Geiler)
                         C      ;		Ae  Oe  Ue  ae  oe  ue  sz  **2 **3 Par my
  D880    5B 5C 5D 7B    C      umltb1:db	5bh,5ch,5dh,7bh,7ch,7dh,7eh,3ch,3eh,40h,5eh
  D884    7C 7D 7E 3C    C      
  D888    3E 40 5E       C      
  D88B    15 16 17 1C    C      umltb2:db	15h,16h,17h,1ch,1dh,1eh,1fh,10h,12h,14h,18h
  D88F    1D 1E 1F 10    C      
  D893    12 14 18       C      
  000B                   C      umllen	equ	umltb2-umltb1
                         C       ENDIF
                         C       IF zsibm ;auf 00..1f erweiterter IBM-Zeichensatz
                         C       ENDIF	
                         C       ENDIF	
