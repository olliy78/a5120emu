                         C      ;************************************************************
                         C      ;	Spezialroutinen
                         C      ;************************************************************
                         C      
                         C      	IF	monitor
                         C      	ENDIF
                         C      
                         C      
                         C      ; Arbeit mit asynchronen Sonderaktionen
                         C      ;======================================
                         C      ; Die folgenden beiden Routinen werden vom BIOS immer dann aufgerufen,
                         C      ; wenn wegen zeitkritischer (z.B. Floppy-Bedienung) oder anderer
                         C      ; BIOS-Arbeit (z.B. Bildschirmrollen) keine parallelen Sonderaktionen
                         C      ; erlaubt sind.
                         C      
                         C      ; Reg A bleibt erhalten
  E715    F5             C      delsps: push	af
  E716    2A 004A        C      	ld	hl,(kritbg)	;evtl. Nutzerroutine fuer Beginn krit. BIOS
  E719    CD E7E6        C      	call	callhl		;aufrufen
  E71C    F1             C      	pop	af
  E71D    21 D23E        C      	ld	hl,synsem	;Verzoegern Sonderaktionen
  E720    34             C      	inc	(hl)
  E721    C9             C      	ret
                         C      
                         C      ; Reg A bleibt erhalten
  E722    F5             C      delspr: push	af
  E723    2A 004C        C      	ld	hl,(kriten)	;evtl. Nutzerroutine fuer Ende krit. BIOS
  E726    CD E7E6        C      	call	callhl		;aufrufen
  E729    F1             C      	pop	af
  E72A    21 D23E        C      	ld	hl,synsem	;Zulassen Sonderaktionen
  E72D    35             C      	dec	(hl)
                         C      
                         C       IF stpvar or monitor
                         C      
                         C      ; Test auf zwischenzeitliche Anforderung von Sonderroutinen
                         C      ;----------------------------------------------------------
                         C      
                         C      ; Diese Routine wird nach dem Lesen eines Tastaturzeichens
                         C      ; als "Ohr" eingeschoben, bevor zur eigentlichen Interrupt-
                         C      ; adresse zurueckgekehrt wird. Sie wird nicht innerhalb der
                         C      ; Interruptroutine ausgefuehrt, um mit offenen Interrupts
                         C      ; arbeiten zu koennen.
                         C      ; maximale Stackbelastung nach RETI von Interruptroutinen:
                         C      ; -	Return-Adresse zum Nutzer
                         C      ; -	AF
  E72E    F3             C      chksp:	di
  E72F    F5             C      	push	af		;A und F Reg retten
  E730    3A D23E        C      	ld	a,(synsem)
  E733    B7             C      	or	a		;asynchr. Routinen zugelassen?
  E734    C2 E74B        C      	jp	nz,chkspx	;nein
  E737    3C             C      	inc	a		;weiteren Eintritt verhindern
  E738    32 D23E        C      	ld	(synsem),a
  E73B    FB             C      chkspn: ei
  E73C    3A D23D        C      	ld	a,(synflg)	;inzw. (neue) Anforderung?
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-103


  0000                   C      rqmask	aset	0
                         C       IF monitor
                         C       ENDIF
                         C       IF stpvar
  0010                   C      rqmask	aset	rqmask+(1 shl stoprq)
                         C       IF chdvar
  0018                   C      rqmask	aset	rqmask+(1 shl synlrq)
                         C       ENDIF
                         C       ENDIF
  E73F    E6 18          C      	and	rqmask
  E741    C2 E74E        C      	jp	nz,chkspd	;ja, ausfuehren
  E744    3A D23E        C      	ld	a,(synsem)
  E747    3D             C      	dec	a
  E748    32 D23E        C      	ld	(synsem),a
  E74B    F1             C      chkspx: pop	af
  E74C    FB             C      	ei
  E74D    C9             C      	ret
                         C      
                         C      ; asynchrone Aktionen ausfuehren
  E74E                   C      chkspd:
                         C       IF monitor
                         C       ENDIF
                         C      
                         C       IF stpvar
  E74E    3A D23D        C      	ld	a,(synflg)
  E751    CB 67          C      	bit	stoprq,a	;inzwischen Stop-Forderung?
  E753    28 10          C      	jr	z,nstpsp	;nein
  E755    CB A7          C      	res	stoprq,a
  E757    32 D23D        C      	ld	(synflg),a
  E75A    F1             C      	pop	af		;Nutzer-Stackbelastung verringern
  E75B    22 E793        C      	ld	(asynhl),hl	;HL freimachen
  E75E    21 E796        C      	ld	hl,stoprt	;Routine
  E761    CD E77F        C      	call	asynrt		;aufrufen mit eigenem Stack
  E764    F5             C      	push	af
  E765                   C      nstpsp:
                         C      
                         C       IF chdvar
  E765    3A D23D        C      	ld	a,(synflg)
  E768    CB 5F          C      	bit	synlrq,a	;inzwischen LST:-Synchr.?
  E76A    28 10          C      	jr	z,nsynlr	;nein
  E76C    CB 9F          C      	res	synlrq,a
  E76E    32 D23D        C      	ld	(synflg),a
  E771    F1             C      	pop	af
  E772    22 E793        C      	ld	(asynhl),hl
  E775    21 D968        C      	ld	hl,lsynch
  E778    CD E77F        C      	call	asynrt
  E77B    F5             C      	push	af
  E77C                   C      nsynlr:
                         C       ENDIF
                         C       ENDIF	;stpvar
                         C      
  E77C    C3 E73B        C      	jp	chkspn		;Test auf neue Requests
                         C      
                         C       IF stpvar or chdvar
                         C      ; Asynchrone Routine (HL) mit eigenem Stack aufrufen
                         C      ;---------------------------------------------------
                         C      
  E77F    ED 73 E790     C      asynrt: ld	(asynsv),sp	;asynchr. Routinen haben
  E783    31 F10E        C      	ld	sp,stpstk	;ein eigenes Stack
  E786    F5             C      	push	af
  E787    D5             C      	push	de
  E788    C5             C      	push	bc
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-104


  E789    CD E7E6        C      	call	callhl		;Routine aufrufen
  E78C    C1             C      	pop	bc
  E78D    D1             C      	pop	de
  E78E    F1             C      	pop	af
  E78F    31 0000        C      	ld	sp,0		;SP wiederherstellen
  E790                   C      asynsv	equ	$-2
  E792    21 0000        C      	ld	hl,0		;gerettetes hl wiederherst.
  E793                   C      asynhl	equ	$-2
  E795    C9             C      	ret
                         C       ENDIF
                         C      
                         C       IF stpvar
                         C      ; Asynchrone Stop-Routine
                         C      ;------------------------
  E796                   C      stoprt:
                         C       IF disknb ne 0
  E796    CD E3BD        C      	call	headup		;Disk-Kopf abheben
                         C       ENDIF
  E799    CD E7D0        C      stopz:	call	stpchp		;holen naechste phys. Taste
                         C      
                         C       IF umlaut
  E79C    FE 75          C      	cp	'u'		;Umlaut-Modus umschalten ?
  E79E    28 04          C      	jr	z,stopzu
  E7A0    FE 55          C      	cp	'U'
  E7A2    20 08          C      	jr	nz,stopnu	;Nein !
  E7A4    21 D23D        C      stopzu: ld	hl,synflg	;Umlaute-Flag im Flagbyte
  E7A7    7E             C      	ld	a,(hl)
  E7A8    EE 04          C      	xor	1 shl umlflg	;umschalten
  E7AA    77             C      	ld	(hl),a
  E7AB    C9             C      	ret
  E7AC                   C      stopnu:
                         C       ENDIF
                         C      
                         C       IF chdvar
  E7AC    FE FB          C      	cp	zblmin		;"- im Ziffernblock": Hardcopy BS -> LIST?
  E7AE    CA D81A        C      	jp	z,crthrd	;ja, ausfuehren
  E7B1    FE CD          C      	cp	spcins		;"INS": I/O-Byte im LST:Kanal weiterschalten?
  E7B3    20 08          C      	jr	nz,stopz2	;nein
  E7B5    21 0003        C      	ld	hl,iobyte
  E7B8    7E             C      	ld	a,(hl)
  E7B9    C6 40          C      	add	a,40h		;Ueberlauf wird ignoriert
  E7BB    77             C      	ld	(hl),a
  E7BC    C9             C      	ret
  E7BD                   C      stopz2:
                         C      
                         C       IF l2bahn
                         C       ENDIF
                         C       ENDIF
                         C      
                         C       IF cpastz or uhrvar
  E7BD    FE EE          C      	cp	pfec		;"F14": Status-Anzeige ein/aus?
  E7BF    20 08          C      	jr	nz,stopz3	;nein
  E7C1    21 D23D        C      	ld	hl,synflg
  E7C4    7E             C      	ld	a,(hl)
  E7C5    EE 40          C      	xor	1 shl stzaus	;Status-Anzeige ein/aus
  E7C7    77             C      	ld	(hl),a
  E7C8    C9             C      	ret			;fertig
  E7C9                   C      stopz3:
                         C       ENDIF
                         C      
                         C       IF costu
                         C       ENDIF
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-105


                         C      
  E7C9    D6 C7          C      	sub	kcurpd		;"Page down": ^C ?
  E7CB    C0             C      	ret	nz		;nein, Stop-Ende
  E7CC    32 D23E        C      	ld	(synsem),a	;falls rst 0 nicht in BIOS fuehrt
  E7CF    C7             C      	rst	0		;sonst Warmstart
                         C      
                         C      ; Holen naechste Taste physisch
  E7D0    21 D23D        C      stpchp: ld	hl,synflg
  E7D3    CB FE          C      	set	phyact,(hl)	;naechste Taste physisch
  E7D5    E5             C      	push	hl
  E7D6    CD E7DD        C      	call	stopch		;holen naechstes Tastaturz.
  E7D9    E1             C      	pop	hl
  E7DA    CB BE          C      	res	phyact,(hl)	;physisches Lesen beendet
  E7DC    C9             C      	ret
                         C      
                         C      ; Holen naechste Taste im Stopzustand
  E7DD    CD D7FB        C      stopch: call	swilmp		;Stop-Lampe an
  E7E0    CD D3E7        C      	call	kbdi		;Warten auf naechstes Zeichen
  E7E3    C3 D7FB        C      	jp	swilmp		;danach Stop-Lampe aus
                         C      
                         C       ENDIF ;stpvar
                         C       ENDIF ;asynchr. Routinen
                         C      
                         C      ;***************************************************
                         C      ;	Allgemeine BIOS-Hilfsprogramme
                         C      ;***************************************************
                         C      
                         C      ; Aufruf der Routine (HL)
  E7E6    E9             C      callhl: jp	(hl)
                         C      
                         C      ; Ausgabe Text ab (HL) bis 00h auf CON: und evtl. LST:
  E7E7    7E             C      putmes: LD	A,(HL)
  E7E8    B7             C      	OR	A
  E7E9    C8             C      	RET	Z
  E7EA    E5             C      	PUSH	HL
  E7EB    4F             C      	LD	C,A
  E7EC    CD D20C        C      	CALL	conol
  E7EF    E1             C      	POP	HL
  E7F0    23             C      	INC	HL
  E7F1    18 F4          C      	JR	putmes
                         C      
                         C      ; Ausgabe Text ab (HL) mit exakter Laenge "stzbl" in Statuszeile
                         C       IF cpastz
                         C       ELSE
  E7E7                   C      biosms	equ	putmes	;0dh,0ah,...,07h,00h im Text ergaenzen!!
                         C       ENDIF
                         C      
                         C      ;	Wait 0.01 sec * (B)
                         C      ; Reg HL bleibt erhalten
  E7F3    C5             C      wait10: push	bc
  E7F4    0E 0A          C      	ld	c,10		;10* 1ms warten
  E7F6    06 BD          C      wait2z: ld	b,189		;(189*13)/(256*9600)=0.001
  E7F8    10 FE          C      wait1z: djnz	wait1z		;1ms warten
  E7FA    0D             C      	dec	c
  E7FB    20 F9          C      	jr	nz,wait2z
  E7FD    C1             C      	pop	bc
  E7FE    10 F3          C      	djnz	wait10
  E800    C9             C      	ret
                         C      
                         C      ;************************************************************
                         C      ;	zentral verwendete Rueckkonvertierungsroutinen
                         C      ;************************************************************
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-106


                         C      
                         C       IF monitor or errvar or iobvar or uhrvar or mprot
                         C      
                         C      ; Rueckkonvertieren Byte ab (HL) nach (DE)
                         C      ; RET: 2 Zeichen ab (DE), DE zeigt auf naechstes freies Byte
  E801    7E             C      mbreco: ld	a,(hl)
                         C      
                         C      ; Rueckkonvertieren Byte in A nach (DE)
                         C      ; RET: 2 Zeichen ab (DE), DE zeigt auf naechstes freies Byte
  E802    CD E805        C      mrecoa: call	mreca
                         C      
                         C      ; Rueckkonvertieren A in HEX-Ziffern nach (DE)
                         C      ; RET: A um 4 bits nach rechts rotiert
                         C      ;      DE zeigt auf naechstes Byte
  E805                   C      mrecol:
  E805    0F             C      mreca:	rrca			;linkes Halbbyte
  E806    0F             C      	rrca
  E807    0F             C      	rrca
  E808    0F             C      	rrca
  E809                   C      mrecor:				;rechtes Halbbyte
  E809    F5             C      	push	af		;fuer 2. mreca-Aufruf retten
  E80A    E6 0F          C      	and	0fh
  E80C    D6 0A          C      	sub	9+1
  E80E    38 02          C      	jr	c,mrecod	;0..9
  E810    C6 07          C      	add	a,7		;A..F
  E812    C6 3A          C      mrecod: add	a,'0'+10
  E814    12             C      	ld	(de),a
  E815    13             C      	inc	de
  E816    F1             C      	pop	af
  E817    C9             C      	ret
                         C      
                         C       ENDIF
                         C      
                         C       IF monitor or cpastz
                         C       ENDIF
                         C      
                         C      
                         C      ;*************************************************************
                         C      ;	wiederholter Kaltstart
                         C      ;*************************************************************
  E818                   C      kalts1:
                         C       IF cpu eq k2521
                         C       ENDIF
                         C       IF (cpu eq k2526) or (cpu eq c1715)
  E818    CD E5EE        C      	call	tim5of		;totlegen aller Interruptquellen
                         C        IF cpu eq k2526
  E81B    CD E5F9        C      	call	tim1of
                         C        ENDIF
                         C        IF cpu eq c1715
                         C        ENDIF
  E81E    F3             C      	di
                         C        IF cpu eq k2526
  E81F    3E F7          C      	ld	a,0f7h
  E821    D3 0A          C      	out	(0ah),a		;Lade-ROM zuschalten
                         C        ENDIF
                         C        IF cpu eq c1715
                         C        ENDIF
  E823    C7             C      	rst	0		;RESET
                         C       ENDIF
                         C      
                         C      ;*************************************************************
                         C      ;	Warmstart
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-107


                         C      ;*************************************************************
                         C       if1
                         C       endif
                         C      
                         C       IF	wbootv eq 1	;Warmstart=Kaltstart
                         C       ELSE
  E824    31 0080        C      WARMST: LD	SP,tpa-80h
                         C      
                         C         if	wbootv eq 0		;;CCP-Kopie im BIOS
  E827    21 E8D1        C      	ld	hl,ccpkop	;;CCP von Kopie wiederherst.
  E82A    11 BC00        C      	ld	de,CCP
  E82D    01 0811        C      	ld	bc,ccpkpl+bdskpl
  E830    ED B0          C      	ldir
                         C         endif
                         C      
                         C         if	(wbootv eq 2) or (wbootv eq 3) or (wbootv eq 4)
                         C         endif ;(wbootv eq 2) or (wbootv eq 3) or (wbootv eq 4)
                         C      
                         C         if (wbootv eq 0) or (wbootv eq 2) or (wbootv eq 3)
  E832    21 BC03        C      	LD	HL,CCP+3	;EINGANG MIT KOMMANDOLOESCHEN
                         C         endif
                         C         if wbootv eq 4
                         C         endif
                         C      	warmin
  E835    F3             C+     wbinit: DI
  E836    E5             C+     	PUSH	HL
  E837    3E F7          C+     	LD	A,high(intvr)
  E839    ED 47          C+     	LD	I,A
  E83B    ED 5E          C+     	im	2
  E83D    3E C3          C+     	LD	A,0C3H
  E83F    32 0000        C+     	LD	(REBOOT),A
  E842    21 0003'       C+     	LD	HL,BIOS+3
  E845    22 0001        C+     	LD	(REBOOT+1),HL
  E848    32 0005        C+     	LD	(BDOSJP),A
  E84B    21 C406        C+     	LD	HL,BDOS+6
  E84E    22 0006        C+     	LD	(BDOSJP+1),HL
  E851    32 0038        C+     	ld	(38h),a		;Breakpoint
  E854    21 0000        C+     	ld	hl,0		;ohne Monitor wie Warmstart
  E857    22 0039        C+     	ld	(38h+1),hl
  E85A    21 D23D        C+     	ld	hl,synflg
  E85D    36 00          C+     	ld	(hl),0
  E85F    23             C+     	inc	hl
  E860    36 00          C+     	ld	(hl),0		;synsem:=0
  E862    21 E5ED        C+     	ld	hl,ret
  E865    22 004A        C+     	ld	(kritbg),hl	;leere Routine fuer Beginn kritischer BIOS-Teil
  E868    22 004C        C+     	ld	(kriten),hl
  E86B    21 E5ED        C+     	ld	hl,ret
  E86E    22 0045        C+     	ld	(tim1rt),hl
  E871    CD E5E7        C+     	call	tim5on
  E874    CD E5F2        C+     	call	tim1on
  E877    AF             C+     	xor	a
  E878    32 D692        C+     	ld	(desc),a	;evtl. ESCAPE-Modus beenden
  E87B    0E 82          C+     	ld	c,82h		;Kursor sichtbar machen
  E87D    CD D654        C+     	call	crto
  E880    3A 0040        C+     	ld	a,(lampbf)
  E883    E6 B3          C+      and (1 shl lmphcp)+(1 shl lmpb2r)+(1 shl lmpb2b)+(1 shl kbdcpb)+(1 shl kbdcal)
  E885    32 0040        C+     	ld	(lampbf),a	;ruecksetzen Lampen
  E888    21 D581        C+     	ld	hl,kbdsts	;Standard-Stringtabelle wiederherstellen
  E88B    22 D23B        C+     	ld	(kbdsst),hl
  E88E    3E FF          C+     	ld	a,0ffh
  E890    32 E0E0        C+     	ld	(dbdev),a
  E893    FB             C+     	EI
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-108


  E894    21 0004        C+     setcld: ld	hl,defaul
  E897    4E             C+     	ld	c,(hl)
  E898    C5             C+     	push	bc
  E899    79             C+     	ld	a,c
  E89A    E6 0F          C+     	and	0fh
  E89C    4F             C+     	ld	c,a
  E89D    AE             C+     	xor	(hl)
  E89E    F6 00          C+     	or	0
  E8A0    77             C+     	ld	(hl),a
  E8A1    CD E8AE        C+     	call	dgetpb
  E8A4    C1             C+     	pop	bc
  E8A5    28 ED          C+     	jr	z,setcld
  E8A7    C9             C+     	ret
                         C       ENDIF	;wbootv ne 1
                         C      
                         C      ;$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$
                         C      ;	Steuertabellen fuer Massenspeicher
                         C      ;$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$
                         C       if1
                         C       endif
                         C      
                         C      ; Tabelle der Adressen der DPH's
                         C      ;===============================
                         C      
                         C      ;===============================================
  0003                   C      @din	aset	dphnb
  E8A8                   C      dphatb: IRP	di,<A,B,C,D,E,F,G,H,I,J,K,L,M,N,O,P>
                         C      	if	@din eq 0
                         C      	EXITM
                         C      	endif
                         C      @din	aset	@din-1
                         C       IF dpha&di ; Laufwerk A auf erstes definiertes Geraet legen
                         C      dphaA	aset	dpha&di
                         C       ENDIF
                         C      	dw	dpha&di
                         C      	ENDM
  E8A8    D23F           C+     	dw	dpha&A
  E8AA    D24F           C+     	dw	dpha&B
  E8AC    D25F           C+     	dw	dpha&C
                         C      
                         C      ; Ermitteln DPH und DPB von (c) nach HL bzw. IX
                         C      ; ret z		DPH existiert nicht, HL=0
                         C      ; ret nz	ok, HL auf DPH, IX auf DPB
                         C      ; BC, DE bleiben erhalten
                         C      ;=====================================================
  E8AE    D5             C      dgetpb: push	de
  E8AF    21 0000        C      	ld	hl,0
  E8B2    79             C      	ld	a,c
  E8B3    FE 03          C      	cp	dphnb		;DPH definiert?
  E8B5    30 16          C      	jr	nc,dgetp0	;nein
  E8B7    EB             C      	ex	de,hl
  E8B8    21 E8A8        C      	ld	hl,dphatb	;Adresstabelle fuer DPH's
  E8BB    59             C      	ld	e,c
  E8BC    19             C      	add	hl,de
  E8BD    19             C      	add	hl,de
  E8BE    7E             C      	ld	a,(hl)
  E8BF    23             C      	inc	hl
  E8C0    66             C      	ld	h,(hl)
  E8C1    6F             C      	ld	l,a		;hl:=^DPH
  E8C2    E5             C      	push	hl
  E8C3    1E 0A          C      	ld	e,10
  E8C5    19             C      	add	hl,de
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-109


  E8C6    5E             C      	ld	e,(hl)
  E8C7    23             C      	inc	hl
  E8C8    56             C      	ld	d,(hl)		;de:=^dpb
  E8C9    D5             C      	push	de
  E8CA    DD E1          C      	pop	ix		;ix:=^dpb
  E8CC    E1             C      	pop	hl
  E8CD    D1             C      dgetp0: pop	de
  E8CE    7C             C      	ld	a,h
  E8CF    B5             C      	or	l		;ret z bei hl=0
  E8D0    C9             C      	ret
                         C      
                         C      
                         C      ;**************************************************
                         C      ;	Arbeits-Felder (ab hier keine Konstanten!!)
                         C      ;	Arbeits-Felder werden benutzt fuer Kaltstart-Routinen
                         C      ;**************************************************
  E8D1                   C      biosds	equ	$
  E8D1                   C      @dsad	aset	biosds
                         C      
                         C      ; ===========allgemeine BIOS-Funktionen=============
                         C      
  0800                   C      ccpkpl	equ	ccpln		;Laenge CCP+ BDOS-Anfang
  0011                   C      bdskpl	equ	11h		;BDOS-Anfang
                         C      
                         C      	if	wbootv eq 0	;CCP-Kopie im BIOS
  E8D1                   C      ccpkop	equ	@dsad
  F0E2                   C      ccpkpe	equ	ccpkop+ccpkpl+bdskpl
  F0E2                   C      @dsad	aset	ccpkpe	;Ende CCP-Kopie
                         C      	endif
                         C      
                         C      	if	(wbootv eq 2) or (wbootv eq 3)
                         C      	endif
                         C      
                         C       IF stpvar
  F10E                   C      @dsad	aset	@dsad+2*22	;Stack fuer asynchrone Routinen
  F10E                   C      stpstk	equ	@dsad
                         C       ENDIF
  F126                   C      @dsad	aset	@dsad+2*12	;Stack fuer Interrupt-Routinen
  F126                   C      intstk	equ	@dsad
                         C      
                         C      ;=============Disketten-Arbeit============
                         C      
  F126                   C      dirbuf	equ	@dsad	;Directory-Puffer fuer alle Laufwerke
  F1A6                   C      @dsad	aset	@dsad+128
                         C      	IRP	di,<A,B,C,D>
                         C       IF disk&di
                         C      alv&di	equ	@dsad		;;Allocation-Vector Disk.
                         C      	IF	((disk&di mod 1000)/100) eq 5	;;5" 
                         C      	if	((disk&di mod 10000)/1000)	;;DS
                         C      @dsad	aset	@dsad+(400+7)/8 ;;reicht fuer 400k (1K Bloecke)
                         C      				;;	bzw. 800K (2K Bloecke)
                         C      	else					;;SS
                         C      @dsad	aset	@dsad+(200+7)/8 ;;reicht fuer 200k (1K Bloecke)
                         C      				;;	bzw. 400K (2K Bloecke)
                         C      	endif
                         C      	ELSE					;;8" 
                         C      	if	(disk&di ge 10000)		;;MFM
                         C      @dsad	aset	@dsad+(352+7)/8 ;;reicht fuer 704 2K Bloecke
                         C      	else					;;FM
                         C      @dsad	aset	@dsad+(250+7)/8 ;;reicht fuer 250K (1K Bloecke)
                         C      				;;	bzw. 500K (2K-Bloecke)
                         C      	endif
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-110


                         C      	ENDIF
                         C      csv&di	equ	@dsad		;;Check Sum
                         C      	IF	(disk&di mod 100) gt 40 ;;8",77 oder 5",80 Track
                         C      	if	((disk&di mod 10000)/1000)	;;DS
                         C      @dsad	aset	@dsad+256/4	;;reicht fuer 256 Dir.eintraege
                         C      	else					;;SS
                         C      @dsad	aset	@dsad+128/4	;;reicht fuer 128 Dir.eintraege
                         C      	endif
                         C      	ELSE				;;5" 40 Track
                         C      	if	((disk&di mod 10000)/1000)	;;DS
                         C      @dsad	aset	@dsad+128/4	;;reicht fuer 128 Dir.eintraege
                         C      	else
                         C      @dsad	aset	@dsad+64/4	;;reicht fuer 64 Dir.eintraege
                         C      	endif
                         C      	ENDIF
                         C       ENDIF
                         C      	ENDM
                         C      
                         C      	if	oss
                         C      	endif
                         C      
                         C      
                         C      	IF	em256
                         C      	ENDIF
                         C      
                         C      	IF	mkd256
                         C      	ENDIF
                         C      
                         C       IF raf
                         C       ENDIF
                         C      
                         C       IF rna
                         C       ENDIF
                         C      
                         C       IF dbufsz gt 7
  F2FC                   C      dbuf	equ	@dsad		;Diskettenpuffer
  F6FC                   C      @dsad	aset	@dsad+(1 shl dbufsz)
                         C       ENDIF
                         C      
                         C      ; ============Tastatur=================
                         C      
                         C       IF cpastz
                         C       ELSE
  F6FC                   C      kbdbuf	equ	@dsad
  F711                   C      @dsad	aset	@dsad+kbdbl+1
                         C       ENDIF
                         C      
                         C      ; Es folgt der Bereich fuer nutzereigene Stringdefinition
                         C      ; immer am Ende, d.h. bis zum Beginn der Interruptsaeule,
                         C      ; damit durch Rundung auf 100h-Grenze freibleibende Bytes
                         C      ; fuer Nutzerstrings zusaetzlich zur Verfuegung stehen.
                         C       IF costu
                         C       ENDIF
                         C      
  F711                   C      biosde	aset	@dsad	;*****Ende BIOS-Arbeitsbereiche*****
                         C      
                         C      
                         C      ; Kontrolle auf Adressenueberschreitung
                         C      ;======================================
                         C       if1
                         C       endif
                         C      
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-111


                         C       if biosde gt intvr
                         C       endif
                         C      
                         C      
                         C       if1
                         C       endif
                         C      
  F711                   C      @diff	aset	biosde
                         C      
                         C       if intvr ge @diff
  0000                   C      @diff	aset	(intvr-@diff) shr 8 shl 8
                         C       if @diff gt 100h ;100h als Unschaerfe zulassen
                         C       endif
                         C       endif ;intvr ge @diff
                         C      
                         C       if1
                         C       endif
                         C      
                         C      ;************************************************
                         C      ;	Kaltstart-Rest, der nicht im Anfangslader
                         C      ; Anschlussbedingung:
                         C      ; i A:	Default-Laufwerk (i.a. =Kaltstartlaufwerk)
                         C      ;	Bit 7 =1, wenn kein jungfr. Kaltstart
                         C      ;************************************************
                         C      
  E8D1                   C      KALTST:				;Kaltstart-Initialisierung
                         C      ; Achtung! Weder Stack noch Reg. A benutzen!
  E8D1    F3             C      	di
                         C       IF dev eq k8915
                         C       ENDIF
  E8D2    21 16E0'       C      	ld	hl,kaltsc
  E8D5    11 0180        C      	ld	de,kaltsb
  E8D8    01 0ADF        C      	ld	bc,kaltsl
  E8DB    ED B0          C      	ldir			;Kaltstart-Code nach vorn
  E8DD    C3 0180        C      	jp	kaltsb		;und abarbeiten
                         C      	.DEPHASE
                         C      
                         C       IF dev eq OEM
  0180                   C      kaltsb	equ	180h		;Basisadr fuer Kaltstartcode
                         C       ENDIF
                         C       IF dev eq K8915
                         C       ENDIF
  16E0'                  C      kaltsc: .PHASE	kaltsb
                         C      
                         C      ; Loeschen 0..tpa-80h
  0180    21 0000        C      	ld	hl,0
  0183    36 00          C      	ld	(hl),0
  0185    11 0001        C      	ld	de,1
  0188    01 007F        C      	ld	bc,tpa-80h-1
  018B    ED B0          C      	ldir
                         C      ;
  018D    31 0180        C      	ld	sp,kaltsb
  0190    F5             C      	push	af		;merken Default
  0191    E6 80          C      	and	80h		;Bit 7
  0193    32 0932        C      	ld	(cjungf),a	;merken
  0196    F1             C      	pop	af
                         C      
  0197    E6 03          C      	and	03h
  0199    32 0004        C      	ld	(defaul),a	;setzen Default-Laufwerk
  019C    32 E89F        C      	ld	(clddev),a
                         C      
                         C       if (wbootv eq 2) or (wbootv eq 3) or (wbootv eq 4)
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-112


                         C       endif
                         C      
                         C      ; Loeschen BIOS-Arbeitsbreiche zur Spur-Suche
                         C      ;~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
                         C      
  019F    21 E8D1        C      	ld	hl,biosds
  01A2    11 E8D2        C      	ld	de,biosds+1
  01A5    01 0E3F        C      	ld	bc,biosde-biosds-1
  01A8    36 FD          C      	ld	(hl),0fdh
  01AA    ED B0          C      	ldir
                         C      
                         C      ; Definieren Interruptvektor
                         C      ;~~~~~~~~~~~~~~~~~~~~~~~~~~~
  01AC    21 F7D0        C      	LD	HL,intvr
  01AF    7C             C      	LD	A,H
  01B0    ED 47          C      	LD	I,A
  01B2    ED 5E          C      	im	2
                         C       IF (intvec+100h-intvr) eq 256
                         C       ELSE
  01B4    06 30          C      	ld	b,intvec+100h-intvr
                         C       ENDIF
  01B6    36 00          C      intvcl: ld	(hl),0		;vorloeschen Interruptsaeule
  01B8    23             C      	inc	hl
  01B9    10 FB          C      	djnz	intvcl
  01BB    21 D308        C      	ld	hl,cpmx00	;Adr.Sprungvektor CP/M-Erw.
  01BE    22 004E        C      	ld	(cpmext),hl	;eintragen
                         C      
                         C      ; Definieren Arbeitszellen fuer asynchrone Routinen
                         C      ;--------------------------------------------------
                         C      
  01C1    21 E5ED        C      	ld	hl,ret
  01C4    22 004A        C      	ld	(kritbg),hl
  01C7    22 004C        C      	ld	(kriten),hl
                                
                                ;#############################################################
                                ; Kaltstart-Initialisierungen
                                ;----------------------------
                         C      	include BIOSTIMC
                         C      
                         C      ; Kaltstart-Initialisierung Timer
                         C      ;================================
                         C      ; 21.03.89
                         C      
                         C       IF cpu eq c1715
                         C       ELSE
  0002                   C      tim5ct	equ	2
  0003                   C      tim1ct	equ	3
                         C       ENDIF
  01CA    21 E5FD        C      	ld	hl,tim5it	;;int.adr.
  01CD    22 F7FC        C      	ld	(intvec+ivctc0+2*tim5ct),hl
                         C       IF cpu ne c1715
  01D0    21 E62B        C       	ld	hl,tim1it	;;int.adr. 1 sec
  01D3    22 F7FE        C      	ld	(intvec+ivctc0+2*tim1ct),hl
                         C       ENDIF
  01D6    3E F8          C      	ld	a,ivctc0
  01D8    D3 0C          C      	out	(sysctc),a	;;int.vekt.
  01DA    3E 37          C      	ld	a,00110111b
                         C      ;;kein int./zeitg./vort.256/pos.flanke/naechst.zykl./zk folgt/abbruch/1
  01DC    D3 0E          C      	out	(sysctc+tim5ct),a
  0030                   C      tim5zk	equ	(5*100*cpuclk)/256	;;Zeitkonstante 5 ms
                         C       IF cpu eq c1715
                         C       ELSE
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-113


  01DE    3E 30          C      	ld	a,tim5zk		;;zk fuer 5 ms
                         C       ENDIF
  01E0    D3 0E          C       	out	(sysctc+tim5ct),a
                         C       IF cpu ne c1715
  01E2    3E 57          C       	ld	a,01010111b
                         C      ;;kein int./zaehler//pos.flanke//zk folgt/abbruch/1
  01E4    D3 0F          C      	out	(sysctc+tim1ct),a
  01E6    3E C8          C      	ld	a,1000/5		;;zk fuer 1s
  01E8    D3 0F          C      	out	(sysctc+tim1ct),a
                         C       ENDIF
                         C      	include BIOSCHDC
                         C      ; Kaltstart-Initialisierung zeichenorientierte Geraete
                         C      ;=====================================================
                         C      ; 03.04.89
                         C       if cdtpio
                         C       endif
                         C       if iobuc1
                         C       IF (uc1dat xor uc1sta) eq 01b	;Kanal-Nr ist Bit 1 (bei Buerocomp und OEM)
                         C        IF (uc1sta and 10b) eq 00b	;UC1 ist an Kanal A
  01EA    21 DAFF        C      	ld	hl,uc1rin	;;Empf-Interrupt fuer UC1:
  01ED    22 F7DC        C      	ld	(intvec+ivsio6),hl ;;Kanal A
  01F0    21 DB49        C      	ld	hl,uc1err	;;spez. Empf.Bedingung fuer UC1:
  01F3    22 F7DE        C      	ld	(intvec+ivsio7),hl ;;Kanal A
                         C        ENDIF
                         C       ENDIF
                         C       endif
                                  IF disknb ne 0
                         C      	include BIOSDSKC
                         C      
                         C      ; Kaltstart-Initialisierung Floppy
                         C      ;=================================
                         C      
                         C      ;; Steuer-PIO A
  01F6    21 E39A        C      	LD	HL,itimeo		;;Interrupt bei Indexpunkt
  01F9    22 F7E8        C      	LD	(intvec+ivdsk1),HL
  01FC    3E E8          C      	ld	a,ivdsk1
  01FE    D3 11          C      	OUT	(flcoac),A
  0200    3E 7F          C      	LD	A,7FH
  0202    D3 11          C      	OUT	(flcoac),A		;;zunaechst Byte Eingabe
                         C      ;; Daten-PIO B (Lesen)
  0204    D3 17          C      	OUT	(fldabc),A		;;Byte Eingabe
  0206    DB 16          C      	IN	A,(fldabd)		;;Scheineingabe
                         C      ;; weiter Steuer-PIO A
  0208    3E FD          C      	LD	A,11111101b		;;AMF aus
  020A    D3 10          C      	OUT	(flcoad),A
