  E50E                   C      diotrr:
  E50E    DB 16          C      diotr0:	in	a,(fldabd)
  E510    BB             C      	cp	e		;'A1', d.h. noch in Kluft?
  E511    28 FB          C      	jr	z,diotr0	;ja
  E513    BA             C      	cp	d		;'FE', d.h. Sektorbeginn?
  E514    DB 16          C      	in	a,(fldabd)	;wenn ja, so ist das die Spur
  E516    20 AF          C      	jr	nz,diomrk	;nein, weitersuchen
  E518    D9             C      	exx
  E519    ED B2          C      	inir			;Sektorid lesen
  E51B    D9             C      	exx
  E51C    6F             C      	ld	l,a		;Spur retten
  E51D    3A E4C8        C      	ld	a,(diom03)
  E520    D3 10          C      	out	(flcoad),a	;Lesen 1
  E522    7D             C      	ld	a,l
  E523    B9             C      	cp	c		;richtige Spur?
  E524    28 09          C      	jr	z,diotr1	;ja
  E526    3A E3DF        C      	ld	a,(ft.sid)
  E529    90             C      	sub	b		;stimmt side?
  E52A    20 0B          C      	jr	nz,diotre	;nein, dies ist kein Sektid.
  E52C    B9             C      	cp	c		;war Spur 0 gefordert?
  E52D    28 23          C      	jr	z,serr2		;ja, nachjustieren (ft.trk steht noch)
  E52F    7D             C      diotr1:	ld	a,l
  E530    32 E3DE        C      	ld	(ft.trk),a	;(tatsaechliche) Spur aus Sekt.Id.
  E533    3E 03          C      	ld	a,dtrner-dtrwjr	;Reaktionsroutine
  E535    18 5D          C      	jr	dioend		;Abschlussbehandlung
  E537    D9             C      diotre:	exx
  E538    01 0316        C      	ld	bc,3*256+fldabd	;Lesen 3 Bytes Sektorid
  E53B    21 E3DF        C      	ld	hl,ft.trk+1	;dorthin Sektorid hinterlegen
  E53E    D9             C      	exx
  E53F    18 07          C      	jr	serr1
