  DFA5    47             C      	ld	b,a
  DFA6    DD 7E 18       C      	ld	a,(ix+dpbtyp)	;5"/8", FM/MFM, 40/80, Verify nach Schreiben
  DFA9    E6 78          C       and (1 shl dpbt80)+(1 shl dpbt5z)+(1 shl dpbtdd)+(1 shl dpbtwv) ;aus DPB
  DFAB    A8             C      	xor	b
