  D596    C8 01 18       C+     	db	kcurdw,1,'X' and 1fh
  D599    E0 01 02       C+     	db	pf0c,1,'B' and 1fh
  D59C    E1 01 07       C+     	db	pf1c,1,'G' and 1fh
  D59F    E2 01 19       C+     	db	pf2c,1,'Y' and 1fh
  D5A2    E3 01 14       C+     	db	pf3c,1,'T' and 1fh
  D5A5    E4 01 16       C+     	db	pf4c,1,'V' and 1fh
