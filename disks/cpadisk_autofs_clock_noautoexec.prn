  DCE9    23             C      	inc	hl
  DCEA    4E             C      	ld	c,(hl)		;Abstand der Blockgroessentab.
  DCEB    06 00          C      	ld	b,0
  DCED    09             C      	add	hl,bc		;auf Blockgroessentabelle
  DCEE    4E             C      	ld	c,(hl)
  DCEF    DD 71 02       C      	ld	(ix+dpbbls),c
  DCF2    23             C      	inc	hl
  DCF3    4E             C      	ld	c,(hl)
  DCF4    DD 71 03       C      	ld	(ix+dpbblm),c
  DCF7    23             C      	inc	hl
  DCF8    4E             C      	ld	c,(hl)
  DCF9    DD 71 04       C      	ld	(ix+dpbexm),c
                         C      
                         C      ; Bestimmen Zahl der abweichenden 128er-Sektoren ab Spur 0
                         C      
  DCFC    AF             C      	xor	a
  DCFD    32 E0DA        C      	ld	(dfrmtr),a	;ab Spur 0
                         C      		;(gleichz. Spurkorr. bei falschen Doppelstepimpulsen)
  DD00    CD DF16        C      sf128z:	call	dsidtr		;beliebigen SektId lesen
  DD03    20 18          C      	jr	nz,sf128e	;Fehler
  DD05    7C             C      	ld	a,h		;Sektorlaenge
  DD06    DD BE 10       C      	cp	(ix+dpbslc)	;gleich Disketten-Rest?
  DD09    28 12          C      	jr	z,sf128e	;ja
  DD0B    DD 7E 0F       C      	ld	a,(ix+dpbflg)
  DD0E    E6 03          C      	and	dpbfsm		;bisherige Anzahl abweichender Spuren
  DD10    FE 03          C      	cp	dpbfsm		;Zaehler voll?
  DD12    28 09          C      	jr	z,sf128e	;ja
  DD14    DD 34 0F       C      	inc	(ix+dpbflg)	;erhoehen abweich. Spurzahl
  DD17    21 E0DA        C      	ld	hl,dfrmtr	;naechste (logische!) Spur
  DD1A    34             C      	inc	(hl)
  DD1B    18 E3          C      	jr	sf128z
  DD1D                   C      sf128e:
                         C      
                         C      ; Setzen Anzahl der logischen 128er Rekords im Puffer -1
                         C      ; Es wird immer das Maximum gesetzt, dies setzt eine dichte
                         C      ; Sektorfolge beim Transfer voraus! (so in dpbstr)
                         C      
                         C      	IF	dbufsz gt 7
  DD1D    DD 36 11 07    C      	ld	(ix+dpbbfm),+(1 shl (dbufsz-7))-1
                         C      	ENDIF
                         C      
                         C      ; Berechnen Speicherkapazitaet-1 in BDOS-Bloecken aus
                         C      ; ((Tracks-dpbofs)*dpbspt/(2**dpbbls))-1
  DD21    DD 6E 14       C      	ld	l,(ix+dpbtrk)
  DD24    AF             C      	xor	a
  DD25    67             C      	ld	h,a		;hl:=log. Spurzahl
  DD26    DD 5E 0D       C      	ld	e,(ix+dpbofs)
  DD29    57             C      	ld	d,a		;de:=log. offset-Spurzahl
  DD2A    ED 52          C      	sbc	hl,de
  DD2C    EB             C      	ex	de,hl		;de:=log. Daten-Spurzahl
  DD2D    6F             C      	ld	l,a		;hl:=0
  DD2E    DD 46 00       C      	ld	b,(ix+dpbspt)
  DD31    19             C      dsizmz:	add	hl,de
  DD32    10 FD          C      	djnz	dsizmz		;hl:=(tracks-dpbofs)*dpbspt
  DD34    DD 46 02       C      dsizme:	ld	b,(ix+dpbbls)
  DD37    CB 3C          C      dsizdz:	srl	h
  DD39    CB 1D          C      	rr	l
  DD3B    10 FA          C      	djnz	dsizdz
  DD3D    2B             C      	dec	hl
  DD3E    DD 75 05       C      	ld	(ix+dpbsiz),l
  DD41    DD 74 06       C      	ld	(ix+dpbsiz+1),h
  DD44    DD 7E 07       C      	ld	a,(ix+dpbdir)	;Dir-Groesse
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-65


  DD47    3C             C      	inc	a
  DD48    E6 FC          C      	and	0fch		;abrunden auf durch 4 teilbare Dir-Groesse
  DD4A    0F             C      	rrca
  DD4B    0F             C      	rrca			;div 4, da 4 Dir-Eintr. /Sekt.
  DD4C    DD 77 0B       C      	ld	(ix+dpbchk),a	;ist Sektorzahl = Check size
  DD4F    DD 46 02       C      	ld	b,(ix+dpbbls)	;block shift
  DD52    0F             C      seldla:	rrca			;BDOS-Bloecke fuer Dir.
  DD53    10 FD          C      	djnz	seldla
