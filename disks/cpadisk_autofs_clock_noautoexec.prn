                         C      ;	Zeitgeberdienst
                         C      ; 15.06.88
                         C      ; - BAB2 als Standard
                         C       IF cpu eq c1715
                         C       ENDIF
                         C      ; - zusaetzliche Laufwerksabschaltung ueber Zeittakt eingefuehrt
                         C      ; - Abfrage von 'synsem' in 1-sec-Interrupt entfernt (kein setbs/setram notw.)
                         C      ; 24.09.88
                         C      ; - Bildschirmpuffer kann ausserhalb des normalen RAM's liegen
                         C      ; 09.10.88
                         C      ; - Pflege der Statuszeile nur bei stzaus=0
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-97


                         C      ; 23.12.88
                         C      ; - Einbau der Pflege des Datums
                         C      ; 07.01.89
                         C      ; - Tastaturpolling nur wenn Zugriff zur Statuszeile erlaubt
                         C      ; 20.03.89
                         C      ; - Laufwerksabschaltung ueber Zeittakt nur bei FDC K5120/22 und F1715
                         C      ;*************************************************************
                         C      
                         C       IF1
                         C       ENDIF
                         C      
                         C      ; 5ms/25ms an
  E5E7                   C      tim5on:
                         C       IF cpu eq c1715
                         C       ENDIF
  E5E7    3E B1          C      	ld	a,10110001b
                         C      	;int./zeitg./vort.256/pos.flanke/naechst.zykl./keine zk/weiter/1
  E5E9    F3             C      tim5ot:	DI
  E5EA    D3 0E          C      	out	(sysctc+tim5ct),a
  E5EC    FB             C      	EI
  E5ED    C9             C      ret:	ret
                         C      
                         C      ; 5ms/25ms aus
  E5EE                   C      tim5of:
                         C       IF cpu eq c1715
                         C       ENDIF
  E5EE    3E 31          C      	ld	a,00110001b	;kein int./...
  E5F0    18 F7          C      	jr	tim5ot
                         C      
                         C       IF cpu eq c1715
                         C       ELSE
                         C      ; 1s an
  E5F2    3E D1          C      tim1on:	ld	a,11010001b
                         C      	;int./zaehler//pos.flanke//keine zk/weiter/1
  E5F4    F3             C      tim1ot:	DI
  E5F5    D3 0F          C      	out	(sysctc+tim1ct),a
  E5F7    FB             C      	EI
  E5F8    C9             C      	ret
                         C      ; 1s aus
  E5F9    3E 51          C      tim1of:	ld	a,01010001b	;kein int./...
  E5FB    18 F7          C      	jr	tim1ot
                         C       ENDIF
                         C      
                         C      ; Interr.routine 5ms/25ms
  E5FD                   C      tim5it:
                         C       IF stpvar or monitor
  E5FD    22 E605        C      	ld	(t5ihl),hl	;retten hl
  E600    21 E72E        C      	ld	hl,chksp	;Test auf haengende Spezialfktnen
  E603    E5             C      	push	hl		;nach const-Aufruf in CTC-Interrupt
  E604    21 0000        C      	ld	hl,0		;wiederherstellen hl
  E605                   C      t5ihl	equ	$-2
                         C       ENDIF
  E607    ED 73 E626     C      	ld	(intsp),sp
  E60B    31 F126        C      	ld	sp,intstk
  E60E    F5             C      	push	af
  E60F    E5             C      	push	hl
  E610    D5             C      	push	de
  E611    C5             C      	push	bc
  E612    2A 0041        C      	ld	hl,(tim5cn)
  E615    23             C      	inc	hl
  E616    22 0041        C      	ld	(tim5cn),hl
                         C       IF cpu eq c1715
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-98


                         C       ENDIF
  E619    3A D23D        C      	ld	a,(synflg)
