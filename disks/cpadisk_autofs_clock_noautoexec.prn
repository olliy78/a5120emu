                         C       ENDIF
  DFAC    CB 66          C      	bit	dioftr,(hl)	;Fehlerbehandlung unterdruecken?
  DFAE    28 01          C      	jr	z,dionft	;nein
  DFB0    3C             C      	inc	a
  DFB1                   C      dionft:
  DFB1    32 E3DA        C      	ld	(ft.kom),a	
                         C      
  DFB4    23             C      	inc	hl
  DFB5    DD 7E 15       C      	ld	a,(ix+dpbdnr)	;physische LW-Nr.
  DFB8    32 E3DD        C      	ld	(ft.lwn),a
                         C      
  DFBB    23             C      	inc	hl
  DFBC    7E             C      	ld	a,(hl)
  DFBD    32 E3DE        C      	ld	(ft.trk),a
  DFC0    23             C      	inc	hl
  DFC1    7E             C      	ld	a,(hl)
  DFC2    32 E3DF        C      	ld	(ft.sid),a
  DFC5    23             C      	inc	hl
  DFC6    7E             C      	ld	a,(hl)
  DFC7    32 E3E0        C      	ld	(ft.sec),a
  DFCA    23             C      	inc	hl
  DFCB    7E             C      	ld	a,(hl)
  DFCC    32 E3E1        C      	ld	(ft.len),a
  DFCF    23             C      	inc	hl
  DFD0    7E             C      	ld	a,(hl)
  DFD1    32 E3E2        C      	ld	(ft.anz),a
                         C      
  DFD4    DD 7E 12       C      	ld	a,(ix+dpbstp)	;Anzahl der Stepimpulse
  DFD7    32 E3E3        C      	ld	(ft.stp),a
                         C      
  DFDA    DD 7E 17       C      	ld	a,(ix+dpbsti)	;Schrittzeit
  DFDD    32 E3E4        C      	ld	(ft.sti),a
                         C      
  DFE0    2A E100        C      	ld	hl,(diocad)
  DFE3    22 E3DB        C      	ld	(ft.adr),hl
                         C      
                         C       IF stpvar or monitor
  DFE6    CD E715        C      	call	delsps		;Sondertasten verbieten
                         C       ENDIF
                         C       IF hdsk
                         C       ELSE
  DFE9    CD E102        C      	call	floppy		;$$$ phys. Transfer $$$
                         C       ENDIF
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-74


                         C       IF stpvar or monitor
  DFEC    CD E722        C      	call	delspr		;Sondertasten wieder erlauben
                         C       ENDIF
                         C      
  DFEF    E1             C      	pop	hl		;HL wieder auf Paramfeld-Adresse
  DFF0    DD E1          C      	pop	ix		;IX wieder auf DPB
                         C      
  DFF2                   C      dioert:
                         C      ; Fehlerprotokoll
  DFF2    CB 66          C      	bit	dioftr,(hl)	;Fehlerprotokoll und -behandlung  unterdr.?
  DFF4    20 33          C      	jr	nz,dtrok	;ja
  DFF6    B7             C      	or	a		;Returncode
  DFF7    28 30          C      	jr	z,dtrok		; -> fehlerfrei
  DFF9    FE 52          C      	cp	'R'		;not ready?
  DFFB    CA DF9C        C      	jp	z,diorty	;ja, Wiederholung
                         C      
                         C       IF errvar
  DFFE    32 E0BF        C      	ld	(derrcd),a	;Fehlercode
  E001    CB 56          C      	bit	diofwr,(hl)	;war lesen?
  E003    3E 52          C      	ld	a,'R'
  E005    28 02          C      	jr	z,derrr		;ja
  E007    3E 57          C      	ld	a,'W'
  E009    32 E0BE        C      derrr:	ld	(derrrw),a
                         C        IF dev eq cpd
                         C        ELSE
  E00C    21 E3DE        C      	ld	hl,ft.trk	;phys. Spur
  E00F    11 E0C9        C      	ld	de,derrtr
  E012    CD E801        C      	call	mbreco
  E015    21 E3DF        C      	ld	hl,ft.sid	;Seite
  E018    CD E801        C      	call	mbreco
  E01B    21 E3E0        C      	ld	hl,ft.sec	;Sektor
  E01E    CD E801        C      	call	mbreco
                         C        ENDIF
  E021    21 E0BC        C      	ld	hl,derrms
  E024    CD E7E7        C      	call	biosms
                         C       ENDIF
  E027    3E 01          C       	ld	a,1		;return mit Fehler
                         C      
  E029    B7             C      dtrok:	or	a		;stellen Z-Flag
  E02A    ED 5B E3DE     C      	ld	de,(ft.trk)	;E:=trk, D:=sid
  E02E    2A E3E0        C      	ld	hl,(ft.sec)	;L:=sec, H:=len
  E031    DD E1          C      	pop	ix
  E033    C1             C      	pop	bc
  E034    C9             C      	ret
                         C      
                         C       IF	format
                         C      
                         C      ; Stellen HL entsprechend Sektorlaengencode in (A)
                         C      ;=================================================
                         C      ; ret nz bei unzulaessigem
  E035    B7             C      dtrsla:	or	a
  E036    21 E049        C      	ld	hl,dtrsl0
  E039    C8             C      	ret	z		;=0 (128)
  E03A    3D             C      	dec	a
  E03B    21 E05D        C      	ld	hl,dtrsl1	;=1 (256)
  E03E    C8             C      	ret	z
  E03F    3D             C      	dec	a
  E040    21 E071        C      	ld	hl,dtrsl2	;=2 (512)
  E043    C8             C      	ret	z
  E044    3D             C      	dec	a
  E045    21 E085        C      	ld	hl,dtrsl3	;=3 (1024)
  E048    C9             C      	ret
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-75


                         C      
                         C       ENDIF
                         C      
                         C      ;************************************************
                         C      ;	Steuertabellen
                         C      ;************************************************
                         C      
                         C      
                         C       IF	format
                         C      ; Modifizierungstabellen entspr. Sektorlaenge und LW-Typ
                         C      ;-------------------------------------------------------
                         C      
                         C      ; Struktur:
                         C      
  0000                   C      dsltrk	equ	0		;benutzte Spuren
  0001                   C      dslspt	equ	dsltrk+1	;Sektoren/Spur
  0002                   C      dsldir	equ	dslspt+1	;Dir-Eintraege
  0003                   C      dsloff	equ	dsldir+1	;2*offset
                         C      				;[+Flag fuer festes offset]
  0001                   C      dslfo	equ	1		;festes offset
  0000                   C      dslvo	equ	0		;offset =0, falls Directory mgl.
  0004                   C      dslblk	equ	dsloff+1	;rel. Adr. Tab. BDOS-Blockgroesse
  0005                   C      dsll	equ	5		;Laenge eines Eintrags
                         C      
                         C      ; Reihenfolge
                         C      ; 5", 40 Tr, SS
                         C      ; 5", 80 Tr, SS
                         C      ; 5", 40 Tr, DS
                         C      ; 5", 80 Tr, DS
                         C       if	disk8
                         C       endif
                         C      
                         C      ; Zur automatischen Bestimmung des Spurformats wird dasjenige
                         C      ; Format der Spur "dlgint" benutzt, alle folgenden Spuren
                         C      ; muessen das gleiche Format haben!
  0003                   C      dlgint	equ	3	;groesste Anzahl SS-Systemspuren
                         C      
                         C      ; 128
  E049                   C      dtrsl0:	
  E049    28 1A 3F 04    C      	db	40,26,63,2*2+dslvo,dbl1k-$	;CP/M Standard
  E04D    4C             C      
  E04E    50 1A 7F 04    C      	db	80,26,127,2*2+dslvo,dbl2k-$
  E052    4A             C      
  E053    50 1A 7F 01    C      	db	80,26,127,2*0+dslfo,dbl2k-$
  E057    45             C      
  E058    A0 1A 7F 01    C      	db	160,26,127,2*0+dslfo,dbl2k0-$
  E05C    43             C      
                         C      
                         C      	if	disk8
                         C      	endif
                         C      
                         C      ; 256
  E05D                   C      dtrsl1:	
  E05D    28 20 3F 07    C      	db	40,32,63,2*3+dslfo,dbl2k-$	;SCP Hausformat A51xx
  E061    3B             C      
  E062    50 20 3F 07    C      	db	80,32,63,2*3+dslfo,dbl2k-$	;SCP
  E066    36             C      
  E067    50 20 7F 09    C      	db	80,32,127,2*4+dslfo,dbl2k-$
  E06B    31             C      
  E06C    A0 20 7F 09    C      	db	160,32,127,2*4+dslfo,dbl2k0-$	;SCP Hausformat PC1715
  E070    2F             C      
                         C      
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-76


                         C      	if	disk8
                         C      	endif
                         C      
                         C      ; 512
  E071                   C      dtrsl2:	
  E071    28 24 00 01    C      	db	40,36,0,2*0+dslfo,dbl1k-$
  E075    24             C      
  E076    50 24 00 01    C      	db	80,36,0,2*0+dslfo,dbl2k-$
  E07A    22             C      
  E07B    50 24 00 01    C      	db	80,36,0,2*0+dslfo,dbl2k-$
  E07F    1D             C      
  E080    A0 24 00 01    C      	db	160,36,0,2*0+dslfo,dbl2k0-$
  E084    1B             C      
                         C      
                         C      	if	disk8
                         C      	endif
                         C      	
                         C      ; 1024
  E085                   C      dtrsl3:	
  E085    28 28 3F 04    C      	db	40,40,63,2*2+dslvo,dbl1k-$	;CP/A Standard A51xx
  E089    10             C      
  E08A    50 28 7F 04    C      	db	80,40,127,2*2+dslvo,dbl2k-$	;CP/A
  E08E    0E             C      
  E08F    50 28 7F 00    C      	db	80,40,127,2*0+dslvo,dbl2k-$	;CP/A
  E093    09             C      
  E094    A0 28 BF 08    C      	db	160,40,191,2*4+dslvo,dbl2k0-$	;CP/A (und SCP)
  E098    07             C      
                         C      
                         C      	if	disk8
                         C      	endif
                         C      
                         C      ; Modifizierungstabellen fuer BDOS-Blockgroesse
  E099    03 07 00       C      dbl1k:	db	3,7,0		;Bl. Shift, Bl. Mask, Ext. Mask
  E09C    04 0F 01       C      dbl2k:	db	4,0fh,1
  E09F    04 0F 00       C      dbl2k0:	db	4,0fh,0		;fuer Kapazitaet >255
                         C      
                         C      ; log. Sektortranslate-Tabelle fuer 26*128
  E0A2    01 07 0D 13    C      xlt:	db	1,7,13,19,25,5,11,17,23,3,9,15,21
  E0A6    19 05 0B 11    C      
  E0AA    17 03 09 0F    C      
  E0AE    15             C      
  E0AF    02 08 0E 14    C      	db	2,8,14,20,26,6,12,18,24,4,10,16,22
  E0B3    1A 06 0C 12    C      
  E0B7    18 04 0A 10    C      
  E0BB    16             C      
                         C      
                         C       ENDIF	;format
                         C      
                         C      	include BIOSDSKW
                         C      ;;***************************************************************
                         C      ;;	Arbeitsbereiche logischer Floppy-Treiber im System-RAM *
                         C      ;;***************************************************************
                         C      ;; 03.06.89
                         C      
                         C       IF errvar
                         C      ;; Fehlermeldung Disk I/O Error
                         C      ;;=============================
                         C      ;; Genau so lang (kurz), wie in Statuszeile Platz dafuer da ist!
                         C      ;; und das sind 17 Bytes!
  E0BC                   C      derrms:
                         C       IF cpastz
                         C       ELSE
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-77


  E0BC    0D 0A          C      	db	0dh,0ah
                         C       ENDIF
  E0BE    58             C      derrrw:	db	'X'
  E0BF    58 3B 54 2C    C      derrcd:	db	'X;T,Si,Se='
  E0C3    53 69 2C 53    C      
  E0C7    65 3D          C      
  E0C9    58 58          C      derrtr:	db	'XX'
  E0CB    58 58          C      derrts:	db	'XX'
  E0CD    58 58          C      derrsc:	db	'XX'
                         C       IF cpastz
                         C       ELSE
  E0CF    07 00          C      	db	07h,0
                         C       ENDIF
                         C      
                         C       ENDIF
                         C      
                         C      ;; CDB's
                         C      ;;======
                         C      
                         C      ;;CDB fuer Bestimmung Laufwerksbereitschaft bei Select Disk
                         C      ;;--------------------------------------------------------
  E0D1                   C      drdcdb:
  E0D1    10             C      drdflg:	db	(1 shl dioftr)	;;Lesen, kein Fehlerprotokoll
  E0D2    FF             C      drddev:	db	0ffh		;;Geraet
  E0D3    0000           C      drdtrk:	dw	0		;;Spur
  E0D5    01             C      	db	1		;;Sektor (bel.)
  E0D6    01             C      	db	1		;;Sektorlaengencode (>0, 1..3)
  E0D7    00             C      	db	0		;;Sektoranzahl=0 -> nur Positionieren
                         C      
                         C      	IF	format
                         C      ;; CDB fuer Bestimmung Spurformat
                         C      ;;------------------------------------
  E0D8                   C      dfrcdb:
  E0D8    12             C      dfrflg:	db	(1 shl diofid)+(1 shl dioftr)
                         C      ;;		Lesen Sektorid., kein Fehlerprotokoll
  E0D9    FF             C      dfrmdv:	db	0ffh		;;Geraet
  E0DA    FF             C      dfrmtr:	db	0ffh		;;Spur
  E0DB    FF             C      	db	0ffh		;;Seite (bel.)
  E0DC    01             C      	db	1		;;Sektor (bel.)
  E0DD    01             C      	db	1		;;Sektorlaengencode (>0, 1..3)
  E0DE    01             C      	db	1		;;Sektoranzahl (>0)
                         C      	ENDIF
                         C      
                         C      	IF	format or (dbufsz gt 7)
                         C      ;; Puffer-CDB
                         C      ;;-----------
  E0DF                   C      dbcdb:
  E0DF    00             C      dbflg:	db	0
  0000                   C      dfbprr	equ	diof00		;;=1, wenn Puffer erst gelesen 
                         C      ;;				     werden muss
  0002                   C      dfbwr	equ	diofwr		;;=1, wenn Puffer durch
                         C      ;;				     Schreiben veraendert
  0004                   C      dfbtr	equ	dioftr		;;=1, wenn mit Fehlerprotokoll
                         C      ;; restliche Bits immer =0
  E0E0    FF             C      dbdev:	db	0ffh
  E0E1    FF             C      dbtrk:	db	0ffh
  E0E2    FF             C      dbsid:	db	0ffh
  E0E3    FF             C      dbsec:	db	0ffh
  E0E4    FF             C      dbslc:	db	0ffh
  E0E5    FF             C      dbsnb:	db	0ffh
                         C      	IF	dbufsz gt 7
  E0E6    F2FC           C      dbdma:	dw	dbuf
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-78


                         C      	ENDIF
                         C      	ENDIF
                         C      
                         C      ;; CDB fuer ungepufferte E/A
                         C      ;;--------------------------
                         C      
  E0E8                   C      dcdb:
  E0E8    00             C      dflg:	db	0
  0002                   C      dfwr	equ	diofwr 		;;=1, wenn write-Aufruf
                         C      ;; restliche Bits immer =0
  E0E9    00             C      ddrive:	db	0
  E0EA    FF             C      dtrack:	db	0ffh
  E0EB    FF             C      	db	0ffh		;;Seite
  E0EC    FF             C      dsectr:	db	0ffh
  E0ED    00             C      	db	0		;;128 Bytes Sektorlaenge
  E0EE    01             C      	db	1		;;immer nur 1 Sektor
  E0EF    FFFF           C      ddma:	dw	0ffffh
                         C      
                         C       if ramfl
                         C       endif
                         C      
                         C      ;; Pufferzugriff
                         C       IF @write
                         C       IF dbufsz gt 7
  E0F1    00 FF FF FF    C      unacnt:	db	0,0ffh,0ffh,0ffh,0
  E0F5    00             C      
  E0F2                   C      unadev	equ	unacnt+1
  E0F3                   C      unatrk	equ	unacnt+2
  E0F5                   C      unasec	equ	unacnt+4
                         C       ENDIF
                         C       ENDIF
                         C       IF dbufsz gt 7
  E0F6    FF             C      dbnb:	db	0ffh
  E0F7    FF             C      dwrtyp:	db	0ffh
  E0F8    00             C      dberrf:	db	0		;;Ergebnisflag letztes dbtran
                         C       ENDIF
                         C      	include BIOSDSKB
                         C      ;;***************************************************************
                         C      ;;	Arbeitsbereiche logischer Floppy-Treiber im BIOS-RAM   *
                         C      ;;***************************************************************
                         C       IF dev eq cpd
                         C       ELSE
  E0F9                   C      diocdb:	ds	9,0ffh
                         C       ENDIF
  E0F9                   C      diocfl	equ	diocdb+0
  E0FA                   C      diocde	equ	diocdb+1
  E0FB                   C      dioctr	equ	diocdb+2
  E0FC                   C      diocsi	equ	diocdb+3
  E0FD                   C      diocse	equ	diocdb+4
  E0FE                   C      diocsl	equ	diocdb+5
  E0FF                   C      diocsn	equ	diocdb+6
  E100                   C      diocad	equ	diocdb+7
  0009                   C      diocdl	equ	9		;;Anzahl der Bytes
                         C      
                         C       IF dev eq cpd
                         C       ELSE
                         C        IF disknb eq 0
                         C        ENDIF
                         C       ENDIF
                                 IF disknb ne 0
                         C      	include BIOSDSKT
                         C      ;*********************************************************
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-79


                         C      ; physischer Disketten-Transfer
                         C      ; Aenderungen:
                         C      ; - Es koennen 9 statt bisher 4 phys. Sektoren auf einmal gelesen werden
                         C      ;!-!Schnittstellenaenderung bei SektId lesen:
                         C      ;   ft.anz muss <>0 sein (zuvor beliebig, bei =0 kein Transfer)
                         C      ;   ft.len muss 0..3 sein (zuvor beliebig, bei >3 fehlerhafte Tabellenmodif.)
                         C      ;   ft.kom, Bit 7 eingefuehrt: =0 Vorderseite, =1 Rueckseite
                         C      ;   ft.kom, Bit 0 (Verify nach Schreiben) auf Bit 6 verlegt
                         C      ;   ft.kom, Bit 0 =1 bedeutet "keine Fehlerwiederholung"
                         C      ; - Floppy-Treiber auch fuer Variante K5120/22 generierbar
                         C      ; 06.07.88
                         C      ; - Motor-Start-Wait von 254 auf 252 veraendert (2.5 Umdrehungen)
                         C      ;   (ist bei einigen Laufwerken wegen PreReady notwendig)
                         C      ; 03.11.22
                         C      ; - Variante K5122 eingefuegt
                         C      ; 25.09.89
                         C      ; - bei MFS 1.2 bei Mehr-Sektor-Transfer "Fault reset" zwischen den Sektoren
                         C      ;*********************************************************
                         C      
                         C      ; Aufruf:
                         C      ; -------
                         C      ; Bereitstellung der Parameter auf den Bytes:
                         C      
                         C      ;       ft.kom:	db	0	; bit0 - =1 ohne Fehlerwiederholung
                         C      ;				     1 - =1 lesen ft.len von beliebigem Sektor
                         C      ;				     2 - =0 lesen ; =1 schreiben Sektor(en)
                         C      ;				     3 - =0-FM; =1-MFM   (5"FM nur bei PC1715)
                         C      ;				     4 - =0-8"; =1-5"
                         C      ;				     5 - =0- 40-Spur-Laufwerk; =1- 80-Spur-LW
                         C      ;				     6 - =1 bei verify nach schreiben
                         C      ;				     7 - =0 Vorderseite, =1 Rueckseite
                         C      ;	ft.adr: dw	0	; Transferadresse
                         C      ;	ft.lwn: db	0	; 0..3 phys. Laufwerksnummer
                         C      ;	ft.trk: db	0	; 0..  track
                         C      ;	ft.sid: db	0	; 0..ff side (side=0 auf Rueckseite moeglich!)
                         C      ;	ft.sec: db	0	; 0..  sector (beliebig bei SektId lesen)
                         C      ;	ft.len: db	0	; 0..3 Sektorlaenge (auch 0..3 bei SektId les.)
                         C      ;	ft.anz: db	0	; 0..9 Anzahl der zu uebertragenden Sektoren
                         C      ;				;      =0: nur Positionieren
                         C      ;				;      (<>0 bei SektId lesen)
                         C      ;       ft.stp: db	0	;      Anzahl der Stepimpulse von Spur zu Spur
                         C      ;	ft.sti: db	0	;      Schrittzeit von Spur zu Spur
                         C      ;				;      in 0,1ms Einheiten
                         C      ;
                         C      ;	call	floppy
                         C      ;       ...			; in A steht Ergebniskode
                         C      ;				; alle Register (auch IX) undef.
                         C      ;
                         C      ; Ergebniskode (in Reg. A):
                         C      ;	00h kein Fehler (Z-Flag nicht von floppy gesetzt)
                         C      ;	'C' CRC-Fehler
                         C      ;	'D' LW nicht existent
                         C      ;	'R' Geraet nicht bereit, aber existent
                         C      ;	'L' unzulaessige Transferlaenge
                         C      ;	'S' Sektor nicht gefunden
                         C      ;	'T' Spurnummer zu gross
                         C      ;	'U' keine Marke gefunden
                         C      ;	'W' Diskette schreibgeschuetzt
                         C      
                         C      ; Paramfeld wird an folgenden Stellen veraendert:
                         C      ;  Komm. "Lesen Sekt,Id.":	ft.trk .. ft.len gestellt
                         C      ;  Komm. "Schreiben mit Verify":ft.kom, bit 2 geloescht
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-80


                         C      ;**************************************************
                         C      
  0004                   C      maxlw	equ	4		; Anzahl der Laufwerke (1..4)
                         C      
                         C      ; Adressen der Floppy-Karte
                         C      ;==========================
                         C      
                         C       IF (fdc eq k5120) or (fdc eq k5122)
                         C      ;Steuer-PIO
  0010                   C      flcoad    equ  10h  ;PORT A
  0011                   C      flcoac    equ  11h
  0012                   C      flcobd    equ  12h  ;PORT B
  0013                   C      flcobc    equ  13h
                         C      
                         C      ;Daten-PIO
  0014                   C      fldaad    equ  14h  ;Port A Schreib-Daten
  0015                   C      fldaac    equ  15h
  0016                   C      fldabd    equ  16h  ;Port B Lese-Daten
  0017                   C      fldabc    equ  17h
                         C      
                         C      ;Select-Latch
  0018                   C      flsel     equ  18h  ;Bit 7..4 /Sel LW3..0;Bit 3..0  /LCK  LW 3..0
                         C      ;
                         C       ENDIF
                         C      
                         C       IF (fdc eq f1715)
                         C       ENDIF
                         C      
                         C      ;; Legende AMF:
                         C      ;;   Port A
                         C      ;;  | 7 | 6 | 5 | 4 | 3 | 2 | 1 | 0 |
                         C      ;;    |   |   |   |   |   |   |   |__ A  /WE  0-Schreiben ein
                         C      ;;    |   |   |   |   |   |   |______ A   MK  lesen  0-MFM-A1 Erkennung
                         C      ;;    |   |   |   |   |   |                          1-FM-Mark., MFM-C2 Erkenn.
                         C      ;;    |   |   |   |   |   |               schreiben  0-Takt fuer MFM
                         C      ;;    |   |   |   |   |   |                          1-Marken FM und A1 MFM
                         C      ;;    |   |   |   |   |   |__________ A  /SIDE 0-Kopf Seite 1; 1-Kopf Seite 0
                         C      ;;    |   |   |   |   |        oder   A  /FR   0-Fault reset;  1-kein FR
                         C      ;;    |   |   |   |   |______________ A  /STR 0-AMF aktiv
                         C      ;;    |   |   |   |                           1-AMF ausgeschaltet
                         C      ;;    |   |   |   |__________________ A   MK1 lesen  0-Informationen einlesen
                         C      ;;    |   |   |                                      1-nur 1 einlesen
                         C      ;;    |   |   |                           schreiben  0-FM-Daten schreiben
                         C      ;;    |   |   |                                      1-MFM und FM-Marken schr.
                         C      ;;    |   |   |______________________ A   MR, SD     0-steppen Richtung aussen
                         C      ;;    |   |                                          1-Marke-erkannt loeschen
                         C      ;;    |   |                                            steppen Richtung innen
                         C      ;;    |   |__________________________ A  /HL         0-Kopf geladen
                         C      ;;    |                                              1-Kopf entladen
                         C      ;;    |______________________________ A  /ST         0-Stepsignal an LW ein
                         C      ;;                                                   1-Stepsignal an LW aus
                         C      ;;
                         C      ;;  Port B
                         C      ;;  | 7 | 6 | 5 | 4 | 3 | 2 | 1 | 0 |
                         C      ;;    |   |   |   |   |   |   |   |__ E  /RDY  0-Laufwerk bereit
                         C      ;;    |   |   |   |   |   |   |                1-Laufwerk nicht bereit
                         C      ;;    |   |   |   |   |   |   |______ E  /MKE  0-Marke erkannt
                         C      ;;    |   |   |   |   |   |                    1-Marke noch nicht erkannt
                         C      ;;    |   |   |   |   |	 oder PC1715  E   MKE  1-Marke erkannt
                         C      ;;    |   |   |   |   |   | u.K5122            0-Marke noch nicht erkannt
                         C      ;;    |   |   |   |   |   |__________ E  /SYN  ???? (K5120)
                         C      ;;    |   |   |   |   |  oder K5122   A  /HF   0-Takt fuer 8" MFM
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-81


                         C      ;;    |   |   |   |   |                        1-Takt fuer 5" MFM und 8" FM
                         C      ;;    |   |   |   |   |  oder PC1715: A   MFM  0-FM-Aufzeichnung
                         C      ;;    |   |   |   |   |                        1-MFM-Aufzeichnung
                         C      ;;    |   |   |   |   |______________ A   PRE  0-schreiben ohne Prekompensation
                         C      ;;    |   |   |   |                            1-schreiben mit         "
                         C      ;;    |   |   |   |__________________ E  /FA   0-Fehler in der AMF aufgetreten
                         C      ;;    |   |   |                                1-kein Fehler aufgetreten
                         C      ;;    |   |   |          oder PC1715: A   FO   0-5"-Disketten
                         C      ;;    |   |   |                                1-8"-Disketten
                         C      ;;    |   |   |______________________ E  /WP   0-Schreibschutz ist ein
                         C      ;;    |   |                                    1-kein Schreibschutz
                         C      ;;    |   |__________________________ E  /FW   0-Laufwerk meldete Schreibfehler
                         C      ;;    |                                        1-Laufwerk meldete keinen Fehler
                         C      ;;    |______________________________ E  /T0   0-Kopf steht auf Spur 0
                         C      ;;                                             1-Kopf steht nicht auf Spur 0
                         C      
                         C      ;$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$
                         C      ;	FLOPPY-Treiber
                         C      ;$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$
  E102                   C      floppy:
                         C      
                         C      ; Anfangswerte stellen
  E102    3A E3DA        C      	ld	a,(ft.kom)
  E105    E6 01          C      	and	1		;Fehlerwiederholung?
  E107    20 02          C      	jr	nz,setecr	;nein, A=0+1 (keine Wiederholung)
  E109    3E 10          C      	ld	a,15+1
  E10B    32 E400        C      setecr:	ld	(crerc),a	; Fehlerzaehler fuer CRC-Fehlerwiederholungen
  E10E    20 02          C      	jr	nz,setesp
  E110    3E 05          C      	ld	a,4+1		; Fehlerzaehler fuer Spurfindewiederholungen
  E112    32 E401        C      setesp:	ld	(sperc),a
                         C      
                         C      ; Laufwerksnummer pruefen
  E115    3A E3DD        C      	ld	a,(ft.lwn)	; LW
                         C      ;	cp	maxlw		; LW < groesster LW-Nr.?
                         C      ;	jr	nc,nolw		; -> nein, Fehler: LW nicht existent
  E118    4F             C      	ld	c,a		; merken LW fuer Motor-an-Test
  E119    47             C      	ld	b,a		; fuer djnz
  E11A    B7             C      	or	a		; LW=0?
  E11B    3A E403        C      	ld	a,(lwexis)
  E11E    28 04          C      	jr	z,drv0		; ->ja
  E120    0F             C      sp13: 	rrca
  E121    0F             C      	rrca
  E122    10 FC          C      	djnz	sp13
  E124    E6 03          C      drv0: 	and	3
  E126    20 05          C      	jr	nz,drv0a
                         C      
  E128    3E 44          C      nolw: 	ld	a,'D'		; LW nicht existent
  E12A    C3 E2D6        C      	jp	fehret		; -> Fehler
                         C      
  E12D                   C      drv0a:
                         C      ; LW selektieren und Motor einschalten
  E12D    AF             C      	xor	a
  E12E    32 E3AB        C      	ld	(pretx+1),a	;Motorabschaltung verhindern
  E131    3D             C      	dec	a		;A:=255
  E132    CD E392        C      	call	fl.sto		;Index-Ueberwachung ein
  E135    CB D9          C      	set	3,c		; Motor-an-Bit setzen
  E137    21 E404        C      	ld	hl,alwnr
  E13A    7E             C      	ld	a,(hl)
  E13B    B9             C      	cp	c		; ist es das richtige LW und Motor an?
  E13C    3E 6A          C      	ld	a,+pvrw2-(xpvrw+2) ; jr z,pvrw2 (keine Vertikalstab.)
  E13E    28 42          C      	jr	z,dskmon	; ->ja, Kopf ist noch aufgesetzt
                         C      ; falsches LW oder Motor des LW aus
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-82


  E140    CD E3C5        C      	call	flres		; alte Spurnr. merken
                         C      
                         C      ; neues LW anwaehlen, Motor einschalten und alte Spurnr. holen
  E143    71             C      	ld	(hl),c		; neues LW, Motor-an-Bit
  E144    EB             C      	ex	de,hl		;merken ^alwnr
  E145    CB 99          C      	res	3,c		; alte Spurnr. holen
  E147    06 00          C      	ld	b,0
  E149    21 E406        C      	ld	hl,spnrl
  E14C    09             C      	add	hl,bc
  E14D    7E             C      	ld	a,(hl)
  E14E    32 E405        C      	ld	(aspnr),a
  E151    41             C      	ld	b,c
  E152    04             C      	inc	b
  E153    3E 77          C      	ld	a,077h		; LW-Anwahlbyte bilden (mit Lock)
  E155    07             C      nfdei2: rlca
  E156    10 FD          C      	djnz	nfdei2
  E158    D3 18          C      	out	(flsel),a	; Laufwerk selektieren (und evtl. Motor ein)
                         C       IF fdc eq f1715
                         C       ENDIF
  E15A    3E A9          C      	ld	a,10101001b	; Kopf laden, Fault reset
  E15C    D3 10          C      	out	(flcoad),a
                         C      
                         C      ; Motor-Start
  E15E    2E FD          C      	ld	l,252+1		;von 255 auf 252, d.h. mind 2 Umdrehungen?
  E160    3A E3DA        C      	ld	a,(ft.kom)
  E163    CB 67          C      	bit	4,a		;5"?
  E165    28 06          C      	jr	z,dskmo1	;nein
  E167    CB 6F          C      	bit	5,a		;5" 40 Spur?
  E169    20 02          C      	jr	nz,dskmo1	;nein
  E16B    2E FB          C      	ld	l,250+1		;von 255 auf 250,
                         C      				; d.h. mind. 4 volle Umdrehungen?
                         C      				;(bei MFS 1.2 kommt evtl. ready zu frueh)
  E16D                   C      dskmo1:
  E16D    3A E3A3        C      dskdaw:	ld	a,(fl.zto)	;Index-Interrupt-Zaehler
  E170    BD             C      	cp	l		;entprechend viele Umdrehungen vorbei?
  E171    38 0D          C      	jr	c,dskda		;ja
  E173    0D             C      	dec	c		; warten, bis Diskette eingeschoben
  E174    20 F7          C      	jr	nz,dskdaw
  E176    10 F5          C      	djnz	dskdaw
  E178    EB             C      	ex	de,hl
  E179    CB 9E          C      	res	3,(hl)		;loeschen Motor an Bit
  E17B    3E 52          C      	ld	a,'R'		;LW nicht bereit
  E17D    C3 E2D6        C      	jp	fehret
  E180    3E 61          C      dskda:	ld	a,+pvrw1-(xpvrw+2) ; jr z,pvrw1 (mit Vertikal-Stabil.)
  E182                   C      dskmon:
  E182    32 E1CA        C      	ld	(xpvrw+1),a	; Vertikal-Stabilisierung ein/aus
                         C      
                         C      
                         C       IF dsk8fm+dsk8mf+dsk5fm; Standard ist 5"MFM
                         C       ELSE
                         C       IF @write
  E185    21 E59A        C      	ld	hl,diwmfm
  E188    22 E4FF        C      	ld	(dioop),hl	;Schreiben einstellen (falls Lesen war)
                         C       ENDIF
                         C       ENDIF
                         C       if dsk80
  E18B    3A E3DA        C      	ld	a,(ft.kom)
                         C       if dsk8fm+dsk8mf
                         C       endif
  E18E    CB 6F          C      	bit	5,a		;80-Spur-LW?
  E190    3E 19          C      	ld	a,25		;Spur, ab der mit Praekomp.
  E192    28 02          C      	jr	z,dprec2	;nein
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-83


  E194    3E 29          C      	ld	a,41
  E196    32 E250        C      dprec2:	ld	(dpretr),a
  E199                   C      dprecn:
                         C       endif
                         C      
                         C      ; modifizieren entspr. phys. Sektorlaenge
  E199    3A E3E1        C      	ld	a,(ft.len)
  E19C    32 E4AE        C      	ld	(sidlen),a
  E19F    21 E414        C      	ld	hl,dsln0-dslnl
  E1A2    47             C      	ld	b,a
  E1A3    04             C      	inc	b
  E1A4    11 0009        C      	ld	de,dslnl
  E1A7    19             C      dtrsll:	add	hl,de
  E1A8    10 FD          C      	djnz	dtrsll
  E1AA    EB             C      	ex	de,hl
  E1AB    21 E40A        C      	ld	hl,dslnmt	;Tabelle der Modif.adr.
  E1AE    CD E333        C      	call	flmodf
                         C      
                         C      ; Kopf positionieren
  E1B1    21 E3DE        C      	ld	hl,ft.trk	; gewuenschte Spur
  E1B4    7E             C      	ld	a,(hl)
  E1B5    B7             C      	or	a		;Spur 0?
  E1B6    20 0D          C      	jr	nz,npost0	;nein
  E1B8    3A E3E2        C      	ld	a,(ft.anz)	;Sektorzahl
  E1BB    B7             C      	or	a		;nur positionieren auf Spur 0 (FORMAT-Progr.)
  E1BC    28 4F          C      	jr	z,trk0		;ja, Spur 0 immer ueber Recalibrate
  E1BE    3A E3DA        C      	ld	a,(ft.kom)
  E1C1    CB 4F          C      	bit	1,a		;Lesen Sekt.id Spur 0?
  E1C3    20 53          C      	jr	nz,trk0s	;ja, Lesen Sektid Spur 0 ueber Recalibrate
  E1C5    3A E405        C      npost0:	ld	a,(aspnr)	; stimmt Spur?
  E1C8    BE             C      	cp	(hl)
  E1C9    28 61          C      xpvrw:	jr	z,pvrw1		; -> ja, Kopf evtl. vertikal stabilisieren
                         C      				; auf jr z,pvrw2, wenn Kopf noch aufgesetzt
  E1CB                   C      spprty:				;Wiederholung bei fehlerhafter Spur
                         C      ; Positionierung auf ft.trk
  E1CB    3A E3DE        C      spe: 	ld	a,(ft.trk)
  E1CE    06 8F          C      	ld	b,08fh		; stepout-Befehl
  E1D0    21 E405        C      	ld	hl,aspnr
  E1D3    BE             C      	cp	(hl)		; auf richtiger Spur angekommen?
  E1D4    28 56          C      	jr	z,phrw		; -> ja, Kopf horizontal stabilisieren
  E1D6    38 0D          C      	jr	c,spre		; -> stepout
  E1D8    FE 55          C      xmaxtr: cp	85		; Spur zu gross?
  E1DA    38 05          C      	jr	c,spve		; -> nein, stepin
  E1DC    3E 54          C      	ld	a,'T'		; Fehler: Spurnr. zu gross
  E1DE    C3 E2D6        C      	jp	fehret
                         C      
                         C      ; stepin
  E1E1    06 AF          C      spve:	ld	b,0afh		; stepin-Befehl
  E1E3    34             C      	inc	(hl)		; alte Spurnr. erhoehen
  E1E4    34             C      	inc	(hl)		; wegen stepout-dec
                         C      
                         C      ; stepout
  E1E5    35             C      spre: 	dec	(hl)		; alte Spurnr. verringern
  E1E6    CD E1EB        C      	call	step
  E1E9    18 E0          C      	jr	spe
                         C      
                         C      ; steppen
  E1EB    3A E3E3        C      step: 	ld	a,(ft.stp)	; Anzahl der Stepimpulse pro Step
  E1EE    0E 10          C      step0: 	ld	c,flcoad
  E1F0    ED 41          C      	out	(c),b		; select direction
                         C      ;;;	push	bc
                         C      ;;;	ld	b,0
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-84


                         C      ;;;step1: 	djnz	step1		; 1,3ms warten
                         C      ;;;	pop	bc
  E1F2    C5             C      step2: 	push	bc
  E1F3    CB B8          C      	res	7,b
  E1F5    F3             C      	di			;verhindern Unterbrechung
  E1F6    ED 41          C      	out	(c),b
  E1F8    CB F8          C      	set	7,b
  E1FA    ED 41          C      	out	(c),b		; step
  E1FC    FB             C      	ei
  E1FD    ED 4B E3E4     C      	ld	bc,(ft.sti)	; 13,2 / 11,6 / 3,0 ms Schrittzeit
  E201    06 13          C      stepw1: ld	b,19		;(19*13)/(256*9600)=0.0001
  E203    10 FE          C      stepw: 	djnz	stepw		;0.1 ms warten
  E205    0D             C      	dec	c
  E206    20 F9          C      	jr	nz,stepw1
  E208    C1             C      	pop	bc
  E209    3D             C      	dec	a
  E20A    20 E6          C      	jr	nz,step2
  E20C    C9             C      	ret
                         C      
                         C      ; Spur 0 anfahren (Recalibrate)
  E20D    06 02          C      trk0:	ld	b,2		; nach innen, falls auf Spur -1
  E20F    C5             C      trk0i:	push	bc
  E210    06 AF          C      	ld	b,0afh	 	; stepin
  E212    CD E1EB        C      	call	step
  E215    C1             C      	pop	bc
  E216    10 F7          C      	djnz	trk0i
  E218    DB 12          C      trk0s:	in	a,(flcobd)
  E21A    07             C      	rlca			; Spur 0 erreicht?
  E21B    30 09          C      	jr	nc,trk0f	; -> ja
  E21D    06 8F          C      	ld	b,08fh		; stepout-Befehl
  E21F    3E 01          C      	ld	a,1		; in phys. Schritten
  E221    CD E1EE        C      	call	step0
  E224    18 F2          C      	jr	trk0s
  E226    AF             C      trk0f: 	xor	a
  E227    32 E405        C      	ld	(aspnr),a	; aktuelle Spurnr ist 0
  E22A    18 9F          C      	jr	spprty
                         C      
                         C      
                         C      ; Kopf stabilisieren (horizontal und vertikal)
  E22C                   C      pvrw1:	; Kopf vertikal stabilisieren
  E22C                   C      phrw:	; Kopf horizontal (und evtl. auch vertikal) stabilisieren
  E22C    3E 32          C      	ld	a,50		; 50 ms (fuer alle Laufwerkstypen)
  E22E    06 BD          C      phrww1: ld	b,189		; (189*13)/(256*9600)=0.001
  E230    10 FE          C      phrww: 	djnz	phrww		; 1 ms warten
  E232    3D             C      	dec	a
  E233    20 F9          C      	jr	nz,phrww1
  E235                   C      pvrw2:	; Kopf war aufgesetzt und Spur stimmte auch - keine Stabilis.
                         C      
  E235                   C      rdwr:
                         C      ; Anfangswerte fuer Transfer der physischen Sektoren
  E235    3A E3E2        C      	ld	a,(ft.anz)	; Anzahl der zu uebertragenden phys. Sektoren
  E238    32 E4A3        C      	ld	(secan1),a
  E23B    32 E345        C      	ld	(secanz),a	; fuer CRC-Berechnung
                         C      
  E23E    3A E3DE        C      	ld	a,(ft.trk)	; Spur
  E241    32 E4AA        C      	ld	(sidtr),a
  E244    21 E3E3        C      	ld	hl,ft.stp
  E247    CB 46          C      	bit	0,(hl)		;Doppelschritte?
  E249    28 01          C      	jr	z,dprec1	;nein
  E24B    87             C      	add	a,a		;sonst phys. Spur verdoppeln
  E24C                   C      dprec1:
                         C      ; evtl. Precompensation einschalten
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-85


  E24C    01 0412        C      	ld	bc,00000100b*256+flcobd
  E24E                   C      dfrcod	equ	$-1		; Frequenzcode
  E24F    FE 19          C      	cp	25		; Spur ab der mit writeprecomp.
  E250                   C      dpretr	equ	$-1
  E251    38 02          C      	jr	c,prec		; <, ohne Precompensation
  E253    CB D8          C      	set	3,b		; >= , mit
  E255    ED 41          C      prec: 	out	(c),b
                         C      
  E257    3A E3E0        C      	ld	a,(ft.sec)	; erste zu uebertr. Sektornr.
  E25A    32 E4AD        C      	ld	(sidsec),a
  E25D    3A E3DF        C      	ld	a,(ft.sid)
  E260    32 E4AB        C      	ld	(sidsid),a
                         C      
                         C       IF dskds ; double sided
                         C      ; evtl. side 1 anwaehlen vorbereiten
  E263    3A E3DA        C      	ld	a,(ft.kom)
  E266    21 E441        C      	ld	hl,dsidmt
  E269    46             C      	ld	b,(hl)
  E26A    23             C      dsidmz:	inc	hl
  E26B    5E             C      	ld	e,(hl)
  E26C    23             C      	inc	hl
  E26D    56             C      	ld	d,(hl)
  E26E    EB             C      	ex	de,hl
  E26F    CB 7F          C      	bit	7,a		; side 0?
  E271    28 04          C      	jr	z,pside0	; ja
  E273    CB 96          C      	res	2,(hl)		; side 1 einstellen
  E275    18 02          C      	jr 	pside1
  E277    CB D6          C      pside0:	set	2,(hl)
  E279    EB             C      pside1:	ex	de,hl
  E27A    10 EE          C      	djnz	dsidmz
  E27C    CB 6F          C      	bit	5,a		;40-Spur LW?
  E27E    20 03          C      	jr	nz,pside2	;nein
  E280    EB             C      	ex	de,hl		;diom11
  E281    CB 96          C      	res	2,(hl)		;fault reset zwischen den Sektoren
  E283                   C      pside2:
                         C       ENDIF
                         C      
                         C      ; evtl. nur Lesen Sektor-Id.
  E283    3A E3DA        C      	ld	a,(ft.kom)
  E286    CB 4F          C      	bit	1,a		; Lesen Sekt.Id?
  E288    21 E49B        C      	ld	hl,dio
  E28B    28 03          C      	jr	z,srdsid	; -> nein
  E28D    21 E501        C      	ld	hl,diotsr
  E290    22 E45B        C      srdsid:	ld	(diortn),hl
                         C      
                         C       IF @write
  E293    3A E3DA        C      	ld	a,(ft.kom)	; Schreiben?
  E296    CB 57          C      	bit	2,a
  E298    20 08          C      	jr	nz,writpt	; -> ja, Schreibroutine steht auf dioop
                         C       ENDIF
  E29A    21 E556        C      	ld	hl,diord
  E29D    22 E4FF        C      	ld	(dioop),hl	; read einstellen
                         C      
                         C       IF @write
  E2A0    18 22          C      	jr	dtrdyt
  E2A2                   C      writpt:		; pruefen, ob Schreiben erlaubt ist
  E2A2    DB 12          C      	in	a,(flcobd)
  E2A4    CB 6F          C      	bit	5,a		; /WP
  E2A6    3E 57          C      	ld	a,'W'		; Fehler: write protected
  E2A8    CA E2D6        C      	jp	z,fehret
                         C      
                         C      ; CRC-Zeichen der zu schreibenden Daten berechnen und in crcber ablegen
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-86


  E2AB    2A E3DB        C      	ld	hl,(ft.adr)
  E2AE    DD 21 E3E5     C      	ld	ix,crcber	; Pointer auf 1. Daten-CRC stellen
  E2B2    DD 36 00 FB    C      crcbes: ld	(ix),0fbh	; Datenbeginn
  E2B6    CD E355        C      	call	crcbd		; CRC eines phys. Sektors berechnen
  E2B9    DD 72 00       C      	ld	(ix+0),d
  E2BC    DD 73 01       C      	ld	(ix+1),e	; ... und ablegen
  E2BF    CD E340        C      	call	crcnb		; weiterer phys. Sektor?
  E2C2    20 EE          C      	jr	nz,crcbes	; -> ja
                         C       ENDIF ;@write
                         C      
                         C      
                         C      ; Disk inzwischen ready?
                         C      
  E2C4                   C      dtrdyt:
  E2C4    DB 12          C      dtrdyz:	IN	A,(flcobd)
  E2C6    1F             C      	RRA			;ready-bit =0?
  E2C7    38 FB          C      dtrdyw:	JR	C,dtrdyz	;nein, 5" Disk not ready
                         C      				;auf jr c,$+2 modif bei 8"
                         C      
  E2C9    3E 05          C      	ld	a,5
  E2CB    CD E392        C      	call	fl.sto		;bei evtl. Fehlerwiederholung
                         C      				; timeout-Wert wieder hochstellen
                         C      				; fuer Ueberwachung auf fehlende Marke
  E2CE    3A E3E2        C      	ld	a,(ft.anz)	;Sektorzahl
  E2D1    B7             C      	or	a		; nur positionieren?
  E2D2    C2 E454        C      	jp	nz,diorun	; -> nein, Start des Transfers
                         C      
                         C      ; kein Fehler aufgetreten
  E2D5    AF             C      noerr:	xor	a
                         C      
                         C      ; Fertigmelden, Ergebnis in A
  E2D6    F5             C      fehret:	push	af
  E2D7    21 E3AB        C      	ld	hl,pretx+1	;Motorabschaltung ueber Index-Interrupt
  E2DA    36 0B          C      	ld	(hl),pret3-pret4;jr pret4
  E2DC    3E 14          C      	ld	a,20		;nach 20*200ms = 4 sec
  E2DE    CD E392        C      	call	fl.sto
  E2E1    F1             C      	pop	af
  E2E2    C9             C      	ret
                         C      
                         C      ; normale Beendigung
                         C      ;===================
                         C      
                         C      ; Schreiben
  E2E3    21 E3DA        C      dtrwre:	ld	hl,ft.kom
  E2E6    CB 76          C      	bit	6,(hl)		;Kontrollesen?
  E2E8    28 EB          C      	jr	z,noerr		;nein, fertig
  E2EA    CB 96          C      	res	2,(hl)		;sonst schreiben loeschen (d.h. auf lesen)
  E2EC    C3 E235        C      	jp	rdwr		;und auf gleichen Puffer zuruecklesen
                         C      
                         C      ; Lesen
  E2EF    2A E3DB        C      dtrrde:	ld	hl,(ft.adr)
  E2F2    DD 21 E3E5     C      	ld	ix,crcber
  E2F6    CD E355        C      crcbel:	call	crcbd		;CRC bilden
  E2F9    CD E34B        C      	call	crcvgl		; und vergleichen
  E2FC    20 07          C      	jr	nz,crcerx	; -> Fehler
  E2FE    CD E340        C      	call	crcnb		;noch ein Sektor?
  E301    20 F3          C      	jr	nz,crcbel	;ja
  E303    18 D0          C      	jr	noerr
                         C      
                         C      ; Fehlerbehandlung
                         C      ;=================
                         C      ; blieb weiterer Versuch, Sektor CRC-richtig reinzubekommen?
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-87


  E305    21 E400        C      crcerx: ld	hl,crerc
  E308    35             C      	dec	(hl)
  E309    C2 E235        C      	jp	nz,rdwr		; -> ja, alles noch mal
  E30C    3E 43          C      	ld	a,'C'		; Fehler: CRC-Zeichen falsch
  E30E    18 C6          C      	jr	fehret
                         C      
                         C      ; Sektor nicht gefunden, evtl. falsche Spur
  E310                   C      serrx:
                         C      ; blieb weiterer Versuch, die richtige Spur zu finden?
  E310    21 E401        C      	ld	hl,sperc
  E313    35             C      	dec	(hl)
  E314    28 15          C      	jr	z,sperr2	; Wiederhlg. abgelaufen
  E316    3E 02          C      	ld	a,2
  E318    BE             C      	cp	(hl)		;> 2 Wiederhlg?
  E319    DA E20D        C      	jp	c,trk0		;ja, Spur neu anfahren
  E31C    06 8F          C      	ld	b,08fh		;stepout
  E31E    28 05          C      	jr	z,sperr4	;=2 Wiederhlg., stepout
  E320    06 AF          C      	ld	b,0afh		;stepin
  E322    CD E1EB        C      	call	step		;2 mal (zuvor war stepout)
  E325    CD E1EB        C      sperr4:	call	step
  E328    C3 E22C        C      	jp	phrw		;Wiederholung
                         C      
  E32B    3E 53          C      sperr2:	ld	a,'S'		; Fehler: Sektor ist nicht zu finden
  E32D    18 A7          C      	jr	fehret
                         C      
                         C      
  E32F                   C      fl.to1: ; keine Sektor-Marke gefunden
  E32F    3E 55          C      	ld	a,'U'		; time-out (undefind)
  E331    18 A3          C      	jr	fehret
                         C      
                         C      ; Modifizierung entsprechend Steuertabelle
                         C      ;=========================================
                         C      ; i HL	Tabelle der Modifizierungsadressen (wohin)
                         C      ; i DE	Tabelle der Modifizierungsbytes    (was)
  E333    46             C      flmodf:	ld	b,(hl)		;Anzahl der Adressen
  E334    23             C      dslnmz:	inc	hl
  E335    C5             C      	push	bc
  E336    4E             C      	ld	c,(hl)
  E337    23             C      	inc	hl
  E338    46             C      	ld	b,(hl)		;bc:=wohin
  E339    1A             C      	ld	a,(de)		;a:=was
  E33A    13             C      	inc	de
  E33B    02             C      	ld	(bc),a
  E33C    C1             C      	pop	bc
  E33D    10 F5          C      	djnz	dslnmz
  E33F    C9             C      	ret
                         C      
                         C      ; CRC-Berechnung
                         C      ;===============
                         C      
                         C      ; von weiterem Sektor CRC-Zeichen berechnen?
                         C      ; IX wird weitergestellt
  E340    DD 23          C      crcnb: 	inc	ix		; CRC-Pointer erhoehen
  E342    DD 23          C      	inc	ix
  E344    3E FF          C      	ld	a,0ffh
  E345                   C      secanz	equ	$-1
  E346    3D             C      	dec	a
  E347    32 E345        C      	ld	(secanz),a
  E34A    C9             C      	ret
                         C      
                         C      ; CRC-Vergleich DE mit (IX)
  E34B    DD 7E 00       C      crcvgl: ld	a,(ix+0)
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-88


  E34E    BA             C      	cp	d
  E34F    C0             C      	ret	nz
  E350    DD 7E 01       C      	ld	a,(ix+1)
  E353    BB             C      	cp	e
  E354    C9             C      	ret
                         C      
                         C      ; von einem phys. Sektor ab HL die CRC-Zeichen berechnen
                         C      ; HL wird weitergestellt
  E355    11 CDB4        C      crcbd:	ld	de,0cdb4h	;CRC Anfangswert
  E356                   C      crcbeg	equ	$-2
  E358    DD E5          C      	push	ix
  E35A    E3             C      	ex	(sp),hl		;hl:= ^Datenbeginn-Byte
  E35B    06 01          C      	ld	b,1
  E35D    CD E36F        C      	call	bercrc		;CRC ueber Datenbeginn-Byte
  E360    E3             C      	ex	(sp),hl
  E361    DD E1          C      	pop	ix
  E363    06 01          C      	ld	b,1
  E364                   C      fl.tsb	equ	$-1		; Zahl der 128er Bloecke
  E365    C5             C      sp74: 	push	bc
  E366    06 80          C      	ld	b,128
  E368    CD E36F        C      	call	bercrc
  E36B    C1             C      	pop	bc
  E36C    10 F7          C      	djnz	sp74
  E36E    C9             C      	ret
                         C      
                         C      ; von HL an B Zeichen auf DE als CRC-Polynom draufrechnen
  E36F    7E             C      bercrc: ld	a,(hl)
  E370    AA             C      	xor	d
  E371    57             C      	ld	d,a
  E372    0F             C      	rrca
  E373    0F             C      	rrca
  E374    0F             C      	rrca
  E375    0F             C      	rrca
  E376    E6 0F          C      	and	0fh
  E378    AA             C      	xor	d
  E379    57             C      	ld	d,a
  E37A    0F             C      	rrca
  E37B    0F             C      	rrca
  E37C    0F             C      	rrca
  E37D    4F             C      	ld	c,a
  E37E    E6 1F          C      	and	1fh
  E380    AB             C      	xor	e
  E381    5F             C      	ld	e,a
  E382    79             C      	ld	a,c
  E383    0F             C      	rrca
  E384    E6 F0          C      	and	0f0h
  E386    AB             C      	xor	e
  E387    5F             C      	ld	e,a
  E388    79             C      	ld	a,c
  E389    E6 E0          C      	and	0e0h
  E38B    AA             C      	xor	d
  E38C    53             C      	ld	d,e
  E38D    5F             C      	ld	e,a
  E38E    23             C      	inc	hl
  E38F    10 DE          C      	djnz	bercrc
  E391    C9             C      	ret
                         C      
                         C      ; Aktivieren Indexpunktueberwachung
                         C      ; i A	Zaehler (wird bis 0 runtergezaehlt)
                         C      ; nur Reg. A zerstoert
                         C      
  E392    32 E3A3        C      fl.sto:	ld	(fl.zto),a	;Setzen Zaehler fuer Indexpunkte
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-89


  E395    3E 83          C      	ld	a,83h		;zulassen Indexinterrupt
  E397    D3 11          C      	out	(flcoac),a
  E399    C9             C      	ret
                         C      
                         C      ; Interruptbehandlungsroutine: time-out-Zeit abgelaufen
                         C      ; ausgeloest durch Index-Interrupt
  E39A    ED 73 E626     C      itimeo: ld	(intsp),sp
  E39E    31 F126        C      	ld	sp,intstk
  E3A1    F5             C      	push	af
  E3A2    3E 00          C      	ld	a,0		; Zaehler fuer time-out Takte
  E3A3                   C      fl.zto	equ	$-1
  E3A4    3D             C      	dec	a		; time-out -1
  E3A5    32 E3A3        C      	ld	(fl.zto),a
  E3A8    20 10          C      	jr	nz,pret1	;-> nicht abgelaufen
  E3AA    18 0B          C      pretx:	jr	pret3		;modif. auf "jr pret4" waehrend Transfer
  E3AC                   C      pret4:
                         C       IF cpu eq k2526
  E3AC    3E A9          C      	ld	a,10101001b	;Time out waehrend Transfer
  E3AE    D3 10          C      	out	(flcoad),a	;CPU 2 stoppen
  E3B0    3E 00          C      	ld	a,dtrtor-dtrwjr
  E3B2    32 E48B        C      	ld	(dtrret),a	;Reaktionsroutine "keine Marke gefunden"
                         C       ENDIF
  E3B5    18 03          C      	jr	pret1
  E3B7    CD E3BD        C      pret3:	call	headup
  E3BA    C3 E624        C      pret1: 	jp	intraf		; allg. Ausgang Interruptroutinen
                         C      
                         C      ; Motor-Abschaltung von aussen her
                         C      ; nur Reg. AF zerstoert
  E3BD    3E 03          C      headup:	ld	a,3		; Indexinterrupt sperren
  E3BF    D3 11          C      	out	(flcoac),a
  E3C1    3E FF          C      	ld	a,0ffh		; Motor aus
  E3C3    D3 18          C      	out	(flsel),a
                         C       IF fdc eq f1715
                         C       ENDIF
                         C      ; Motor aus und alte Spurnummer merken
  E3C5    E5             C      flres: 	push	hl
  E3C6    C5             C      	push	bc
  E3C7    21 E404        C      	ld	hl,alwnr
  E3CA    CB 9E          C      	res	3,(hl)		; Motor aus vermerken
  E3CC    4E             C      	ld	c,(hl)
  E3CD    06 00          C      	ld	b,0
  E3CF    21 E406        C      	ld	hl,spnrl	; alte Spurnr. in Tabelle merken
  E3D2    09             C      	add	hl,bc
  E3D3    3A E405        C       	ld	a,(aspnr)
  E3D6    77             C      	ld	(hl),a
  E3D7    C1             C      	pop	bc
  E3D8    E1             C      	pop	hl
  E3D9    C9             C      	ret
                         C      
                         C      
                         C      ;*****************************************************
                         C      ;	Arbeitsbereiche phys. Floppy-Treiber
                         C      ;*****************************************************
                         C      
                         C      ; Parameterfeld
                         C      ;==============
  E3DA    00             C      ft.kom: db	0	; Kommando
  E3DB    0000           C      ft.adr: dw	0	; Transferadresse
  E3DD    00             C      ft.lwn: db	0	; Laufwerksnummer 0..3
  E3DE    00             C      ft.trk: db	0	; Spurnummer   0..
  E3DF    00             C      ft.sid: db	0	; side-Nr.     0..1
  E3E0    00             C      ft.sec: db	0	; Sektornummer
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-90


  E3E1    00             C      ft.len: db	0	; Sektorlaenge 0..3
  E3E2    00             C      ft.anz: db	0	; Anz. phys. Sektoren
  E3E3    00             C      ft.stp: db	0	; Anzahl der Stepimpulse pro Spur
  E3E4    00             C      ft.sti: db	0	; Schrittzeit von Spur zu Spur
                         C      
  E3E5                   C      crcber: ds	3*9,0ffh; Ber. zum Ablegen der gelesenen/zu schreibenden CRC-Z.
                         C      			; reicht fuer 9 physische Sektoren pro Transfer
                         C      ; Fehler-Wiederholungszaehler
  E400    00             C      crerc: 	db	0	; CRC-Fehler
  E401    00             C      sperc: 	db	0	; Spur nicht gefunden
  E402    00             C      seerc: 	db	0	; Sektor nicht gefunden
  E403    00             C      lwexis: db	0	; Anzeigebyte fuer vorhandene Laufwerke
                         C      			; bit 0 = 1 LW 0 vorhanden
                         C      			; bit 2 = 1 LW 1 vorhanden
                         C      			; bit 4 = 1 LW 2 vorhanden
                         C      			; bit 6 = 1 LW 3 vorhanden
                         C      
  E404    00             C      alwnr: 	db	0	; alte Laufwerksnummer vom vergangenen Zugriff
                         C      			; bit 0-2 LW-Nr., bit 3 = 1 Motor laeuft noch
                         C      
  E405    00             C      aspnr:	db	0	; aktuelle Spur des durch alwnr bezeichneten LW
  E406    00 00 00 00    C      spnrl: 	db	0,0,0,0	; Tabelle der alten Spurnummern
                         C      
                         C       IF dsk8fm+dsk8mf+dsk5fm
                         C       ENDIF ;nicht nur 5" MFM
                         C      
                         C      ; Modifizierungstabelle entspr. Sektorlaenge
                         C      
  E40A    09             C      dslnmt:	db	dslnl		;Tabellenlaenge
  E40B    E364           C      	dw	fl.tsb		;Anzahl der 128er Bloecke
  E40D    E567           C      	dw	diosl1		;Laenge erstes INIR
                         C       IF cpu eq k2526
  E40F    E573           C      	dw	dini1+1		;INI oder INIR
  E411    E576           C      	dw	dini2+1
  E413    E579           C      	dw	dini3+1
                         C       ENDIF
                         C       if @write
  E415    E5C7           C      	dw	diosl2		;Laenge erstes OTIR
                         C        IF cpu eq k2526
  E417    E5CA           C      	dw	doti1+1		;OUTI oder OTIR
  E419    E5CC           C      	dw	doti2+1
  E41B    E5CE           C      	dw	doti3+1
                         C        ENDIF
                         C       endif
  0009                   C      dslnl	equ	($-dslnmt-1)/2	;Tabellenlaenge
                         C      
                         C      ; 128
  E41D    01             C      dsln0:	db	1
                         C       IF cpu eq k2526
  E41E    80 A2 A2 A2    C      	db	128,0a2h,0a2h,0a2h
                         C       ENDIF
                         C       if @write
                         C        IF cpu eq k2526
  E422    80 A3 A3 A3    C      	db	128,0a3h,0a3h,0a3h
                         C        ENDIF
                         C       endif
                         C      
                         C      ; 256
  E426    02             C      dsln1:	db	2
                         C       IF cpu eq k2526
  E427    00 A2 A2 A2    C      	db	0,0a2h,0a2h,0a2h
                         C       ENDIF
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-91


                         C       if @write
                         C        IF cpu eq k2526
  E42B    00 A3 A3 A3    C      	db	0,0a3h,0a3h,0a3h
                         C        ENDIF
                         C       endif
                         C      
                         C      ; 512
  E42F    04             C      dsln2:	db	4
                         C       IF cpu eq k2526
  E430    00 A2 A2 B2    C      	db	0,0a2h,0a2h,0b2h
                         C       ENDIF
                         C       if @write
                         C        IF cpu eq k2526
  E434    00 A3 A3 B3    C      	db	0,0a3h,0a3h,0b3h
                         C        ENDIF
                         C       endif
                         C      
                         C      ; 1024
  E438    08             C      dsln3:	db	8
                         C       IF cpu eq k2526
  E439    00 B2 B2 B2    C      	db	0,0b2h,0b2h,0b2h
                         C       ENDIF
                         C       if @write
                         C        IF cpu eq k2526
  E43D    00 B3 B3 B3    C      	db	0,0b3h,0b3h,0b3h
                         C        ENDIF
                         C       endif
                         C      
                         C       IF dskds
                         C      ; Modifizierungsadressen fuer Seitenauswahl
  E441    09             C      dsidmt:	db	dsidtl		; MFM		 FM
  E442    E4CC           C      	dw	diom01		;85/81		87/83
                         C       IF cpu eq k2526
  E444    E478           C      	dw	diom02		;a5/a1		a5/a1
  E446    E4C8           C       	dw	diom03		;b5/b1		b5/b1
  E448    E4B8           C      	dw	diom13		;bd/b9		bd/b9
                         C       ENDIF
                         C       if @write
                         C        IF dsk8fm+dsk5fm
                         C        ENDIF
  E44A    E5A0           C      	dw	diom07		;b4/b0		 -
  E44C    E5B2           C      	dw	diom08		;b6/b2		 -
  E44E    E5BC           C      	dw	diom09		;b4/b0		 -
                         C       endif
  E450    E55F           C      	dw	diom10		;b5/b1		b5/b1
                         C      ;;diom11 muss letztes Byte in der Tabelle sein
  E452    E5DE           C      	dw	diom11		;b5/b1		b5/b1
  0009                   C      dsidtl	equ	($-dsidmt-1)/2
                         C       ENDIF
                         C      	include BIOSDSKP
                         C      ;****************************************************************
                         C      ; Treiber fuer Ansteuerung K5120/K5122 ueber K2526 (mit Hilfsprozessor)
                         C      ; 04.06.87
                         C      ; - Fehlerkorrektur 8" MFM (Taktzeiten)
                         C      ; 25.09.89
                         C      ; - wegen MFS 1.2 nach Transfer b1 (= fault reset) als Standardwert
                         C      ;****************************************************************
                         C      
  E454                   C      diorun:
  E454    2A E3DB        C      	ld	hl,(ft.adr)
  E457    22 E4A0        C      	ld	(diodma),hl
                         C      
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-92


                         C      ; physischen Transfer ueber CPU 2 starten
                         C      
  E45A    21 E49B        C      	ld	hl,dio
  E45B                   C      diortn	equ	$-2
  E45D    ED 4B 0001     C      	ld	bc,(1)		;retten HS 1
  E461    22 0001        C      	ld	(1),hl		;CPU 2 -Routine
  E464    3E FE          C      	ld	a,0feh
  E466    32 E48B        C      	ld	(dtrret),a	;stellen Warte-Reaktion
  E469    AF             C      	XOR	A
  E46A    D3 14          C      	OUT	(fldaad),A
  E46C    D3 04          C      	OUT	(04H),A		;reset CPU 2
  E46E    3D             C      	dec	a		;Mode 3 (Bit E/A)
  E46F    D3 17          C      	OUT	(fldabc),A
  E471    D3 17          C      	OUT	(fldabc),A	;alles Input
  E473    3E B9          C      	ld	a,10111001b	;AMF aus, Fault reset
  E475    D3 10          C      	out	(flcoad),a
  E477    3E A5          C      	LD	A,10100101b	;Seite einstellen, Mark reset, AMF aktiv
  E478                   C      diom02	equ	$-1		;a5/a1
  E479    D3 10          C      	OUT	(flcoad),A
  E47B    3E 7F          C      	LD	A,7FH		;Mode 1
  E47D    D3 17          C      	OUT	(fldabc),A
  E47F    DB 16          C      	IN	A,(fldabd)	;CPU2 starten (ueber BUSRQ)
                         C      ; durch die Anfangsinitialisierung der CPU2 vergehen die notwendigen
                         C      ; 100 Mikrosek. fuer Seitenumschaltung
  E481    ED 43 0001     C      	ld	(1),bc		;HS 1 wiederherst.
  E485    3A E4CC        C      	LD	A,(diom01)	;Lesen Marke
  E488    D3 10          C      	OUT	(flcoad),A	;weiter bei CPU2 nach Anfangsinit.
                         C      ; Achtung!! Zur Synchronisation CPU1 und CPU2 keine 2-Byte-Werte
                         C      ; (Adressen) verwenden, da dazwischen BUSRQ auftreten kann und dann
                         C      ; nur ein Byte gesetzt wurde!!
  E48A    18 FE          C      	jr	$		;auf CPU 2 Ende warten
  E48B                   C      dtrret	equ	$-1
  E48C                   C      dtrwjr:
  E48C    C3 E32F        C      dtrtor:	jp	fl.to1		;time out
  E48F    C3 E2D5        C      dtrner:	jp	noerr		;fehlerfrei (Sekt.id)
  E492    C3 E310        C      dtrnsr:	jp	serrx		;Sektor nicht gefunden
  E495    C3 E2EF        C      dtrrdr:	jp	dtrrde		;Read Ende
  E498    C3 E2E3        C      dtrwrr:	jp	dtrwre		;Write Ende
                         C      ;--------------------------
                         C      
                         C      
                         C      ; Code CPU 2 fuer phys. Diskettentransfer
                         C      ;========================================
                         C      ; Zeitbedingungen fuer 8" MFM:
                         C      ; 6 Umdrehungen pro Sec bei 2*5208 Bytes pro Spur bedeutet
                         C      ; 1/(6*2*5208), d.h. 16 Mikrosec pro Byte!!
                         C      ; Bei einer Taktfrequenz von (9600*256)=2457600 Hz sind das
                         C      ; (9600*256)/(6*2*5208) Takte, d.h. max. 39 Takte pro Byte!!
                         C      ; Wegen BUSRQ/BUSAK muss davon der laengste Maschinenzyklus
                         C      ; der CPU 1 abgezogen werden, d.h. 6 Takte (Interruptannahme),
                         C      ; weiterhin je ein Takt fuer BUSRQ/BUSAK-Umschaltung,
                         C      ; es verbleiben 31 Takte zwischen den E/A-Maschinenzyklen!!
                         C      
                         C      ; normaler Entry in phys. Diskettentransfer
                         C      ;==========================================
  E49B                   C      dio:	
  E49B    AF             C      	xor	a		;wiederherstellen 'jr diokl'
  E49C    32 E4D4        C      	ld	(diomd1+1),a
  E49F    21 0000        C      	ld	hl,0
  E4A0                   C      diodma	equ	$-2		;Transferadresse
  E4A2    3E 00          C      	ld	a,0
  E4A3                   C      secan1	equ	$-1		;a':=Zahl zu transfer. phys. Sekt.
