  E5AB    03             C      	db	3
  E5AC    D454           C      	dw	crto		;0 crt:
  E5AE    D132           C      	dw	dumo		;1 dum:
  E5B0    E5C0           C      	dw	list		;2 lst:
  E5B2    D6EB           C      	dw	uc1o		;3 uc1: (wartet, bis frei)
                         C      
                         C      
  E5B4                   C      listst:			; iobyte:  xx 00 00 00
  E5B4    CD E5CC        C      	call	iodisp
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-104


  E5B7    05             C      	db	5
  E5B8    D755           C      	dw	ttyst		;0 tty:
  E5BA    D12C           C      	dw	crtst		;1 crt:
  E5BC    D75B           C      	dw	lptst		;2 lpt:
  E5BE    D12C           C      	dw	dumst		;3 dum:
                         C      
  E5C0                   C      list:			; iobyte:  xx 00 00 00
  E5C0    CD E5CC        C      	call	iodisp
  E5C3    05             C      	db	5
  E5C4    D6DF           C      	dw	ttyo		;0 tty:
  E5C6    D454           C      	dw	crto		;1 crt:
  E5C8    D6E5           C      	dw	lpto		;2 lpt:
  E5CA    D132           C      	dw	dumo		;3 dum:
                         C      
                         C      
                         C      ; IOBYTE-Auswertung - Verteilung auf die physischen Geraete
                         C      ; ---------------------------------------------------------
                         C      ; A,HL werden zerstoert
                         C      ; Anwender-IX wird gerettet, darf von Treiber-Routine zerstoert werden
                         C      ; damit kann Treiber auch aus Interrupt-Routine aufgerufen werden
                         C      
  E5CC                   C      iodisp:
  E5CC    E1             C      	pop	hl
  E5CD    C5             C      	push	bc
  E5CE    46             C      	ld	b,(hl)
  E5CF    23             C      	inc	hl
  E5D0    3A 0003        C      	ld	a,(iobyte)
  E5D3    0F             C      iodis1: rrca
  E5D4    10 FD          C      	djnz	iodis1
  E5D6    E6 06          C      	and	6
  E5D8    4F             C      	ld	c,a
  E5D9    09             C      	add	hl,bc
  E5DA    7E             C      	ld	a,(hl)
  E5DB    23             C      	inc	hl
  E5DC    66             C      	ld	h,(hl)
  E5DD    6F             C      	ld	l,a
  E5DE    C1             C      	pop	bc
  E5DF    DD E5          C      	push	ix		;retten Anwender-IX
  E5E1    CD E6B8        C      	call	callhl
  E5E4    DD E1          C      	pop	ix		;wiederherstellen Anwender-IX
  E5E6    C9             C      	ret
                         C      
                         C       ENDIF
                         C      
                         C      ;************************************************************
                         C      ;	Spezialroutinen
                         C      ;************************************************************
                         C      
                         C      	IF	monitor
                         C      	ENDIF
                         C      
                         C      
                         C      ; Arbeit mit asynchronen Sonderaktionen
                         C      ;======================================
                         C      ; Die folgenden beiden Routinen werden vom BIOS immer dann aufgerufen,
                         C      ; wenn wegen zeitkritischer (z.B. Floppy-Bedienung) oder anderer
                         C      ; BIOS-Arbeit (z.B. Bildschirmrollen) keine parallelen Sonderaktionen
                         C      ; erlaubt sind.
                         C      
                         C      ; Reg A bleibt erhalten
  E5E7    F5             C      delsps: push	af
  E5E8    2A 004A        C      	ld	hl,(kritbg)	;evtl. Nutzerroutine fuer Beginn krit. BIOS
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-105


  E5EB    CD E6B8        C      	call	callhl		;aufrufen
  E5EE    F1             C      	pop	af
  E5EF    21 D03E        C      	ld	hl,synsem	;Verzoegern Sonderaktionen
  E5F2    34             C      	inc	(hl)
  E5F3    C9             C      	ret
                         C      
                         C      ; Reg A bleibt erhalten
  E5F4    F5             C      delspr: push	af
  E5F5    2A 004C        C      	ld	hl,(kriten)	;evtl. Nutzerroutine fuer Ende krit. BIOS
  E5F8    CD E6B8        C      	call	callhl		;aufrufen
  E5FB    F1             C      	pop	af
  E5FC    21 D03E        C      	ld	hl,synsem	;Zulassen Sonderaktionen
  E5FF    35             C      	dec	(hl)
                         C      
                         C       IF stpvar or monitor
                         C      
                         C      ; Test auf zwischenzeitliche Anforderung von Sonderroutinen
                         C      ;----------------------------------------------------------
                         C      
                         C      ; Diese Routine wird nach dem Lesen eines Tastaturzeichens
                         C      ; als "Ohr" eingeschoben, bevor zur eigentlichen Interrupt-
                         C      ; adresse zurueckgekehrt wird. Sie wird nicht innerhalb der
                         C      ; Interruptroutine ausgefuehrt, um mit offenen Interrupts
                         C      ; arbeiten zu koennen.
                         C      ; maximale Stackbelastung nach RETI von Interruptroutinen:
                         C      ; -	Return-Adresse zum Nutzer
                         C      ; -	AF
  E600    F3             C      chksp:	di
  E601    F5             C      	push	af		;A und F Reg retten
  E602    3A D03E        C      	ld	a,(synsem)
  E605    B7             C      	or	a		;asynchr. Routinen zugelassen?
  E606    C2 E61D        C      	jp	nz,chkspx	;nein
  E609    3C             C      	inc	a		;weiteren Eintritt verhindern
  E60A    32 D03E        C      	ld	(synsem),a
  E60D    FB             C      chkspn: ei
  E60E    3A D03D        C      	ld	a,(synflg)	;inzw. (neue) Anforderung?
  0000                   C      rqmask	aset	0
                         C       IF monitor
                         C       ENDIF
                         C       IF stpvar
  0010                   C      rqmask	aset	rqmask+(1 shl stoprq)
                         C       IF chdvar
  0018                   C      rqmask	aset	rqmask+(1 shl synlrq)
                         C       ENDIF
                         C       ENDIF
  E611    E6 18          C      	and	rqmask
  E613    C2 E620        C      	jp	nz,chkspd	;ja, ausfuehren
  E616    3A D03E        C      	ld	a,(synsem)
  E619    3D             C      	dec	a
  E61A    32 D03E        C      	ld	(synsem),a
  E61D    F1             C      chkspx: pop	af
  E61E    FB             C      	ei
  E61F    C9             C      	ret
                         C      
                         C      ; asynchrone Aktionen ausfuehren
  E620                   C      chkspd:
                         C       IF monitor
                         C       ENDIF
                         C      
                         C       IF stpvar
  E620    3A D03D        C      	ld	a,(synflg)
  E623    CB 67          C      	bit	stoprq,a	;inzwischen Stop-Forderung?
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-106


  E625    28 10          C      	jr	z,nstpsp	;nein
  E627    CB A7          C      	res	stoprq,a
  E629    32 D03D        C      	ld	(synflg),a
  E62C    F1             C      	pop	af		;Nutzer-Stackbelastung verringern
  E62D    22 E665        C      	ld	(asynhl),hl	;HL freimachen
  E630    21 E668        C      	ld	hl,stoprt	;Routine
  E633    CD E651        C      	call	asynrt		;aufrufen mit eigenem Stack
  E636    F5             C      	push	af
  E637                   C      nstpsp:
                         C      
                         C       IF chdvar
  E637    3A D03D        C      	ld	a,(synflg)
  E63A    CB 5F          C      	bit	synlrq,a	;inzwischen LST:-Synchr.?
  E63C    28 10          C      	jr	z,nsynlr	;nein
  E63E    CB 9F          C      	res	synlrq,a
  E640    32 D03D        C      	ld	(synflg),a
  E643    F1             C      	pop	af
  E644    22 E665        C      	ld	(asynhl),hl
  E647    21 D768        C      	ld	hl,lsynch
  E64A    CD E651        C      	call	asynrt
  E64D    F5             C      	push	af
  E64E                   C      nsynlr:
                         C       ENDIF
                         C       ENDIF	;stpvar
                         C      
  E64E    C3 E60D        C      	jp	chkspn		;Test auf neue Requests
                         C      
                         C       IF stpvar or chdvar
                         C      ; Asynchrone Routine (HL) mit eigenem Stack aufrufen
                         C      ;---------------------------------------------------
                         C      
  E651    ED 73 E662     C      asynrt: ld	(asynsv),sp	;asynchr. Routinen haben
  E655    31 EFF4        C      	ld	sp,stpstk	;ein eigenes Stack
  E658    F5             C      	push	af
  E659    D5             C      	push	de
  E65A    C5             C      	push	bc
  E65B    CD E6B8        C      	call	callhl		;Routine aufrufen
  E65E    C1             C      	pop	bc
  E65F    D1             C      	pop	de
  E660    F1             C      	pop	af
  E661    31 0000        C      	ld	sp,0		;SP wiederherstellen
  E662                   C      asynsv	equ	$-2
  E664    21 0000        C      	ld	hl,0		;gerettetes hl wiederherst.
  E665                   C      asynhl	equ	$-2
  E667    C9             C      	ret
                         C       ENDIF
                         C      
                         C       IF stpvar
                         C      ; Asynchrone Stop-Routine
                         C      ;------------------------
  E668                   C      stoprt:
                         C       IF disknb ne 0
  E668    CD E1D0        C      	call	headup		;Disk-Kopf abheben
                         C       ENDIF
  E66B    CD E6A2        C      stopz:	call	stpchp		;holen naechste phys. Taste
                         C      
                         C       IF umlaut
  E66E    FE 75          C      	cp	'u'		;Umlaut-Modus umschalten ?
  E670    28 04          C      	jr	z,stopzu
  E672    FE 55          C      	cp	'U'
  E674    20 08          C      	jr	nz,stopnu	;Nein !
  E676    21 D03D        C      stopzu: ld	hl,synflg	;Umlaute-Flag im Flagbyte
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-107


  E679    7E             C      	ld	a,(hl)
  E67A    EE 04          C      	xor	1 shl umlflg	;umschalten
  E67C    77             C      	ld	(hl),a
  E67D    C9             C      	ret
  E67E                   C      stopnu:
                         C       ENDIF
                         C      
