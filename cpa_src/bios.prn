  098E    E6 0F          C      	and	0fh
  0990    D6 0A          C      	sub	9+1
  0992    38 02          C      	jr	c,dcnvod	;0..9
  0994    C6 07          C      	add	a,7		;A..F
  0996    C6 3A          C      dcnvod:	add	a,'0'+10
  0998    12             C      	ld	(de),a
  0999    13             C      	inc	de
  099A    F1             C      	pop	af
  099B    C9             C      	ret
