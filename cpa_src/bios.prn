BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-68


  DC17    CB C6          C      	set	dfbprr,(hl)	;preread notwendig
  DC19    3E 02          C      	ld	a,2
  DC1B    32 DF0A        C      	ld	(dwrtyp),a
                         C      
  DC1E                   C      alloc:
                         C        IF @write
