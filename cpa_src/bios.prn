  DBF3    3C             C      unatr1:	inc	a		;naechster Sektor
  DBF4    77             C      	ld	(hl),a
  DBF5    21 DEF2        C      	ld	hl,dbflg
  DBF8    CB 86          C      	res	dfbprr,(hl)	;anzeigen kein preread notw.
                         C      	ENDIF
  DBFA    18 26          C      	jr	drw
                         C      
                         C       ENDIF ;@write
                         C      
                         C      ; Abbruch read/write mit E/A-Fehler
