  096E    20 2C          C      	jr	nz,ramter	;nein
  0970    2F             C      	cpl
  0971    77             C      	ld	(hl),a
  0972    23             C      	inc	hl
  0973    0B             C      	dec	bc
  0974    78             C      	ld	a,b
  0975    B1             C      	or	c
  0976    20 F2          C      	jr	nz,ramtz
  0978    21 0D49        C      	ld	hl,ramtok
  097B    CD 0AA6        C      	call	cputms
