BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-70


                         C      ; Sektor in/aus Puffer holen
                         C      ;===========================
  DCD9    F1             C      	pop	af		;Puffernr. in Spur wegschm.
  DCDA    F1             C      	pop	af		;128-er Index im Puffer
  DCDB    F5             C      	push	af
  DCDC    1F             C      	rra			;Sektornb*128 berechnen
  DCDD    47             C      	ld	b,a
  DCDE    0E 00          C      	ld	c,0
  DCE0    CB 19          C      	rr	c
  DCE2    21 F282        C      	ld	hl,dbuf
  DCE5    09             C      	add	hl,bc		;Adresse im Puffer
  DCE6    ED 5B DF02     C      	ld	de,(ddma)	;Nutzer-DMA
  DCEA    3A DEFB        C      	ld	a,(dflg)
  DCED    CB 57          C      	bit	dfwr,a		;Schreiben?
  DCEF    28 09          C      	jr	z,dsmove	;nein
  DCF1    3A DEF2        C      	ld	a,(dbflg)
  DCF4    CB D7          C      	set	dfbwr,a		;anzeigen Puffer beschrieben
  DCF6    32 DEF2        C      	ld	(dbflg),a
  DCF9    EB             C      	ex	de,hl
  DCFA    01 0080        C      dsmove:	ld	bc,128
                         C       IF dev eq cpd
                         C       ELSE
  DCFD    ED B0          C      	ldir
                         C       ENDIF
  DCFF    F1             C      	pop	af		;128-Index im Puffer
  DD00    DD BE 11       C      	cp	(ix+dpbbfm)	;letzter Sektor im Puffer
  DD03    28 05          C      	jr	z,dmovew	;ja, Puffer ausgeben
  DD05    3A DF0A        C      	ld	a,(dwrtyp)
  DD08    FE 01          C      	cp	1		;write to directory?
  DD0A    CC DD11        C      dmovew:	call	z,dbtrw		;ja, veraend. Puffer ausgeben
  DD0D    3A DF0B        C      	ld	a,(dberrf)	;Ergebnis letztes dbtran
  DD10    C9             C      	ret
                         C      
                         C      ; Schreiben Puffer, wenn notw.
                         C      ;=============================
  DD11    21 DEF2        C      dbtrw:	ld	hl,dbflg
  DD14    CB 56          C      	bit	dfbwr,(hl)	;Puffer veraendert?
  DD16    C8             C      	ret	z		;nein, Schreiben unterdruecken
                         C      	ENDIF	;dbufsz gt 7
                         C      
                         C      	IF	format or (dbufsz gt 7)
                         C      ; gemeinsamer Zweig Lesen/Schreiben Puffer
