                         C       ENDIF
                         C      
  E69B    D6 C7          C      	sub	kcurpd		;"Page down": ^C ?
  E69D    C0             C      	ret	nz		;nein, Stop-Ende
  E69E    32 D03E        C      	ld	(synsem),a	;falls rst 0 nicht in BIOS fuehrt
  E6A1    C7             C      	rst	0		;sonst Warmstart
                         C      
                         C      ; Holen naechste Taste physisch
  E6A2    21 D03D        C      stpchp: ld	hl,synflg
  E6A5    CB FE          C      	set	phyact,(hl)	;naechste Taste physisch
  E6A7    E5             C      	push	hl
  E6A8    CD E6AF        C      	call	stopch		;holen naechstes Tastaturz.
  E6AB    E1             C      	pop	hl
  E6AC    CB BE          C      	res	phyact,(hl)	;physisches Lesen beendet
  E6AE    C9             C      	ret
