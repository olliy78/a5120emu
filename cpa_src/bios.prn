  E55F    30 01          C      	jr	nc,t1nmo2	;ja
  E561    AF             C      	xor	a
  E562    32 E1B6        C      t1nmo2:	ld	(fl.zto),a
  E565    CC E1D0        C      	call	z,headup	;Ueberw.zeit abgelaufen -> Motor aus
  E568                   C      t1nmo1:
