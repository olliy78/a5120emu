                         C      ; - Tastaturpolling nur wenn Zugriff zur Statuszeile erlaubt
                         C      ; 20.03.89
                         C      ; - Laufwerksabschaltung ueber Zeittakt nur bei FDC K5120/22 und F1715
                         C      ;*************************************************************
                         C      
                         C       IF1
                         C       ENDIF
                         C      
                         C      ; 5ms/25ms an
  E4B9                   C      tim5on:
                         C       IF cpu eq c1715
                         C       ENDIF
  E4B9    3E B1          C      	ld	a,10110001b
                         C      	;int./zeitg./vort.256/pos.flanke/naechst.zykl./keine zk/weiter/1
  E4BB    F3             C      tim5ot:	DI
  E4BC    D3 0E          C      	out	(sysctc+tim5ct),a
  E4BE    FB             C      	EI
  E4BF    C9             C      ret:	ret
                         C      
                         C      ; 5ms/25ms aus
  E4C0                   C      tim5of:
                         C       IF cpu eq c1715
                         C       ENDIF
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-100


  E4C0    3E 31          C      	ld	a,00110001b	;kein int./...
  E4C2    18 F7          C      	jr	tim5ot
                         C      
                         C       IF cpu eq c1715
                         C       ELSE
                         C      ; 1s an
  E4C4    3E D1          C      tim1on:	ld	a,11010001b
                         C      	;int./zaehler//pos.flanke//keine zk/weiter/1
  E4C6    F3             C      tim1ot:	DI
  E4C7    D3 0F          C      	out	(sysctc+tim1ct),a
  E4C9    FB             C      	EI
  E4CA    C9             C      	ret
                         C      ; 1s aus
  E4CB    3E 51          C      tim1of:	ld	a,01010001b	;kein int./...
  E4CD    18 F7          C      	jr	tim1ot
                         C       ENDIF
                         C      
                         C      ; Interr.routine 5ms/25ms
  E4CF                   C      tim5it:
                         C       IF stpvar or monitor
  E4CF    22 E4D7        C      	ld	(t5ihl),hl	;retten hl
  E4D2    21 E600        C      	ld	hl,chksp	;Test auf haengende Spezialfktnen
  E4D5    E5             C      	push	hl		;nach const-Aufruf in CTC-Interrupt
  E4D6    21 0000        C      	ld	hl,0		;wiederherstellen hl
  E4D7                   C      t5ihl	equ	$-2
                         C       ENDIF
  E4D9    ED 73 E4F8     C      	ld	(intsp),sp
  E4DD    31 F00C        C      	ld	sp,intstk
  E4E0    F5             C      	push	af
  E4E1    E5             C      	push	hl
  E4E2    D5             C      	push	de
  E4E3    C5             C      	push	bc
  E4E4    2A 0041        C      	ld	hl,(tim5cn)
  E4E7    23             C      	inc	hl
  E4E8    22 0041        C      	ld	(tim5cn),hl
