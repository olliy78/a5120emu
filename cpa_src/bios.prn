                         C      ;===========================================
  D1E7                   C      kbdi:
  D1E7                   C      kbdmd1:		;Modifizierung bei K7634/36/37 mit:
                         C      ;kbdwin:call	kbdst		;Taste im Puffer
                         C      ;	jr	z,kbdwin	;nein, warten
                         C      ;	jp	kbdinn		;sonst aeltestes Pufferzeichen
                         C      
  D1E7    CD D14F        C      kbdwin:	call	kbdst		;Taste im Puffer?
  D1EA    20 32          C      	jr	nz,kbdinn	;ja
  D1EC    21 D1F0        C      	ld	hl,kbdwt	;wartefaktor
  D1EF    06 64          C      	ld	b,100		;fuer dauerfunktion
  D1F0                   C      kbdwt	equ	$-1
  D1F1    36 0A          C      	ld	(hl),10		;auf 10*0,01sec fuer
                         C      				;gleiche taste
  D1F3    18 07          C      	jr	kbdwst		;einspr. in zyklus
  D1F5    C5             C      kbdwa:	push	bc
  D1F6    06 01          C      	ld	b,1		;0,01 sec warten
  D1F8    CD E6C5        C      	call	wait10
  D1FB    C1             C      	pop	bc
  D1FC    CD D233        C      kbdwst:	call	kbdst1		;taste neu gedrueckt?
  D1FF    20 13          C      	jr	nz,kbdwb	;ja, abholen ueber kbdst
  D201    DB 06          C      	in	a,(kbdpci)	;taste noch gedrueckt?
  D203    B7             C      	or	a		;(funktioniert nur bei K760X!)
  D204    28 0E          C      	jr	z,kbdwb		;nein; warten
