                                  IF cdtdc1 or cdtdtr
                         C      	include BIOSCSIO
                         C      ;===================================================================
                         C      ; SIO-Treiber, DTR- und DC1/DC3-Protokoll
                         C      ;===================================================================
                         C      ;
                         C      ; Aenderungen:
                         C      ; - Statusabfrage jedesmal, auch wenn zuvor frei gemeldet
                         C      ; - Pufferueberlauf bei UC1-Puffer kontrolliert
                         C      ; - bei DC1/DC3 nach Initialisierung 7fh an Drucker und max. 30 sec auf
                         C      ;  Antwort gewartet (sonst Fehler am SD1157, wenn zu frueh gesendet wird)
                         C      ; 29.6.88:
                         C      ; - bei DC1/3 Protokoll wird neu initialisiert, wenn DC4 vom Drucker kommt
                         C      ;  (Probleme bei K6314)
                         C      ; 20.09.88
                         C      ; - Neben DTR-Statusabfrage ueber Kanal B, Bit 3 (Treiber 1, Standard)
                         C      ;  auch DTR-Statusabfrage ueber Kanal A, Bit 5 (Treiber 3) unterstuetzt
                         C      ; 23.03.89
                         C      ; - CTS-Zusammenspiel bei K6311 u.ae. funktioniert nur, wenn bis zum
                         C      ;   Verlassen aller Bits aus dem Sender gewartet wird und nicht nur auf
                         C      ;   das Freiwerden des Sendepuffers - sonst Zeichenverlust!
                         C      ; - wenn UC1 am Kanal A wird WR1 Bit2 und WR2 im Kanal B gesetzt
                         C       IF cpu eq c1715
                         C       ENDIF
                         C      ; 04.04.89
                         C      ; - nach Drucker-Init 'set 0,(ix+ltpst)' statt 'ld (ix+ltpst),11h'
                         C      ; 06.07.89
                         C      ; - wegen K6314-Problemen wird nach Initialisierung DC1 angenommen
                         C      ; - bei UC1-Kopplung ueber DTR ohne Warten auf Senderegister leer,
                         C      ;   nur Warten auf Sendepuffer leer
                         C      ;   (Aenderung 23.03.89 daher nur fuer Drucker wirksam, sonst zu langsam)
                         C      ; 15.09.89
                         C      ; - bei UC1-Kopplung ueber DC1/DC3 nicht 7fh zu Beginn gesendet, sondern DC1
                         C      ;**************************************************************************
                         C      
  D12F                   C      cdsioi	equ	dumi		;keine Zeicheneingabe unterstuetzt
                         C      
                         C      ; Einzelzeichenausgabe Reg. A
  D7D4    DD 4E 02       C      cdsioo:	ld	c,(ix+ltpsd)	;Datenport
  D7D7    ED 79          C      	out	(c),a
  D7D9    C9             C      	ret
                         C      
                         C      ;------------------------------------
                         C      
                         C      ; Statusabfrage
  D7DA    DD 7E 00       C      cdsios:	ld	a,(ix+ltpst)	;Status
  D7DD    CB 4F          C      	bit	1,a		;senderseitig blockiert?
  D7DF    20 3F          C      	jr	nz,lstsr	;ja, frei rueckmelden
  D7E1    B7             C      	or	a		;initialisiert?
  D7E2    CC D847        C      	call	z,cdsins	;nein
  D7E5    DD CB 0A 7E    C      	bit	7,(ix+ltpw5)	;Prozedur DTR?
  D7E9    28 3A          C      	JR	Z,lstsdc	;nein
  D7EB    DD 4E 03       C      	ld	c,(ix+ltpsc)	;SIO Kommando
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-55


                         C       IF iobuc1
  D7EE    DD CB 01 7E    C      	bit	7,(ix+ltpdc)	;Warten auf Senderegister leer?
  D7F2    28 0C          C      	jr	z,lstse0	;ja
  D7F4    3E 10          C      	ld	a,00010000b	;Reset Ext/Status-Interrupt, Lesereg. 0
  D7F6    ED 79          C      	out	(c),a		;Status abspeichern
  D7F8    ED 78          C      	in	a,(c)		;Lesereg. 0
  D7FA    CB 57          C      	bit	2,a		;Sendepuffer leer?
  D7FC    20 0C          C      	jr	nz,lstse1	;ja
  D7FE    18 20          C      	jr	lstsr		;nein, Drucker besetzt
  D800                   C      lstse0:
                         C       ENDIF
                         C       IF cpu eq c1715 ;wegen evtl. parallelem Tastaturpolling am gleichen SIO-Kanal
                         C       ENDIF
  D800    3E 11          C      	LD	a,00010001b	;Reset Ext/Status-Interrupt, Lesereg. 1
  D802    ED 79          C      	OUT	(C),a		;Status abspeichern
  D804    ED 78          C      	IN	a,(C)		;Leseregister 1
                         C       IF cpu eq c1715 ;wegen evtl. parallelem Tastaturpolling am gleichen SIO-Kanal
                         C       ENDIF
  D806    CB 47          C      	bit	0,a		;alle Bits gesendet?
                         C      				; Sendepuffer frei reicht nicht, da
                         C      				; K6311 u.ae. nicht korrekt arbeiten
  D808    28 16          C      	jr	z,lstsr		;nein, Drucker besetzt
  D80A    DD CB 01 5E    C      lstse1:	bit	3,(ix+ltpdc)	;Abfrage DTR ueber DCD im Kanal B?
  D80E    20 06          C      	jr	nz,lstsb3	;ja
  D810    ED 78          C      	in	a,(c)		;Leseregister 0
  D812    CB 6F          C      	bit	5,a		;CTS?
  D814    18 0A          C      	jr	lstsr		;nz bei ja
  D816    0C             C      lstsb3:	inc	c
  D817    0C             C      	inc	c		;auf Kanal B
  D818    3E 10          C      	LD	a,00010000b	;Reset Ext/Status-Interrupt, Lesereg. 0
  D81A    ED 79          C      	out	(c),a		;DCD in RR0 Kanal B abspeichern
  D81C    ED 78          C      	in	a,(c)		;Leseregister 0 des Kanal B
  D81E    CB 5F          C      	bit	3,a		;DCD im Kanal B (ist DTR-Bit vom Kanal A)
                         C      ; Ausgang Senderstatus
  D820                   C      lstsr:
  D820    3E FF          C      lstsr1:	ld	a,0ffh
  D822    C0             C      	ret	nz		;senderseitig frei
  D823    3C             C      	inc	a		;A=00, ret z
  D824    C9             C      	RET			;senderseitig besetzt
                         C      ;-----------------------
                         C      ; DC1/DC3 und XON/XOFF
  D825    DD 4E 02       C      lstsdc:	LD	C,(ix+ltpsd)	;SIO Daten
  D828    ED 78          C      	IN	A,(C)		;Status lesen (SIO speichert letzten Status)
  D82A    DD 77 01       C      	LD	(ix+ltpdc),A	;zuletzt empf. Zeichen fuer Fehlersuche merken
  D82D    E6 7F          C      	and	7fh		;evtl. Paritaet ignorieren
  D82F    FE 13          C      	cp	13h		;DC3?
  D831    28 12          C      	jr	z,lstsd2	;ja, besetzt
  D833    FE 14          C      	cp	14h		;DC4 (Status)?
  D835    20 05          C      	jr	nz,lstsd1	;nein (DC1 angenommen)
  D837    CD D87B        C      	call	cdsini		;statt Status abzuholen neu initialisieren
  D83A    18 E9          C      	jr	lstsdc		;und Status neu abfragen
  D83C    DD 4E 03       C      lstsd1:	ld	c,(ix+ltpsc)	;SIO Kommando
  D83F    ED 78          C      	in	a,(c)
  D841    CB 57          C      	bit	2,a		;Sendepuffer leer? (nz bei ja)
  D843    18 DB          C      	jr	lstsr
  D845    AF             C      lstsd2:	xor	a		;A=00, ret z
  D846    C9             C      	ret			;senderseitig besetzt
                         C      
                         C      ;-----------------------
                         C      
                         C      ; (Re-)Initialisierung
                         C      ; IX auf Steuertabelle
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-56


                         C      ; ret: C zeigt auf Kommandoport
                         C      
                         C      ; Sender initialisieren
  D847                   C      cdsins:
  D847    DD CB 00 C6    C      	set	0,(ix+ltpst)	;Sender ist initialisiert
  D84B    CD D87B        C      	call	cdsini
  D84E    DD CB 0A 7E    C      	bit	7,(ix+ltpw5)	;Prozedur DC1/DC3?
  D852    C0             C      	ret	nz		;nein
  D853    41             C      	ld	b,c
  D854    DD 4E 02       C      	ld	c,(ix+ltpsd)	;Datenport
                         C       IF iobuc1
  D857    DD CB 01 7E    C       	bit	7,(ix+ltpdc)	;Warten auf Senderegister leer?
  D85B    28 06          C      	jr	z,cdsind	;ja, Drucker
  D85D    3E 11          C      	ld	a,11h		;bei UC1: mit DC1/DC3-Protokoll DC1 senden
  D85F    ED 79          C      	out	(c),a
  D861    48             C      	ld	c,b
  D862    C9             C      	ret
                         C       ENDIF
  D863    3E 7F          C      cdsind:	ld	a,7fh		;nach Initialisierung RESET senden
  D865    ED 79          C      	out	(c),a
  D867    48             C      	ld	c,b
  D868    11 0BB8        C      	ld	de,30*100	;max. Wartezeit ca. 30 sec (SD1157!)
  D86B    ED 78          C      cdsinw:	in	a,(c)
  D86D    CB 47          C      	bit	0,a		;Antwort da?
  D86F    C0             C      	ret	nz		;ja
  D870    06 01          C      	ld	b,1
  D872    CD E6C5        C      	call	wait10		;10ms warten
  D875    1B             C      	dec	de
  D876    7A             C      	ld	a,d
  D877    B3             C      	or	e		;max. Wartezeit abgelaufen?
  D878    20 F1          C      	jr	nz,cdsinw	;nein
  D87A    C9             C      	ret			;sonst Drucker wohl nicht bereit
                         C      
                         C      
                         C      ; gem. UP fuer Sender und Empf. initialisieren
  D87B                   C      cdsini:
  D87B    DD E5          C      	push	ix
  D87D    E1             C      	pop	hl
  D87E    01 000B        C      	ld	bc,ltpini
  D881    09             C      	add	hl,bc
                         C       IF cpu eq c1715 ;wegen evtl. parallelem Tastaturpolling am gleichen SIO-Kanal
                         C       ENDIF
  D882    CD D773        C      	call	portpr		;CTC, WR0, WR4, WR1, WR3
                         C       IF cpu eq c1715 ;wegen evtl. parallelem Tastaturpolling am gleichen SIO-Kanal
                         C       ENDIF
  D885    DD 5E 0A       C      ltpow5:	LD	e,(ix+ltpw5)	;Prozedurtyp/Bitanzahl
                         C      ; Stellen Schreibregister 5
                         C      ; Reg. B,HL bleiben erhalten
  D888    3E 05          C      ltpot5:	ld	a,5
  D88A    DD 4E 03       C      	ld	c,(ix+ltpsc)
                         C       IF cpu eq c1715 ;wegen evtl. parallelem Tastaturpolling am gleichen SIO-Kanal
                         C       ENDIF
  D88D    ED 79          C      	OUT	(C),A
  D88F    ED 59          C      	OUT	(C),e
                         C       IF cpu eq c1715 ;wegen evtl. parallelem Tastaturpolling am gleichen SIO-Kanal
                         C       ENDIF
  D891    C9             C      	RET
                         C      
                         C      ;-------------------------------------
                         C       if iobuc1
                         C      
                         C      ; UC1-Routinen (ausser Senden)
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-57


                         C      
                         C      ; UC1: Empf.-Status
                         C      ;==================
                         C      ; o A=0, ret z	: kein Zeichen empfangen
                         C      ; o A=ff,ret nz	: Zeichen da
  D892    DD 21 D7B7     C      uc1st:	ld	ix,lstuc1	;Stellen IX auf Steuertabelle
  D896                   C      uc1si:	;interner Aufruf mit gestelltem IX
  D896    DD CB 00 66    C      	bit	4,(ix+ltpst)	;initialisiert?
  D89A    20 19          C      	jr	nz,uc1si1	;ja
  D89C    AF             C      	xor	a
  D89D    32 D963        C      	ld	(uc1bfp),a	;Puffer leeren
  D8A0    CD D87B        C      	call	cdsini		;Initialisierung
  D8A3    DD CB 00 E6    C      	set	4,(ix+ltpst)	;Empfaenger ist initialisiert
  D8A7    F3             C      	di
                         C       IF (uc1dat xor uc1sta) eq 01b	;Kanal-Nr ist Bit 1 (bei Buerocomp und OEM)
                         C        IF (uc1sta and 10b) eq 00b	;UC1 ist an Kanal A
  D8A8    CB C9          C      	set	1,c		;Kanal B erzwingen
                         C        ENDIF
                         C       ENDIF
  D8AA    21 D8BD        C      	ld	hl,uc1i2	;WR1,WR2 programmieren
  D8AD    06 04          C       	ld	b,uc1il
  D8AF    ED B3          C      	otir
  D8B1    FB             C      	ei
  D8B2    CD D8EC        C      	call	uc1ird		;DTR bzw. DC1 senden
  D8B5    3A D963        C      uc1si1:	ld	a,(uc1bfp)	;Zeichen im Empfpuffer?
  D8B8    B7             C      	or	a
  D8B9    C8             C      	ret	z		;nein
  D8BA    3E FF          C      	ld	a,0ffh
  D8BC    C9             C      	ret
                         C      
  D8BD                   C      uc1i2: ;zusaetzliche Initialisierung fuer WR1/Bit2 und WR2 (beide nur Kanal B)
                         C       IF (uc1dat xor uc1sta) eq 01b	;Kanal-Nr ist Bit 1 (bei Buerocomp und OEM)
                         C        IF (uc1sta and 10b) eq 00b	;UC1 ist an Kanal A
  D8BD    01 04          C      	db	1,00000100b	;WR1, Kanal B: Intv.modif. setzen
                         C        ENDIF
                         C       ENDIF
  D8BF    02 D0          C      	db	2,ivsio0	;WR2, Kanal B: Interruptvektor
  0004                   C      uc1il	equ	$-uc1i2
                         C      ; UC1: empf. Zeichen an Nutzer
                         C      ;=============================
                         C      ; o A:	aeltestes empf. Zeichen
                         C      
  D8C1    DD 21 D7B7     C      uc1i:	ld	ix,lstuc1	;Stellen IX auf Steuertabelle
                         C      
  D8C5                   C      uc1ii:	;interner Aufruf mit gestelltem IX
  D8C5    FB             C      uc1iw:	ei			;UC1:-Interrupt zulassen
  D8C6    CD D896        C      	call	uc1si		;Zeichen da?
  D8C9    28 FA          C      	jr	z,uc1iw		;nein ***keine Zeitueberwachung!***
  D8CB    21 D963        C      	ld	hl,uc1bfp
  D8CE    F3             C      	di
  D8CF    4E             C      	ld	c,(hl)
  D8D0    35             C      	dec	(hl)		;Pufferlaenge -1
  D8D1    06 00          C      	ld	b,0
  D8D3    23             C      	inc	hl		;^(aeltestes Pufferzeichen)
  D8D4    7E             C      	ld	a,(hl)		;Zeichen nach A
  D8D5    11 D965        C      	ld	de,uc1buf+1
  D8D8    EB             C      	ex	de,hl
  D8D9    ED B0          C      	ldir			;Puffer aufschieben
  D8DB    FB             C      	ei
  D8DC    DD CB 00 7E    C      	bit	7,(ix+ltpst)	;war Stopaufforderung?
  D8E0    C8             C      	ret	z		;nein
  D8E1    F5             C      	push	af		;retten Zeichen
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-58


  D8E2    3A D963        C      	ld	a,(uc1bfp)	;Pufferbelegung
  D8E5    FE 06          C      	cp	1*uc1bfl/3	;unter dem Limit?
  D8E7    DC D8EC        C      	call	c,uc1ird	;ja, Senden wieder erlauben
  D8EA    F1             C      	pop	af
  D8EB    C9             C      	ret
                         C      
                         C      ; Empfangsbereitschaft anzeigen
  D8EC    DD CB 00 BE    C      uc1ird:	res	7,(ix+ltpst)
  D8F0    DD CB 0A 7E    C      	bit	7,(ix+ltpw5)	;Prozedur DC1/DC3?
  D8F4    C2 D885        C      	jp	nz,ltpow5	;nein, DTR wieder setzen
  D8F7    3E 11          C      	ld	a,11h		;DC1 (Senden wieder erlauben)
  D8F9    DD 4E 02       C      	LD	C,(ix+ltpsd)	;SIO Daten
  D8FC    ED 79          C      	OUT	(C),A
  D8FE    C9             C      	ret
                         C      
                         C      ; UC1: Empf.-Interrupt
                         C      ;=====================
  D8FF    ED 73 E4F8     C      uc1rin:	ld	(intsp),sp
  D903    31 F00C        C      	ld	sp,intstk
  D906    F5             C      	push	af
  D907    E5             C      	push	hl
  D908    D5             C      	push	de
  D909    C5             C      	push	bc
  D90A    DD E5          C      	push	ix
  D90C    21 D92C        C      	ld	hl,uc1rir
  D90F    E5             C      	push	hl
  D910    DD 21 D7B7     C      	ld	ix,lstuc1	;Stellen IX auf Steuertabelle
  D914    DD 4E 02       C      	ld	c,(ix+ltpsd)	;SIO Daten
  D917    ED 40          C      	in	b,(c)		;Zeichen lesen
  D919    21 D963        C      	ld	hl,uc1bfp	;Pufferzeiger zum zuletzt empf. Zeichen
  D91C    7E             C      	ld	a,(hl)
  D91D    FE 14          C      	cp	uc1bfl		;Puffer voll?
  D91F    D0             C      	ret	nc		;ja, Zeichen ignorieren
  D920    FE 0D          C      	cp	2*uc1bfl/3	;Puffer fast voll (SIO-Empf.puffer 3 Byte!)?
  D922    D4 D931        C      	call	nc,uc1ri1	;ja, DC3 senden bzw. DTR wegnehmen
  D925    34             C      	inc	(hl)		;+1
  D926    5E             C      	ld	e,(hl)
  D927    16 00          C      	ld	d,0
  D929    19             C      	add	hl,de		;naechste freie Stelle
  D92A    70             C      	ld	(hl),b		;Zeichen in Puffer
  D92B    C9             C      	ret
  D92C    DD E1          C      uc1rir:	pop	ix
  D92E    C3 E4F3        C      	jp	intrbc		;fertig
                         C      
                         C      ; Stopaufforderung senden
                         C      ; B,HL bleibt erhalten
  D931    DD CB 00 FE    C      uc1ri1:	set	7,(ix+ltpst)	;merken Stopaufforderung
  D935    DD 5E 0A       C      	ld	e,(ix+ltpw5)
  D938    CB 7B          C      	bit	7,e		;Prozedur DC1/DC3?
  D93A    28 05          C      	jr	z,uc1ri2	;ja
  D93C    CB BB          C      	res	7,e		;DTR loeschen
  D93E    C3 D888        C      	jp	ltpot5
  D941    3E 13          C      uc1ri2:	ld	a,13h		;DC3 an Partner (Senden stopppen)
  D943    DD 4E 02       C      	LD	C,(ix+ltpsd)	;SIO Daten
  D946    ED 79          C      	OUT	(C),A
  D948    C9             C      	ret
                         C      
                         C      ; UC1: Interrupt Empf.-Fehler (Parit., Ueberlauf, Rahmenfehler)
                         C      ;============================
  D949    ED 73 E4F8     C      uc1err:	ld	(intsp),sp
  D94D    31 F00C        C      	ld	sp,intstk
  D950    F5             C      	push	af
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-59


  D951    E5             C      	push	hl
  D952    D5             C      	push	de
  D953    C5             C      	push	bc
  D954    DD E5          C      	push	ix
  D956    DD 21 D7B7     C      	ld	ix,lstuc1	;Stellen IX auf Steuertabelle
  D95A    DD 4E 03       C      	ld	c,(ix+ltpsc)	;SIO Kommando
  D95D    16 30          C      	ld	d,00110000b	;Reset Fehler-Interrupt
  D95F    ED 51          C      	out	(c),d
                         C      				;keine Fehlermeldung, da bei
                         C      				;Empf.ueberlauf alles noch
                         C      				;mehr verzoegert wird
  D961    18 C9          C      	jr	uc1rir
                         C      
                         C      ; UC1: Empfangspuffer
                         C      ;====================
  D963    00             C      uc1bfp:	db	0
  D964                   C      uc1buf:	ds	uc1bfl,0
                         C      
                         C       endif	;uc1
                         C      
                                  ENDIF
                                  IF cdtsib
                                  ENDIF
                                  IF cdtpio
                                  ENDIF
                                  IF cdtp54
                                  ENDIF
                                  IF cdth54
                                  ENDIF
                                  IF cdtn56 or cdtp56
                                  ENDIF
                                 ENDIF
                                
                         C      	include BIOSDSK
                         C      
                         C      ;****************************************************
                         C      ;	Diskettentreiber; Umkleidung des phys. Transfers
                         C      ;	Version 04.11.88
                         C      ; Aenderungen:
                         C      ; - Jeder Fehler in Spur 0, Sektor 1 fuehrt zur Annahme von Systemspuren
                         C      ;   (A7100-System mit 5" FM und 8272-Hardware mit 128er Sektorlaenge)
                         C      ; - !!Schnittstelle fuer diskio-Aufruf neu!! (Flags neu, side zusaetzlich)
                         C      ; - Verify nach Schreiben kann laufwerksspezifisch gewaehlt werden
                         C      ; - Laufwerkskapazitaet nach phys. LW-Nr in Statuszeile
                         C      ; - Fehlerkorrektur bei KAYPRO IV fuer C128
                         C      ; 12.06.88
                         C      ; - bei stzaus in synflg keine Pflege der Statuszeile
                         C      ; 06.07.88:
                         C      ; - Spurnummer generell auf 16 bit erweitert
                         C      ; 14.10.88
                         C      ; - Generierung ohne Floppy-Laufwerke moeglich
                         C      ; 26.10.88
                         C      ; - Test der Laufwerksbereitschaft bei Select
                         C      ; 04.11.88
                         C      ; - bei 5" und 512 Sektorlaenge Dir-Groesse 0
                         C      ; 12.03.89
                         C      ; - 'ibmfrm' gestrichen, phys. Formaterkennung fuer SIOS erfolgt immer
                         C      ;****************************************************
                         C      
                         C       if1
                         C       endif
                         C      
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-60


                         C      ; Laufwerksauswahl
                         C      ;=================
                         C      ; i C: Laufw. (0=A:, 1=B: ...)
                         C      ; i E: Bit 0 ist LOGIN-Bit von BDOS (=0, wenn LOGIN)
                         C      
  D978    CD E794        C      seldsk:	call	dgetpb		;HL auf DPH stellen, IX auf DPB
  D97B    C8             C      	ret	z		;Geraet ex. nicht
  D97C    79             C      	ld	a,c
  D97D    32 DEFC        C      	ld	(ddrive),a	;Laufwerk merken
  D980    CB 43          C      	bit	0,e		;LOGIN von BDOS?
  D982    C0             C      	ret	nz		;nein
                         C       if ramfl
                         C      ;###RAM-Floppy
  D983    DD CB 0F 7E    C      	bit	dpbfnd,(ix+dpbflg)	;Diskette?
  D987    C0             C      	ret	nz		;nein, fertig
                         C      ;####
                         C       endif
  D988    E5             C      	push	hl		;^DPH merken
                         C      
                         C      	IF	dbufsz gt 7
  D989    21 DEF3        C      	ld	hl,dbdev
  D98C    BE             C      	cp	(hl)		;LOGIN fuer gepuffertes Device?
  D98D    20 07          C      	jr	nz,dselnb	;nein
  D98F    36 FF          C      	ld	(hl),0ffh	;Puffer ist ungueltig
  D991    21 DEF2        C      	ld	hl,dbflg
  D994    CB 96          C      	res	dfbwr,(hl)	;kein veraend. Puffer auszug.!
  D996                   C      dselnb:
                         C      	ENDIF
                         C      
                         C       IF format
  D996    DD CB 0F 76    C      	bit	dpbfrm,(ix+dpbflg);Formaterkennung unterdr.?
  D99A    28 1A          C      	jr	z,drdfrm	;nein
                         C       ENDIF
                         C      
                         C      ; Test der Laufwerks-Bereitschaft; nur dann Select Disk ok
                         C      ;---------------------------------------------------------
  D99C    32 DEE5        C      	ld	(drddev),a	;log. LW
  D99F    DD 6E 0D       C      	ld	l,(ix+dpbofs)
  D9A2    DD 66 0E       C      	ld	h,(ix+dpbofs+1)
  D9A5    22 DEE6        C      	ld	(drdtrk),hl	;auf Beginn des Verzeichnisses
  D9A8    21 DEE4        C      	ld	hl,drdcdb	;Positionieren ohne Fehlerbehandlung
  D9AB    CD DD31        C      	call	dsktra
  D9AE    CA DB63        C      	jp	z,selext	;ok
  D9B1    E1             C      	pop	hl		;^DPH wegschmeissen
  D9B2    21 0000        C      	ld	hl,0		;Select Fehler
  D9B5    C9             C      	ret
  D9B6                   C      drdfrm:
                         C      
                         C      	IF	format
                         C      ;++++++++++Automatische Format-Erkennung++++++++++
                         C      ; Reg. C zeigt auf Laufwerk
                         C      
                         C      	IF	dbufsz gt 7
  D9B6    CD DD11        C       	call	dbtrw		;Puffer freimachen
                         C      				;und auf Lesen schalten
  D9B9    21 DF09        C      	ld	hl,dbnb
  D9BC    36 FF          C      	ld	(hl),0ffh	;Puffernummer ist ungueltig, obwohl evtl.
                         C      				;alle anderen Pufferparameter stimmen
                         C      				;(da nur 128 Bytes vom Puffer belegt sind)
                         C      	ENDIF
                         C      
  D9BE    79             C      	ld	a,c
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-61


  D9BF    32 DEEC        C      	ld	(dfrmdv),a
  D9C2    32 DEF3        C      	ld	(dbdev),a
                         C      
  D9C5    AF             C      	xor	a
  D9C6    DD 77 0F       C      	ld	(ix+dpbflg),a	;ruecksetzen alle Flags
  D9C9    DD 77 13       C      	ld	(ix+dpbsn0),a	;keine Weiter-Numm. auf Ruecks.
  D9CC    DD 77 0D       C      	ld	(ix+dpbofs),a	;keine Systemspuren
                         C      
  D9CF    32 DEED        C      	ld	(dfrmtr),a	;Spur 0
  D9D2    32 DEF4        C      	ld	(dbtrk),a
  D9D5    32 DEF5        C      	ld	(dbtrk+1),a
  D9D8    3C             C      	inc	a
  D9D9    32 DEF6        C      	ld	(dbsec),a	;Sektor 1
  D9DC    32 DEF8        C      	ld	(dbsnb),a	;1 phys. Sektor lesen
                         C      
                         C      ; Stellen  Sektor-Translate-Tabelle 1,2,3,...
  D9DF    DD E5          C      	push	ix
  D9E1    06 1A          C      	ld	b,26		;max. Laenge der Tabelle
                         C       IF dsk8mf
                         C       ENDIF
  D9E3    DD 77 19       C      selstz:	ld	(ix+dpbstr),a
  D9E6    DD 23          C      	inc	ix
  D9E8    3C             C      	inc	a
  D9E9    10 F8          C      	djnz	selstz
  D9EB    DD E1          C      	pop	ix
                         C      
                         C      ; Positionieren auf Spur 0 und analysieren Systemspuren
  D9ED    CD DD29        C      	call	dsidtr		;beliebigen Sekt.Id lesen
  D9F0    20 3E          C      	jr	nz,selsys	;Fehler beim Lesen; Systemsp. annehmen
                         C      ;				 (z.B. SCP1700 mit 5"FM in Spur 0!!)
  D9F2    7C             C      	ld	a,h
  D9F3    32 DEF7        C      	ld	(dbslc),a	;setzen Spurformat fuer Sp. 0
                         C      	IF	dbufsz le 7
                         C      	ENDIF
  D9F6    21 DEF2        C      	ld	hl,dbflg
                         C       IF dsk8mf
                         C       ENDIF
  D9F9    46             C      	ld	b,(hl)		;merken Fehlerprotokoll-Bit
  D9FA    CB E6          C      	set	dfbtr,(hl)	;kein Fehlerprotokoll
  D9FC    E5             C      	push	hl
  D9FD    CD DD17        C      	call	dbtran		;Lesen Spur 0, Sektor 1
  DA00    E1             C      	pop	hl
  DA01    70             C      	ld	(hl),b		;setzen Standard fuer Fehlerprotokoll-Bit
  DA02    20 2C          C      	jr	nz,selsys	;Fehler, Systemspuren annehmen
  DA04    FD E5          C      	push	iy
  DA06    FD 2A DEF9     C      	ld	iy,(dbdma)
  DA0A    FD 7E 00       C      	ld	a,(iy+0)	;Format-Loeschbyte
  DA0D    FE E5          C      	cp	0e5h		;leere Diskette/geloeschter Eintrag?
  DA0F    20 0A          C      	jr	nz,selsy2	;nein, weder/noch
  DA11    FD BE 01       C      	cp	(iy+1)		;auch danach 0e5h?
  DA14    20 15          C      	jr	nz,selsy0	;nein, geloeschter Dir-Eintrag
  DA16    DD 35 0D       C      	dec	(ix+dpbofs)	;Flag: leere Disk oder leere Systemsp.
  DA19    18 10          C      	jr	selsy0		;dpbofs auf 254
  DA1B                   C      selsy2:
  DA1B    FE 40          C      	cp	40h		;IBM-Format (SIOS-Daten-Diskette)?
  DA1D    28 0F          C      	jr	z,selsy1	;ja, 0 Systemspuren annehmen
  DA1F    FE 20          C      	cp	20h		;<=31 ? ("S"YL ist groesser!)
  DA21    30 0B          C      	jr	nc,selsy1	;nein, kann kein Directory sein; 0 Systemsp.
                         C      ;Systemlader fuer PC1715 beginnt mit 02 oder 03
  DA23    FD 7E 20       C      	ld	a,(iy+20h)	;bei SCP1715-Systemdiskette dort 00h
                         C      				;bei MicroDos dort 10h
  DA26    FD B6 21       C      	or	(iy+21h)	;bei SCP1715-Systemdiskette dort 00h
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-62


                         C      				;bei CP/A dort Dir-Eintrag (E5 oder Filename)
  DA29    28 03          C      	jr	z,selsy1	;beides 00h, kein Directory; 0 Systemsp.
  DA2B    DD 35 0D       C      selsy0:	dec	(ix+dpbofs)	;=255, wenn Directory; =254 wenn vorn leer
  DA2E                   C      selsy1:
  DA2E    FD E1          C      	pop	iy
  DA30                   C      selsys:
                         C      
                         C      ; Analysieren Datenspur
                         C      
                         C      ; SS/DS-Analyse
  DA30    DD 36 12 02    C      	ld	(ix+dpbstp),2	;Doppel-Step-Impulse
  DA34    3E 03          C      	ld	a,dlgint	;auf LOGIN-Spur
  DA36    CD DD26        C      	call	dsidtt		;belieb. SektId Vorderseite lesen
  DA39    20 2B          C      	jr	nz,seldle	;Fehler, unsicheres Format
  DA3B    54             C      	ld	d,h		;d:=Sektorlcode, e:=Spur
                         C       IF dsk8mf
                         C       ENDIF
                         C       IF dskds
  DA3C    DD CB 18 46    C      	bit	dpbtds,(ix+dpbtyp)	;ist es ein DS-Laufwerk?
  DA40    28 14          C      	jr	z,selss		;nein, SS
  DA42    D5             C      	push	de		;merken Sektorlaengencode und Spur
  DA43    DD CB 0F EE    C      	set	dpbfds,(ix+dpbflg)
  DA47    3E 07          C      	ld	a,1+(dlgint*2)	;Rueckseite der Spur,
                         C      				;ab der Format bei SS konstant
  DA49    CD DD26        C      	call	dsidtt		;beliebigen Sekt.Id Ruecks. lesen
  DA4C    7A             C      	ld	a,d		;merken side Ruecks.
  DA4D    6B             C      	ld	l,e		;h:=Sektorlcode, l:=Spur Rueckseite
  DA4E    D1             C      	pop	de		;wiederherstellen Vorderseite
  DA4F    20 05          C      	jr	nz,selss	;Fehler beim Lesen, SS
  DA51    B7             C      	or	a
  DA52    ED 52          C      	sbc	hl,de		;Vorder- gleich Rueckseite?
  DA54    28 04          C      	jr	z,sel48		;ja; 40 Tr/ 80 Tr unterscheiden
  DA56    DD CB 0F AE    C      selss:	res	dpbfds,(ix+dpbflg)
                         C       ENDIF
                         C      
                         C      ; 40/80 Track Analyse
  DA5A    7B             C      sel48:	ld	a,e		;trk
  DA5B    D6 03          C      	sub	dlgint		;waren 2 Steps richtig? 
  DA5D    28 12          C      	jr	z,seldl1	;ja
  DA5F    DD 35 12       C      	dec	(ix+dpbstp)	;Einzelstep-Impulse
  DA62    D6 03          C      	sub	dlgint		;waere 1 Step richtig?
  DA64    28 0B          C      	jr	z,seldl1	;ja
                         C      				;nein, unsicher
  DA66    DD 36 10 FF    C      seldle:	ld	(ix+dpbslc),0ffh;provozieren 'BAD SECTOR'
  DA6A    21 0000        C      	ld	hl,0		;erzeugen 'SELECT' Error
  DA6D    E3             C      	ex	(sp),hl
  DA6E    C3 DB63        C      	jp	selext
                         C      
                         C      ; DS/SS und 40/80 ist unterschieden, es fehlt Sektorlaenge
  DA71    7A             C      seldl1:	ld	a,d
  DA72    DD 77 10       C      	ld	(ix+dpbslc),a	;definieren Sektorlaengencode
                         C       IF	dbufsz le 7
                         C       ELSE
                         C      	IF	dbufsz lt 10	;Test, ob Disk-Puffer ausreicht
                         C      	ENDIF
  DA75    B7             C      	or	a		;Sektorlaenge 128?
  DA76    20 0F          C      	jr	nz,seldxl	;nein, normale Sektorfolge
                         C       ENDIF	;dbufsz gt 7
                         C       IF dsk8mf
                         C       ENDIF
  DA78                   C      seldsv:
                         C      ; Stellen Sektor-Translate-Tabelle 1,7,13,..
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-63


  DA78    DD E5          C      	push	ix
  DA7A    E1             C      	pop	hl
  DA7B    01 0019        C      	ld	bc,dpbstr
  DA7E    09             C      	add	hl,bc
  DA7F    EB             C      	ex	de,hl
  DA80    21 DEB5        C      	ld	hl,xlt
  DA83    0E 1A          C      	ld	c,26
  DA85    ED B0          C      	ldir
  DA87                   C      seldxl:
                         C      
  DA87    CD DE48        C      	call	dtrsla		;stellen hl entspr. Sektorlaenge
  DA8A    20 DA          C      	jr	nz,seldle	;unzulaessig
  DA8C    01 0005        C      	ld	bc,dsll		;Laenge eines Eintrags
                         C       IF disk8
                         C       ENDIF
  DA8F    DD CB 12 4E    C      	bit	1,(ix+dpbstp)	;40 Tr. auf 80er LW?
  DA93    20 08          C      	jr	nz,seld40	;ja
  DA95    DD 7E 16       C      	ld	a,(ix+dpbptr)	;40er LW?
  DA98    FE 29          C      	cp	40+1
  DA9A    38 01          C      	jr	c,seld40	;ja, 40 Tr. auf 40er LW
  DA9C    09             C      	add	hl,bc		;auf 80er Format stellen
  DA9D    DD CB 0F 6E    C      seld40:	bit	dpbfds,(ix+dpbflg)	;DS?
  DAA1    28 02          C      	jr	z,seldss	;nein
  DAA3    09             C      	add	hl,bc		;auf DS Format
  DAA4    09             C      	add	hl,bc
  DAA5                   C      seldss:
  DAA5                   C      selset:
                         C      ; DPB modifizieren entsprechend erkanntem Format
  DAA5    4E             C      	ld	c,(hl)		;Zahl der benutzten Spuren
  DAA6    DD 71 14       C      	ld	(ix+dpbtrk),c
  DAA9    23             C      	inc	hl
  DAAA    4E             C      	ld	c,(hl)		;Anzahl 128er Sektoren pro Spur
  DAAB    DD 71 00       C      	ld	(ix+dpbspt),c
  DAAE    23             C      	inc	hl
  DAAF    4E             C      	ld	c,(hl)		;Anzahl der Dir-Eintraege -1
  DAB0    23             C      	inc	hl
  DAB1    7E             C      	ld	a,(hl)		;Anzahl der Systemspuren
  DAB2    CB 3F          C      	srl	a		;feste Anzahl erzwungen?
  DAB4    38 28          C      	jr	c,seldof	;ja
  DAB6    DD CB 0D 7E    C      	bit	7,(ix+dpbofs)	;kann Spur 0 Directory sein?
  DABA    28 22          C      	jr	z,seldof	;nein, Standardanzahl setzen
  DABC    DD 34 0D       C      	inc	(ix+dpbofs)	;evtl. leere Systemspur?
  DABF    28 1C          C      	jr	z,seldo0	;nein, 0 Systemspuren
  DAC1    47             C      	ld	b,a		;retten Anzahl Systemspuren
  DAC2    32 DEF4        C      	ld	(dbtrk),a	;einlesen evtl. moeglicher Datenbeginn
  DAC5    E5             C      	push	hl
  DAC6    CD DD17        C      	call	dbtran		; dauert bei falscher Spur etwas laenger
  DAC9    E1             C      	pop	hl
  DACA    78             C      	ld	a,b
  DACB    20 11          C      	jr	nz,seldof	;Fehler, mit Systemspuren annehmen
  DACD    FD E5          C      	push	iy
  DACF    FD 2A DEF9     C      	ld	iy,(dbdma)
  DAD3    FD 7E 0E       C      	ld	a,(iy+14)	;falls dort Dir, so Byte 14 von Dir =0
  DAD6    FE E5          C      	cp	0e5h		;Daten auch leer?
  DAD8    FD E1          C      	pop	iy
  DADA    78             C      	ld	a,b
  DADB    20 01          C      	jr	nz,seldof	;nein, vorn liegen nichtbelegte Systemspuren
  DADD    AF             C      seldo0:	xor	a		;sonst ohne Systemspuren
  DADE    DD 77 0D       C      seldof:	ld	(ix+dpbofs),a
  DAE1    B7             C      	or	a		;0 Systemspuren?
  DAE2    28 07          C      	jr	z,selddr	;ja
  DAE4    79             C      	ld	a,c		;Anzahl Dir-Eintraege -1
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-64


  DAE5    FE BF          C      	cp	192-1		;>=192 Dir-Eintraege ?
  DAE7    38 02          C      	jr	c,selddr	;nein
  DAE9    0E 7F          C      	ld	c,128-1		;780k hat 128 Dir-Eintraege
  DAEB    DD 71 07       C      selddr:	ld	(ix+dpbdir),c
  DAEE    23             C      	inc	hl
  DAEF    4E             C      	ld	c,(hl)		;Abstand der Blockgroessentab.
  DAF0    06 00          C      	ld	b,0
  DAF2    09             C      	add	hl,bc		;auf Blockgroessentabelle
  DAF3    4E             C      	ld	c,(hl)
  DAF4    DD 71 02       C      	ld	(ix+dpbbls),c
  DAF7    23             C      	inc	hl
  DAF8    4E             C      	ld	c,(hl)
  DAF9    DD 71 03       C      	ld	(ix+dpbblm),c
  DAFC    23             C      	inc	hl
  DAFD    4E             C      	ld	c,(hl)
  DAFE    DD 71 04       C      	ld	(ix+dpbexm),c
                         C      
                         C      ; Bestimmen Zahl der abweichenden 128er-Sektoren ab Spur 0
                         C      
  DB01    AF             C      	xor	a
  DB02    32 DEED        C      	ld	(dfrmtr),a	;ab Spur 0
                         C      		;(gleichz. Spurkorr. bei falschen Doppelstepimpulsen)
  DB05    CD DD29        C      sf128z:	call	dsidtr		;beliebigen SektId lesen
  DB08    20 18          C      	jr	nz,sf128e	;Fehler
  DB0A    7C             C      	ld	a,h		;Sektorlaenge
  DB0B    DD BE 10       C      	cp	(ix+dpbslc)	;gleich Disketten-Rest?
  DB0E    28 12          C      	jr	z,sf128e	;ja
  DB10    DD 7E 0F       C      	ld	a,(ix+dpbflg)
  DB13    E6 03          C      	and	dpbfsm		;bisherige Anzahl abweichender Spuren
  DB15    FE 03          C      	cp	dpbfsm		;Zaehler voll?
  DB17    28 09          C      	jr	z,sf128e	;ja
  DB19    DD 34 0F       C      	inc	(ix+dpbflg)	;erhoehen abweich. Spurzahl
  DB1C    21 DEED        C      	ld	hl,dfrmtr	;naechste (logische!) Spur
  DB1F    34             C      	inc	(hl)
  DB20    18 E3          C      	jr	sf128z
  DB22                   C      sf128e:
                         C      
                         C      ; Setzen Anzahl der logischen 128er Rekords im Puffer -1
                         C      ; Es wird immer das Maximum gesetzt, dies setzt eine dichte
                         C      ; Sektorfolge beim Transfer voraus! (so in dpbstr)
                         C      
                         C      	IF	dbufsz gt 7
  DB22    DD 36 11 07    C      	ld	(ix+dpbbfm),+(1 shl (dbufsz-7))-1
                         C      	ENDIF
                         C      
                         C      ; Berechnen Speicherkapazitaet-1 in BDOS-Bloecken aus
                         C      ; ((Tracks-dpbofs)*dpbspt/(2**dpbbls))-1
  DB26    DD 6E 14       C      	ld	l,(ix+dpbtrk)
  DB29    AF             C      	xor	a
  DB2A    67             C      	ld	h,a		;hl:=log. Spurzahl
  DB2B    DD 5E 0D       C      	ld	e,(ix+dpbofs)
  DB2E    57             C      	ld	d,a		;de:=log. offset-Spurzahl
  DB2F    ED 52          C      	sbc	hl,de
  DB31    EB             C      	ex	de,hl		;de:=log. Daten-Spurzahl
  DB32    6F             C      	ld	l,a		;hl:=0
  DB33    DD 46 00       C      	ld	b,(ix+dpbspt)
  DB36    19             C      dsizmz:	add	hl,de
  DB37    10 FD          C      	djnz	dsizmz		;hl:=(tracks-dpbofs)*dpbspt
  DB39    DD 46 02       C      dsizme:	ld	b,(ix+dpbbls)
  DB3C    CB 3C          C      dsizdz:	srl	h
  DB3E    CB 1D          C      	rr	l
  DB40    10 FA          C      	djnz	dsizdz
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-65


  DB42    2B             C      	dec	hl
  DB43    DD 75 05       C      	ld	(ix+dpbsiz),l
  DB46    DD 74 06       C      	ld	(ix+dpbsiz+1),h
  DB49    DD 7E 07       C      	ld	a,(ix+dpbdir)	;Dir-Groesse
  DB4C    3C             C      	inc	a
  DB4D    E6 FC          C      	and	0fch		;abrunden auf durch 4 teilbare Dir-Groesse
  DB4F    0F             C      	rrca
  DB50    0F             C      	rrca			;div 4, da 4 Dir-Eintr. /Sekt.
  DB51    DD 77 0B       C      	ld	(ix+dpbchk),a	;ist Sektorzahl = Check size
  DB54    DD 46 02       C      	ld	b,(ix+dpbbls)	;block shift
  DB57    0F             C      seldla:	rrca			;BDOS-Bloecke fuer Dir.
  DB58    10 FD          C      	djnz	seldla
  DB5A    47             C      	ld	b,a
  DB5B    AF             C      	xor	a
  DB5C    37             C      seldal:	scf			;Allocation-Bits fuer Dir.
  DB5D    1F             C      	rra
  DB5E    10 FC          C      	djnz	seldal
