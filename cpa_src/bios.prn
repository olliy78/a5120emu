  DB7E    ED 43 DF02     C      setdma:	LD	(ddma),BC
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-66


  DB82    C9             C      	RET
                         C      ;-----------------------
                         C      
                         C      ; Uebersetzung Sektornummer 
                         C      ;==========================
                         C      ; Translate-Tab-Adr. in DE, Eingangs-Sektornummer in BC,
                         C      ;			    Ausgangs-Sektornummer in HL
                         C      ; Es wird keine Translate-Tabelle benutzt, da die Sektor-
                         C      ; nummernverwaltung verallgemeinert im nicht-Standard-DPB 
                         C      ; enthalten ist (auch fuer physische Sektorlaenge <>128)
                         C      
  DB83                   C      sectran:
  DB83    60             C      	LD	H,B
  DB84    69             C      	LD	L,C
  DB85    23             C      	inc	hl		;Sektoren zaehlen in CP/A ab 1
  DB86    C9             C      	RET
                         C      ;-----------------------
                         C      
                         C      ; Schreiben Sektor
                         C      ;=================
                         C      ; Register C (vom BDOS gestellt):
                         C      ;	=0, wenn normales write
                         C      ;	=1, wenn directory-write (sofort ausgeben)
                         C      ;	=2, wenn Beginn eines neuen Datenblocks (kein preread)
                         C      
  DB87                   C      write:
                         C       IF @write
  DB87    59             C      	ld	e,c		;retten Reg. C
  DB88    3A DEFC        C      	ld	a,(ddrive)
  DB8B    4F             C      	ld	c,a
  DB8C    CD E794        C      	call	dgetpb		;ix:=dpb(ddrive)
  DB8F    28 6B          C      	jr	z,drwerr	;Geraet ex. nicht
                         C       if ramfl
                         C      ;###RAM-Floppy
  DB91    DD CB 0F 7E    C      	bit	dpbfnd,(ix+dpbflg)	;Diskette?
  DB95    C2 E3FA        C      	jp	nz,wrramf	;nein
                         C      ;###
                         C       endif
  DB98    21 DEFB        C      	ld	hl,dflg
  DB9B    CB D6          C      	set	dfwr,(hl)	;Write-Flag setzen
                         C      
                         C      	IF	dbufsz gt 7	;gepufferte Disk E/A
  DB9D    21 DEF2        C      	ld	hl,dbflg
  DBA0    CB C6          C      	set	dfbprr,(hl)	;Annahme preread notwendig
  DBA2    7B             C      	ld	a,e		;A:= Write-Typ
  DBA3    32 DF0A        C      	ld	(dwrtyp),a	;merken Write-Typ
  DBA6    FE 02          C      	cp	2		;write to unallocated?
  DBA8    20 17          C      	jr	nz,chkuna	;nein
  DBAA    DD 7E 03       C      	ld	a,(ix+dpbblm)	;Zahl der 128-Sekt. im Block -1
  DBAD    3C             C      	inc	a
  DBAE    32 DF04        C      	ld	(unacnt),a	;fuer diese Sekt. kein preread
  DBB1    21 DF05        C      	ld	hl,unadev
  DBB4    71             C      	ld	(hl),c
  DBB5    2A DEFD        C      	ld	hl,(dtrack)
  DBB8    22 DF06        C      	ld	(unatrk),hl
  DBBB    3A DEFF        C      	ld	a,(dsectr)
  DBBE    32 DF08        C      	ld	(unasec),a
  DBC1    21 DF04        C      chkuna:	ld	hl,unacnt
  DBC4    7E             C      	ld	a,(hl)
  DBC5    B7             C      	or	a		;noch nicht geschr. Sekt. da?
  DBC6    28 56          C      	jr	z,alloc		;nein
  DBC8    3D             C      	dec	a		;sonst Restzahl -1
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-67


  DBC9    77             C      	ld	(hl),a
  DBCA    23             C      	inc	hl
  DBCB    79             C      	ld	a,c
  DBCC    BE             C      	cp	(hl)		;gleiches Geraet?
  DBCD    20 4F          C      	jr	nz,alloc	;nein
  DBCF    23             C      	inc	hl
  DBD0    3A DEFD        C      	ld	a,(dtrack)
  DBD3    BE             C      	cp	(hl)		;gleiche Spur?
  DBD4    20 48          C      	jr	nz,alloc	;nein
  DBD6    23             C      	inc	hl
  DBD7    3A DEFE        C      	ld	a,(dtrack+1)
  DBDA    BE             C      	cp	(hl)
  DBDB    20 41          C      	jr	nz,alloc
  DBDD    23             C      	inc	hl
  DBDE    3A DEFF        C      	ld	a,(dsectr)
  DBE1    BE             C      	cp	(hl)		;gleicher Sektor?
  DBE2    20 3A          C      	jr	nz,alloc	;nein
                         C      ; Vorbereiten naechsten unalloc write-Aufruf
  DBE4    DD BE 00       C      	cp	(ix+dpbspt)	;neue Spur?
  DBE7    38 0A          C      	jr	c,unatr1	;nein
  DBE9    2B             C      	dec	hl
  DBEA    56             C      	ld	d,(hl)
  DBEB    2B             C      	dec	hl
  DBEC    5E             C      	ld	e,(hl)
  DBED    13             C      	inc	de		;unatrk +1
  DBEE    73             C      	ld	(hl),e
  DBEF    23             C      	inc	hl
  DBF0    72             C      	ld	(hl),d
  DBF1    23             C      	inc	hl
