  E543    11 F848        C      	ld	de,bsanf2+bssp2-8
  E544                   C      bsuhr	equ	$-2		;BS-Puffer-Adr. fuer Uhr
                         C        ENDIF
                         C       ENDIF
  E546    06 03          C      	ld	b,3
  E548    18 04          C      	jr	t1uhr4		;Einsprung in Zyklus
  E54A    3E 3A          C      t1uhr3:	ld	a,':'
  E54C    12             C      	ld	(de),a
  E54D    13             C      	inc	de
  E54E    CD E6D3        C      t1uhr4:	call	mbreco
  E551    23             C      	inc	hl
  E552    10 F6          C      	djnz	t1uhr3
                         C        IF crtbfl
  E554                   C      t1uhrn:
                         C        ENDIF
