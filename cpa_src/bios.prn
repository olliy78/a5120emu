                         C      ; - BAB2 als Standard
                         C       IF cpu eq c1715
                         C       ENDIF
                         C      ; - zusaetzliche Laufwerksabschaltung ueber Zeittakt eingefuehrt
                         C      ; - Abfrage von 'synsem' in 1-sec-Interrupt entfernt (kein setbs/setram notw.)
                         C      ; 24.09.88
