  075E    E6 01          C      	and	1
  0760    C8             C      	ret	z		;(a)=0, z=1
  0761    21 D03D        C      	ld	hl,synflg
  0764    CB 46          C      	bit	ctrlst,(hl)	;Ersatz-CNTL?
  0766    3E FF          C      	ld	a,0ffh		;Schnittmaske c0..ff -> c0..ff
  0768    28 02          C      	jr	z,cst37b	;nein
