                         C        ENDIF
                         C      
                         C       ENDIF
                         C      
                         C      ; gemeinsamer Zweig read/write Floppy
                         C      ;------------------------------------
                         C      
  DC22    3A DEFF        C      drw:	ld	a,(dsectr)	;Sektornummer in 1..dpbspt ?
  DC25    3D             C      	dec	a		;ab 0 zaehlen
  DC26    FA DBFC        C      	jp	m,drwerr	;<0, Fehler
  DC29    DD BE 00       C      	cp	(ix+dpbspt)	;<dpbspt?
  DC2C    30 CE          C      	jr	nc,drwerr	;nein, Fehler
                         C       IF dbufsz gt 7
  DC2E    47             C      	ld	b,a		;retten dsectr-1
                         C       ENDIF
  DC2F    DD 7E 0F       C      	ld	a,(ix+dpbflg)
  DC32    E6 03          C      	and	dpbfsm		;Anzahl der abweich. 128er Spuren
  DC34    5F             C      	ld	e,a
  DC35    16 00          C      	ld	d,0
  DC37    2A DEFD        C      	ld	hl,(dtrack)	;verlangte Spur
  DC3A    B7             C      	or	a
  DC3B    ED 52          C      	sbc	hl,de		;im abweichenden Spurformat?
  DC3D    DA DD2E        C      	jp	c,drwsec	;ja, Sektorlaenge 128
                         C      
                         C       IF dbufsz gt 7	;gepufferte Disk E/A
                         C       IF dbufsz lt 12 ;<2**12 =4K Puffer
  DC40    DD 7E 10       C      	ld	a,(ix+dpbslc)	;phys. Sektorlaenge 128?
  DC43    B7             C      	or	a		;d.h. mit Sektorversatz?
  DC44    CA DD2E        C      	jp	z,drwsec	;ja, keine Pufferung sinnvoll
                         C       ENDIF
  DC47    78             C      	ld	a,b
  DC48    DD 56 11       C      	ld	d,(ix+dpbbfm)	;Puffermaske
  DC4B    A2             C      	and	d		;rel. Sekt.nr. des BDOS-Blocks zum Puff.anf.
  DC4C    F5             C      	push	af		;merken fuer move
  DC4D    A8             C      	xor	b		;a ist Sektornr. des Puff.anf.
  DC4E    CB 3F          C      drwbnr:	srl	a		;ermitteln Puffernr in Spur
  DC50    CB 1A          C      	rr	d		;noch Bits in Puffermaske?
  DC52    20 FA          C      	jr	nz,drwbnr	;ja
                         C      ; Test, ob dieser Puffer da ist
  DC54    F5             C      	push	af		;merken Puffernummer
  DC55    21 DF09        C      	ld	hl,dbnb
  DC58    BE             C      	cp	(hl)		;richtige Puffernummer?
  DC59    20 12          C      	jr	nz,dbn		;nein
  DC5B    2A DEFD        C      	ld	hl,(dtrack)	;geforderte Spur
  DC5E    ED 5B DEF4     C      	ld	de,(dbtrk)
  DC62    B7             C      	or	a
  DC63    ED 52          C      	sbc	hl,de		;richtige Spur?
  DC65    20 06          C      	jr	nz,dbn
  DC67    3A DEF3        C      	ld	a,(dbdev)	;zum Puffer gehoeriges Geraet
  DC6A    B9             C      	cp	c		;richtiges Geraet?
  DC6B    28 6C          C      	jr	z,dbmat		;ja, Sektor steht im Puffer
                         C      
  DC6D    C5             C      dbn:	push	bc		;retten ddrive
  DC6E    CD DD11        C      	call	dbtrw		;veraenderten Puffer ausgeben
