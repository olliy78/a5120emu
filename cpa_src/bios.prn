  D206    10 ED          C      	djnz	kbdwa		;abwarten, wie lange
                         C      
  D208    CD D253        C      	call	kbdrch		;Zeichen umkodieren
  D20B    B7             C      	or	a		;Sondertaste?
  D20C    FA D1E7        C      	jp	m,kbdwin	;ja, keine Dauerfunktion
  D20F    CD D1C2        C      	call	kbdput		;sonst puffern
  D212    18 0A          C      	jr	kbdinn		;und aeltestes Pufferzeichen uebergeben
  D214    CD D14F        C      kbdwb:	call	kbdst		;abwarten tastendruck
  D217    28 FB          C      	jr	z,kbdwb
