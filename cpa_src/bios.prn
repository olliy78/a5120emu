  E67E    FE FB          C      	cp	zblmin		;"- im Ziffernblock": Hardcopy BS -> LIST?
  E680    CA D61A        C      	jp	z,crthrd	;ja, ausfuehren
  E683    FE CD          C      	cp	spcins		;"INS": I/O-Byte im LST:Kanal weiterschalten?
  E685    20 08          C      	jr	nz,stopz2	;nein
  E687    21 0003        C      	ld	hl,iobyte
  E68A    7E             C      	ld	a,(hl)
  E68B    C6 40          C      	add	a,40h		;Ueberlauf wird ignoriert
  E68D    77             C      	ld	(hl),a
  E68E    C9             C      	ret
  E68F                   C      stopz2:
                         C      
                         C       IF l2bahn
                         C       ENDIF
                         C       ENDIF
                         C      
                         C       IF cpastz or uhrvar
  E68F    FE EE          C      	cp	pfec		;"F14": Status-Anzeige ein/aus?
  E691    20 08          C      	jr	nz,stopz3	;nein
  E693    21 D03D        C      	ld	hl,synflg
  E696    7E             C      	ld	a,(hl)
  E697    EE 40          C      	xor	1 shl stzaus	;Status-Anzeige ein/aus
  E699    77             C      	ld	(hl),a
  E69A    C9             C      	ret			;fertig
  E69B                   C      stopz3:
                         C       ENDIF
                         C      
