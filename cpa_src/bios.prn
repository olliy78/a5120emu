  D1D6    C3 D5F3        C      	jp	crtclk		;Puffer voll anzeigen
                         C      
                         C      ; Ablegen String im Puffer
                         C      ;-------------------------
                         C      ; i E	Stringlaenge -1
                         C      ; i HL	Stringanfang
  D1D9    1C             C      kbdco1:	inc	e
  D1DA    E5             C      kbdco2:	push	hl
  D1DB    D5             C      	push	de
  D1DC    7E             C      	ld	a,(hl)
  D1DD    CD D1C2        C      	call	kbdput		;Zeichen in Puffer
  D1E0    D1             C      	pop	de
  D1E1    E1             C      	pop	hl
  D1E2    23             C      	inc	hl
  D1E3    1D             C      	dec	e
  D1E4    20 F4          C      	jr	nz,kbdco2	;wenn String noch nicht fertig
  D1E6    C9             C      	ret
                         C      
