                         C      ;***************************************************
                         C      ;	Allgemeine BIOS-Hilfsprogramme
                         C      ;***************************************************
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-108


                         C      
                         C      ; Aufruf der Routine (HL)
  E6B8    E9             C      callhl: jp	(hl)
                         C      
                         C      ; Ausgabe Text ab (HL) bis 00h auf CON: und evtl. LST:
  E6B9    7E             C      putmes: LD	A,(HL)
  E6BA    B7             C      	OR	A
  E6BB    C8             C      	RET	Z
  E6BC    E5             C      	PUSH	HL
  E6BD    4F             C      	LD	C,A
  E6BE    CD D00C        C      	CALL	conol
  E6C1    E1             C      	POP	HL
  E6C2    23             C      	INC	HL
  E6C3    18 F4          C      	JR	putmes
                         C      
                         C      ; Ausgabe Text ab (HL) mit exakter Laenge "stzbl" in Statuszeile
                         C       IF cpastz
                         C       ELSE
  E6B9                   C      biosms	equ	putmes	;0dh,0ah,...,07h,00h im Text ergaenzen!!
                         C       ENDIF
                         C      
                         C      ;	Wait 0.01 sec * (B)
                         C      ; Reg HL bleibt erhalten
  E6C5    C5             C      wait10: push	bc
  E6C6    0E 0A          C      	ld	c,10		;10* 1ms warten
  E6C8    06 BD          C      wait2z: ld	b,189		;(189*13)/(256*9600)=0.001
  E6CA    10 FE          C      wait1z: djnz	wait1z		;1ms warten
  E6CC    0D             C      	dec	c
  E6CD    20 F9          C      	jr	nz,wait2z
  E6CF    C1             C      	pop	bc
  E6D0    10 F3          C      	djnz	wait10
  E6D2    C9             C      	ret
                         C      
                         C      ;************************************************************
                         C      ;	zentral verwendete Rueckkonvertierungsroutinen
                         C      ;************************************************************
                         C      
                         C       IF monitor or errvar or iobvar or uhrvar or mprot
                         C      
                         C      ; Rueckkonvertieren Byte ab (HL) nach (DE)
                         C      ; RET: 2 Zeichen ab (DE), DE zeigt auf naechstes freies Byte
  E6D3    7E             C      mbreco: ld	a,(hl)
                         C      
                         C      ; Rueckkonvertieren Byte in A nach (DE)
                         C      ; RET: 2 Zeichen ab (DE), DE zeigt auf naechstes freies Byte
  E6D4    CD E6D7        C      mrecoa: call	mreca
                         C      
                         C      ; Rueckkonvertieren A in HEX-Ziffern nach (DE)
                         C      ; RET: A um 4 bits nach rechts rotiert
                         C      ;      DE zeigt auf naechstes Byte
  E6D7                   C      mrecol:
  E6D7    0F             C      mreca:	rrca			;linkes Halbbyte
  E6D8    0F             C      	rrca
  E6D9    0F             C      	rrca
  E6DA    0F             C      	rrca
  E6DB                   C      mrecor:				;rechtes Halbbyte
  E6DB    F5             C      	push	af		;fuer 2. mreca-Aufruf retten
  E6DC    E6 0F          C      	and	0fh
  E6DE    D6 0A          C      	sub	9+1
  E6E0    38 02          C      	jr	c,mrecod	;0..9
  E6E2    C6 07          C      	add	a,7		;A..F
  E6E4    C6 3A          C      mrecod: add	a,'0'+10
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-109


  E6E6    12             C      	ld	(de),a
  E6E7    13             C      	inc	de
  E6E8    F1             C      	pop	af
  E6E9    C9             C      	ret
                         C      
                         C       ENDIF
                         C      
                         C       IF monitor or cpastz
                         C       ENDIF
                         C      
                         C      
                         C      ;*************************************************************
                         C      ;	wiederholter Kaltstart
                         C      ;*************************************************************
  E6EA                   C      kalts1:
                         C       IF cpu eq k2521
                         C       ENDIF
                         C       IF (cpu eq k2526) or (cpu eq c1715)
  E6EA    CD E4C0        C      	call	tim5of		;totlegen aller Interruptquellen
                         C        IF cpu eq k2526
  E6ED    CD E4CB        C      	call	tim1of
                         C        ENDIF
                         C        IF cpu eq c1715
                         C        ENDIF
  E6F0    F3             C      	di
                         C        IF cpu eq k2526
  E6F1    3E F7          C      	ld	a,0f7h
  E6F3    D3 0A          C      	out	(0ah),a		;Lade-ROM zuschalten
                         C        ENDIF
                         C        IF cpu eq c1715
                         C        ENDIF
  E6F5    C7             C      	rst	0		;RESET
                         C       ENDIF
                         C      
                         C      ;*************************************************************
                         C      ;	Warmstart
                         C      ;*************************************************************
                         C       if1
                         C       endif
                         C      
                         C       IF	wbootv eq 1	;Warmstart=Kaltstart
                         C       ELSE
  E6F6    31 0080        C      WARMST: LD	SP,tpa-80h
                         C      
                         C         if	wbootv eq 0		;;CCP-Kopie im BIOS
  E6F9    21 E7B7        C      	ld	hl,ccpkop	;;CCP von Kopie wiederherst.
  E6FC    11 BA00        C      	ld	de,CCP
  E6FF    01 0811        C      	ld	bc,ccpkpl+bdskpl
  E702    ED B0          C      	ldir
                         C         endif
                         C      
                         C         if	(wbootv eq 2) or (wbootv eq 3) or (wbootv eq 4)
                         C         endif ;(wbootv eq 2) or (wbootv eq 3) or (wbootv eq 4)
                         C      
                         C         if (wbootv eq 0) or (wbootv eq 2) or (wbootv eq 3)
  E704    21 BA03        C      	LD	HL,CCP+3	;EINGANG MIT KOMMANDOLOESCHEN
                         C         endif
                         C         if wbootv eq 4
                         C         endif
                         C      	warmin
  E707    F3             C+     wbinit: DI
  E708    E5             C+     	PUSH	HL
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-110


  E709    3E F7          C+     	LD	A,high(intvr)
  E70B    ED 47          C+     	LD	I,A
  E70D    ED 5E          C+     	im	2
  E70F    3E C3          C+     	LD	A,0C3H
  E711    32 0000        C+     	LD	(REBOOT),A
  E714    21 0003'       C+     	LD	HL,BIOS+3
  E717    22 0001        C+     	LD	(REBOOT+1),HL
  E71A    32 0005        C+     	LD	(BDOSJP),A
  E71D    21 C206        C+     	LD	HL,BDOS+6
  E720    22 0006        C+     	LD	(BDOSJP+1),HL
  E723    32 0038        C+     	ld	(38h),a		;Breakpoint
  E726    21 0000        C+     	ld	hl,0		;ohne Monitor wie Warmstart
  E729    22 0039        C+     	ld	(38h+1),hl
  E72C    21 D03D        C+     	ld	hl,synflg
  E72F    36 00          C+     	ld	(hl),0
  E731    23             C+     	inc	hl
  E732    36 00          C+     	ld	(hl),0		;synsem:=0
  E734    21 E4BF        C+     	ld	hl,ret
  E737    22 004A        C+     	ld	(kritbg),hl	;leere Routine fuer Beginn kritischer BIOS-Teil
  E73A    22 004C        C+     	ld	(kriten),hl
  E73D    21 E4BF        C+     	ld	hl,ret
  E740    22 0045        C+     	ld	(tim1rt),hl
  E743    CD E4B9        C+     	call	tim5on
  E746    CD E4C4        C+     	call	tim1on
  E749    AF             C+     	xor	a
  E74A    32 D492        C+     	ld	(desc),a	;evtl. ESCAPE-Modus beenden
  E74D    0E 82          C+     	ld	c,82h		;Kursor sichtbar machen
  E74F    CD D454        C+     	call	crto
  E752    3A 0040        C+     	ld	a,(lampbf)
  E755    E6 B3          C+      and (1 shl lmphcp)+(1 shl lmpb2r)+(1 shl lmpb2b)+(1 shl kbdcpb)+(1 shl kbdcal)
  E757    32 0040        C+     	ld	(lampbf),a	;ruecksetzen Lampen
  E75A    21 D381        C+     	ld	hl,kbdsts	;Standard-Stringtabelle wiederherstellen
  E75D    22 D03B        C+     	ld	(kbdsst),hl
  E760    3E FF          C+     	ld	a,0ffh
  E762    32 DEF3        C+     	ld	(dbdev),a
  E765    FB             C+     	EI
  E766    21 0004        C+     setcld: ld	hl,defaul
  E769    4E             C+     	ld	c,(hl)
  E76A    C5             C+     	push	bc
  E76B    79             C+     	ld	a,c
  E76C    E6 0F          C+     	and	0fh
  E76E    4F             C+     	ld	c,a
  E76F    AE             C+     	xor	(hl)
  E770    F6 00          C+     	or	0
  E772    77             C+     	ld	(hl),a
  E773    CD E794        C+     	call	dgetpb
  E776    C1             C+     	pop	bc
  E777    28 ED          C+     	jr	z,setcld
  E779    C9             C+     	ret
                         C       ENDIF	;wbootv ne 1
