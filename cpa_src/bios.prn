  D5B9                   C      crtm45	equ	$-2
  D5BB    21 FF2F        C      	ld	hl,bsend2-bssp2	;Quelle
  D5BC                   C      crtm46	equ	$-2
                         C      	setbs
  D5BE    ED B8          C      	lddr			;eine Zeile nach unten schieben
                         C      	setram
  D5C0    D1             C      crtil1:	pop	de
  D5C1    62             C      	ld	h,d
  D5C2    6B             C      	ld	l,e
  D5C3    18 D5          C      	jr	crtzlr		;freigewordene Zeile loeschen
                         C      ;-----------------------------
  D5C5    CD D549        C      crtdll:	call	crtcr		;Delete Line
  D5C8    E5             C      	push	hl
  D5C9    11 FF30        C      	ld	de,bsend2-bssp2+1	;Anfang letzte Zeile
  D5CA                   C      crtm47	equ	$-2
  D5CC    EB             C      	ex	de,hl
  D5CD    B7             C      	or	a
  D5CE    ED 52          C      	sbc	hl,de		;Laenge
  D5D0    28 08          C      	jr	z,crtdl1	;letzte Zeile
  D5D2    E3             C      	ex	(sp),hl
  D5D3    54             C      	ld	d,h
  D5D4    5D             C      	ld	e,l		;de auf Ziel (Zeilenanfang)
  D5D5    09             C      	add	hl,bc		;hl auf Quelle
  D5D6    C1             C      	pop	bc
  D5D7    D5             C      	push	de
                         C      	setbs
  D5D8    ED B0          C      	ldir			;eine Zeile nach oben schieben
                         C      	setram
  D5DA    21 FF30        C      crtdl1:	ld	hl,bsend2-bssp2+1
  D5DB                   C      crtm48	equ	$-2
  D5DD    54             C      	ld	d,h
  D5DE    5D             C      	ld	e,l
  D5DF    CD D59A        C      	call	crtzlr		;letzte Zeile loeschen
  D5E2    E1             C      	pop	hl
  D5E3    C9             C      	ret
                         C      ;-----------------------------
                         C       ENDIF	;inslin
  D5E4    3E 02          C      crtesc:	ld	a,2		;escape flag setzen
  D5E6    32 D492        C      	ld	(desc),a
                         C      
                         C      	if	costu or adm3a
                         C      	endif
                         C      
  D5E9    C9             C      	ret
                         C      ;-----------------------------
  D5EA    3E 80          C      crtcrt:	ld	a,80h		;cursor an
  D5EC    18 01          C      	jr	crto14
                         C      ;-----------------------------
  D5EE    AF             C      crtcof:	xor	a		;cursor aus
  D5EF    32 D466        C      crto14:	ld	(dcurs),a
  D5F2    C9             C      	ret
                         C      ;-----------------------------
                         C      ; Realisierung 07h
                         C      ; Achtung! Diese Routine wird aus Interruptroutine aufgerufen!
  D5F3    CD D5F6        C      crtclk:	call	crtcl1		;Fehlerlampe umschalten
                         C      
  D5F6    06 19          C      crtcl1:	ld	b,25		;0.25 sec warten
  D5F8    CD E6C5        C      	call	wait10
                         C      				;Fehlerlampe wieder zurueck
                         C      ; Fehlerlampe umschalten
                         C      ; Reg. A, HL bleiben erhalten
  D5FB    F5             C      swilmp:	push	af
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-42


  D5FC    E5             C      	push	hl
  D5FD    21 0040        C      	ld	hl,lampbf
  D600    7E             C      	ld	a,(hl)
  D601    EE 40          C      	xor	1 shl lmperr
  D603    77             C      	ld	(hl),a
  D604    CD D2B0        C      	call	lampen
  D607    E1             C      	pop	hl
  D608    F1             C      	pop	af
  D609    C9             C      	ret
                         C      ;-----------------------------
                         C       IF umlaut
                         C      ; Umschalten auf 2. Zeichensatz
  D60A    E5             C      crt2zs:	push	hl
  D60B    21 D03D        C      	ld	hl,synflg
  D60E    CB D6          C      	set	umlflg,(hl)
  D610    E1             C      	pop	hl
  D611    C9             C      	ret
                         C      ; Umschalten auf 1. Zeichensatz
  D612    E5             C      crt1zs:	push	hl
  D613    21 D03D        C      	ld	hl,synflg
  D616    CB 96          C      	res	umlflg,(hl)
  D618    E1             C      	pop	hl
  D619    C9             C      	ret
                         C       ENDIF
                         C      ;-----------------------------
                         C      
                         C       IF stpvar
                         C       IF chdvar
                         C      ;Hardcopy Bildschirm -> LST
  D61A    E5             C      crthrd:	push	hl
  D61B    21 FC00        C      	ld	hl,bsanf1
  D61C                   C      crtm22	equ	$-2
  D61E    0E 11          C      	ld	c,bszl1+1
  D61F                   C      crtm23	equ	$-1
  D620    18 30          C      	jr	crthd3		;zu Beginn neue Zeile
  D622    06 40          C      crthd1:	ld	b,bssp1
  D623                   C      crtm24	equ	$-1
  D624    C5             C      crthd2:	push	bc
                         C      	setbs
  D625    7E             C      	ld	a,(hl)
                         C      	setram
  D626    23             C      	inc	hl
  D627    E5             C      	push	hl
  D628    E6 7F          C      	and	7fh
  D62A    FE 20          C      	cp	20h		;BS-Steuerzeichen?
  D62C    30 1C          C      	jr	nc,crthd4	;nein
                         C       IF umlaut
  D62E    21 D03D        C      	ld	hl,synflg	;Schalterbyte 
  D631    CB 56          C      	bit	umlflg,(hl)	;Umlaute anzeigen ?
  D633    28 13          C      	jr	z,cnuml1	;nein!
  D635    21 D68B        C      	ld	hl,umltb2	;Umlautcodierung ?
  D638    01 000B        C      	ld	bc,umllen
  D63B    ED B1          C      	cpir
  D63D    20 09          C      	jr	nz,cnuml1	;nein !
  D63F    01 000C        C      	ld	bc,umllen+1	;sonst rueckkodieren
  D642    B7             C      	or	a
  D643    ED 42          C      	sbc	hl,bc
  D645    7E             C      	ld	a,(hl)		;rueckkodiertes Zeichen
  D646    18 02          C      	jr	crthd4
  D648                   C      cnuml1:
                         C       ENDIF
  D648    3E 5E          C      	ld	a,'^'		;sonst Sonderzeichen
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-43


  D64A    4F             C      crthd4:	ld	c,a
  D64B    CD D00F        C      	call	BIOS0F		;LIST
  D64E    E1             C      	pop	hl
  D64F    C1             C      	pop	bc
  D650    10 D2          C      	djnz	crthd2		;bis Zeilenende
  D652    C5             C      crthd3:	push	bc
  D653    E5             C      	push	hl
  D654    0E 0D          C      	ld	c,0dh
  D656    CD D00F        C      	call	BIOS0F
  D659    0E 0A          C      	ld	c,0ah
  D65B    CD D00F        C      	call	BIOS0F
  D65E    E1             C      	pop	hl
  D65F    C1             C      	pop	bc
  D660    0D             C      	dec	c		;Bildschirmende?
  D661    20 BF          C      	jr	nz,crthd1	;nein
  D663    E1             C      	pop	hl
  D664    C9             C      	ret
                         C       ENDIF
                         C       ENDIF	;stpvar
                         C      
                         C       IF umlaut
                         C      ; Umlaute umcodieren fuer Anzeige auf BAB1/BAB2 (Sonder-PROM)
  D665                   C      crtuml:	
  D665    E5             C      	push 	hl		;retten wegen evtl. ext. Verwendung
  D666    C5             C      	push 	bc
  D667    21 D03D        C      	ld	hl,synflg	;Schalterbyte
  D66A    CB 56          C      	bit	umlflg,(hl)	;Umlaute anzeigen ?
  D66C    28 0F          C      	jr	z,umlcn1	;nein !
  D66E    21 D680        C      	ld 	hl,umltb1
  D671    01 000B        C      	ld 	bc,umllen
  D674    ED B1          C      	cpir			;in Tabelle suchen
  D676    20 05          C      	jr	nz,umlcn1	;nicht gefunden
  D678    01 000A        C      	ld	bc,umllen-1	;wegen cpir
  D67B    09             C      	add 	hl,bc
  D67C    7E             C      	ld	a,(hl)		;umcodieren
  D67D    C1             C      umlcn1:	pop	bc
  D67E    E1             C      	pop	hl
  D67F    C9             C      	ret
                         C      
                         C      ;------------------------------
                         C      ; Umcodiertabelle fuer Umlautumcodierung
                         C       IF zsuml ;auf freie 7023/24-Steuerzeichen (IH Mittweida, Koll. Geiler)
                         C      ;		Ae  Oe  Ue  ae  oe  ue  sz  **2 **3 Par my
  D680    5B 5C 5D 7B    C      umltb1:db	5bh,5ch,5dh,7bh,7ch,7dh,7eh,3ch,3eh,40h,5eh
  D684    7C 7D 7E 3C    C      
  D688    3E 40 5E       C      
  D68B    15 16 17 1C    C      umltb2:db	15h,16h,17h,1ch,1dh,1eh,1fh,10h,12h,14h,18h
  D68F    1D 1E 1F 10    C      
  D693    12 14 18       C      
  000B                   C      umllen	equ	umltb2-umltb1
                         C       ENDIF
                         C       IF zsibm ;auf 00..1f erweiterter IBM-Zeichensatz
                         C       ENDIF	
                         C       ENDIF	
                         C      
                         C      ; Arbeitszellen
                         C      ;==============
                         C      
  D696    00             C      crtcch:	db	0		;direkt auszugebendes BS-Zeichen
                         C       if crt eq dsy5
                         C       endif
                         C      
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-44


                         C      ; Tabelle der Sonderzeichen, SCP kompatibel!
                         C      ;==========================================
                         C      
  D697                   C      dszta:	
  D697    00             C      	db	00h	;nop
  D698    01             C      	db	01h	;home
  D699    02             C      	db	02h	;(auch 82h) cursor an
  D69A    03             C      	db	03h	;(auch 83h) cursor aus
  D69B    04             C      	db	04h	;(auch 84h) normal, nicht inv.
  D69C    05             C      	db	05h	;(auch 85h) normal,       inv.
  D69D    06             C      	db	06h	;(auch 86h) hell  , nicht inv.
                         C      ;			 (nur  87h) hell  ,       inv.
  D69E    07             C      	db	07h	;bell (akustisches zeichen)
  D69F    08             C      	db	08h	;cursor zurueck
  D6A0    0A             C      	db	0ah	;LF
  D6A1    0C             C      	db	0ch	;bs loeschen, cursor links oben
  D6A2    0D             C      	db	0dh	;CR
                         C       if umlaut
  D6A3    0E             C      	db	0eh	;umschalten auf 2. Zeichensatz
  D6A4    0F             C      	db	0fh	;umschalten auf 1. Zeichensatz
                         C       endif
  D6A5    14             C      	db	14h	;rest bs loeschen
  D6A6    15             C      	db	15h	;cursor vorwaerts
  D6A7    16             C      	db	16h	;rest der zeile loeschen
                         C       IF inslin
  D6A8    17             C      	db	17h	;Insert Line
                         C       ENDIF
  D6A9    18             C      	db	18h	;zeile loeschen, cursor an zeilanf.
                         C       IF inslin
  D6AA    19             C      	db	19h	;Delete Line
                         C       ENDIF
  D6AB    1A             C      	db	1ah	;eine zeile hoch
                         C      			;bei ADM3a wie 0ch
  D6AC    1B             C      	db	1bh	;escape
                         C      ;		1b zeile+80h spalte+80h		Kursor posit. SCP
                         C      ;		1b zeile+00h spalte+00h		geht auch bei CP/A
                         C      ;		1b '='/'Y' zeile+20h spalte+20h	Kursor posit. bei ADM3A
                         C      ;		1b 5e xx	Feldattribut setzen (SCP1715 fuer 8275-Contr.)
                         C      ;			mit xx= 01urggbh
                         C      ;				  u		unterstreichen,
                         C      ;				   r		invers,
                         C      ;				    gg		Zeichengenerator-Umschaltung,
                         C      ;				      b		blinken,
                         C      ;				       h	heller 
                         C      ;		1b 5f xx	Spezialzeichen setzen (SCP1715 fuer 8275)
                         C      ;			mit xx= 01ssssbh
                         C      ;				  ssss		Zeichencode (1100 Sonderfkt)
                         C      ;				      b		blinken des Sonderzeichens
                         C      ;				       h	heller des Sonderzeichens
                         C      	if	adm3a
                         C      	endif
                         C       if crt eq dsy5
                         C       endif
  D6AD    7F             C      	db	7fh	;delete
  D6AE    87             C      	db	87h	;(nicht 07h) hell  ,      inv.
  0018                   C       dsztal	equ	$-dszta	;Tabellenlaenge
                         C      
                         C      ; Reaktionsroutinen fuer Sonderzeichen
                         C      
  D6AF    D4F7           C      	dw	crtnop	;00
  D6B1    D586           C      	dw	crthom	;01
  D6B3    D5EA           C      	dw	crtcrt	;02/82
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-45


  D6B5    D5EE           C      	dw	crtcof	;03/83
  D6B7    D4D0           C      	dw	crto84	;04/84
  D6B9    D4D0           C      	dw	crto85	;05/85
  D6BB    D4D0           C      	dw	crto86	;06/86
  D6BD    D5F3           C      	dw	crtclk	;07
  D6BF    D568           C      	dw	crtcl	;08
  D6C1    D55A           C      	dw	crtlf	;0A
  D6C3    D571           C      	dw	crtbsl	;0C
  D6C5    D549           C      	dw	crtcr	;0D
                         C       if umlaut
  D6C7    D60A           C      	dw	crt2zs	;0E
  D6C9    D612           C      	dw	crt1zs	;0F
                         C       endif
  D6CB    D574           C      	dw	crtbsr	;14
  D6CD    D4AD           C      	dw	crtcur	;15
