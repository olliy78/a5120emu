                         C      ;$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$
                         C      ;	Steuertabellen fuer Massenspeicher
                         C      ;$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$
                         C       if1
                         C       endif
                         C      
                         C      ; Tabelle der Adressen der DPH's
                         C      ;===============================
                         C      
                         C      ;===============================================
  000D                   C      @din	aset	dphnb
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-111


  E77A                   C      dphatb: IRP	di,<A,B,C,D,E,F,G,H,I,J,K,L,M,N,O,P>
                         C      	if	@din eq 0
                         C      	EXITM
                         C      	endif
                         C      @din	aset	@din-1
                         C       IF dpha&di ; Laufwerk A auf erstes definiertes Geraet legen
                         C      dphaA	aset	dpha&di
                         C       ENDIF
                         C      	dw	dpha&di
                         C      	ENDM
  E77A    D03F           C+     	dw	dpha&A
  E77C    D04F           C+     	dw	dpha&B
  E77E    D05F           C+     	dw	dpha&C
  E780    0000           C+     	dw	dpha&D
  E782    0000           C+     	dw	dpha&E
  E784    0000           C+     	dw	dpha&F
  E786    0000           C+     	dw	dpha&G
  E788    0000           C+     	dw	dpha&H
  E78A    0000           C+     	dw	dpha&I
  E78C    0000           C+     	dw	dpha&J
  E78E    0000           C+     	dw	dpha&K
  E790    0000           C+     	dw	dpha&L
  E792    E499           C+     	dw	dpha&M
                         C      
                         C      ; Ermitteln DPH und DPB von (c) nach HL bzw. IX
                         C      ; ret z		DPH existiert nicht, HL=0
                         C      ; ret nz	ok, HL auf DPH, IX auf DPB
                         C      ; BC, DE bleiben erhalten
                         C      ;=====================================================
  E794    D5             C      dgetpb: push	de
  E795    21 0000        C      	ld	hl,0
  E798    79             C      	ld	a,c
  E799    FE 0D          C      	cp	dphnb		;DPH definiert?
  E79B    30 16          C      	jr	nc,dgetp0	;nein
  E79D    EB             C      	ex	de,hl
  E79E    21 E77A        C      	ld	hl,dphatb	;Adresstabelle fuer DPH's
  E7A1    59             C      	ld	e,c
  E7A2    19             C      	add	hl,de
  E7A3    19             C      	add	hl,de
  E7A4    7E             C      	ld	a,(hl)
  E7A5    23             C      	inc	hl
  E7A6    66             C      	ld	h,(hl)
  E7A7    6F             C      	ld	l,a		;hl:=^DPH
  E7A8    E5             C      	push	hl
  E7A9    1E 0A          C      	ld	e,10
  E7AB    19             C      	add	hl,de
  E7AC    5E             C      	ld	e,(hl)
  E7AD    23             C      	inc	hl
  E7AE    56             C      	ld	d,(hl)		;de:=^dpb
  E7AF    D5             C      	push	de
  E7B0    DD E1          C      	pop	ix		;ix:=^dpb
  E7B2    E1             C      	pop	hl
  E7B3    D1             C      dgetp0: pop	de
  E7B4    7C             C      	ld	a,h
  E7B5    B5             C      	or	l		;ret z bei hl=0
  E7B6    C9             C      	ret
                         C      
                         C      
                         C      ;**************************************************
                         C      ;	Arbeits-Felder (ab hier keine Konstanten!!)
                         C      ;	Arbeits-Felder werden benutzt fuer Kaltstart-Routinen
                         C      ;**************************************************
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-112


  E7B7                   C      biosds	equ	$
  E7B7                   C      @dsad	aset	biosds
                         C      
                         C      ; ===========allgemeine BIOS-Funktionen=============
                         C      
  0800                   C      ccpkpl	equ	ccpln		;Laenge CCP+ BDOS-Anfang
  0011                   C      bdskpl	equ	11h		;BDOS-Anfang
                         C      
                         C      	if	wbootv eq 0	;CCP-Kopie im BIOS
  E7B7                   C      ccpkop	equ	@dsad
  EFC8                   C      ccpkpe	equ	ccpkop+ccpkpl+bdskpl
  EFC8                   C      @dsad	aset	ccpkpe	;Ende CCP-Kopie
                         C      	endif
                         C      
                         C      	if	(wbootv eq 2) or (wbootv eq 3)
                         C      	endif
                         C      
                         C       IF stpvar
  EFF4                   C      @dsad	aset	@dsad+2*22	;Stack fuer asynchrone Routinen
  EFF4                   C      stpstk	equ	@dsad
                         C       ENDIF
  F00C                   C      @dsad	aset	@dsad+2*12	;Stack fuer Interrupt-Routinen
  F00C                   C      intstk	equ	@dsad
                         C      
                         C      ;=============Disketten-Arbeit============
                         C      
  F00C                   C      dirbuf	equ	@dsad	;Directory-Puffer fuer alle Laufwerke
  F08C                   C      @dsad	aset	@dsad+128
                         C      	IRP	di,<A,B,C,D>
                         C       IF disk&di
                         C      alv&di	equ	@dsad		;;Allocation-Vector Disk.
                         C      	IF	((disk&di mod 1000)/100) eq 5	;;5" 
                         C      	if	((disk&di mod 10000)/1000)	;;DS
                         C      @dsad	aset	@dsad+(400+7)/8 ;;reicht fuer 400k (1K Bloecke)
                         C      				;;	bzw. 800K (2K Bloecke)
                         C      	else					;;SS
                         C      @dsad	aset	@dsad+(200+7)/8 ;;reicht fuer 200k (1K Bloecke)
                         C      				;;	bzw. 400K (2K Bloecke)
                         C      	endif
                         C      	ELSE					;;8" 
                         C      	if	(disk&di ge 10000)		;;MFM
                         C      @dsad	aset	@dsad+(352+7)/8 ;;reicht fuer 704 2K Bloecke
                         C      	else					;;FM
                         C      @dsad	aset	@dsad+(250+7)/8 ;;reicht fuer 250K (1K Bloecke)
                         C      				;;	bzw. 500K (2K-Bloecke)
                         C      	endif
                         C      	ENDIF
                         C      csv&di	equ	@dsad		;;Check Sum
                         C      	IF	(disk&di mod 100) gt 40 ;;8",77 oder 5",80 Track
                         C      	if	((disk&di mod 10000)/1000)	;;DS
                         C      @dsad	aset	@dsad+256/4	;;reicht fuer 256 Dir.eintraege
                         C      	else					;;SS
                         C      @dsad	aset	@dsad+128/4	;;reicht fuer 128 Dir.eintraege
                         C      	endif
                         C      	ELSE				;;5" 40 Track
                         C      	if	((disk&di mod 10000)/1000)	;;DS
                         C      @dsad	aset	@dsad+128/4	;;reicht fuer 128 Dir.eintraege
                         C      	else
                         C      @dsad	aset	@dsad+64/4	;;reicht fuer 64 Dir.eintraege
                         C      	endif
                         C      	ENDIF
                         C       ENDIF
