                         C      
                         C       IF iobvar
                         C      ;Verteiler fuer die 1-Zeichen-Kanaele entsprechend IOBYTE:
                         C      ;=========================================================
                         C      
  E56C                   C      const:			; iobyte  00 00 00 xx
  E56C    CD E5CC        C      	call	iodisp
  E56F    07             C      	db	7
  E570    D14F           C      	dw	kbdst		;0 kbd:
  E572    D14F           C      	dw	kbdst		;1 kbd:
  E574    E590           C      	dw	reades		;2 rdr:
  E576    D892           C      	dw	uc1st		;3 uc1: (liefert, ob Z. da)
                         C      
  E578                   C      conin:			; iobyte:  00 00 00 xx
  E578    CD E5CC        C      	call	iodisp
  E57B    07             C      	db	7
  E57C    D1E7           C      	dw	kbdi		;0 kbd:
  E57E    D1E7           C      	dw	kbdi		;1 kbd:
  E580    E59C           C      	dw	reader		;2 rdr:
  E582    D8C1           C      	dw	uc1i		;3 uc1: (wartet, bis Z. da)
                         C      
  E584                   C      conout:			; iobyte:  00 00 00 xx
  E584    CD E5CC        C      	call	iodisp
  E587    07             C      	db	7
  E588    D454           C      	dw	crto		;0 crt:
  E58A    D132           C      	dw	dumo		;1 dum:
  E58C    E5A8           C      	dw	punch		;2 pun:
  E58E    D6EB           C      	dw	uc1o		;3 uc1: (wartet, bis frei)
                         C      
  E590                   C      reades:			; iobyte:   00 00 xx 00
  E590    CD E5CC        C      	call	iodisp
  E593    01             C      	db	1
  E594    D14F           C      	dw	kbdst		;0 kbd:
  E596    D12C           C      	dw	dumst		;1 dum:
  E598    D12C           C      	dw	dumst		;2 dum:
  E59A    D892           C      	dw	uc1st		;3 uc1: (liefert, ob Z. da)
                         C      
  E59C                   C      reader:			; iobyte:   00 00 xx 00
  E59C    CD E5CC        C      	call	iodisp
  E59F    01             C      	db	1
  E5A0    D1E7           C      	dw	kbdi		;0 kbd:
  E5A2    D12F           C      	dw	dumi		;1 dum:
  E5A4    D12F           C      	dw	dumi		;2 dum:
  E5A6    D8C1           C      	dw	uc1i		;3 uc1: (wartet, bis Z. da)
