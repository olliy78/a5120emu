  DC89    3C             C      	inc	a
  DC8A    87             C      	add	a,a		;CY:=0
  DC8B    04             C      	inc	b		;fuer djnz, falls dpbslc=0
  DC8C    0F             C      dbsnbz:	rrca			;Zahl der phys. Sekt. im Puff.
  DC8D    10 FD          C      	djnz	dbsnbz
  DC8F    57             C      	ld	d,a		;merken
  DC90    AF             C      	xor	a
  DC91    C1             C      	pop	bc		;b:=geforderte Puffernr.
  DC92    C5             C      	push	bc
  DC93    21 DF09        C      	ld	hl,dbnb
  DC96    70             C      	ld	(hl),b
  DC97    04             C      	inc	b
  DC98    05             C      	dec	b		;Puffernr. 0?
  DC99    28 03          C      	jr	z,dbsec0	;ja
  DC9B    82             C      dbsecz:	add	a,d		;0. phys. Sekt. im Puffer
  DC9C    10 FD          C      	djnz	dbsecz		;=dbsnb.*Puffernr.
  DC9E    5F             C      dbsec0:	ld	e,a		;merken Pufferanf.-Sektor
  DC9F    DD 46 10       C      	ld	b,(ix+dpbslc)
  DCA2    DD 7E 00       C      	ld	a,(ix+dpbspt)
  DCA5    04             C      	inc	b		;wegen djnz
  DCA6    87             C      	add	a,a
  DCA7    CB 3F          C      dbsecm:	srl	a		;phys. Sektoranzahl
  DCA9    10 FC          C      	djnz	dbsecm
  DCAB    93             C      	sub	e		;Restsektorzahl auf Spur
  DCAC    BA             C      	cp	d		;>= Zahl zu transferierender?
  DCAD    30 01          C      	jr	nc,dbseco	;ja
  DCAF    57             C      	ld	d,a		;sonst nur Restsektorzahl
  DCB0    1C             C      dbseco:	inc	e		;Sektoren zaehlen ab 1
  DCB1    7B             C      	ld	a,e
  DCB2    32 DEF6        C      	ld	(dbsec),a	;Sektor
  DCB5    7A             C      	ld	a,d
  DCB6    32 DEF8        C      	ld	(dbsnb),a	;Sektorzahl
  DCB9    21 DEF2        C      	ld	hl,dbflg
  DCBC    CB 96          C      	res	dfbwr,(hl)
                         C       if @write
  DCBE    CB 46          C      	bit	dfbprr,(hl)	;muss neuer Puffer gel. werden?
  DCC0    20 14          C      	jr	nz,dbprr	;ja
                         C      ; nur dann kein preread, wenn Rest BDOS-Block >= phys. Puff.
