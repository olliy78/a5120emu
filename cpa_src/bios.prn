                                	ELSE
  D117    C9                    	ret
  D118    00                    	nop
  D119    00                    	nop
  D11A    C9                    	ret
  D11B    00                    	nop
  D11C    00                    	nop
  D11D    C9                    	ret
  D11E    00                    	nop
  D11F    00                    	nop
                                	ENDIF
