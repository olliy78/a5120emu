  E49B    0000 0000      C      	dw	0,0,0
  E49F    0000           C      
  E4A1    F00C           C      	dw	dirbuf
  E4A3    E4A9 0000      C      	dw	dpbem,0,alvem
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-99


  E4A7    F1E2           C      
                         C      
  E4A9                   C      dpbem:
  E4A9    0020           C      dpbm:	dw	32	;Recs per Track
  E4AB    03 07 00       C      	db	3,7,0	;1k-BDOS-Bloecke 
  E4AE    00FF           C      	dw	256-1	;256k
  E4B0    003F           C      	dw	64-1	;64 Dir-.Eintraege
  E4B2    C0 00          C      	db	0c0h,0	;Alloc. fuer 64 Dir.
  E4B4    0000           C      	dw	0	;kein check
  E4B6    0000           C      	dw	0	;Offset: keine Systemspuren
  E4B8    80             C      	db	80h	;kein Disketten-DPB
