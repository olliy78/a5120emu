  D108                          cpmx00: IF	monitor
                                	ELSE
  D108    C9                    	ret
  D109    00                    	nop
  D10A    00                    	nop
                                	ENDIF
  D10B    C3 E4B9               cpmx03: jp	tim5on		;5ms Takt an
  D10E    C3 E4C0               cpmx06: jp	tim5of		;5ms Takt aus
  D111    C3 E4C4               cpmx09: jp	tim1on		;1s Takt an
  D114    C3 E4CB               cpmx0c: jp	tim1of		;1s Takt aus
