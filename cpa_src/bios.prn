                         C      
                         C       IF cpastz
                         C       ENDIF
                         C      
                         C      
                         C      ; auf Spur 0 zurueck (vor jedem Dir-Zugriff)
                         C      ;===================
  DB65                   C      home:
                         C      	IF	dbufsz gt 7
  DB65    21 DEF2        C      	ld	hl,dbflg
  DB68    CB 56          C      	bit	dfbwr,(hl)	;veraenderter Puffer?
  DB6A    20 05          C      	jr	nz,home1	;ja, nicht freigeben
  DB6C    3E FF          C      	ld	a,0ffh		;sonst Diskwechsel erlauben
  DB6E    32 DEF3        C      	ld	(dbdev),a	;Puffer ist nicht aktiv
                         C      	ENDIF
  DB71    01 0000        C      home1:	ld	bc,0
                         C      ;-----------------------
