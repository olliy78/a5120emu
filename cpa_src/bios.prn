  D6DB    D567           C      	dw	crtdel	;7F
  D6DD    D4D0           C      	dw	crto87	;87
  D6DF                   C      dswe 	equ	$	;tabellenende
                         C      
                                
                                 IF chdvar
                         C      	include BIOSCHD
                         C      ;**************************************************************
                         C      ;	zeichenorientierte Geraete
                         C      ; Aenderungen:
                         C      ; Fehlerkorrektur UC1:-Treiber
                         C      ; - getrennter Status Sender/Empf.
                         C      ; - Verwaltung des DTR-Bits auf Empf.seite
                         C      ; - UC1: arbeitet empfangsseitig interruptgetrieben
                         C      ; - Einfuehrung eines UC1:-Puffers als Verlaengerung des SIO-Puffers
                         C      ; - bei E/A-Fehler (Drucker nicht bereit) warten auf Bestaetigung,
                         C      ;   moegliche Reaktion ^C, I(gnore device) oder R(etry)
                         C      ; 29.09.88
                         C      ; - beide Bahnen parallel wird zurueckgesetzt, wenn linke oder rechte
                         C      ;   Bahn ausgewaehlt wird
                         C      ; 04.04.89
                         C      ; - zeichenweise Geraete werden bei Warmstart nicht neu initialisiert,
                         C      ;   nur beim Betaetigen der Taste "Synchronisieren"
                         C      ; 06.07.89
                         C      ; - bei DTR mit/ohne Warten auf Senderegister leer
                         C      ; 15.09.89
                         C      ; - wegen Drucker 1152.257 TimeOut auf nicht-Bereitschaft von 30 s auf 2 min
                         C      ;**************************************************************
                         C      
                         C       if1
                         C       endif ; if1
                         C      
                         C      
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-46


                         C      ; Ausgabe
                         C      ;~~~~~~~~
                         C      ; TTY:
                         C      ;=====
                         C       if	iobtty
  D6DF    DD 21 D77D     C      ttyo:	ld	ix,lsttty
  D6E3    18 0C          C      	jr	lsto
                         C       endif
                         C      
                         C      ; LPT:
                         C      ;=====
                         C       if	ioblpt
  D6E5    DD 21 D79A     C      lpto:	ld	ix,lstlpt
  D6E9    18 06          C      	jr	lsto
                         C       endif
                         C      
                         C      ; UC1:
                         C      ;=====
                         C       if	iobuc1
  D6EB    DD 21 D7B7     C      uc1o:	ld	ix,lstuc1
  D6EF    18 00          C      	jr	lstoch		;nicht 2 Bahn Zeichen interpr.
                         C       endif
                         C      
  D6F1                   C      lsto:
  D6F1                   C      listi:	;interner Aufruf lsto mit gestelltem IX
                         C       IF l2bahn
                         C       ENDIF
                         C      
                         C      ; Einzelzeichenausgabe Reg. C
                         C      ;-----------------------------
  D6F1                   C      lstoch:
  D6F1    DD CB 00 4E    C      	bit	1,(ix+ltpst)	;senderseitig blockiert?
  D6F5    C0             C      	ret	nz		;ja, Ausgabe ignorieren
  D6F6    C5             C      	push	bc		;retten Zeichen in C
  D6F7    0E 78          C      loutws:	ld	c,120		;max. Wartezeit in Sek. auf ready
  D6F9    06 64          C      loutw1:	ld	b,100		;100*10ms warten
  D6FB    C5             C      loutwt:	push	bc
  D6FC    CD D761        C      	CALL	lststi		;Status holen
  D6FF    20 16          C      	jr	nz,loutwf	;ist frei
  D701    06 01          C      	ld	b,1
  D703    CD E6C5        C      	call	wait10		;Warten 10 ms
  D706    C1             C      	pop	bc
  D707    10 F2          C      	djnz	loutwt		;weiter warten?
  D709    0D             C      	dec	c		;weitere Sekunde warten?
  D70A    20 ED          C      	jr	nz,loutw1	;ja
                         C       IF errvar
  D70C    CD D721        C      	call	spioer		;Fehlermeldung
  D70F    20 E6          C      	jr	nz,loutws	;Wiederholung
                         C       ENDIF
  D711    C1             C      	pop	bc
  D712    DD CB 00 CE    C      	set	1,(ix+ltpst)	;Sender blockiert
  D716    C9             C      	ret			;folgende Ausgaben werden ignor.
  D717    C1             C      loutwf:	pop	bc
  D718    C1             C      	pop	bc
  D719    79             C      	ld	a,c		;auszugebendes Zeichen nach A
  D71A    DD 6E 04       C      	ld	l,(ix+ltpo)
  D71D    DD 66 05       C      	ld	h,(ix+ltpo+1)
  D720    E9             C      	jp	(hl)
                         C      
                         C       IF errvar
  D721    DD 7E 02       C      spioer:	ld	a,(ix+ltpsd)	;Daten-Port-Adresse
  D724    11 D742        C      	ld	de,louttp
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-47


  D727    CD E6D4        C      	call	mrecoa		;in Text
  D72A    21 D740        C      	ld	hl,loutto
  D72D    CD E6B9        C      	call	biosms
  D730    CD D194        C      	call	kbdbcl
  D733    CD E578        C      	call	conin
  D736    CB AF          C      	res	5,a
  D738    FE 03          C      	cp	'C' and 1fh	;^C ?
  D73A    CA 0000        C      	jp	z,0		;ja, Abbruch
  D73D    FE 49          C      	cp	'I'		;ret z: 'I'; ret nz: 'R'
  D73F    C9             C      	ret
                         C      
  D740                   C      loutto:
                         C       IF cpastz
                         C       ELSE
  D740    0D 0A          C      	db	0dh,0ah
                         C       ENDIF
  D742    58 58 68 20    C      louttp:	db	'XXh Fehler ^C/I/R'
  D746    46 65 68 6C    C      
  D74A    65 72 20 5E    C      
  D74E    43 2F 49 2F    C      
  D752    52             C      
                         C       IF cpastz
                         C       ELSE
  D753    07 00          C      	db	07h,0
                         C       ENDIF
                         C       ENDIF	;errvar
                         C      
                         C      ;-----------------------
                         C      
                         C      
                         C      ; Status
                         C      ;-------
                         C      ; o A=0, ret z	: Ausgabe besetzt
                         C      ; o A=ff,ret nz	: Ausgabe frei
                         C      
                         C      ; TTY:
                         C      ;=====
                         C       if	iobtty
  D755    DD 21 D77D     C      ttyst:	ld	ix,lsttty
  D759    18 06          C      	jr	lstst
                         C       endif
                         C      
                         C      ; LPT
                         C      ;====
                         C       if	ioblpt
  D75B    DD 21 D79A     C      lptst:	ld	ix,lstlpt
  D75F    18 00          C      	jr	lstst
                         C       endif
                         C      
                         C       if iobuc1
                         C       endif
                         C      
  D761                   C      lstst:
  D761                   C      lststi:	;interner Aufruf Sender-Status mit gestelltem IX
                         C      ; ret nz, A=FF fuer frei
                         C      ; ret z , A=00 fuer besetzt
                         C      
  D761    DD 6E 08       C      	ld	l,(ix+ltps)
  D764    DD 66 09       C      	ld	h,(ix+ltps+1)
  D767    E9             C      	jp	(hl)
                         C      
                         C      ;-----------------------------
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-48


                         C      
                         C      ; Zeichenempfang
                         C      ;---------------
                         C      
  D12F                   C      ttyi	equ	dumi
  D12F                   C      lpti	equ	dumi
                         C       if iobuc1
                         C       endif
                         C      
                         C      ;-------------------------------
                         C      
                         C      ; Alle zeichenweisen Geraete neu synchronisieren
                         C      ;-----------------------------------------------
  D768                   C      lsynch:	
  D768    AF             C      	xor	a
                         C      	if	iobtty
  D769    32 D77D        C      	ld	(lsttty+ltpst),a
                         C      	endif
                         C      	if	ioblpt
  D76C    32 D79A        C      	ld	(lstlpt+ltpst),a
                         C      	endif
                         C      	if	iobuc1
  D76F    32 D7B7        C      	ld	(lstuc1+ltpst),a
                         C      	endif
  D772    C9             C      	ret
                         C      
                         C      ; Portprogrammierung
                         C      ;===================
                         C      ; i HL	^Steuertabelle, Laenge+1, Port, Bytes,...,1
  D773                   C      portpr:
  D773    46             C      portpz:	ld	b,(hl)		;Stringlaenge +1
  D774    23             C      	inc	hl
  D775    05             C      	dec	b		;Ende?
  D776    C8             C      	ret	z		;ja
  D777    4E             C      	ld	c,(hl)		;Port
  D778    23             C      	inc	hl
  D779    ED B3          C      	otir
  D77B    18 F6          C      	jr	portpz
                         C      
                         C      ;Steuertabellen fuer zeichenweise arbeitende Geraete
                         C      ;===================================================
                         C      
                         C      ;Struktur:
                         C      ; fester Teil
  0000                   C      ltpst	equ	0	;Status
                         C      			;Bit  7-4 Empf.,3-0 Sender  Bedeutung, wenn =1
                         C      			;	4	0 Empfseite init./ Senderseite init.
                         C      			;	5	1      -	 / Sender blockiert
                         C      			;	7	3 Sender gestoppt/ Sender hat frei gem.
  0001                   C      ltpdc	equ	1	;DC1/DC3: zuletzt empf. Zeichen (i.a. DCx)
                         C      			;DTR:	Statusmaske (Bit 5 Kanal A, Bit 3 Kanal B),
                         C      			;	Bit 7 =1 wenn kein Wait auf Senderegister leer
  0002                   C      ltpsd	equ	2	;Portadr. Daten
  0003                   C      ltpsc	equ	3	;Portadr. Kommando/Status (noch mal in ltpini!)
                         C      
  0004                   C      ltpo	equ	4	;Adresse der Senderoutine
  0006                   C      ltpi	equ	6	;Adresse der Empfangsroutine
  0008                   C      ltps	equ	8	;Adresse der Empfangsstatus-Routine
                         C      
                         C      ; Der folgende Teil existiert nur fuer SIO-Treiber
  000A                   C      ltpw5	equ	10	;WR5:
                         C      			;DTR/RTS Bit 7,1: 11 DTR; 00 DC1/DC3
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-49


                         C      			;Bitanzahl/Byte Bit 6,5: 00 5;01 7;10 6;11 8
                         C      			;Bit 3 = 1 (Senderfreigabe)
                         C      			;Bit 0,2,4 = 0
                         C      ; Port-Initialisierung (fuer alle Treiber)
  000B                   C      ltpini	equ	11	;jeweils Byteanzahl+1; Port; Bytefolge
                         C      			;variabel lang
                         C      
                         C      			;fuer SIO-Treiber einige Erlaeuterungen:
  000C                   C      ltpcs	equ	12	;Port CTC-Sendetakt
                         C      			;Vorteiler (37h Vorteiler 256, 17h Vorteiler 16)
                         C      			;Baudrate (1=9600,2=4800,..64=150,96=100,128=75)
                         C      			;evtl. nochmal fuer Port CTC-Empf.takt
                         C      			;WR4:
                         C      			;Paritaet  in Bit 1,0: 00 ohne, 01 unger., 11 ger.
                         C      			;Stop-Bits in Bit 3,2: 01 1; 10 1,5; 11 2
                         C      			;Reserve   in Bit 5,4: 00 immer (nur fuer Synchr.mode)
                         C      			;Takt      in Bit 7,6: 00 *1, 01 *16, 10 *32, 11 *64
                         C      			;WR1:
                         C      			;Interrvektormod. in Bit 2: 0=keine Modifizierung
                         C      			;in Kanal B!! setzen
                         C      			;Empf.interr.mode Bit4,3: 00 kein Interrupt
                         C      			;			  01 bei erstem Zeichen
                         C      			;			  10 bei jedem mit Mod.
                         C      			;			  11 bei jedem ohne Mod.
                         C      			;WR3:
                         C      			;Empf.freigabe in Bit 0: 0=Empf. gesperrt; 1=Empf. frei
                         C      			;Bit 1-5:00000
                         C      			;Bitanzahl/Byte Bit 7,6:00 5;01 7;10 6;11 8
                         C      
                                 IF iobtty
  0713                          @lt	aset	iobtty
  0050                          @ld	aset	ttydat
  0051                          @ls	aset	ttysta
  000C                          @lcs	aset	ttycts
  000C                          @lcr	aset	ttyctr
  0000                          @wr1	aset	00000000b ;WR1: kein Interruptbetrieb
  0000                          @wsre	aset	00000000b ;Bit 7=0: Warten auf Senderegister leer
  D77D                   C      lsttty: include BIOSCPB
                         C      ;; 07.04.89
                         C      ;; 06.07.89
                         C      ;; - Einfuehrung Bit 7 in Statusmaske DTR - =1 kein Warten Senderegister leer
  D77D    00             C      	db	00H	;Status
                         C       IF ((@lt mod 10) eq 1) or ((@lt mod 10) eq 3)
                         C        IF (@lt mod 10) eq 1; DTR, Treiber 1
  0008                   C      @l	aset	@wsre xor 08h	;Statusmaske DTR-Abfrage ueber DCD im Kanal B
                         C        ENDIF
                         C        IF (@lt mod 10) eq 3; DTR, Treiber 3
                         C        ENDIF
  D77E    08             C      	db	@l	;DTR-Abfrage-Maske, Bit 7 Wait_Senderegister_leer-Flag
                         C       ENDIF
  D77F    50             C      	db	@ld	;Port fuer Daten
  D780    51             C      	DB	@ls	;Port fuer Status/Kommando
                         C       IF (@lt mod 10) lt 5	;;SIO ###########################################
                         C       if ((@lt mod 10) eq 0) or ((@lt mod 10) eq 1) or ((@lt mod 10) eq 3)
  D781    D7D4           C      	dw	cdsioo	;;Senden
  D783    D12F           C      	dw	cdsioi	;;Empfang
  D785    D7DA           C      	dw	cdsios	;;Empf.Status
                         C       endif
                         C       if (@lt mod 10) eq 2
                         C       endif
  0008                   C      @l	aset	00001000b	;;DC1/3, 5 Bit
                         C       if ((@lt mod 10) eq 1) or ((@lt mod 10) eq 3)
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-50


  008A                   C      @l	aset	@l xor 10000010b	;;DTR
                         C       endif
                         C       if ((@lt mod 1000)/100) eq 6
                         C       endif
                         C       if ((@lt mod 1000)/100) eq 7
                         C       endif
                         C       if ((@lt mod 1000)/100) eq 8
  00EA                   C      @l	aset	@l xor 01100000b
                         C       endif
  D787    EA             C      	db	@l	;WR5
                         C      			;**Portinitialisierung**
                         C      ; CTC Sendetakt
  D788    03             C       	db	2+1
  D789    0C             C      	db	@lcs		;CTC Senden
                         C       IF (cpu eq c1715) and (@ld eq kbdsci)	;;PC1715, SIO durch Tastatur init.!!
                         C       ELSE
  D78A    17             C      	db	17h		;Vorteiler 16
                         C       ENDIF
  0001                   C      @l	aset	1 shl (((@lt mod 100)/10)-1)
                         C        if ((@lt mod 100)/10) eq 8
                         C        endif
                         C        if ((@lt mod 100)/10) eq 9
                         C        endif
  D78B    01             C      	db	@l		;Baudrate senden
                         C       IF (cpu eq c1715) and (@ld eq kbdsci)	;;PC1715, SIO durch Tastatur init.!!
                         C       ELSE
                         C      ;;; zum nachtraeglichen Patchen immer CTC Empf. generieren
                         C      ;;; auch wenn '@cls eq @clr'
                         C      ; CTC Empfangstakt
  D78C    03             C      	db	2+1
  D78D    0C             C      	db	@lcr		;CTC Empf.
  D78E    17             C      	db	17h		;Vorteiler 16
  D78F    01             C      	db	@l		;Baudrate empf.
                         C      ; SIO-Initialisierung
  D790    08             C      	db	7+1
  D791    51             C      	db	@ls		;SIO-Komm.
  D792    18             C      	db	18h		;WR0
  0044                   C      @l	aset	01000100b	;;Takt*16, ohne P., 1 Stbit, DTR
                         C       if (@lt mod 10) eq 2
                         C       endif
                         C        if @lt ge 10000
                         C        endif
                         C        if @lt ge 20000
                         C        endif
                         C        if ((@lt mod 10000)/1000) eq 2
                         C        endif
                         C        if ((@lt mod 10000)/1000) eq 3
                         C        endif
  D793    04 44          C      	db	4,@l		;WR4
  D795    01 00          C      	db	1,@wr1		;WR1
  0001                   C      @l	aset	00000001b	;;5 Bit, Empf.freigabe
                         C        if ((@lt mod 1000)/100) eq 6
                         C        endif
                         C        if ((@lt mod 1000)/100) eq 7
                         C        endif
                         C        if ((@lt mod 1000)/100) eq 8
  00C1                   C      @l	aset	@l xor 11000000b
                         C        endif
  D797    03 C1          C      	db	3,@l		;WR3
                         C        ENDIF	;;(cpu ne c1715) or (@ld ne kbdsci)
  D799    01             C      	db	1	;**Ende SIO-Initialisierung** 
                         C       ENDIF
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-51


                         C      
                                 ENDIF
                                
                                 IF ioblpt
  2DBE                          @lt	aset	ioblpt
  005E                          @ld	aset	lptdat
  005F                          @ls	aset	lptsta
  0058                          @lcs	aset	lptcts
  0058                          @lcr	aset	lptctr
  0000                          @wr1	aset	00000000b ;WR1: kein Interruptbetrieb
  0000                          @wsre	aset	00000000b ;Bit 7=0: Warten auf Senderegister leer
  D79A                   C      lstlpt: include BIOSCPB
                         C      ;; 07.04.89
                         C      ;; 06.07.89
                         C      ;; - Einfuehrung Bit 7 in Statusmaske DTR - =1 kein Warten Senderegister leer
  D79A    00             C      	db	00H	;Status
                         C       IF ((@lt mod 10) eq 1) or ((@lt mod 10) eq 3)
                         C       ELSE ;DC1/3 oder PIO
  D79B    00             C      	db	00H	;zuletzt empfangenes Zeichen
                         C       ENDIF
  D79C    5E             C      	db	@ld	;Port fuer Daten
  D79D    5F             C      	DB	@ls	;Port fuer Status/Kommando
                         C       IF (@lt mod 10) lt 5	;;SIO ###########################################
                         C       if ((@lt mod 10) eq 0) or ((@lt mod 10) eq 1) or ((@lt mod 10) eq 3)
  D79E    D7D4           C      	dw	cdsioo	;;Senden
  D7A0    D12F           C      	dw	cdsioi	;;Empfang
  D7A2    D7DA           C      	dw	cdsios	;;Empf.Status
                         C       endif
                         C       if (@lt mod 10) eq 2
                         C       endif
  0008                   C      @l	aset	00001000b	;;DC1/3, 5 Bit
                         C       if ((@lt mod 10) eq 1) or ((@lt mod 10) eq 3)
                         C       endif
                         C       if ((@lt mod 1000)/100) eq 6
                         C       endif
                         C       if ((@lt mod 1000)/100) eq 7
  0028                   C      @l	aset	@l xor 00100000b
                         C       endif
                         C       if ((@lt mod 1000)/100) eq 8
                         C       endif
  D7A4    28             C      	db	@l	;WR5
                         C      			;**Portinitialisierung**
                         C      ; CTC Sendetakt
  D7A5    03             C       	db	2+1
  D7A6    58             C      	db	@lcs		;CTC Senden
                         C       IF (cpu eq c1715) and (@ld eq kbdsci)	;;PC1715, SIO durch Tastatur init.!!
                         C       ELSE
  D7A7    17             C      	db	17h		;Vorteiler 16
                         C       ENDIF
  0001                   C      @l	aset	1 shl (((@lt mod 100)/10)-1)
                         C        if ((@lt mod 100)/10) eq 8
                         C        endif
                         C        if ((@lt mod 100)/10) eq 9
                         C        endif
  D7A8    01             C      	db	@l		;Baudrate senden
                         C       IF (cpu eq c1715) and (@ld eq kbdsci)	;;PC1715, SIO durch Tastatur init.!!
                         C       ELSE
                         C      ;;; zum nachtraeglichen Patchen immer CTC Empf. generieren
                         C      ;;; auch wenn '@cls eq @clr'
                         C      ; CTC Empfangstakt
  D7A9    03             C      	db	2+1
  D7AA    58             C      	db	@lcr		;CTC Empf.
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-52


  D7AB    17             C      	db	17h		;Vorteiler 16
  D7AC    01             C      	db	@l		;Baudrate empf.
                         C      ; SIO-Initialisierung
  D7AD    08             C      	db	7+1
  D7AE    5F             C      	db	@ls		;SIO-Komm.
  D7AF    18             C      	db	18h		;WR0
  0044                   C      @l	aset	01000100b	;;Takt*16, ohne P., 1 Stbit, DTR
                         C       if (@lt mod 10) eq 2
                         C       endif
                         C        if @lt ge 10000
  0045                   C      @l	aset	@l xor 00000001b	;;ung P.
                         C        endif
                         C        if @lt ge 20000
                         C        endif
                         C        if ((@lt mod 10000)/1000) eq 2
                         C        endif
                         C        if ((@lt mod 10000)/1000) eq 3
                         C        endif
  D7B0    04 45          C      	db	4,@l		;WR4
  D7B2    01 00          C      	db	1,@wr1		;WR1
  0001                   C      @l	aset	00000001b	;;5 Bit, Empf.freigabe
                         C        if ((@lt mod 1000)/100) eq 6
                         C        endif
                         C        if ((@lt mod 1000)/100) eq 7
  0041                   C      @l	aset	@l xor 01000000b
                         C        endif
                         C        if ((@lt mod 1000)/100) eq 8
                         C        endif
  D7B4    03 41          C      	db	3,@l		;WR3
                         C        ENDIF	;;(cpu ne c1715) or (@ld ne kbdsci)
  D7B6    01             C      	db	1	;**Ende SIO-Initialisierung** 
                         C       ENDIF
                         C      
                                 ENDIF
                                
                                 IF iobuc1
  0713                          @lt	aset	iobuc1
  0050                          @ld	aset	uc1dat
  0051                          @ls	aset	uc1sta
  000C                          @lcs	aset	uc1cts
  000C                          @lcr	aset	uc1ctr
  0014                          @wr1	aset	00010100b ;WR1: Empfangsinterr. bei jedem Char., Intv.modif.
  0080                          @wsre	aset	10000000b ;Bit 7=1: kein Warten auf Senderegister leer
  D7B7                   C      lstuc1: include BIOSCPB
                         C      ;; 07.04.89
                         C      ;; 06.07.89
                         C      ;; - Einfuehrung Bit 7 in Statusmaske DTR - =1 kein Warten Senderegister leer
  D7B7    00             C      	db	00H	;Status
                         C       IF ((@lt mod 10) eq 1) or ((@lt mod 10) eq 3)
                         C        IF (@lt mod 10) eq 1; DTR, Treiber 1
  0088                   C      @l	aset	@wsre xor 08h	;Statusmaske DTR-Abfrage ueber DCD im Kanal B
                         C        ENDIF
                         C        IF (@lt mod 10) eq 3; DTR, Treiber 3
                         C        ENDIF
  D7B8    88             C      	db	@l	;DTR-Abfrage-Maske, Bit 7 Wait_Senderegister_leer-Flag
                         C       ENDIF
  D7B9    50             C      	db	@ld	;Port fuer Daten
  D7BA    51             C      	DB	@ls	;Port fuer Status/Kommando
                         C       IF (@lt mod 10) lt 5	;;SIO ###########################################
                         C       if ((@lt mod 10) eq 0) or ((@lt mod 10) eq 1) or ((@lt mod 10) eq 3)
  D7BB    D7D4           C      	dw	cdsioo	;;Senden
  D7BD    D12F           C      	dw	cdsioi	;;Empfang
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-53


  D7BF    D7DA           C      	dw	cdsios	;;Empf.Status
                         C       endif
                         C       if (@lt mod 10) eq 2
                         C       endif
  0008                   C      @l	aset	00001000b	;;DC1/3, 5 Bit
                         C       if ((@lt mod 10) eq 1) or ((@lt mod 10) eq 3)
  008A                   C      @l	aset	@l xor 10000010b	;;DTR
                         C       endif
                         C       if ((@lt mod 1000)/100) eq 6
                         C       endif
                         C       if ((@lt mod 1000)/100) eq 7
                         C       endif
                         C       if ((@lt mod 1000)/100) eq 8
  00EA                   C      @l	aset	@l xor 01100000b
                         C       endif
  D7C1    EA             C      	db	@l	;WR5
                         C      			;**Portinitialisierung**
                         C      ; CTC Sendetakt
  D7C2    03             C       	db	2+1
  D7C3    0C             C      	db	@lcs		;CTC Senden
                         C       IF (cpu eq c1715) and (@ld eq kbdsci)	;;PC1715, SIO durch Tastatur init.!!
                         C       ELSE
  D7C4    17             C      	db	17h		;Vorteiler 16
                         C       ENDIF
  0001                   C      @l	aset	1 shl (((@lt mod 100)/10)-1)
                         C        if ((@lt mod 100)/10) eq 8
                         C        endif
                         C        if ((@lt mod 100)/10) eq 9
                         C        endif
  D7C5    01             C      	db	@l		;Baudrate senden
                         C       IF (cpu eq c1715) and (@ld eq kbdsci)	;;PC1715, SIO durch Tastatur init.!!
                         C       ELSE
                         C      ;;; zum nachtraeglichen Patchen immer CTC Empf. generieren
                         C      ;;; auch wenn '@cls eq @clr'
                         C      ; CTC Empfangstakt
  D7C6    03             C      	db	2+1
  D7C7    0C             C      	db	@lcr		;CTC Empf.
  D7C8    17             C      	db	17h		;Vorteiler 16
  D7C9    01             C      	db	@l		;Baudrate empf.
                         C      ; SIO-Initialisierung
  D7CA    08             C      	db	7+1
  D7CB    51             C      	db	@ls		;SIO-Komm.
  D7CC    18             C      	db	18h		;WR0
  0044                   C      @l	aset	01000100b	;;Takt*16, ohne P., 1 Stbit, DTR
                         C       if (@lt mod 10) eq 2
                         C       endif
                         C        if @lt ge 10000
                         C        endif
                         C        if @lt ge 20000
                         C        endif
                         C        if ((@lt mod 10000)/1000) eq 2
                         C        endif
                         C        if ((@lt mod 10000)/1000) eq 3
                         C        endif
  D7CD    04 44          C      	db	4,@l		;WR4
  D7CF    01 14          C      	db	1,@wr1		;WR1
  0001                   C      @l	aset	00000001b	;;5 Bit, Empf.freigabe
                         C        if ((@lt mod 1000)/100) eq 6
                         C        endif
                         C        if ((@lt mod 1000)/100) eq 7
                         C        endif
                         C        if ((@lt mod 1000)/100) eq 8
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-54


  00C1                   C      @l	aset	@l xor 11000000b
                         C        endif
  D7D1    03 C1          C      	db	3,@l		;WR3
                         C        ENDIF	;;(cpu ne c1715) or (@ld ne kbdsci)
  D7D3    01             C      	db	1	;**Ende SIO-Initialisierung** 
                         C       ENDIF
