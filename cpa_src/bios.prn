                         C      	IF	dbufsz gt 7
  DD1A    CD DD31        C      	call	dsktra
  DD1D    32 DF0B        C      	ld	(dberrf),a	;Fehlerflag stellen
  DD20    21 DEF2        C      	ld	hl,dbflg
  DD23    CB 96          C      	res	dfbwr,(hl)	;Puffer ist nicht beschrieben
  DD25    C9             C      	ret
                         C      	ENDIF
                         C      
                         C      	ENDIF
                         C      
                         C      	IF	format
