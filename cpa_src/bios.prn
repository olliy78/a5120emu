                         C      	include BIOSCRT
                         C      ;************************************************************
                         C      ; Bildschirm-Ausgabe K7023, K7024, DSY5 u.ae.
                         C      ; - Fehlerkorrektur Steuerzeichen 18h (es wurden nur 79 Zeichen gel.)
                         C      ; - bei Tastenumdefinition auch chr(253) als Begrenzer (dbase)
                         C      ; - BAB2 als Standardvariante
                         C      ; - 17h (insline) und 19h (delline) eingefuehrt fuer TURBO-PASCAL-Editor
                         C      ; - Realisierung der SCP1715-Steuerzeichen 1b 5e xx (Feldattribut)
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-35


                         C      ;   und 1b 5f xx (Spezialzeichen)
                         C      ;   Diese ESC-Folgen fueren beim Buerocomputer i.a. auf '^' (unzulaessig),
                         C      ;   ausser Feldattribute invers und hell (Reaktion wie Steuerz. 84..87)
                         C      ; - Einfuehrung Umlaut-Umkodierung fuer deutschen Zeichensatz
                         C      ;   einschl. SCP1715-Steuerzeichen 0Eh und 0Fh
                         C      ; - Einfuehrung MACROS "setbs" und "setram" zum Hin- und Rueckschalten
                         C      ;   des Bildschirmpuffers
                         C      ; 17.06.88
                         C      ; - Zugriff zum Bildschirm aus Interruptroutinen unterdrueckt
                         C      ; - Unterstuetzung von Karten mit Bit 7 invers (z.B. DSY5)
                         C      ; - Unterst. einer weiteren Variante fuer dtsch. Zeichens. auf 00..1f (ZSIBM)
                         C      ; 23.09.88
                         C      ; - Einfuehrung der Macros 'crton' und 'crtoff'
                         C      ; - di/ei waehrend Bildschirmumschaltung eingefuehrt
                         C      ;************************************************************
                         C      
                         C       if1
                         C       endif	;if1
                         C      
                         C       IF crtbfl eq 0
                         C       ELSE ;crtbfl ne 0
                         C        IF1
                         C        ENDIF
                         C       ENDIF
                         C      
                         C      
                         C      ;**************************************************************************
  D12C                   C      crtst	equ	dumst		;CRT:-Status immer ready
                         C      
  D454                   C      crto:
  D454    3E C3          C      	ld	a,0c3h		;jp ...
  D456    32 E536        C      	ld	(intcrt),a	;waehrend Bildaufbau Interrupt-Zugriff verb.
  D459    C5             C      	push	bc		;merken zeichen in c
  D45A    2A D038        C      	ld	hl,(crtcps)	;Kursorposition	
                         C      	setbs
  D45D    CB BE          C      	res	7,(hl)		;loeschen Kursor
                         C      	setram
  D45F    CD D491        C      	call	crtoti		;Zeichen ausgeben
                         C      ;				 HL danach auf neuer Kursorpositon
                         C      
                         C      ; Setzen Kursor auf (HL)
                         C      
  D462    22 D038        C      	ld	(crtcps),hl	;cursorposition
                         C      	setbs
  D465    3E 80          C      	ld	a,80h
  D466                   C      dcurs	equ	$-1
  D467    B6             C      	or	(hl)		;Kursor setzen
  D468    77             C      	ld	(hl),a
                         C      	setram
  D469    C1             C      crtonc:	pop	bc		;wiederherstellen c-reg
                         C      
  D46A    3E 21          C      	ld	a,021h		;ld hl,...
  D46C    32 E536        C      	ld	(intcrt),a	;wiederzulassen Zugriff aus Interruptrtn
                         C      
                         C       if (stpvar ne 0)  and (chdvar ne 0)
                         C      ; Hardcopy realisieren
                         C      
  D46F    3A 0040        C      	ld	a,(lampbf)
  D472    CB 7F          C      	bit	lmphcp,a	;Hardcopy?
  D474    C8             C      	ret	z		;nein
  D475    79             C      	ld	a,c
  D476    E6 7F          C      	and	7fh
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-36


  D478    FE 20          C      	cp	20h		;Steuerzeichen?
  D47A    38 03          C      	jr	c,crtoe1	;ja
  D47C    FE 7F          C      	cp	7fh
  D47E    D8             C      	ret	c
  D47F    C5             C      crtoe1:	push	bc
  D480    21 D48D        C      	ld	hl,crtlc	;zugelassene Steuerzeichen
  D483    01 0004        C      	ld	bc,crtlcl
  D486    ED B1          C      	cpir			;erlaubt?
  D488    C1             C      	pop	bc
  D489    C8             C      	ret	z		;ja
  D48A    0E 5E          C      	ld	c,'^'		;sonst Spezialzeichen
  D48C    C9             C      	ret
                         C      
                         C      ; bei Hardcopy Bildschirm -> Drucker zugelassene Steuerzeichen
                         C      
  D48D    08 0A 0C 0D    C      crtlc:	db	08h,0ah,0ch,0dh
  0004                   C      crtlcl	equ	$-crtlc
                         C      
                         C       endif	;stpvar and chdvar
                         C      
                         C      
                         C      ;========================================================
                         C      ; interner Aufruf Bildschirmtreiber
                         C      ; i HL	Zeiger in Bildschirmpuffer auf Kursorposition
                         C      ; o HL	neuer Zeiger auf Kursorposition
                         C      ;========================================================
                         C      
  D491                   C      crtoti:
  D491    3E 00          C      	ld	a,0		;escape mode
  D492                   C      desc	equ	$-1
  D493    B7             C      	or	a
  D494    20 62          C      	jr	nz,crto04	;ja
  D496    79             C      crto02:	ld	a,c
  D497    32 D696        C      	ld	(crtcch),a	;merken fuer direkte Ausgabe
  D49A    FE 87          C      	cp	87h		;07h ist bell!, daher 87h<>07h
  D49C    28 39          C      	jr	z,crto09
  D49E    CB BF          C      	res	7,a		;sonst 1xxxxxxxB  = 0xxxxxxxB
  D4A0    FE 20          C      	cp	20h		;steuerzeichen?
  D4A2    38 33          C      	jr	c,crto09	;ja
  D4A4    FE 7F          C      	cp	7fh
  D4A6    30 2F          C      	jr	nc,crto09
                         C       IF umlaut
  D4A8    CD D665        C      	call	crtuml		;evtl. Umlaute umkodieren
                         C       ENDIF
  D4AB                   C      crtobs:
  D4AB    EB             C      	ex	de,hl
                         C       IF crt eq dsy5
                         C       ENDIF
  D4AC                   C      crtsbl:
                         C      	setbs
  D4AC    12             C      	ld	(de),a		;Zeichen in Bildschirmpuffer
                         C      	setram
  D4AD    21 0001        C      crtcur:	ld	hl,0-bsend1
  D4AE                   C      crtm01	equ	$-2
  D4B0    19             C      	add	hl,de		;bs voll?
  D4B1    EB             C      	ex	de,hl
  D4B2    23             C      	inc	hl	
  D4B3    D0             C      	ret	nc
  D4B4    11 FFC0        C      	ld	de,bsend1-bssp1+1
  D4B5                   C      crtm02	equ	$-2
  D4B7    D5             C      crto03:	push	de
  D4B8    21 FC40        C      	ld	hl,bsanf1+bssp1	;aufschieben
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-37


  D4B9                   C      crtm03	equ	$-2
  D4BB    11 FC00        C      	ld	de,bsanf1
  D4BC                   C      crtm04	equ	$-2
  D4BE    01 03C0        C      	ld	bc,bsend1-bsanf1-bssp1+1
  D4BF                   C      crtm05	equ	$-2
                         C      	setbs
  D4C1    ED B0          C      	ldir
  D4C3    2B             C      	dec	hl
  D4C4    36 20          C      	ld	(hl),' '	;letzte zeile loeschen
  D4C6    11 FFFE        C      	ld	de,bsend1-1
  D4C7                   C      crtm06	equ	$-2
  D4C9    01 003F        C      	ld	bc,bssp1-1
  D4CA                   C      crtm07	equ	$-2
  D4CC    ED B8          C      	lddr
                         C      	setram
  D4CE    E1             C      	pop	hl
  D4CF    C9             C      	ret
