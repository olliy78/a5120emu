                                ;$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$
                                ;	Beginn BIOS-Treiber
                                ;$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$
                                
                                ; Dummy-Treiber
  D12C                          dumst:
  D12C    AF                    	xor	a
  D12D    3D                    	dec	a		;Status immer FF (bereit)
                                 IF iobvar
                                 ENDIF
  D12E    C9                    	ret			;Status immer FF (bereit)
                                
                                 IF iobvar
  D12F    3E 1A                 dumi:	ld	a,1ah		;Eingabe-Zeichen immer EOF
  D131    C9                    	ret
  D132    79                    dumo:	ld	a,c
  D133    11 D13F               	ld	de,dumoh
  D136    CD E6D4               	call	mrecoa		;Zeichen hex aufbereiten
  D139    0E 28                 	ld	c,'('
  D13B    CD D454               	call	crto
  D13E    01 0000               	ld	bc,0
  D13F                          dumoh	equ	$-2
  D141    C5                    	push	bc
  D142    CD D454               	call	crto
  D145    C1                    	pop	bc
  D146    48                    	ld	c,b
  D147    CD D454               	call	crto
  D14A    0E 29                 	ld	c,')'
  D14C    C3 D454               	jp	crto
                                 ENDIF
                                
                         C      	include BIOSKBD
                         C      ;****************************************************
                         C      ;	Tastatur-Eingabe
                         C      ; - Unterstuetzung weiterer Steckplaetze fuer IFSS-Tastatur
                         C      ;   (z.B. Digitalisier-AP)
                         C      ; - freie Belegbarkeit Kursor- und rechter Ziffernblock
                         C      ; 17.07.88
                         C      ; - uebersichtlichere Darstellung phys. -> virtueller Tastencode
                         C      ; 24.09.88
                         C      ; - Anpassung Tastaturpuffer in Statuszeile an umschaltbaren Bildschirmpuffer
                         C      ; 25.09.88
                         C      ; - Fehler in Stop-Tasten-Behandlung korrigiert
                         C      ; 07.11.88
                         C      ; - Erweiterung des virtuellen Tastaturcodes um K7634-spezifische Tasten
                         C      ; 23.12.88
                         C      ; - saemtliche Sondertasten c0..ff liefern mit Control oder Shift einen
                         C      ;   virtuellen Zwischencode 80..bf
                         C      ; 14.01.89
                         C      ; - Variante K7633 (kbdotp eq 3) eingefuehrt
                         C      ; - wenn Tastatur nach RESET gross schreibt, so caps-lock-Test invertiert
                         C      ; 20.01.89
                         C      ; - Abtesten auf ^Q-Prefix ueber virtuellen Tastencode
                         C      ; 22.03.89
                         C      ; - Control-Flag gilt genau fuer das naechste Zeichen
                         C      ; 31.03.89
                         C      ; - Sondertasten >=80h ignoriert, wenn nicht in Tastatur-Tabelle
                         C      ; 25.09.89
                         C      ; - Fehlerkorrektur K7637: CTRL-Ersatztaste brachte kein ^Q-Prefix
                         C      ;****************************************************
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-24


                         C      
                         C       if1
                         C       endif	;if1
                         C      
                         C      ; Tastatur-Status
                         C      ;================
  D14F                   C      kbdst:
                         C      ; vor Pufferabfrage anstehende Zeichen lesen (falls 5ms Takt aus)
  D14F    F3             C      	di			;parallele Abfrage ueber 5ms verhindern
                         C       IF cpastz
                         C       ENDIF
  D150    CD D157        C      	call	kbdsti		;interner Aufruf
  D153    FB             C      	ei
                         C       IF stpvar or monitor
  D154    C3 E600        C      	jp	chksp		;Test auf Spezialfunktionen
                         C       ENDIF
                         C      
  D157                   C      kbdsti:				;kbdst-Aufruf intern
  D157    CD D233        C      kbdstz:	call	kbdst1		;Taste neu gedrueckt ?
  D15A    28 05          C      	jr	z,kbdsnt	;nein
  D15C    CD D168        C      	call	kbdrdt		;Taste in Puffer ablegen
                         C       IF stpvar
                         C       ENDIF
  D15F    18 F6          C      	jr	kbdstz		;auf neuen Tastendruck testen
                         C      
  D161    3E 00          C      kbdsnt:	ld	a,0		;erstes Pufferzeichen
  D162                   C      kbdbfe	equ	$-1
  D163    B7             C      	or	a		;Puffer leer?
  D164    C8             C      	ret	z		;ja
  D165    3E FF          C      	ld	a,0ffh
  D167    C9             C      	ret
                         C      
                         C      ;------------------------------------------------------------
                         C      
                         C      
                         C      ; Taste umkodieren und im Puffer ablegen
                         C      ;=======================================
                         C      ; Achtung!! Dieses UP wird aus Interruptroutine aufgmrufen
  D168    CD D253        C      kbdrdt:	call	kbdrch		;Zeichen evtl. umkodieren
  D16B    21 D03D        C      	ld	hl,synflg
                         C      
  D16E    FE DF          C      	cp	ctlc		;Ersatz-Control-Taste ?
  D170    20 05          C      	jr	nz,kbdnct	;nein
  D172    7E             C      	ld	a,(hl)
  D173    EE 01          C      	xor	1 shl ctrlst	;CTRL-Status umkehren
  D175    77             C      	ld	(hl),a
  D176    C9             C      	ret			;und Zeichen ignorieren
  D177                   C      kbdnct:
                         C      
                         C       IF stpvar
  D177    CB 7E          C      	bit	phyact,(hl)	;Taste physisch in Puffer?
  D179    C2 D1C2        C      	jp	nz,kbdput	;ja, direkt ablegen
                         C       ENDIF
                         C       IF costu
                         C       ENDIF
  D17C    2A D03B        C      	ld	hl,(kbdsst)	;Adresse der Standardstringtabelle
  D17F    CD D299        C      	call	costr		;Standardstring?
  D182    28 07          C      	jr	z,kbdnco	;nein
  D184    1D             C      kbdco:	dec	e		;String der Laenge 0?
  D185    C8             C      	ret	z		;ja, zu ignorierende Taste
  D186    1D             C      	dec	e		;String exakt ein Zeichen lang?
  D187    C2 D1D9        C      	jp	nz,kbdco1	;nein, kann keine Sondertaste sein
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-25


  D18A    7E             C      	ld	a,(hl)		;holen erstes Stringzeichen
  D18B    21 D03D        C      kbdnco:	ld	hl,synflg
                         C      
                         C      ; Auswertung Sondertasten, die nicht im Puffer abgelegt werden
                         C      ;-------------------------------------------------------------
                         C      
  D18E    FE DE          C      	cp	stpc		;STOP ?
  D190    20 0A          C      	jr	nz,kbdnst
  D192    CB E6          C      	set	stoprq,(hl)	;Stop-Request vermerken
                         C      
                         C      ; Rest des Konsolpuffers streichen
                         C      ;---------------------------------
  D194    AF             C      kbdbcl:	xor	a
                         C       IF cpastz
                         C       ENDIF
  D195    32 FFFF        C      	ld	(0ffffh),a
  D196                   C      crtm36	equ	$-2
                         C       IF cpastz
                         C       ENDIF
  D198    32 D162        C      	ld	(kbdbfe),a
  D19B    C9             C      	ret
                         C      
  D19C                   C      kbdnst:
                         C       IF stpvar
                         C       IF chdvar
  D19C    FE D9          C      	cp	SyLc		;Drucker Synchronisieren?
  D19E    20 03          C      	jr	nz,kbdnsy	;nein
  D1A0    CB DE          C      	set	synlrq,(hl)	;sonst vermerken
  D1A2    C9             C      	ret
  D1A3                   C      kbdnsy:
  D1A3    FE DA          C      	cp	HrLc		;Hardcopy ein/aus ?
  D1A5    20 0C          C      	jr	nz,kbdnhc
  D1A7    21 D00C        C      	ld	hl,conol
  D1AA    7E             C      	ld	a,(hl)
  D1AB    EE 0E          C      	xor	0cdh xor 0c3h	;CALL aus JP u.umgekehrt
  D1AD    77             C      	ld	(hl),a
  D1AE    3E 80          C      	ld	a,1 shl lmphcp	;Hardcopy-Lampe
  D1B0    C3 D2AB        C      	jp	kbdslm
  D1B3                   C      kbdnhc:
                         C       ENDIF
                         C       ENDIF	;stpvar
                         C      
                         C       IF monitor
                         C       ENDIF
                         C      
  D1B3    FE D1          C      	cp	Sel0		;Selector 0?
  D1B5    38 09          C      	jr	c,kbdnsl	;nein
  D1B7    FE D9          C      	cp	Sel3+1		;Selector 0..3?
  D1B9    30 05          C      	jr	nc,kbdnsl	;nein
  D1BB    E6 0F          C      	and	0fh		;Bit 0..3
  D1BD    C3 D2AB        C      	jp	kbdslm
  D1C0                   C      kbdnsl:
  D1C0    B7             C      	or	a		;Taste zu ignorieren?
  D1C1    F8             C      	ret	m		;ja
                         C      
                         C      ; Zeichen im Puffer ablegen
                         C      ;--------------------------
  D1C2                   C      kbdput:
                         C       IF cpastz
                         C       ENDIF
  D1C2    21 FFFF        C      	ld	hl,0ffffh	;Pufferadresse
  D1C3                   C      crtm35	equ	$-2
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-26


  D1C5    01 0014        C      	ld	bc,kbdbl	;Pufferlaenge
  D1C8    5F             C      	ld	e,a		;A retten
  D1C9    AF             C      	xor	a		;Pufferende-Kennzeichen
  D1CA    ED B1          C      	cpir
  D1CC    20 08          C      	jr	nz,kbdpt1	;Puffer voll
  D1CE    77             C      	ld	(hl),a		;neues Pufferende anzeigen
  D1CF    7B             C      	ld	a,e		;A wiederherstellen
  D1D0    2B             C      	dec	hl
  D1D1    77             C      	ld	(hl),a		;Zeichen puffern
                         C      ;um bei Arbeit mit Anzeige des Tastaturpuffers in Statuszeile
                         C      ;Bildschirmflimmern zu vermeiden hinterlegen des gepufferten Zeichens
                         C      ;ausserhalb des Bildschirmbereichs fuer Test, ob ueberhaupt etwas im Puffer
