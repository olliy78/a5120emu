  E4F6                   C      intraf:				;allg. Interr.-ausgang
  E4F6    F1             C      	pop	af
  E4F7    31 0000        C      	ld	sp,0
  E4F8                   C      intsp	equ	$-2
  E4FA                   C      intret:				;allg. Interr.-ausgang
  E4FA    FB             C      	ei
  E4FB    ED 4D          C      	reti
