BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-125


                         C      ; 07.11.88
                         C      ; - Erweiterung um K7634-spezifische Tasten
                         C      ;14.01.89
                         C      ; - Einbau K7633
                         C      ;16.02.89
                         C      ; - Ueberwachung der Tabellenlaenge zur Modifizierung der Tastaturcodes
                         C      ;22.03.89
                         C      ; - INSLINE -> spcins  bei K7634 in Umkodierungstabelle aufgenommen
                         C      ; - bei K7633 war KORR und ABBR vertauscht
                         C      ;07.08.89
                         C      ; - Fehlerkorrektur K7637: CTRL-Ersatztaste brachte kein ^Q-Prefix
                         C      
  051C    AF             C      	xor	a
  051D    32 FFFF        C      	ld	(0ffffh),a	;;Tastaturpuffer leeren
  051E                   C      crtm43	equ	$-2
                         C      
                         C       IF costu
                         C       ENDIF
                         C      
                         C      ;;automatische Tastaturerkennung
                         C      ;;~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
                         C       IF kbdpin
                         C       ENDIF
  0520    06 03          C       	ld	b,3
  0522    11 0400        C      ciini1:	ld	de,400h
  0525    1B             C      ciini2:	dec	de
  0526    DB 06          C      	in	a,(kbdpci)	;;ueberlesen Tastaturzeichen
  0528    7A             C      	ld	a,d
  0529    B3             C      	or	e
  052A    20 F9          C      	jr	nz,ciini2
  052C    10 F4          C      	djnz	ciini1
                         C      
  052E    DB 01          C      	in	a,(kbdpcs)	;;Status einer leeren Tastatur
  0530    E6 08          C      	and	8		;;ist Taste gedrueckt?
  0532    20 06          C      	jr	nz,ciini3	;;nein
  0534    32 063B        C      	ld	(coistc),a	;;sonst cpl -> nop
  0537    32 D235        C      	ld	(kbdstc),a
  053A                   C      ciini3:
                         C      
  053A                   C      ciisrt:		;;Eingang fuer Wiederholen Tastatur-Abfrage
  053A    AF             C      	xor	a
  053B    D3 03          C      	out	(kbdp3o),a	;;ruecksetzen K7634/36
                         C       IF kbdotp eq 3
                         C       ENDIF
  053D    ED 4B 063D     C      	ld	bc,(kbdsmt)
  0541    06 05          C      	ld	b,00000101b	;;di/zeitg/vt16/neg.fl/strt/zk
  0543    ED 41          C      	out	(c),b		;;Zeitgeber fuer IFSS-Tastatur
  0545    06 01          C      	ld	b,1		;;Zeitkonstante 9600bd
  0547    ED 41          C      	out	(c),b
  0549    ED 4B 063F     C      	ld	bc,(kbdsms)
  054D    06 0A          C      	ld	b,k37prl	;;ruecksetzen K7637
  054F    21 0641        C      	ld	hl,k37par
  0552    ED B3          C      	otir			;;SIO initialisieren
  0554    ED 4B 063E     C      	ld	bc,(kbdsmi)
  0558    AF             C      	xor	a		;;reset an Tastatur
  0559    ED 79          C      	out	(c),a
                         C      ;; Bediensicherung nach RESET wird als unzulaessiges Zeichen
                         C      ;; bei der normalen Tastatureingabe ignoriert
