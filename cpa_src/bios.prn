                         C       IF dsk8mf
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-71


                         C       ENDIF
  DD2C    18 03          C      	jr	dsktra		;belieb. SektId lesen
                         C      	ENDIF
                         C      
                         C      
                         C      ; gemeinsamer Zweig Read/Write 128-Sektor einzeln
                         C      ;================================================
  DD2E                   C      drwsec:
  DD2E    21 DEFB        C      	ld	hl,dcdb
                         C      
                         C      ; interner Aufruf phys. Diskettentransfer
                         C      ;----------------------------------------
                         C      ; i HL auf CDB
  DD31                   C      dsktra:
                         C       IF dev eq cpd
                         C       ENDIF
                         C      
                         C      ;*********************************************************
                         C      ; Umkleidung des physischer Disketten-Transfers
                         C      ;*********************************************************
                         C      
                         C      ; Parameter: HL auf CDB mit folgender Struktur:
                         C      ; +0: cdbfl	;Flags	(Struktur angepasst an ft.kom)
  0000                   C      diof00	equ	0	;** frei fuer Anw. ** (frueher Verify nach Schreiben)
  0001                   C      diofid	equ	1	;fest	;=1, wenn nur Sektid. zu lesen
  0002                   C      diofwr	equ	2	;fest	;=1, wenn Schreiben
  0003                   C      dioffm	equ	3	;fest	;=1, wenn temporaer FM-Format erzwungen
  0004                   C      dioftr	equ	4		;=1, wenn keine Fehlermeldung (und -behandlg)
  0005                   C      diofhd	equ	5		;=1, wenn Kopf hochnehmen ("headup")
  0006                   C      diofps	equ	6		;=1, wenn trk,sid,sec schon physisch
  0007                   C      diofs1	equ	7	;fest	;=1, wenn Rueckseite
                         C      
                         C      ; ab hier unwichtig bei "diofhd" in cdbfl =1 (headup)
                         C      ; +1: cdbdev	;logisches Geraet 0 .. dphnb-1
                         C      ; +2: cdbtrk	;log./phys. Spur
                         C      ; +3: cdbsid	;bel./phys. Seite
                         C      ; +4: cdbsec	;log./phys. Sektor
                         C      ; +5: cdbslc	;Sektorlaengencode (0=128, 1=256, 2=512, 3=1024)
                         C      ; +6: cdbsnb	;Anz. zu uebertr. ph. Sekt. (wenn =0, so nur position.)
                         C      ; ab hier nur wichtig, wenn "diofid" in cdbfl =0:
                         C      ; +7,8: cdbdma	;Transferadresse
                         C      
                         C      ; Return, falls nicht "diofhd" in cdbfl =1:
                         C      ;	A=0 (ret z) bei fehlerfrei, sonst A=1 (ret nz) bei cdbfl, "dioftr" =0
                         C      ;	oder Returncode phys. Transfer
                         C      ;	E:=trk, D:=sid ,L:=sec, H:=len
                         C      ;	BC,IX unveraendert
                         C      
  DD31                   C      diskio:	;Aufruf ueber Sprungvektor von BIOS-Erweiterung
  DD31    C5             C      	push	bc
  DD32    11 DF0C        C      	ld	de,diocdb	;CDB des Nutzers auf internen Hilfsspeicher
  DD35    01 0009        C      	ld	bc,diocdl	;da modifiziert
  DD38    D5             C       	push	de
                         C       IF dev eq cpd
                         C       ELSE
  DD39    ED B0          C      	ldir
                         C       ENDIF
  DD3B    E1             C      diskii:	pop	hl		;hl auf diocdb
  DD3C    C1             C      	pop	bc
                         C      
  DD3D    CB 6E          C      	bit	diofhd,(hl)	;Kopf hochnehmen?
                         C       IF disknb ne 0
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-72


  DD3F    C2 E1D0        C      	jp	nz,headup	;ja, kein Transfer
                         C       ENDIF
  DD42    C5             C      	push	bc
  DD43    DD E5          C      	push	ix
  DD45    E5             C      	push	hl
  DD46    23             C       	inc	hl
  DD47    4E             C      	ld	c,(hl)		;logisches Laufwerk
  DD48    CD E794        C      	call	dgetpb		;IX auf DPB stellen
  DD4B    E1             C      	pop	hl		;wiederherstellen hl
  DD4C    3E 44          C      	ld	a,'D'		;falls LW nicht ex.
  DD4E    CA DE05        C      	jp	z,dioert	;LW ex. nicht
                         C      
                         C       IF hdsk
                         C       ENDIF
  DD51    CB 76          C      	bit	diofps,(hl)	;trk,sid,sec schon physisch?
  DD53    20 5A          C      	jr	nz,diophy	;ja
                         C       IF dsk8mf
                         C       ENDIF
                         C      ; Track, Side und Sector entpsr. Diskettenformat setzen
  DD55    23             C      	inc	hl
  DD56    23             C      	inc	hl
  DD57    56             C      	ld	d,(hl)		;Track
  DD58    5A             C      	ld	e,d		;merken
  DD59    23             C      	inc	hl
  DD5A    23             C      	inc	hl
  DD5B    4E             C      	ld	c,(hl)		;Sektornummer ab 1
  DD5C    0D             C      	dec	c		;Sektornr. ab 0
  DD5D    DD CB 0F 66    C      	bit	dpbf86,(ix+dpbflg)	;Fortsetzung Dsk. auf Ruecks.?
  DD61    20 0C          C      	jr	nz,diots2	;ja
  DD63    DD CB 0F 6E    C      	bit	dpbfds,(ix+dpbflg)	;ungerade Spuren auf Rueckseite?
  DD67    28 29          C      	jr	z,diotrs	;nein, einseitig
  DD69    CB 3A          C      	srl	d		;Spur halbieren
  DD6B    30 25          C      	jr	nc,diotrs	;gerade Spur, Vorderseite
  DD6D    18 12          C      	jr	diots1		;auf Rueckseite
  DD6F    DD 46 14       C      diots2:	ld	b,(ix+dpbtrk)	;log. Spurzahl
  DD72    CB 38          C      	srl	b		;Spuren auf Vorderseite
  DD74    7A             C      	ld	a,d
  DD75    90             C      	sub	b		;Spur auf Vorderseite?
  DD76    38 1A          C      	jr	c,diotrs	;ja, Spur in d unveraendert lassen
                         C      				;40 ->  0; 41 ->  1; ...; 79 ->  39
                         C      				;77 ->  0; 78 ->  1; ...;153 ->  76
  DD78    DD CB 0F 5E    C      	bit	dpbfsv,(ix+dpbflg)	;Ruecks. von aussen nach innen?
  DD7C    20 02          C      	jr	nz,diots4	;ja
  DD7E    2F             C      	cpl			;40 -> -1; 41 -> -2; ...; 79 -> -40
                         C      				;77 -> -1; 78 -> -2; ...;153 -> -77
  DD7F    80             C      	add	a,b		;40 -> 39; 41 -> 38; ...; 79 ->   0
                         C      				;77 -> 76; 78 -> 75; ...;153 ->   0
  DD80    57             C      diots4:	ld	d,a
  DD81    3A DF0C        C      diots1:	ld	a,(diocfl)
  DD84    CB FF          C      	set	diofs1,a	;vermerken Rueckseite
  DD86    32 DF0C        C      	ld	(diocfl),a
  DD89    DD 7E 13       C      	ld	a,(ix+dpbsn0)	;Versch. der Sektornr. auf Rueckseite
  DD8C    81             C      	add	a,c		;Sektornr. evtl. weiterzaehlen
                         C      ;;;	cp	c		;Weiternummerierung auf Rueckseite?
  DD8D    4F             C      	ld	c,a
                         C      ;;;	jr	nz,diotrs	;ja, dann side:=0
  DD8E    3E 01          C      	ld	a,1		;side:=1
  DD90    18 01          C      	jr	diotss
  DD92    AF             C      diotrs:	xor	a		;side:=0
  DD93    32 DF0F        C      diotss:	ld	(diocsi),a	;phys. Seite setzen
  DD96    7A             C      	ld	a,d
  DD97    32 DF0E        C      	ld	(dioctr),a	;phys. Spur setzen
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-73


                         C      
  DD9A    7B             C      	ld	a,e		;log. Spurnr. zurueck nach A
  DD9B    DD E5          C      	push	ix
  DD9D    E1             C      	pop	hl
  DD9E    11 0019        C      	ld	de,dpbstr	;d:=0
  DDA1    19             C      	add	hl,de
  DDA2    DD BE 0D       C      	cp	(ix+dpbofs)	;Systemspur?
  DDA5    38 03          C      	jr	c,diossp	;ja, Sektornummern nicht logisch
  DDA7    59             C      	ld	e,c
  DDA8    19             C      	add	hl,de		;HL entspr. Index in dpbstr
  DDA9    4A             C      	ld	c,d		;c:=0
  DDAA    79             C      diossp:	ld	a,c		;phys. Sektornr. ab 0
  DDAB    86             C      	add	a,(hl)		;+echte Sektornr.
  DDAC    32 DF10        C      	ld	(diocse),a	;phys. Sektor setzen
  DDAF                   C      diophy:
                         C      
                         C      ; i ret, BC, IX im Stack
                         C      ; i cdb auf diocdb
                         C      ; i IX auf DPB
                         C      
  DDAF                   C      diorty:	;interne Wiederholung diskio
  DDAF    DD E5          C      	push	ix		;retten IX fuer evtl. Wiederholung
  DDB1    21 DF0C        C      	ld	hl,diocdb
  DDB4    E5             C      	push	hl
  DDB5    7E             C      	ld	a,(hl)		;side 0/1, -/FM, read/write, -/sectid l.
  DDB6    E6 8E          C       and (1 shl diofs1)+(1 shl dioffm)+(1 shl diofwr)+(1 shl diofid)
  DDB8    47             C      	ld	b,a
  DDB9    DD 7E 18       C      	ld	a,(ix+dpbtyp)	;5"/8", FM/MFM, 40/80, Verify nach Schreiben
  DDBC    E6 78          C       and (1 shl dpbt80)+(1 shl dpbt5z)+(1 shl dpbtdd)+(1 shl dpbtwv) ;aus DPB
  DDBE    A8             C      	xor	b
                         C       IF dsk8mf
                         C       ENDIF
  DDBF    CB 66          C      	bit	dioftr,(hl)	;Fehlerbehandlung unterdruecken?
  DDC1    28 01          C      	jr	z,dionft	;nein
  DDC3    3C             C      	inc	a
  DDC4                   C      dionft:
  DDC4    32 E1ED        C      	ld	(ft.kom),a	
                         C      
  DDC7    23             C      	inc	hl
  DDC8    DD 7E 15       C      	ld	a,(ix+dpbdnr)	;physische LW-Nr.
  DDCB    32 E1F0        C      	ld	(ft.lwn),a
                         C      
  DDCE    23             C      	inc	hl
  DDCF    7E             C      	ld	a,(hl)
  DDD0    32 E1F1        C      	ld	(ft.trk),a
  DDD3    23             C      	inc	hl
  DDD4    7E             C      	ld	a,(hl)
  DDD5    32 E1F2        C      	ld	(ft.sid),a
  DDD8    23             C      	inc	hl
  DDD9    7E             C      	ld	a,(hl)
  DDDA    32 E1F3        C      	ld	(ft.sec),a
  DDDD    23             C      	inc	hl
  DDDE    7E             C      	ld	a,(hl)
  DDDF    32 E1F4        C      	ld	(ft.len),a
  DDE2    23             C      	inc	hl
  DDE3    7E             C      	ld	a,(hl)
  DDE4    32 E1F5        C      	ld	(ft.anz),a
                         C      
  DDE7    DD 7E 12       C      	ld	a,(ix+dpbstp)	;Anzahl der Stepimpulse
  DDEA    32 E1F6        C      	ld	(ft.stp),a
                         C      
  DDED    DD 7E 17       C      	ld	a,(ix+dpbsti)	;Schrittzeit
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-74


  DDF0    32 E1F7        C      	ld	(ft.sti),a
                         C      
  DDF3    2A DF13        C      	ld	hl,(diocad)
  DDF6    22 E1EE        C      	ld	(ft.adr),hl
                         C      
                         C       IF stpvar or monitor
  DDF9    CD E5E7        C      	call	delsps		;Sondertasten verbieten
                         C       ENDIF
                         C       IF hdsk
                         C       ELSE
  DDFC    CD DF15        C      	call	floppy		;$$$ phys. Transfer $$$
                         C       ENDIF
                         C       IF stpvar or monitor
  DDFF    CD E5F4        C      	call	delspr		;Sondertasten wieder erlauben
                         C       ENDIF
                         C      
  DE02    E1             C      	pop	hl		;HL wieder auf Paramfeld-Adresse
  DE03    DD E1          C      	pop	ix		;IX wieder auf DPB
                         C      
  DE05                   C      dioert:
                         C      ; Fehlerprotokoll
  DE05    CB 66          C      	bit	dioftr,(hl)	;Fehlerprotokoll und -behandlung  unterdr.?
  DE07    20 33          C      	jr	nz,dtrok	;ja
  DE09    B7             C      	or	a		;Returncode
  DE0A    28 30          C      	jr	z,dtrok		; -> fehlerfrei
  DE0C    FE 52          C      	cp	'R'		;not ready?
  DE0E    CA DDAF        C      	jp	z,diorty	;ja, Wiederholung
                         C      
                         C       IF errvar
  DE11    32 DED2        C      	ld	(derrcd),a	;Fehlercode
  DE14    CB 56          C      	bit	diofwr,(hl)	;war lesen?
  DE16    3E 52          C      	ld	a,'R'
  DE18    28 02          C      	jr	z,derrr		;ja
  DE1A    3E 57          C      	ld	a,'W'
  DE1C    32 DED1        C      derrr:	ld	(derrrw),a
                         C        IF dev eq cpd
                         C        ELSE
  DE1F    21 E1F1        C      	ld	hl,ft.trk	;phys. Spur
  DE22    11 DEDC        C      	ld	de,derrtr
  DE25    CD E6D3        C      	call	mbreco
  DE28    21 E1F2        C      	ld	hl,ft.sid	;Seite
  DE2B    CD E6D3        C      	call	mbreco
  DE2E    21 E1F3        C      	ld	hl,ft.sec	;Sektor
  DE31    CD E6D3        C      	call	mbreco
                         C        ENDIF
  DE34    21 DECF        C      	ld	hl,derrms
  DE37    CD E6B9        C      	call	biosms
                         C       ENDIF
  DE3A    3E 01          C       	ld	a,1		;return mit Fehler
                         C      
  DE3C    B7             C      dtrok:	or	a		;stellen Z-Flag
  DE3D    ED 5B E1F1     C      	ld	de,(ft.trk)	;E:=trk, D:=sid
  DE41    2A E1F3        C      	ld	hl,(ft.sec)	;L:=sec, H:=len
  DE44    DD E1          C      	pop	ix
  DE46    C1             C      	pop	bc
  DE47    C9             C      	ret
                         C      
                         C       IF	format
                         C      
                         C      ; Stellen HL entsprechend Sektorlaengencode in (A)
                         C      ;=================================================
                         C      ; ret nz bei unzulaessigem
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-75


  DE48    B7             C      dtrsla:	or	a
  DE49    21 DE5C        C      	ld	hl,dtrsl0
  DE4C    C8             C      	ret	z		;=0 (128)
  DE4D    3D             C      	dec	a
  DE4E    21 DE70        C      	ld	hl,dtrsl1	;=1 (256)
  DE51    C8             C      	ret	z
  DE52    3D             C      	dec	a
  DE53    21 DE84        C      	ld	hl,dtrsl2	;=2 (512)
  DE56    C8             C      	ret	z
  DE57    3D             C      	dec	a
  DE58    21 DE98        C      	ld	hl,dtrsl3	;=3 (1024)
  DE5B    C9             C      	ret
                         C      
                         C       ENDIF
                         C      
                         C      ;************************************************
                         C      ;	Steuertabellen
                         C      ;************************************************
                         C      
                         C      
                         C       IF	format
                         C      ; Modifizierungstabellen entspr. Sektorlaenge und LW-Typ
                         C      ;-------------------------------------------------------
                         C      
                         C      ; Struktur:
                         C      
  0000                   C      dsltrk	equ	0		;benutzte Spuren
  0001                   C      dslspt	equ	dsltrk+1	;Sektoren/Spur
  0002                   C      dsldir	equ	dslspt+1	;Dir-Eintraege
  0003                   C      dsloff	equ	dsldir+1	;2*offset
                         C      				;[+Flag fuer festes offset]
  0001                   C      dslfo	equ	1		;festes offset
  0000                   C      dslvo	equ	0		;offset =0, falls Directory mgl.
  0004                   C      dslblk	equ	dsloff+1	;rel. Adr. Tab. BDOS-Blockgroesse
  0005                   C      dsll	equ	5		;Laenge eines Eintrags
                         C      
                         C      ; Reihenfolge
                         C      ; 5", 40 Tr, SS
                         C      ; 5", 80 Tr, SS
                         C      ; 5", 40 Tr, DS
                         C      ; 5", 80 Tr, DS
                         C       if	disk8
                         C       endif
                         C      
                         C      ; Zur automatischen Bestimmung des Spurformats wird dasjenige
                         C      ; Format der Spur "dlgint" benutzt, alle folgenden Spuren
                         C      ; muessen das gleiche Format haben!
  0003                   C      dlgint	equ	3	;groesste Anzahl SS-Systemspuren
                         C      
                         C      ; 128
  DE5C                   C      dtrsl0:	
  DE5C    28 1A 3F 04    C      	db	40,26,63,2*2+dslvo,dbl1k-$	;CP/M Standard
  DE60    4C             C      
  DE61    50 1A 7F 04    C      	db	80,26,127,2*2+dslvo,dbl2k-$
  DE65    4A             C      
  DE66    50 1A 7F 01    C      	db	80,26,127,2*0+dslfo,dbl2k-$
  DE6A    45             C      
  DE6B    A0 1A 7F 01    C      	db	160,26,127,2*0+dslfo,dbl2k0-$
  DE6F    43             C      
                         C      
                         C      	if	disk8
                         C      	endif
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-76


                         C      
                         C      ; 256
  DE70                   C      dtrsl1:	
  DE70    28 20 3F 07    C      	db	40,32,63,2*3+dslfo,dbl2k-$	;SCP Hausformat A51xx
  DE74    3B             C      
  DE75    50 20 3F 07    C      	db	80,32,63,2*3+dslfo,dbl2k-$	;SCP
  DE79    36             C      
  DE7A    50 20 7F 09    C      	db	80,32,127,2*4+dslfo,dbl2k-$
  DE7E    31             C      
  DE7F    A0 20 7F 09    C      	db	160,32,127,2*4+dslfo,dbl2k0-$	;SCP Hausformat PC1715
  DE83    2F             C      
                         C      
                         C      	if	disk8
                         C      	endif
                         C      
                         C      ; 512
  DE84                   C      dtrsl2:	
  DE84    28 24 00 01    C      	db	40,36,0,2*0+dslfo,dbl1k-$
  DE88    24             C      
  DE89    50 24 00 01    C      	db	80,36,0,2*0+dslfo,dbl2k-$
  DE8D    22             C      
  DE8E    50 24 00 01    C      	db	80,36,0,2*0+dslfo,dbl2k-$
  DE92    1D             C      
  DE93    A0 24 00 01    C      	db	160,36,0,2*0+dslfo,dbl2k0-$
  DE97    1B             C      
                         C      
                         C      	if	disk8
                         C      	endif
                         C      	
                         C      ; 1024
  DE98                   C      dtrsl3:	
  DE98    28 28 3F 04    C      	db	40,40,63,2*2+dslvo,dbl1k-$	;CP/A Standard A51xx
  DE9C    10             C      
  DE9D    50 28 7F 04    C      	db	80,40,127,2*2+dslvo,dbl2k-$	;CP/A
  DEA1    0E             C      
  DEA2    50 28 7F 00    C      	db	80,40,127,2*0+dslvo,dbl2k-$	;CP/A
  DEA6    09             C      
  DEA7    A0 28 BF 08    C      	db	160,40,191,2*4+dslvo,dbl2k0-$	;CP/A (und SCP)
  DEAB    07             C      
                         C      
                         C      	if	disk8
                         C      	endif
                         C      
                         C      ; Modifizierungstabellen fuer BDOS-Blockgroesse
  DEAC    03 07 00       C      dbl1k:	db	3,7,0		;Bl. Shift, Bl. Mask, Ext. Mask
  DEAF    04 0F 01       C      dbl2k:	db	4,0fh,1
  DEB2    04 0F 00       C      dbl2k0:	db	4,0fh,0		;fuer Kapazitaet >255
                         C      
                         C      ; log. Sektortranslate-Tabelle fuer 26*128
  DEB5    01 07 0D 13    C      xlt:	db	1,7,13,19,25,5,11,17,23,3,9,15,21
  DEB9    19 05 0B 11    C      
  DEBD    17 03 09 0F    C      
  DEC1    15             C      
  DEC2    02 08 0E 14    C      	db	2,8,14,20,26,6,12,18,24,4,10,16,22
  DEC6    1A 06 0C 12    C      
  DECA    18 04 0A 10    C      
  DECE    16             C      
                         C      
                         C       ENDIF	;format
                         C      
                         C      	include BIOSDSKW
                         C      ;;***************************************************************
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-77


                         C      ;;	Arbeitsbereiche logischer Floppy-Treiber im System-RAM *
                         C      ;;***************************************************************
                         C      ;; 03.06.89
                         C      
                         C       IF errvar
                         C      ;; Fehlermeldung Disk I/O Error
                         C      ;;=============================
                         C      ;; Genau so lang (kurz), wie in Statuszeile Platz dafuer da ist!
                         C      ;; und das sind 17 Bytes!
  DECF                   C      derrms:
                         C       IF cpastz
                         C       ELSE
  DECF    0D 0A          C      	db	0dh,0ah
                         C       ENDIF
  DED1    58             C      derrrw:	db	'X'
  DED2    58 3B 54 2C    C      derrcd:	db	'X;T,Si,Se='
  DED6    53 69 2C 53    C      
  DEDA    65 3D          C      
  DEDC    58 58          C      derrtr:	db	'XX'
  DEDE    58 58          C      derrts:	db	'XX'
  DEE0    58 58          C      derrsc:	db	'XX'
                         C       IF cpastz
                         C       ELSE
  DEE2    07 00          C      	db	07h,0
                         C       ENDIF
                         C      
                         C       ENDIF
                         C      
                         C      ;; CDB's
                         C      ;;======
                         C      
                         C      ;;CDB fuer Bestimmung Laufwerksbereitschaft bei Select Disk
                         C      ;;--------------------------------------------------------
  DEE4                   C      drdcdb:
  DEE4    10             C      drdflg:	db	(1 shl dioftr)	;;Lesen, kein Fehlerprotokoll
  DEE5    FF             C      drddev:	db	0ffh		;;Geraet
  DEE6    0000           C      drdtrk:	dw	0		;;Spur
  DEE8    01             C      	db	1		;;Sektor (bel.)
  DEE9    01             C      	db	1		;;Sektorlaengencode (>0, 1..3)
  DEEA    00             C      	db	0		;;Sektoranzahl=0 -> nur Positionieren
                         C      
                         C      	IF	format
                         C      ;; CDB fuer Bestimmung Spurformat
                         C      ;;------------------------------------
  DEEB                   C      dfrcdb:
  DEEB    12             C      dfrflg:	db	(1 shl diofid)+(1 shl dioftr)
                         C      ;;		Lesen Sektorid., kein Fehlerprotokoll
  DEEC    FF             C      dfrmdv:	db	0ffh		;;Geraet
  DEED    FF             C      dfrmtr:	db	0ffh		;;Spur
  DEEE    FF             C      	db	0ffh		;;Seite (bel.)
  DEEF    01             C      	db	1		;;Sektor (bel.)
  DEF0    01             C      	db	1		;;Sektorlaengencode (>0, 1..3)
  DEF1    01             C      	db	1		;;Sektoranzahl (>0)
                         C      	ENDIF
                         C      
                         C      	IF	format or (dbufsz gt 7)
                         C      ;; Puffer-CDB
                         C      ;;-----------
  DEF2                   C      dbcdb:
  DEF2    00             C      dbflg:	db	0
  0000                   C      dfbprr	equ	diof00		;;=1, wenn Puffer erst gelesen 
                         C      ;;				     werden muss
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-78


  0002                   C      dfbwr	equ	diofwr		;;=1, wenn Puffer durch
                         C      ;;				     Schreiben veraendert
  0004                   C      dfbtr	equ	dioftr		;;=1, wenn mit Fehlerprotokoll
                         C      ;; restliche Bits immer =0
  DEF3    FF             C      dbdev:	db	0ffh
  DEF4    FF             C      dbtrk:	db	0ffh
  DEF5    FF             C      dbsid:	db	0ffh
  DEF6    FF             C      dbsec:	db	0ffh
  DEF7    FF             C      dbslc:	db	0ffh
  DEF8    FF             C      dbsnb:	db	0ffh
                         C      	IF	dbufsz gt 7
  DEF9    F282           C      dbdma:	dw	dbuf
                         C      	ENDIF
                         C      	ENDIF
                         C      
                         C      ;; CDB fuer ungepufferte E/A
                         C      ;;--------------------------
                         C      
  DEFB                   C      dcdb:
  DEFB    00             C      dflg:	db	0
  0002                   C      dfwr	equ	diofwr 		;;=1, wenn write-Aufruf
                         C      ;; restliche Bits immer =0
  DEFC    00             C      ddrive:	db	0
  DEFD    FF             C      dtrack:	db	0ffh
  DEFE    FF             C      	db	0ffh		;;Seite
  DEFF    FF             C      dsectr:	db	0ffh
  DF00    00             C      	db	0		;;128 Bytes Sektorlaenge
  DF01    01             C      	db	1		;;immer nur 1 Sektor
  DF02    FFFF           C      ddma:	dw	0ffffh
                         C      
                         C       if ramfl
  DEFD                   C      rtrack	equ	dtrack
                         C       endif
                         C      
                         C      ;; Pufferzugriff
                         C       IF @write
                         C       IF dbufsz gt 7
  DF04    00 FF FF FF    C      unacnt:	db	0,0ffh,0ffh,0ffh,0
  DF08    00             C      
  DF05                   C      unadev	equ	unacnt+1
  DF06                   C      unatrk	equ	unacnt+2
  DF08                   C      unasec	equ	unacnt+4
                         C       ENDIF
                         C       ENDIF
                         C       IF dbufsz gt 7
  DF09    FF             C      dbnb:	db	0ffh
  DF0A    FF             C      dwrtyp:	db	0ffh
  DF0B    00             C      dberrf:	db	0		;;Ergebnisflag letztes dbtran
                         C       ENDIF
                         C      	include BIOSDSKB
                         C      ;;***************************************************************
                         C      ;;	Arbeitsbereiche logischer Floppy-Treiber im BIOS-RAM   *
                         C      ;;***************************************************************
                         C       IF dev eq cpd
                         C       ELSE
  DF0C                   C      diocdb:	ds	9,0ffh
                         C       ENDIF
  DF0C                   C      diocfl	equ	diocdb+0
  DF0D                   C      diocde	equ	diocdb+1
  DF0E                   C      dioctr	equ	diocdb+2
  DF0F                   C      diocsi	equ	diocdb+3
  DF10                   C      diocse	equ	diocdb+4
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-79


  DF11                   C      diocsl	equ	diocdb+5
  DF12                   C      diocsn	equ	diocdb+6
  DF13                   C      diocad	equ	diocdb+7
  0009                   C      diocdl	equ	9		;;Anzahl der Bytes
                         C      
                         C       IF dev eq cpd
                         C       ELSE
                         C        IF disknb eq 0
                         C        ENDIF
                         C       ENDIF
                                 IF disknb ne 0
                         C      	include BIOSDSKT
                         C      ;*********************************************************
                         C      ; physischer Disketten-Transfer
                         C      ; Aenderungen:
                         C      ; - Es koennen 9 statt bisher 4 phys. Sektoren auf einmal gelesen werden
                         C      ;!-!Schnittstellenaenderung bei SektId lesen:
                         C      ;   ft.anz muss <>0 sein (zuvor beliebig, bei =0 kein Transfer)
                         C      ;   ft.len muss 0..3 sein (zuvor beliebig, bei >3 fehlerhafte Tabellenmodif.)
                         C      ;   ft.kom, Bit 7 eingefuehrt: =0 Vorderseite, =1 Rueckseite
                         C      ;   ft.kom, Bit 0 (Verify nach Schreiben) auf Bit 6 verlegt
                         C      ;   ft.kom, Bit 0 =1 bedeutet "keine Fehlerwiederholung"
                         C      ; - Floppy-Treiber auch fuer Variante K5120/22 generierbar
                         C      ; 06.07.88
                         C      ; - Motor-Start-Wait von 254 auf 252 veraendert (2.5 Umdrehungen)
                         C      ;   (ist bei einigen Laufwerken wegen PreReady notwendig)
                         C      ; 03.11.22
                         C      ; - Variante K5122 eingefuegt
                         C      ; 25.09.89
                         C      ; - bei MFS 1.2 bei Mehr-Sektor-Transfer "Fault reset" zwischen den Sektoren
                         C      ;*********************************************************
                         C      
                         C      ; Aufruf:
                         C      ; -------
                         C      ; Bereitstellung der Parameter auf den Bytes:
                         C      
                         C      ;       ft.kom:	db	0	; bit0 - =1 ohne Fehlerwiederholung
                         C      ;				     1 - =1 lesen ft.len von beliebigem Sektor
                         C      ;				     2 - =0 lesen ; =1 schreiben Sektor(en)
                         C      ;				     3 - =0-FM; =1-MFM   (5"FM nur bei PC1715)
                         C      ;				     4 - =0-8"; =1-5"
                         C      ;				     5 - =0- 40-Spur-Laufwerk; =1- 80-Spur-LW
                         C      ;				     6 - =1 bei verify nach schreiben
                         C      ;				     7 - =0 Vorderseite, =1 Rueckseite
                         C      ;	ft.adr: dw	0	; Transferadresse
                         C      ;	ft.lwn: db	0	; 0..3 phys. Laufwerksnummer
                         C      ;	ft.trk: db	0	; 0..  track
                         C      ;	ft.sid: db	0	; 0..ff side (side=0 auf Rueckseite moeglich!)
                         C      ;	ft.sec: db	0	; 0..  sector (beliebig bei SektId lesen)
                         C      ;	ft.len: db	0	; 0..3 Sektorlaenge (auch 0..3 bei SektId les.)
                         C      ;	ft.anz: db	0	; 0..9 Anzahl der zu uebertragenden Sektoren
                         C      ;				;      =0: nur Positionieren
                         C      ;				;      (<>0 bei SektId lesen)
                         C      ;       ft.stp: db	0	;      Anzahl der Stepimpulse von Spur zu Spur
                         C      ;	ft.sti: db	0	;      Schrittzeit von Spur zu Spur
                         C      ;				;      in 0,1ms Einheiten
                         C      ;
                         C      ;	call	floppy
                         C      ;       ...			; in A steht Ergebniskode
                         C      ;				; alle Register (auch IX) undef.
                         C      ;
                         C      ; Ergebniskode (in Reg. A):
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-80


                         C      ;	00h kein Fehler (Z-Flag nicht von floppy gesetzt)
                         C      ;	'C' CRC-Fehler
                         C      ;	'D' LW nicht existent
                         C      ;	'R' Geraet nicht bereit, aber existent
                         C      ;	'L' unzulaessige Transferlaenge
                         C      ;	'S' Sektor nicht gefunden
                         C      ;	'T' Spurnummer zu gross
                         C      ;	'U' keine Marke gefunden
                         C      ;	'W' Diskette schreibgeschuetzt
                         C      
                         C      ; Paramfeld wird an folgenden Stellen veraendert:
                         C      ;  Komm. "Lesen Sekt,Id.":	ft.trk .. ft.len gestellt
                         C      ;  Komm. "Schreiben mit Verify":ft.kom, bit 2 geloescht
                         C      ;**************************************************
                         C      
  0004                   C      maxlw	equ	4		; Anzahl der Laufwerke (1..4)
                         C      
                         C      ; Adressen der Floppy-Karte
                         C      ;==========================
                         C      
                         C       IF (fdc eq k5120) or (fdc eq k5122)
                         C      ;Steuer-PIO
  0010                   C      flcoad    equ  10h  ;PORT A
  0011                   C      flcoac    equ  11h
  0012                   C      flcobd    equ  12h  ;PORT B
  0013                   C      flcobc    equ  13h
                         C      
                         C      ;Daten-PIO
  0014                   C      fldaad    equ  14h  ;Port A Schreib-Daten
  0015                   C      fldaac    equ  15h
  0016                   C      fldabd    equ  16h  ;Port B Lese-Daten
  0017                   C      fldabc    equ  17h
                         C      
                         C      ;Select-Latch
  0018                   C      flsel     equ  18h  ;Bit 7..4 /Sel LW3..0;Bit 3..0  /LCK  LW 3..0
                         C      ;
                         C       ENDIF
                         C      
                         C       IF (fdc eq f1715)
                         C       ENDIF
                         C      
                         C      ;; Legende AMF:
                         C      ;;   Port A
                         C      ;;  | 7 | 6 | 5 | 4 | 3 | 2 | 1 | 0 |
                         C      ;;    |   |   |   |   |   |   |   |__ A  /WE  0-Schreiben ein
                         C      ;;    |   |   |   |   |   |   |______ A   MK  lesen  0-MFM-A1 Erkennung
                         C      ;;    |   |   |   |   |   |                          1-FM-Mark., MFM-C2 Erkenn.
                         C      ;;    |   |   |   |   |   |               schreiben  0-Takt fuer MFM
                         C      ;;    |   |   |   |   |   |                          1-Marken FM und A1 MFM
                         C      ;;    |   |   |   |   |   |__________ A  /SIDE 0-Kopf Seite 1; 1-Kopf Seite 0
                         C      ;;    |   |   |   |   |        oder   A  /FR   0-Fault reset;  1-kein FR
                         C      ;;    |   |   |   |   |______________ A  /STR 0-AMF aktiv
                         C      ;;    |   |   |   |                           1-AMF ausgeschaltet
                         C      ;;    |   |   |   |__________________ A   MK1 lesen  0-Informationen einlesen
                         C      ;;    |   |   |                                      1-nur 1 einlesen
                         C      ;;    |   |   |                           schreiben  0-FM-Daten schreiben
                         C      ;;    |   |   |                                      1-MFM und FM-Marken schr.
                         C      ;;    |   |   |______________________ A   MR, SD     0-steppen Richtung aussen
                         C      ;;    |   |                                          1-Marke-erkannt loeschen
                         C      ;;    |   |                                            steppen Richtung innen
                         C      ;;    |   |__________________________ A  /HL         0-Kopf geladen
                         C      ;;    |                                              1-Kopf entladen
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-81


                         C      ;;    |______________________________ A  /ST         0-Stepsignal an LW ein
                         C      ;;                                                   1-Stepsignal an LW aus
                         C      ;;
                         C      ;;  Port B
                         C      ;;  | 7 | 6 | 5 | 4 | 3 | 2 | 1 | 0 |
                         C      ;;    |   |   |   |   |   |   |   |__ E  /RDY  0-Laufwerk bereit
                         C      ;;    |   |   |   |   |   |   |                1-Laufwerk nicht bereit
                         C      ;;    |   |   |   |   |   |   |______ E  /MKE  0-Marke erkannt
                         C      ;;    |   |   |   |   |   |                    1-Marke noch nicht erkannt
                         C      ;;    |   |   |   |   |	 oder PC1715  E   MKE  1-Marke erkannt
                         C      ;;    |   |   |   |   |   | u.K5122            0-Marke noch nicht erkannt
                         C      ;;    |   |   |   |   |   |__________ E  /SYN  ???? (K5120)
                         C      ;;    |   |   |   |   |  oder K5122   A  /HF   0-Takt fuer 8" MFM
                         C      ;;    |   |   |   |   |                        1-Takt fuer 5" MFM und 8" FM
                         C      ;;    |   |   |   |   |  oder PC1715: A   MFM  0-FM-Aufzeichnung
                         C      ;;    |   |   |   |   |                        1-MFM-Aufzeichnung
                         C      ;;    |   |   |   |   |______________ A   PRE  0-schreiben ohne Prekompensation
                         C      ;;    |   |   |   |                            1-schreiben mit         "
                         C      ;;    |   |   |   |__________________ E  /FA   0-Fehler in der AMF aufgetreten
                         C      ;;    |   |   |                                1-kein Fehler aufgetreten
                         C      ;;    |   |   |          oder PC1715: A   FO   0-5"-Disketten
                         C      ;;    |   |   |                                1-8"-Disketten
                         C      ;;    |   |   |______________________ E  /WP   0-Schreibschutz ist ein
                         C      ;;    |   |                                    1-kein Schreibschutz
                         C      ;;    |   |__________________________ E  /FW   0-Laufwerk meldete Schreibfehler
                         C      ;;    |                                        1-Laufwerk meldete keinen Fehler
                         C      ;;    |______________________________ E  /T0   0-Kopf steht auf Spur 0
                         C      ;;                                             1-Kopf steht nicht auf Spur 0
                         C      
                         C      ;$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$
                         C      ;	FLOPPY-Treiber
                         C      ;$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$
  DF15                   C      floppy:
                         C      
                         C      ; Anfangswerte stellen
  DF15    3A E1ED        C      	ld	a,(ft.kom)
  DF18    E6 01          C      	and	1		;Fehlerwiederholung?
  DF1A    20 02          C      	jr	nz,setecr	;nein, A=0+1 (keine Wiederholung)
  DF1C    3E 10          C      	ld	a,15+1
  DF1E    32 E213        C      setecr:	ld	(crerc),a	; Fehlerzaehler fuer CRC-Fehlerwiederholungen
  DF21    20 02          C      	jr	nz,setesp
  DF23    3E 05          C      	ld	a,4+1		; Fehlerzaehler fuer Spurfindewiederholungen
  DF25    32 E214        C      setesp:	ld	(sperc),a
                         C      
                         C      ; Laufwerksnummer pruefen
  DF28    3A E1F0        C      	ld	a,(ft.lwn)	; LW
                         C      ;	cp	maxlw		; LW < groesster LW-Nr.?
                         C      ;	jr	nc,nolw		; -> nein, Fehler: LW nicht existent
  DF2B    4F             C      	ld	c,a		; merken LW fuer Motor-an-Test
  DF2C    47             C      	ld	b,a		; fuer djnz
  DF2D    B7             C      	or	a		; LW=0?
  DF2E    3A E216        C      	ld	a,(lwexis)
  DF31    28 04          C      	jr	z,drv0		; ->ja
  DF33    0F             C      sp13: 	rrca
  DF34    0F             C      	rrca
  DF35    10 FC          C      	djnz	sp13
  DF37    E6 03          C      drv0: 	and	3
  DF39    20 05          C      	jr	nz,drv0a
                         C      
  DF3B    3E 44          C      nolw: 	ld	a,'D'		; LW nicht existent
  DF3D    C3 E0E9        C      	jp	fehret		; -> Fehler
                         C      
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-82


  DF40                   C      drv0a:
                         C      ; LW selektieren und Motor einschalten
  DF40    AF             C      	xor	a
  DF41    32 E1BE        C      	ld	(pretx+1),a	;Motorabschaltung verhindern
  DF44    3D             C      	dec	a		;A:=255
  DF45    CD E1A5        C      	call	fl.sto		;Index-Ueberwachung ein
  DF48    CB D9          C      	set	3,c		; Motor-an-Bit setzen
  DF4A    21 E217        C      	ld	hl,alwnr
  DF4D    7E             C      	ld	a,(hl)
  DF4E    B9             C      	cp	c		; ist es das richtige LW und Motor an?
  DF4F    3E 6A          C      	ld	a,+pvrw2-(xpvrw+2) ; jr z,pvrw2 (keine Vertikalstab.)
  DF51    28 42          C      	jr	z,dskmon	; ->ja, Kopf ist noch aufgesetzt
                         C      ; falsches LW oder Motor des LW aus
  DF53    CD E1D8        C      	call	flres		; alte Spurnr. merken
                         C      
                         C      ; neues LW anwaehlen, Motor einschalten und alte Spurnr. holen
  DF56    71             C      	ld	(hl),c		; neues LW, Motor-an-Bit
  DF57    EB             C      	ex	de,hl		;merken ^alwnr
  DF58    CB 99          C      	res	3,c		; alte Spurnr. holen
  DF5A    06 00          C      	ld	b,0
  DF5C    21 E219        C      	ld	hl,spnrl
  DF5F    09             C      	add	hl,bc
  DF60    7E             C      	ld	a,(hl)
  DF61    32 E218        C      	ld	(aspnr),a
  DF64    41             C      	ld	b,c
  DF65    04             C      	inc	b
  DF66    3E 77          C      	ld	a,077h		; LW-Anwahlbyte bilden (mit Lock)
  DF68    07             C      nfdei2: rlca
  DF69    10 FD          C      	djnz	nfdei2
  DF6B    D3 18          C      	out	(flsel),a	; Laufwerk selektieren (und evtl. Motor ein)
                         C       IF fdc eq f1715
                         C       ENDIF
  DF6D    3E A9          C      	ld	a,10101001b	; Kopf laden, Fault reset
  DF6F    D3 10          C      	out	(flcoad),a
                         C      
                         C      ; Motor-Start
  DF71    2E FD          C      	ld	l,252+1		;von 255 auf 252, d.h. mind 2 Umdrehungen?
  DF73    3A E1ED        C      	ld	a,(ft.kom)
  DF76    CB 67          C      	bit	4,a		;5"?
  DF78    28 06          C      	jr	z,dskmo1	;nein
  DF7A    CB 6F          C      	bit	5,a		;5" 40 Spur?
  DF7C    20 02          C      	jr	nz,dskmo1	;nein
  DF7E    2E FB          C      	ld	l,250+1		;von 255 auf 250,
                         C      				; d.h. mind. 4 volle Umdrehungen?
                         C      				;(bei MFS 1.2 kommt evtl. ready zu frueh)
  DF80                   C      dskmo1:
  DF80    3A E1B6        C      dskdaw:	ld	a,(fl.zto)	;Index-Interrupt-Zaehler
  DF83    BD             C      	cp	l		;entprechend viele Umdrehungen vorbei?
  DF84    38 0D          C      	jr	c,dskda		;ja
  DF86    0D             C      	dec	c		; warten, bis Diskette eingeschoben
  DF87    20 F7          C      	jr	nz,dskdaw
  DF89    10 F5          C      	djnz	dskdaw
  DF8B    EB             C      	ex	de,hl
  DF8C    CB 9E          C      	res	3,(hl)		;loeschen Motor an Bit
  DF8E    3E 52          C      	ld	a,'R'		;LW nicht bereit
  DF90    C3 E0E9        C      	jp	fehret
  DF93    3E 61          C      dskda:	ld	a,+pvrw1-(xpvrw+2) ; jr z,pvrw1 (mit Vertikal-Stabil.)
  DF95                   C      dskmon:
  DF95    32 DFDD        C      	ld	(xpvrw+1),a	; Vertikal-Stabilisierung ein/aus
                         C      
                         C      
                         C       IF dsk8fm+dsk8mf+dsk5fm; Standard ist 5"MFM
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-83


                         C       ELSE
                         C       IF @write
  DF98    21 E3AD        C      	ld	hl,diwmfm
  DF9B    22 E312        C      	ld	(dioop),hl	;Schreiben einstellen (falls Lesen war)
                         C       ENDIF
                         C       ENDIF
                         C       if dsk80
  DF9E    3A E1ED        C      	ld	a,(ft.kom)
                         C       if dsk8fm+dsk8mf
                         C       endif
  DFA1    CB 6F          C      	bit	5,a		;80-Spur-LW?
  DFA3    3E 19          C      	ld	a,25		;Spur, ab der mit Praekomp.
  DFA5    28 02          C      	jr	z,dprec2	;nein
  DFA7    3E 29          C      	ld	a,41
  DFA9    32 E063        C      dprec2:	ld	(dpretr),a
  DFAC                   C      dprecn:
                         C       endif
                         C      
                         C      ; modifizieren entspr. phys. Sektorlaenge
  DFAC    3A E1F4        C      	ld	a,(ft.len)
  DFAF    32 E2C1        C      	ld	(sidlen),a
  DFB2    21 E227        C      	ld	hl,dsln0-dslnl
  DFB5    47             C      	ld	b,a
  DFB6    04             C      	inc	b
  DFB7    11 0009        C      	ld	de,dslnl
  DFBA    19             C      dtrsll:	add	hl,de
  DFBB    10 FD          C      	djnz	dtrsll
  DFBD    EB             C      	ex	de,hl
  DFBE    21 E21D        C      	ld	hl,dslnmt	;Tabelle der Modif.adr.
  DFC1    CD E146        C      	call	flmodf
                         C      
                         C      ; Kopf positionieren
  DFC4    21 E1F1        C      	ld	hl,ft.trk	; gewuenschte Spur
  DFC7    7E             C      	ld	a,(hl)
  DFC8    B7             C      	or	a		;Spur 0?
  DFC9    20 0D          C      	jr	nz,npost0	;nein
  DFCB    3A E1F5        C      	ld	a,(ft.anz)	;Sektorzahl
  DFCE    B7             C      	or	a		;nur positionieren auf Spur 0 (FORMAT-Progr.)
  DFCF    28 4F          C      	jr	z,trk0		;ja, Spur 0 immer ueber Recalibrate
  DFD1    3A E1ED        C      	ld	a,(ft.kom)
  DFD4    CB 4F          C      	bit	1,a		;Lesen Sekt.id Spur 0?
  DFD6    20 53          C      	jr	nz,trk0s	;ja, Lesen Sektid Spur 0 ueber Recalibrate
  DFD8    3A E218        C      npost0:	ld	a,(aspnr)	; stimmt Spur?
  DFDB    BE             C      	cp	(hl)
  DFDC    28 61          C      xpvrw:	jr	z,pvrw1		; -> ja, Kopf evtl. vertikal stabilisieren
                         C      				; auf jr z,pvrw2, wenn Kopf noch aufgesetzt
  DFDE                   C      spprty:				;Wiederholung bei fehlerhafter Spur
                         C      ; Positionierung auf ft.trk
  DFDE    3A E1F1        C      spe: 	ld	a,(ft.trk)
  DFE1    06 8F          C      	ld	b,08fh		; stepout-Befehl
  DFE3    21 E218        C      	ld	hl,aspnr
  DFE6    BE             C      	cp	(hl)		; auf richtiger Spur angekommen?
  DFE7    28 56          C      	jr	z,phrw		; -> ja, Kopf horizontal stabilisieren
  DFE9    38 0D          C      	jr	c,spre		; -> stepout
  DFEB    FE 55          C      xmaxtr: cp	85		; Spur zu gross?
  DFED    38 05          C      	jr	c,spve		; -> nein, stepin
  DFEF    3E 54          C      	ld	a,'T'		; Fehler: Spurnr. zu gross
  DFF1    C3 E0E9        C      	jp	fehret
                         C      
                         C      ; stepin
  DFF4    06 AF          C      spve:	ld	b,0afh		; stepin-Befehl
  DFF6    34             C      	inc	(hl)		; alte Spurnr. erhoehen
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-84


  DFF7    34             C      	inc	(hl)		; wegen stepout-dec
                         C      
                         C      ; stepout
  DFF8    35             C      spre: 	dec	(hl)		; alte Spurnr. verringern
  DFF9    CD DFFE        C      	call	step
  DFFC    18 E0          C      	jr	spe
                         C      
                         C      ; steppen
  DFFE    3A E1F6        C      step: 	ld	a,(ft.stp)	; Anzahl der Stepimpulse pro Step
  E001    0E 10          C      step0: 	ld	c,flcoad
  E003    ED 41          C      	out	(c),b		; select direction
                         C      ;;;	push	bc
                         C      ;;;	ld	b,0
                         C      ;;;step1: 	djnz	step1		; 1,3ms warten
                         C      ;;;	pop	bc
  E005    C5             C      step2: 	push	bc
  E006    CB B8          C      	res	7,b
  E008    F3             C      	di			;verhindern Unterbrechung
  E009    ED 41          C      	out	(c),b
  E00B    CB F8          C      	set	7,b
  E00D    ED 41          C      	out	(c),b		; step
  E00F    FB             C      	ei
  E010    ED 4B E1F7     C      	ld	bc,(ft.sti)	; 13,2 / 11,6 / 3,0 ms Schrittzeit
  E014    06 13          C      stepw1: ld	b,19		;(19*13)/(256*9600)=0.0001
  E016    10 FE          C      stepw: 	djnz	stepw		;0.1 ms warten
  E018    0D             C      	dec	c
  E019    20 F9          C      	jr	nz,stepw1
  E01B    C1             C      	pop	bc
  E01C    3D             C      	dec	a
  E01D    20 E6          C      	jr	nz,step2
  E01F    C9             C      	ret
                         C      
                         C      ; Spur 0 anfahren (Recalibrate)
  E020    06 02          C      trk0:	ld	b,2		; nach innen, falls auf Spur -1
  E022    C5             C      trk0i:	push	bc
  E023    06 AF          C      	ld	b,0afh	 	; stepin
  E025    CD DFFE        C      	call	step
  E028    C1             C      	pop	bc
  E029    10 F7          C      	djnz	trk0i
  E02B    DB 12          C      trk0s:	in	a,(flcobd)
  E02D    07             C      	rlca			; Spur 0 erreicht?
  E02E    30 09          C      	jr	nc,trk0f	; -> ja
  E030    06 8F          C      	ld	b,08fh		; stepout-Befehl
  E032    3E 01          C      	ld	a,1		; in phys. Schritten
  E034    CD E001        C      	call	step0
  E037    18 F2          C      	jr	trk0s
  E039    AF             C      trk0f: 	xor	a
  E03A    32 E218        C      	ld	(aspnr),a	; aktuelle Spurnr ist 0
  E03D    18 9F          C      	jr	spprty
                         C      
                         C      
                         C      ; Kopf stabilisieren (horizontal und vertikal)
  E03F                   C      pvrw1:	; Kopf vertikal stabilisieren
  E03F                   C      phrw:	; Kopf horizontal (und evtl. auch vertikal) stabilisieren
  E03F    3E 32          C      	ld	a,50		; 50 ms (fuer alle Laufwerkstypen)
  E041    06 BD          C      phrww1: ld	b,189		; (189*13)/(256*9600)=0.001
  E043    10 FE          C      phrww: 	djnz	phrww		; 1 ms warten
  E045    3D             C      	dec	a
  E046    20 F9          C      	jr	nz,phrww1
  E048                   C      pvrw2:	; Kopf war aufgesetzt und Spur stimmte auch - keine Stabilis.
                         C      
  E048                   C      rdwr:
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-85


                         C      ; Anfangswerte fuer Transfer der physischen Sektoren
  E048    3A E1F5        C      	ld	a,(ft.anz)	; Anzahl der zu uebertragenden phys. Sektoren
  E04B    32 E2B6        C      	ld	(secan1),a
  E04E    32 E158        C      	ld	(secanz),a	; fuer CRC-Berechnung
                         C      
  E051    3A E1F1        C      	ld	a,(ft.trk)	; Spur
  E054    32 E2BD        C      	ld	(sidtr),a
  E057    21 E1F6        C      	ld	hl,ft.stp
  E05A    CB 46          C      	bit	0,(hl)		;Doppelschritte?
  E05C    28 01          C      	jr	z,dprec1	;nein
  E05E    87             C      	add	a,a		;sonst phys. Spur verdoppeln
  E05F                   C      dprec1:
                         C      ; evtl. Precompensation einschalten
  E05F    01 0412        C      	ld	bc,00000100b*256+flcobd
  E061                   C      dfrcod	equ	$-1		; Frequenzcode
  E062    FE 19          C      	cp	25		; Spur ab der mit writeprecomp.
  E063                   C      dpretr	equ	$-1
  E064    38 02          C      	jr	c,prec		; <, ohne Precompensation
  E066    CB D8          C      	set	3,b		; >= , mit
  E068    ED 41          C      prec: 	out	(c),b
                         C      
  E06A    3A E1F3        C      	ld	a,(ft.sec)	; erste zu uebertr. Sektornr.
  E06D    32 E2C0        C      	ld	(sidsec),a
  E070    3A E1F2        C      	ld	a,(ft.sid)
  E073    32 E2BE        C      	ld	(sidsid),a
                         C      
                         C       IF dskds ; double sided
                         C      ; evtl. side 1 anwaehlen vorbereiten
  E076    3A E1ED        C      	ld	a,(ft.kom)
  E079    21 E254        C      	ld	hl,dsidmt
  E07C    46             C      	ld	b,(hl)
  E07D    23             C      dsidmz:	inc	hl
  E07E    5E             C      	ld	e,(hl)
  E07F    23             C      	inc	hl
  E080    56             C      	ld	d,(hl)
  E081    EB             C      	ex	de,hl
  E082    CB 7F          C      	bit	7,a		; side 0?
  E084    28 04          C      	jr	z,pside0	; ja
  E086    CB 96          C      	res	2,(hl)		; side 1 einstellen
  E088    18 02          C      	jr 	pside1
  E08A    CB D6          C      pside0:	set	2,(hl)
  E08C    EB             C      pside1:	ex	de,hl
  E08D    10 EE          C      	djnz	dsidmz
  E08F    CB 6F          C      	bit	5,a		;40-Spur LW?
  E091    20 03          C      	jr	nz,pside2	;nein
  E093    EB             C      	ex	de,hl		;diom11
  E094    CB 96          C      	res	2,(hl)		;fault reset zwischen den Sektoren
  E096                   C      pside2:
                         C       ENDIF
                         C      
                         C      ; evtl. nur Lesen Sektor-Id.
  E096    3A E1ED        C      	ld	a,(ft.kom)
  E099    CB 4F          C      	bit	1,a		; Lesen Sekt.Id?
  E09B    21 E2AE        C      	ld	hl,dio
  E09E    28 03          C      	jr	z,srdsid	; -> nein
  E0A0    21 E314        C      	ld	hl,diotsr
  E0A3    22 E26E        C      srdsid:	ld	(diortn),hl
                         C      
                         C       IF @write
  E0A6    3A E1ED        C      	ld	a,(ft.kom)	; Schreiben?
  E0A9    CB 57          C      	bit	2,a
  E0AB    20 08          C      	jr	nz,writpt	; -> ja, Schreibroutine steht auf dioop
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-86


                         C       ENDIF
  E0AD    21 E369        C      	ld	hl,diord
  E0B0    22 E312        C      	ld	(dioop),hl	; read einstellen
                         C      
                         C       IF @write
  E0B3    18 22          C      	jr	dtrdyt
  E0B5                   C      writpt:		; pruefen, ob Schreiben erlaubt ist
  E0B5    DB 12          C      	in	a,(flcobd)
  E0B7    CB 6F          C      	bit	5,a		; /WP
  E0B9    3E 57          C      	ld	a,'W'		; Fehler: write protected
  E0BB    CA E0E9        C      	jp	z,fehret
                         C      
                         C      ; CRC-Zeichen der zu schreibenden Daten berechnen und in crcber ablegen
  E0BE    2A E1EE        C      	ld	hl,(ft.adr)
  E0C1    DD 21 E1F8     C      	ld	ix,crcber	; Pointer auf 1. Daten-CRC stellen
  E0C5    DD 36 00 FB    C      crcbes: ld	(ix),0fbh	; Datenbeginn
  E0C9    CD E168        C      	call	crcbd		; CRC eines phys. Sektors berechnen
  E0CC    DD 72 00       C      	ld	(ix+0),d
  E0CF    DD 73 01       C      	ld	(ix+1),e	; ... und ablegen
  E0D2    CD E153        C      	call	crcnb		; weiterer phys. Sektor?
  E0D5    20 EE          C      	jr	nz,crcbes	; -> ja
                         C       ENDIF ;@write
                         C      
                         C      
                         C      ; Disk inzwischen ready?
                         C      
  E0D7                   C      dtrdyt:
  E0D7    DB 12          C      dtrdyz:	IN	A,(flcobd)
  E0D9    1F             C      	RRA			;ready-bit =0?
  E0DA    38 FB          C      dtrdyw:	JR	C,dtrdyz	;nein, 5" Disk not ready
                         C      				;auf jr c,$+2 modif bei 8"
                         C      
  E0DC    3E 05          C      	ld	a,5
  E0DE    CD E1A5        C      	call	fl.sto		;bei evtl. Fehlerwiederholung
                         C      				; timeout-Wert wieder hochstellen
                         C      				; fuer Ueberwachung auf fehlende Marke
  E0E1    3A E1F5        C      	ld	a,(ft.anz)	;Sektorzahl
  E0E4    B7             C      	or	a		; nur positionieren?
  E0E5    C2 E267        C      	jp	nz,diorun	; -> nein, Start des Transfers
                         C      
                         C      ; kein Fehler aufgetreten
  E0E8    AF             C      noerr:	xor	a
                         C      
                         C      ; Fertigmelden, Ergebnis in A
  E0E9    F5             C      fehret:	push	af
  E0EA    21 E1BE        C      	ld	hl,pretx+1	;Motorabschaltung ueber Index-Interrupt
  E0ED    36 0B          C      	ld	(hl),pret3-pret4;jr pret4
  E0EF    3E 14          C      	ld	a,20		;nach 20*200ms = 4 sec
  E0F1    CD E1A5        C      	call	fl.sto
  E0F4    F1             C      	pop	af
  E0F5    C9             C      	ret
                         C      
                         C      ; normale Beendigung
                         C      ;===================
                         C      
                         C      ; Schreiben
  E0F6    21 E1ED        C      dtrwre:	ld	hl,ft.kom
  E0F9    CB 76          C      	bit	6,(hl)		;Kontrollesen?
  E0FB    28 EB          C      	jr	z,noerr		;nein, fertig
  E0FD    CB 96          C      	res	2,(hl)		;sonst schreiben loeschen (d.h. auf lesen)
  E0FF    C3 E048        C      	jp	rdwr		;und auf gleichen Puffer zuruecklesen
                         C      
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-87


                         C      ; Lesen
  E102    2A E1EE        C      dtrrde:	ld	hl,(ft.adr)
  E105    DD 21 E1F8     C      	ld	ix,crcber
  E109    CD E168        C      crcbel:	call	crcbd		;CRC bilden
  E10C    CD E15E        C      	call	crcvgl		; und vergleichen
  E10F    20 07          C      	jr	nz,crcerx	; -> Fehler
  E111    CD E153        C      	call	crcnb		;noch ein Sektor?
  E114    20 F3          C      	jr	nz,crcbel	;ja
  E116    18 D0          C      	jr	noerr
                         C      
                         C      ; Fehlerbehandlung
                         C      ;=================
                         C      ; blieb weiterer Versuch, Sektor CRC-richtig reinzubekommen?
  E118    21 E213        C      crcerx: ld	hl,crerc
  E11B    35             C      	dec	(hl)
  E11C    C2 E048        C      	jp	nz,rdwr		; -> ja, alles noch mal
  E11F    3E 43          C      	ld	a,'C'		; Fehler: CRC-Zeichen falsch
  E121    18 C6          C      	jr	fehret
                         C      
                         C      ; Sektor nicht gefunden, evtl. falsche Spur
  E123                   C      serrx:
                         C      ; blieb weiterer Versuch, die richtige Spur zu finden?
  E123    21 E214        C      	ld	hl,sperc
  E126    35             C      	dec	(hl)
  E127    28 15          C      	jr	z,sperr2	; Wiederhlg. abgelaufen
  E129    3E 02          C      	ld	a,2
  E12B    BE             C      	cp	(hl)		;> 2 Wiederhlg?
  E12C    DA E020        C      	jp	c,trk0		;ja, Spur neu anfahren
  E12F    06 8F          C      	ld	b,08fh		;stepout
  E131    28 05          C      	jr	z,sperr4	;=2 Wiederhlg., stepout
  E133    06 AF          C      	ld	b,0afh		;stepin
  E135    CD DFFE        C      	call	step		;2 mal (zuvor war stepout)
  E138    CD DFFE        C      sperr4:	call	step
  E13B    C3 E03F        C      	jp	phrw		;Wiederholung
                         C      
  E13E    3E 53          C      sperr2:	ld	a,'S'		; Fehler: Sektor ist nicht zu finden
  E140    18 A7          C      	jr	fehret
                         C      
                         C      
  E142                   C      fl.to1: ; keine Sektor-Marke gefunden
  E142    3E 55          C      	ld	a,'U'		; time-out (undefind)
  E144    18 A3          C      	jr	fehret
                         C      
                         C      ; Modifizierung entsprechend Steuertabelle
                         C      ;=========================================
                         C      ; i HL	Tabelle der Modifizierungsadressen (wohin)
                         C      ; i DE	Tabelle der Modifizierungsbytes    (was)
  E146    46             C      flmodf:	ld	b,(hl)		;Anzahl der Adressen
  E147    23             C      dslnmz:	inc	hl
  E148    C5             C      	push	bc
  E149    4E             C      	ld	c,(hl)
  E14A    23             C      	inc	hl
  E14B    46             C      	ld	b,(hl)		;bc:=wohin
  E14C    1A             C      	ld	a,(de)		;a:=was
  E14D    13             C      	inc	de
  E14E    02             C      	ld	(bc),a
  E14F    C1             C      	pop	bc
  E150    10 F5          C      	djnz	dslnmz
  E152    C9             C      	ret
                         C      
                         C      ; CRC-Berechnung
                         C      ;===============
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-88


                         C      
                         C      ; von weiterem Sektor CRC-Zeichen berechnen?
                         C      ; IX wird weitergestellt
  E153    DD 23          C      crcnb: 	inc	ix		; CRC-Pointer erhoehen
  E155    DD 23          C      	inc	ix
  E157    3E FF          C      	ld	a,0ffh
  E158                   C      secanz	equ	$-1
  E159    3D             C      	dec	a
  E15A    32 E158        C      	ld	(secanz),a
  E15D    C9             C      	ret
                         C      
                         C      ; CRC-Vergleich DE mit (IX)
  E15E    DD 7E 00       C      crcvgl: ld	a,(ix+0)
  E161    BA             C      	cp	d
  E162    C0             C      	ret	nz
  E163    DD 7E 01       C      	ld	a,(ix+1)
  E166    BB             C      	cp	e
  E167    C9             C      	ret
                         C      
                         C      ; von einem phys. Sektor ab HL die CRC-Zeichen berechnen
                         C      ; HL wird weitergestellt
  E168    11 CDB4        C      crcbd:	ld	de,0cdb4h	;CRC Anfangswert
  E169                   C      crcbeg	equ	$-2
  E16B    DD E5          C      	push	ix
  E16D    E3             C      	ex	(sp),hl		;hl:= ^Datenbeginn-Byte
  E16E    06 01          C      	ld	b,1
  E170    CD E182        C      	call	bercrc		;CRC ueber Datenbeginn-Byte
  E173    E3             C      	ex	(sp),hl
  E174    DD E1          C      	pop	ix
  E176    06 01          C      	ld	b,1
  E177                   C      fl.tsb	equ	$-1		; Zahl der 128er Bloecke
  E178    C5             C      sp74: 	push	bc
  E179    06 80          C      	ld	b,128
  E17B    CD E182        C      	call	bercrc
  E17E    C1             C      	pop	bc
  E17F    10 F7          C      	djnz	sp74
  E181    C9             C      	ret
                         C      
                         C      ; von HL an B Zeichen auf DE als CRC-Polynom draufrechnen
  E182    7E             C      bercrc: ld	a,(hl)
  E183    AA             C      	xor	d
  E184    57             C      	ld	d,a
  E185    0F             C      	rrca
  E186    0F             C      	rrca
  E187    0F             C      	rrca
  E188    0F             C      	rrca
  E189    E6 0F          C      	and	0fh
  E18B    AA             C      	xor	d
  E18C    57             C      	ld	d,a
  E18D    0F             C      	rrca
  E18E    0F             C      	rrca
  E18F    0F             C      	rrca
  E190    4F             C      	ld	c,a
  E191    E6 1F          C      	and	1fh
  E193    AB             C      	xor	e
  E194    5F             C      	ld	e,a
  E195    79             C      	ld	a,c
  E196    0F             C      	rrca
  E197    E6 F0          C      	and	0f0h
  E199    AB             C      	xor	e
  E19A    5F             C      	ld	e,a
  E19B    79             C      	ld	a,c
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-89


  E19C    E6 E0          C      	and	0e0h
  E19E    AA             C      	xor	d
  E19F    53             C      	ld	d,e
  E1A0    5F             C      	ld	e,a
  E1A1    23             C      	inc	hl
  E1A2    10 DE          C      	djnz	bercrc
  E1A4    C9             C      	ret
                         C      
                         C      ; Aktivieren Indexpunktueberwachung
                         C      ; i A	Zaehler (wird bis 0 runtergezaehlt)
                         C      ; nur Reg. A zerstoert
                         C      
  E1A5    32 E1B6        C      fl.sto:	ld	(fl.zto),a	;Setzen Zaehler fuer Indexpunkte
  E1A8    3E 83          C      	ld	a,83h		;zulassen Indexinterrupt
  E1AA    D3 11          C      	out	(flcoac),a
  E1AC    C9             C      	ret
                         C      
                         C      ; Interruptbehandlungsroutine: time-out-Zeit abgelaufen
                         C      ; ausgeloest durch Index-Interrupt
  E1AD    ED 73 E4F8     C      itimeo: ld	(intsp),sp
  E1B1    31 F00C        C      	ld	sp,intstk
  E1B4    F5             C      	push	af
  E1B5    3E 00          C      	ld	a,0		; Zaehler fuer time-out Takte
  E1B6                   C      fl.zto	equ	$-1
  E1B7    3D             C      	dec	a		; time-out -1
  E1B8    32 E1B6        C      	ld	(fl.zto),a
  E1BB    20 10          C      	jr	nz,pret1	;-> nicht abgelaufen
  E1BD    18 0B          C      pretx:	jr	pret3		;modif. auf "jr pret4" waehrend Transfer
  E1BF                   C      pret4:
                         C       IF cpu eq k2526
  E1BF    3E A9          C      	ld	a,10101001b	;Time out waehrend Transfer
  E1C1    D3 10          C      	out	(flcoad),a	;CPU 2 stoppen
  E1C3    3E 00          C      	ld	a,dtrtor-dtrwjr
  E1C5    32 E29E        C      	ld	(dtrret),a	;Reaktionsroutine "keine Marke gefunden"
                         C       ENDIF
  E1C8    18 03          C      	jr	pret1
  E1CA    CD E1D0        C      pret3:	call	headup
  E1CD    C3 E4F6        C      pret1: 	jp	intraf		; allg. Ausgang Interruptroutinen
                         C      
                         C      ; Motor-Abschaltung von aussen her
                         C      ; nur Reg. AF zerstoert
  E1D0    3E 03          C      headup:	ld	a,3		; Indexinterrupt sperren
  E1D2    D3 11          C      	out	(flcoac),a
  E1D4    3E FF          C      	ld	a,0ffh		; Motor aus
  E1D6    D3 18          C      	out	(flsel),a
                         C       IF fdc eq f1715
                         C       ENDIF
                         C      ; Motor aus und alte Spurnummer merken
  E1D8    E5             C      flres: 	push	hl
  E1D9    C5             C      	push	bc
  E1DA    21 E217        C      	ld	hl,alwnr
  E1DD    CB 9E          C      	res	3,(hl)		; Motor aus vermerken
  E1DF    4E             C      	ld	c,(hl)
  E1E0    06 00          C      	ld	b,0
  E1E2    21 E219        C      	ld	hl,spnrl	; alte Spurnr. in Tabelle merken
  E1E5    09             C      	add	hl,bc
  E1E6    3A E218        C       	ld	a,(aspnr)
  E1E9    77             C      	ld	(hl),a
  E1EA    C1             C      	pop	bc
  E1EB    E1             C      	pop	hl
  E1EC    C9             C      	ret
                         C      
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-90


                         C      
                         C      ;*****************************************************
                         C      ;	Arbeitsbereiche phys. Floppy-Treiber
                         C      ;*****************************************************
                         C      
                         C      ; Parameterfeld
                         C      ;==============
  E1ED    00             C      ft.kom: db	0	; Kommando
  E1EE    0000           C      ft.adr: dw	0	; Transferadresse
  E1F0    00             C      ft.lwn: db	0	; Laufwerksnummer 0..3
  E1F1    00             C      ft.trk: db	0	; Spurnummer   0..
  E1F2    00             C      ft.sid: db	0	; side-Nr.     0..1
  E1F3    00             C      ft.sec: db	0	; Sektornummer
  E1F4    00             C      ft.len: db	0	; Sektorlaenge 0..3
  E1F5    00             C      ft.anz: db	0	; Anz. phys. Sektoren
  E1F6    00             C      ft.stp: db	0	; Anzahl der Stepimpulse pro Spur
  E1F7    00             C      ft.sti: db	0	; Schrittzeit von Spur zu Spur
                         C      
  E1F8                   C      crcber: ds	3*9,0ffh; Ber. zum Ablegen der gelesenen/zu schreibenden CRC-Z.
                         C      			; reicht fuer 9 physische Sektoren pro Transfer
                         C      ; Fehler-Wiederholungszaehler
  E213    00             C      crerc: 	db	0	; CRC-Fehler
  E214    00             C      sperc: 	db	0	; Spur nicht gefunden
  E215    00             C      seerc: 	db	0	; Sektor nicht gefunden
  E216    00             C      lwexis: db	0	; Anzeigebyte fuer vorhandene Laufwerke
                         C      			; bit 0 = 1 LW 0 vorhanden
                         C      			; bit 2 = 1 LW 1 vorhanden
                         C      			; bit 4 = 1 LW 2 vorhanden
                         C      			; bit 6 = 1 LW 3 vorhanden
                         C      
  E217    00             C      alwnr: 	db	0	; alte Laufwerksnummer vom vergangenen Zugriff
                         C      			; bit 0-2 LW-Nr., bit 3 = 1 Motor laeuft noch
                         C      
  E218    00             C      aspnr:	db	0	; aktuelle Spur des durch alwnr bezeichneten LW
  E219    00 00 00 00    C      spnrl: 	db	0,0,0,0	; Tabelle der alten Spurnummern
                         C      
                         C       IF dsk8fm+dsk8mf+dsk5fm
                         C       ENDIF ;nicht nur 5" MFM
                         C      
                         C      ; Modifizierungstabelle entspr. Sektorlaenge
                         C      
  E21D    09             C      dslnmt:	db	dslnl		;Tabellenlaenge
  E21E    E177           C      	dw	fl.tsb		;Anzahl der 128er Bloecke
  E220    E37A           C      	dw	diosl1		;Laenge erstes INIR
                         C       IF cpu eq k2526
  E222    E386           C      	dw	dini1+1		;INI oder INIR
  E224    E389           C      	dw	dini2+1
  E226    E38C           C      	dw	dini3+1
                         C       ENDIF
                         C       if @write
  E228    E3DA           C      	dw	diosl2		;Laenge erstes OTIR
                         C        IF cpu eq k2526
  E22A    E3DD           C      	dw	doti1+1		;OUTI oder OTIR
  E22C    E3DF           C      	dw	doti2+1
  E22E    E3E1           C      	dw	doti3+1
                         C        ENDIF
                         C       endif
  0009                   C      dslnl	equ	($-dslnmt-1)/2	;Tabellenlaenge
                         C      
                         C      ; 128
  E230    01             C      dsln0:	db	1
                         C       IF cpu eq k2526
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-91


  E231    80 A2 A2 A2    C      	db	128,0a2h,0a2h,0a2h
                         C       ENDIF
                         C       if @write
                         C        IF cpu eq k2526
  E235    80 A3 A3 A3    C      	db	128,0a3h,0a3h,0a3h
                         C        ENDIF
                         C       endif
                         C      
                         C      ; 256
  E239    02             C      dsln1:	db	2
                         C       IF cpu eq k2526
  E23A    00 A2 A2 A2    C      	db	0,0a2h,0a2h,0a2h
                         C       ENDIF
                         C       if @write
                         C        IF cpu eq k2526
  E23E    00 A3 A3 A3    C      	db	0,0a3h,0a3h,0a3h
                         C        ENDIF
                         C       endif
                         C      
                         C      ; 512
  E242    04             C      dsln2:	db	4
                         C       IF cpu eq k2526
  E243    00 A2 A2 B2    C      	db	0,0a2h,0a2h,0b2h
                         C       ENDIF
                         C       if @write
                         C        IF cpu eq k2526
  E247    00 A3 A3 B3    C      	db	0,0a3h,0a3h,0b3h
                         C        ENDIF
                         C       endif
                         C      
                         C      ; 1024
  E24B    08             C      dsln3:	db	8
                         C       IF cpu eq k2526
  E24C    00 B2 B2 B2    C      	db	0,0b2h,0b2h,0b2h
                         C       ENDIF
                         C       if @write
                         C        IF cpu eq k2526
  E250    00 B3 B3 B3    C      	db	0,0b3h,0b3h,0b3h
                         C        ENDIF
                         C       endif
                         C      
                         C       IF dskds
                         C      ; Modifizierungsadressen fuer Seitenauswahl
  E254    09             C      dsidmt:	db	dsidtl		; MFM		 FM
  E255    E2DF           C      	dw	diom01		;85/81		87/83
                         C       IF cpu eq k2526
  E257    E28B           C      	dw	diom02		;a5/a1		a5/a1
  E259    E2DB           C       	dw	diom03		;b5/b1		b5/b1
  E25B    E2CB           C      	dw	diom13		;bd/b9		bd/b9
                         C       ENDIF
                         C       if @write
                         C        IF dsk8fm+dsk5fm
                         C        ENDIF
  E25D    E3B3           C      	dw	diom07		;b4/b0		 -
  E25F    E3C5           C      	dw	diom08		;b6/b2		 -
  E261    E3CF           C      	dw	diom09		;b4/b0		 -
                         C       endif
  E263    E372           C      	dw	diom10		;b5/b1		b5/b1
                         C      ;;diom11 muss letztes Byte in der Tabelle sein
  E265    E3F1           C      	dw	diom11		;b5/b1		b5/b1
  0009                   C      dsidtl	equ	($-dsidmt-1)/2
                         C       ENDIF
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-92


                         C      	include BIOSDSKP
                         C      ;****************************************************************
                         C      ; Treiber fuer Ansteuerung K5120/K5122 ueber K2526 (mit Hilfsprozessor)
                         C      ; 04.06.87
                         C      ; - Fehlerkorrektur 8" MFM (Taktzeiten)
                         C      ; 25.09.89
                         C      ; - wegen MFS 1.2 nach Transfer b1 (= fault reset) als Standardwert
                         C      ;****************************************************************
                         C      
  E267                   C      diorun:
  E267    2A E1EE        C      	ld	hl,(ft.adr)
  E26A    22 E2B3        C      	ld	(diodma),hl
                         C      
                         C      ; physischen Transfer ueber CPU 2 starten
                         C      
  E26D    21 E2AE        C      	ld	hl,dio
  E26E                   C      diortn	equ	$-2
  E270    ED 4B 0001     C      	ld	bc,(1)		;retten HS 1
  E274    22 0001        C      	ld	(1),hl		;CPU 2 -Routine
  E277    3E FE          C      	ld	a,0feh
  E279    32 E29E        C      	ld	(dtrret),a	;stellen Warte-Reaktion
  E27C    AF             C      	XOR	A
  E27D    D3 14          C      	OUT	(fldaad),A
  E27F    D3 04          C      	OUT	(04H),A		;reset CPU 2
  E281    3D             C      	dec	a		;Mode 3 (Bit E/A)
  E282    D3 17          C      	OUT	(fldabc),A
  E284    D3 17          C      	OUT	(fldabc),A	;alles Input
  E286    3E B9          C      	ld	a,10111001b	;AMF aus, Fault reset
  E288    D3 10          C      	out	(flcoad),a
  E28A    3E A5          C      	LD	A,10100101b	;Seite einstellen, Mark reset, AMF aktiv
  E28B                   C      diom02	equ	$-1		;a5/a1
  E28C    D3 10          C      	OUT	(flcoad),A
  E28E    3E 7F          C      	LD	A,7FH		;Mode 1
  E290    D3 17          C      	OUT	(fldabc),A
  E292    DB 16          C      	IN	A,(fldabd)	;CPU2 starten (ueber BUSRQ)
                         C      ; durch die Anfangsinitialisierung der CPU2 vergehen die notwendigen
                         C      ; 100 Mikrosek. fuer Seitenumschaltung
  E294    ED 43 0001     C      	ld	(1),bc		;HS 1 wiederherst.
  E298    3A E2DF        C      	LD	A,(diom01)	;Lesen Marke
  E29B    D3 10          C      	OUT	(flcoad),A	;weiter bei CPU2 nach Anfangsinit.
                         C      ; Achtung!! Zur Synchronisation CPU1 und CPU2 keine 2-Byte-Werte
                         C      ; (Adressen) verwenden, da dazwischen BUSRQ auftreten kann und dann
                         C      ; nur ein Byte gesetzt wurde!!
  E29D    18 FE          C      	jr	$		;auf CPU 2 Ende warten
  E29E                   C      dtrret	equ	$-1
  E29F                   C      dtrwjr:
  E29F    C3 E142        C      dtrtor:	jp	fl.to1		;time out
  E2A2    C3 E0E8        C      dtrner:	jp	noerr		;fehlerfrei (Sekt.id)
  E2A5    C3 E123        C      dtrnsr:	jp	serrx		;Sektor nicht gefunden
  E2A8    C3 E102        C      dtrrdr:	jp	dtrrde		;Read Ende
  E2AB    C3 E0F6        C      dtrwrr:	jp	dtrwre		;Write Ende
                         C      ;--------------------------
                         C      
                         C      
                         C      ; Code CPU 2 fuer phys. Diskettentransfer
                         C      ;========================================
                         C      ; Zeitbedingungen fuer 8" MFM:
                         C      ; 6 Umdrehungen pro Sec bei 2*5208 Bytes pro Spur bedeutet
                         C      ; 1/(6*2*5208), d.h. 16 Mikrosec pro Byte!!
                         C      ; Bei einer Taktfrequenz von (9600*256)=2457600 Hz sind das
                         C      ; (9600*256)/(6*2*5208) Takte, d.h. max. 39 Takte pro Byte!!
                         C      ; Wegen BUSRQ/BUSAK muss davon der laengste Maschinenzyklus
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-93


                         C      ; der CPU 1 abgezogen werden, d.h. 6 Takte (Interruptannahme),
                         C      ; weiterhin je ein Takt fuer BUSRQ/BUSAK-Umschaltung,
                         C      ; es verbleiben 31 Takte zwischen den E/A-Maschinenzyklen!!
                         C      
                         C      ; normaler Entry in phys. Diskettentransfer
                         C      ;==========================================
  E2AE                   C      dio:	
  E2AE    AF             C      	xor	a		;wiederherstellen 'jr diokl'
  E2AF    32 E2E7        C      	ld	(diomd1+1),a
  E2B2    21 0000        C      	ld	hl,0
  E2B3                   C      diodma	equ	$-2		;Transferadresse
  E2B5    3E 00          C      	ld	a,0
  E2B6                   C      secan1	equ	$-1		;a':=Zahl zu transfer. phys. Sekt.
  E2B7    08             C      	ex	af,af'
  E2B8    11 E1F8        C      	ld	de,crcber	;auf Beginn Datenbyte-/CRC-Vektor
  E2BB    D9             C      dio2:	exx
  E2BC    01 00FF        C      	ld	bc,000ffh	;bc':= Spur, Seite
  E2BD                   C      sidtr	equ	$-2
  E2BE                   C      sidsid	equ	$-1
  E2BF    21 FFFF        C      	ld	hl,0ffffh	;hl':= Sektor, Sektlngflag
  E2C0                   C      sidsec	equ	$-2
  E2C1                   C      sidlen	equ	$-1
  E2C2    11 FEA1        C      	ld	de,0fea1h	;de':= Sektorid-Byte, Kluftbyte
  E2C5    3E 3C          C      	ld	a,60		;Wiederholungszaehler falscher Sektid.
  E2C7    32 E215        C      	ld	(seerc),a	;fuer ersten Sektor stellen
  E2CA    3E BD          C      diostp:	ld	a,10111101b	;bd/b9, AMF aus, Seite bleibt (>=100 Mikros.)
  E2CB                   C      diom13	equ	$-1
  E2CC    D3 10          C      	out	(flcoad),a	;Ende CPU2
  E2CE    18 12          C      	jr	diogo		;Fortsetzung nach Anfangsinit
                         C      
  E2D0                   C      dionss:
  E2D0    3E 3C          C      	ld	a,60		;Wiederholungszaehler falscher Sektid.
  E2D2    32 E215        C      	ld	(seerc),a	;fuer naechsten Sektor setzen
  E2D5                   C      diomr:
  E2D5    3E 05          C      	ld	a,5		;verhindern unendl. Schleife
  E2D7    32 E1B6        C      	ld	(fl.zto),a	;bei fehlender Sektor-Marke
  E2DA    3E B5          C      diomrk:	ld	a,10110101b	;b5/b1 MFM; b5/b1 FM
  E2DB                   C      diom03	equ	$-1		;Mark reset, lesen 1
  E2DC    D3 10          C      	out	(flcoad),a
  E2DE    3E 85          C      	ld	a,10000101b	;85/81 MFM; 87/83 FM
  E2DF                   C      diom01	equ	$-1		;Lesen Marke entspr. Aufzverf.
  E2E0    D3 10          C      	out	(flcoad),a
  E2E2    DB 16          C      diogo:	in	a,(fldabd)
  E2E4    D3 14          C      	out	(fldaad),a
  E2E6    18 00          C      diomd1:	jr	diomd1+2	;wird modifiziert mit 'jr diotrr',
                         C      				;wenn Sektorid zu lesen
  E2E8    DB 16          C      diokl:	in	a,(fldabd)
  E2EA    BB             C      	cp	e		;'A1', d.h. noch in Kluft?
  E2EB    28 FB          C      	jr	z,diokl		;ja
  E2ED    BA             C      	cp	d		;'FE', d.h. Sektorbeginn?
  E2EE    DB 16          C      	in	a,(fldabd)
  E2F0    20 E8          C      	jr	nz,diomrk	;nein, weitersuchen
  E2F2    B9             C      	cp	c		;Spur ok?
  E2F3    DB 16          C      	in	a,(fldabd)
  E2F5    20 5D          C      	jr	nz,serr		;nein, falscher Sektid.
  E2F7    B8             C      	cp	b		;Seite ok?
  E2F8    DB 16          C      	in	a,(fldabd)
  E2FA    20 58          C      	jr	nz,serr		;nein, falscher Sektid.
  E2FC    BD             C      	cp	l		;Sektor ok?
  E2FD    DB 16          C      	in	a,(fldabd)
  E2FF    20 53          C      	jr	nz,serr		;nein, falscher Sektid.
  E301    BC             C      	cp	h		;Sekt-Laengencode?
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-94


  E302    DB 16          C      	in	a,(fldabd)	;**ignorieren CRC Sektid**
  E304    20 4E          C      	jr	nz,serr		;nein, falscher Sektid.
  E306    D9             C      	exx
  E307    DB 16          C      	in	a,(fldabd)	;**ignorieren CRC Sektid**
  E309    06 11          C      	ld	b,17		;Zahl zu uebergeh. Bytes
  E30A                   C      diomd2	equ	$-1		;bei DD auf 17, bei SD auf 6
  E30B    DB 16          C      diosyn:	in	a,(fldabd)	;Bytes ignorieren
  E30D    10 FC          C      	djnz	diosyn
  E30F    DB 16          C      	in	a,(fldabd)
  E311    C3 E369        C      	jp	diord
  E312                   C      dioop	equ	$-2		;wird modifiziert entspr. Oper.
                         C      ;				 mit diord, diwmfm, diowfm
                         C      
                         C      ; Entry fuer phys. Treiber zum Lesen Sekt.-Id. auf akt. Spur
                         C      ;===========================================================
  E314    3E 39          C      diotsr:	ld	a,diotrr-(diomd1+2)	;jr diotrr
  E316    32 E2E7        C      	ld	(diomd1+1),a	;modifizieren
  E319    01 0316        C      	ld	bc,3*256+fldabd	;Lesen 3 Bytes Sektorid
  E31C    21 E1F2        C      	ld	hl,ft.trk+1	;dorthin Sektorid hinterlegen
  E31F    18 9A          C      	jr	dio2		;Einsprung in phys. Treiber
  E321                   C      diotrr:
  E321    DB 16          C      diotr0:	in	a,(fldabd)
  E323    BB             C      	cp	e		;'A1', d.h. noch in Kluft?
  E324    28 FB          C      	jr	z,diotr0	;ja
  E326    BA             C      	cp	d		;'FE', d.h. Sektorbeginn?
  E327    DB 16          C      	in	a,(fldabd)	;wenn ja, so ist das die Spur
  E329    20 AF          C      	jr	nz,diomrk	;nein, weitersuchen
  E32B    D9             C      	exx
  E32C    ED B2          C      	inir			;Sektorid lesen
  E32E    D9             C      	exx
  E32F    6F             C      	ld	l,a		;Spur retten
  E330    3A E2DB        C      	ld	a,(diom03)
  E333    D3 10          C      	out	(flcoad),a	;Lesen 1
  E335    7D             C      	ld	a,l
  E336    B9             C      	cp	c		;richtige Spur?
  E337    28 09          C      	jr	z,diotr1	;ja
  E339    3A E1F2        C      	ld	a,(ft.sid)
  E33C    90             C      	sub	b		;stimmt side?
  E33D    20 0B          C      	jr	nz,diotre	;nein, dies ist kein Sektid.
  E33F    B9             C      	cp	c		;war Spur 0 gefordert?
  E340    28 23          C      	jr	z,serr2		;ja, nachjustieren (ft.trk steht noch)
  E342    7D             C      diotr1:	ld	a,l
  E343    32 E1F1        C      	ld	(ft.trk),a	;(tatsaechliche) Spur aus Sekt.Id.
  E346    3E 03          C      	ld	a,dtrner-dtrwjr	;Reaktionsroutine
  E348    18 5D          C      	jr	dioend		;Abschlussbehandlung
  E34A    D9             C      diotre:	exx
  E34B    01 0316        C      	ld	bc,3*256+fldabd	;Lesen 3 Bytes Sektorid
  E34E    21 E1F2        C      	ld	hl,ft.trk+1	;dorthin Sektorid hinterlegen
  E351    D9             C      	exx
  E352    18 07          C      	jr	serr1
                         C      ;---------------------------
                         C      
                         C      ; Fehlerausgaenge
                         C      ;----------------
                         C      ; falscher Sektorid.
  E354    DB 16          C      serr:	in	a,(fldabd)
  E356    3A E2DB        C      	ld	a,(diom03)	;Lesen 1
  E359    D3 10          C      	out	(flcoad),a
  E35B    3A E215        C      serr1:	ld	a,(seerc)
  E35E    3D             C      	dec	a		;blieb weiterer Versuch?
  E35F    32 E215        C      	ld	(seerc),a
  E362    C2 E2D5        C      	jp	nz,diomr	;ja
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-95


  E365    3E 06          C      serr2:	ld	a,dtrnsr-dtrwjr	;Sektor nicht gefunden
  E367    18 3E          C      	jr	dioend
                         C      
                         C      ; Lesen
                         C      ;-------
  E369    DB 16          C      diord:	in	a,(fldabd)
  E36B    06 06          C      	ld	b,6
  E36D    DB 16          C      diords:	in	a,(fldabd)	;uebergehen Synchron-Bytes
  E36F    10 FC          C      	djnz	diords
  E371    3E B5          C      	ld	a,10110101b	;b5/b1
  E372                   C      diom10	equ	$-1
  E373    D3 10          C      	out	(flcoad),a	;Lesen 1
  E375    3A E2DF        C      	ld	a,(diom01)	;85/81 MFM; 87/83 FM
  E378    01 8016        C      	ld	bc,128*256+fldabd ;b:=inir-Laenge
  E37A                   C      diosl1	equ	$-1		  ;   128 bei Sektl 128, sonst =0
  E37B    D3 10          C      	out	(flcoad),a	;Lesen Marke
  E37D    DB 16          C      	in	a,(fldabd)	;ignorieren evtl. anstehenden Muell
  E37F    DB 16          C      diorkl:	in	a,(fldabd)
  E381    FE A1          C      	cp	0a1h		;noch in Kluft?
  E383    28 FA          C      	jr	z,diorkl	;ja
  E385    ED A2          C      dini1:	ini			;Daten lesen
  E387    12             C      	ld	(de),a		;Datenbeginn-Byte hinterlegen
  E388    ED A2          C      dini2:	ini
  E38A    13             C      	inc	de
  E38B    ED A2          C      dini3:	ini
  E38D    ED B2          C      	inir
  E38F    EB             C      	ex	de,hl
  E390    ED A2          C      	ini			;CRC Daten
  E392    ED A2          C      	ini
  E394    3A E3F1        C      	ld	a,(diom11)	;b1 fuer MFS 1.2 Fault reset, sonst b5/b1
  E397    D3 10          C      	out	(flcoad),a	;Lesen 1
  E399    EB             C      	ex	de,hl
  E39A    3E 09          C      	ld	a,dtrrdr-dtrwjr	;Reaktionsroutine Read Ende
                         C      
                         C      ; naechsten Sektor behandeln
                         C      ;---------------------------
  E39C    08             C      dions:	ex	af,af'		;Zahl zu uebertr. Sektoren
  E39D    3D             C      	dec	a
  E39E    28 06          C      	jr	z,dionse	;=0, fertig
  E3A0    08             C      	ex	af,af'
  E3A1    D9             C      	exx
  E3A2    2C             C      	inc	l		;Sektor+1
  E3A3    C3 E2D0        C      	jp	dionss
  E3A6    08             C      dionse:	ex	af,af'
                         C      
                         C      ; Abschlussbehandlung
                         C      ;--------------------
  E3A7                   C      dioend:
  E3A7    32 E29E        C      	ld	(dtrret),a	;Reaktionsroutine hinterlegen
  E3AA    C3 E2CA        C      	jp	diostp		;Stop CPU2
                         C      
                         C       IF @write
                         C      
                         C       IF dsk8fm+dsk8mf+dsk5fm
                         C       ENDIF
                         C      
                         C      
                         C      ; Schreiben  MFM
                         C      ;---------------
  E3AD    DB 16          C      diwmfm:	in	a,(fldabd)
  E3AF    DB 16          C      	in	a,(fldabd)
  E3B1    01 B410        C      	ld	bc,10110100b*256+flcoad
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-96


  E3B3                   C      diom07	equ	$-1		;b4/b0
  E3B4    DB 16          C      	in	a,(fldabd)
  E3B6    ED 41          C      	out	(c),b		;Schreiben MFM normal
  E3B8    DB 16          C      	in	a,(fldabd)
  E3BA    AF             C      	xor	a
  E3BB    D3 14          C      	out	(fldaad),a	; 1*'00'
  E3BD    01 0A14        C      	ld	bc,10*256+fldaad
  E3C0    D3 14          C      diwmfs:	out	(fldaad),a	;10*'00'
  E3C2    10 FC          C      	djnz	diwmfs
  E3C4    3E B6          C      	ld	a,10110110b
  E3C5                   C      diom08	equ	$-1		;b6/b2
  E3C6    ED 41          C      	out	(c),b		; 1*'00'
  E3C8    D3 10          C      	out	(flcoad),a	;Schreiben MFM Marke
  E3CA    06 A1          C      	ld	b,0a1h
  E3CC    ED 41          C      	out	(c),b		;3*'A1'
  E3CE    3E B4          C      	ld	a,10110100b
  E3CF                   C      diom09	equ	$-1		;b4/b0
  E3D0    ED 41          C      	out	(c),b
  E3D2    EB             C      	ex	de,hl
  E3D3    ED 41          C      	out	(c),b
  E3D5    D3 10          C      	out	(flcoad),a	;Schreiben MFM normal
  E3D7    ED A3          C      	outi			;'FB'
                         C      
  E3D9    06 80          C      diowrt:	ld	b,128		;Laenge erster OTIR-Block
  E3DA                   C      diosl2	equ	$-1		;128 bei Sektl 128, sonst 0
  E3DB    EB             C      	ex	de,hl
  E3DC    ED A3          C      doti1:	outi			;Daten ausgeben
  E3DE    ED A3          C      doti2:	outi
  E3E0    ED A3          C      doti3:	outi
  E3E2    ED B3          C      	otir
  E3E4    EB             C      	ex	de,hl
  E3E5    ED A3          C      	outi			;CRC Daten
  E3E7    AF             C      	xor	a
  E3E8    ED A3          C      	outi
  E3EA    06 14          C      diowm1:	ld	b,20		;Anzahl der Nach-Null-Bytes
                         C      				;5" MFM/FM: 20; 8" MFM/FM: 2
  E3EC    D3 14          C      diow00:	out	(fldaad),a	;'00'
  E3EE    10 FC          C      	djnz	diow00
  E3F0    3E B1          C      	ld	a,10110001b	;b1 fuer MFS 1.2 Fault reset, sonst b5/b1
  E3F1                   C      diom11	equ	$-1
  E3F2    D3 10          C      	out	(flcoad),a	;Schreiben aus, Lesen 1
  E3F4    EB             C      	ex	de,hl
  E3F5    3E 0C          C      	ld	a,dtrwrr-dtrwjr	;Schreiben OK Reaktion
  E3F7    C3 E39C        C      	jp	dions		;naechster Sektor
                         C      
                         C      	ENDIF	;@write
                                 ENDIF
                                 IF hdsk
                                 ENDIF
                                 IF oss
                                 ENDIF
                                 IF em256
                         C      	include BIOSREM		;RAM-Floppy mit EM256
                         C      ;********************************************************
                         C      ;	RAM-Floppy mit EM256 Erweiterungsmodul (16 Bit mit U8000)
                         C      ; Version 15.05.87
                         C      ;********************************************************
                         C      
                         C       if1
                         C       endif ;if1
                         C      
                         C      ;**************************************************************
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-97


                         C      ;	Schreiben RAM-Floppy
                         C      ;**************************************************************
  E3FA                   C      wrramf:
  E3FA    2A DF02        C      	ld 	hl,(ddma)
  E3FD    01 0080        C      	ld 	bc,128		;128 Byte von DMA nach Puffer
  E400    11 F202        C      	ld 	de,dmabuf
  E403    ED B0          C      	ldir
  E405    3A DEFD        C      	ld	a,(dtrack)
  E408    CD E440        C      	call 	ramon		;Testram / EM256 zuschalten
  E40B    C5             C      	push 	bc
  E40C    EB             C      	ex 	de,hl
  E40D    01 0080        C      	ld 	bc,128
  E410    21 F202        C      	ld 	hl,dmabuf	;128 byte von Puffer nach RAM-Floppy
  E413    ED B0          C      	ldir
  E415    C1             C      	pop 	bc
  E416    CD E473        C      	call	ramoff
                         C      	IF	em256
  E419    3A E498        C      	ld	a,(parerr)
                         C      	ENDIF
  E41C    C9             C      	ret
                         C      
                         C      ;**************************************************************
                         C      ;	Lesen RAM-Floppy
                         C      ;**************************************************************
                         C      
  E41D                   C      rdramf:
  E41D    3A DEFD        C      	ld	a,(dtrack)
  E420    CD E440        C      	call 	ramon		;Testram aktivieren
  E423    C5             C      	push 	bc
  E424    01 0080        C      	ld 	bc,128		;128 Byte 
  E427    11 F202        C      	ld 	de,dmabuf	;nach Puffer
  E42A    ED B0          C      	ldir
  E42C    C1             C      	pop 	bc
  E42D    CD E473        C      	call 	ramoff		;Testram abschalten
  E430    21 F202        C      	ld 	hl,dmabuf	;von Puffer nach DMA uebertragen
  E433    01 0080        C      	ld 	bc,128
  E436    ED 5B DF02     C      	ld 	de,(ddma)
  E43A    ED B0          C      	ldir
                         C      	IF	em256
  E43C    3A E498        C      	ld	a,(parerr)
                         C      	ENDIF
  E43F    C9             C      	ret
                         C      
                         C      ;********************************************************************
                         C      ;	Unterprogramme fuer RAM-Floppy
                         C      ;********************************************************************
                         C      
                         C      ;Routinen fuer EM256-RAM-Floppy
                         C      ;==============================
                         C      ;
                         C      ;Aktivieren / Deaktivieren der RAM des EM256
                         C      ;Eintritt: <A> - Tracknummer, <dsectr> - Sektornummer
                         C      ;Austritt: <DE>- Anfangsadresse des Sektors
                         C      ;
  E440    57             C      ramon:	ld	d,a		;<a>=  0  0 S1 S0 P3 P2 P1 P0
  E441    0F             C      	rrca			;          Segment   Page   
  E442    0F             C      	rrca
  E443    0F             C      	rrca
  E444    0F             C      	rrca			;<a>= P3 P2 P1 P0  0  0 S1 S0
  E445    E6 3F          C      	and	3fh		;   =  0  0 P1 P0  0  0 S1 S0
  E447    F6 40          C      	or	high(hbemadr)	;   = H3 H2 P1 P0  0  0 S1 S0
  E449    47             C      	ld	b,a		;H3,H2 sind ext. Adresse!!
BIOS CP/A, Buerocomputer (A5120/30 u. ae.)	MACRO-80 V3.50	25-Oct-85	Page	1-98


  E44A    7A             C      	ld	a,d
  E44B    2F             C      	cpl
  E44C    E6 0C          C      	and	0ch		;<a>=  0  0  0  0 /P3/P2  0  0
  E44E    B0             C      	or	b		;   = H3 H2 P1 P0 /P3/P2 S1 S0
  E44F    47             C      	ld	b,a		;Low-Nibble gleichgueltig (retten)
  E450    0E AF          C      	ld 	c,modadr+7	;Adressierung 16*4-RAM
  E452    E6 0C          C      	and	0ch		;<a>=  0  0  0  0 /P3/P2  0  0     
                         C      				;EM256 erkennt sich auf em256adr
                         C      				;Write enable, Page enable
  E454    ED 79          C      	out	(c),a
  E456    78             C      	ld	a,b
  E457    E6 03          C      	and	3		;Segmentnummer
  E459    F6 10          C      	or	1 shl reset16	;U8000-Reset, RAM-Enable
  E45B    D3 A9          C      	out	(modadr+1),a	;RAM scharf
  E45D    78             C      	ld	a,b
  E45E    E6 F0          C      	and	0f0h
  E460    57             C      	ld 	d,a		;Page erscheint auf Adr. in DE
  E461    AF             C      	xor 	a
  E462    5F             C      	ld	e,a
  E463    32 E498        C      	ld	(parerr),a	;Paritaetsfehler reset
  E466    3A DEFF        C      	ld	a,(dsectr)	;offset aus Sektornummer berechnen
  E469    3D             C      	dec	a
  E46A    67             C      	ld 	h,a
  E46B    2E 00          C      	ld	l,0
  E46D    CB 3C          C      	srl	h
  E46F    CB 1D          C      	rr	l		
  E471    19             C      	add	hl,de		;Offset zu Track(Page)Adresse addieren
  E472    C9             C      	ret
  E473    78             C      ramoff:	ld a,b
  E474    E6 0C          C      	and	0ch
  E476    F6 03          C      	or	1 shl n_pagen or 1 shl n_write	;page disable, write disable
  E478    ED 79          C      	out 	(c),a
  E47A    3E 14          C      	ld	a,1 shl reset16 or 1 shl n_ramen
  E47C    D3 A9          C      	out	(modadr+1),a
  E47E    C9             C      	ret
                         C      
  E47F    32 E497        C      parrou:	ld	(rettea),a	;Interruptbedienung Paritaetsfehler
  E482    3E 01          C      	ld	a,1		;benoetigt keinen eigenen Stack
  E484    32 E498        C      	ld	(parerr),a	;Kennung Fehler
  E487    DB A9          C      	in	a,(modadr+1)
  E489    CB F7          C      	set	prreset,a
  E48B    D3 A9          C      	out	(modadr+1),a	;Fehler ruecksetzen
  E48D    CB B7          C      	res	prreset,a
  E48F    D3 A9          C      	out	(modadr+1),a
  E491    3A E497        C      	ld	a,(rettea)
  E494    FB             C      	ei
  E495    ED 4D          C      	reti
                         C      
  E497    00             C      rettea:	db	0		;A bei Parityinterrupt
  E498    00             C      parerr:	db	0		;Paritaetsfehlerspeicher
