; ============================================================================
; SPUR-BEARBEITUNGS-SCHLEIFE
; Iteriert ueber alle zu bearbeitenden Spuren (von Startspur bis Endspur).
; Pro Spur:
;   1. Seek zur gewuenschten Spur (ueber cpmx21)
;   2. Je nach Funktion: Formatieren / Daten kopieren / Verifizieren
;   3. Optional: Verify nach Schreiben (Ruecklesen und Vergleichen)
;   4. Fehlermeldung bei Problemen, bis zu 2 Wiederholungen
;   5. Naechste Spur, bis alle fertig
; ============================================================================
format_next_track:
	LD IX,active_cdb                        ; 09F1: DD 21 D0 1B
	LD IY,drive_a_params                    ; 09F5: FD 21 1E 1C
	CALL seek_only                          ; 09F9: CD 00 0C
	XOR A                                   ; 09FC: AF
	LD (1C8FH),A                            ; 09FD: 32 8F 1C
	LD DE,6CB0H                             ; 0A00: 11 B0 6C
