; ============================================================================
; FORMAT.COM - Disketten-FORMAT fuer Buerocomputer
; Robotron A5120 - CPA/CP/M 2.2 System
; Version 19.05.89
; Size: 17408 bytes (4400H)
; Address range: 0100H - 44FFH
;
; Disassembled from binary - all bytes accounted for
;
; PROGRAMMSTRUKTUR UND UEBERSICHT
; ================================
; Dieses Programm ist das universelle Formatierungswerkzeug fuer den
; Robotron A5120 Buerocomputer. Es unterstuetzt:
;   - Formatieren von 5.25"- und 8"-Disketten in verschiedensten Formaten
;   - Kopieren ganzer Disketten (Spur fuer Spur)
;   - Pruefen (Verify) bereits beschriebener Disketten
;   - Automatische Formaterkennung im BIOS einstellen
;
; HARDWARE-ARCHITEKTUR (K2526/K5122/K7027)
; =========================================
; Der A5120 verwendet separate Hardwarekarten:
;   K2526  - CPU-Karte mit 2 CPUs (Z80/U880) und EPROM
;            CPU1: Hauptprozessor (fuehrt das Betriebssystem und Programme aus)
;            CPU2: Wird fuer zeitkritische Formatierung aktiviert
;   K5122  - Floppydisk-Controllerkarte (FDC) mit PIO-Baustellen
;            Steuert bis zu 4 Diskettenlaufwerke ueber PIO-Ports
;   K7027  - Bildschirmkarte (80x24 Zeichen)
;
; DIREKTER HARDWARE-ZUGRIFF (AM OS VORBEI)
; ==========================================
; Das Programm greift an mehreren kritischen Stellen direkt auf die
; Hardware zu, ohne den Umweg ueber BDOS/BIOS zu nehmen:
;
; 1) CPU2-FORMATIERUNGSCODE (1C8EH-1EDEH):
;    Dies ist der wichtigste Bereich direkten Hardwarezugriffs.
;    Der komplette Formatiervorgang (Gap-Bytes, Sync-Markierungen,
;    Adressfelder, Datenfelder) wird ueber direkte Port-I/O an die
;    PIO-Bausteine der K5122-Karte gesendet. CPU2 der K2526 fuehrt
;    diesen Code aus, waehrend CPU1 in einer JR $-Schleife wartet.
;    Ports: 10H (FDC-Steuersignale), 11H (PIO-Interrupt-Steuerung),
;           14H (Datenbytes zum FDC), 04H, 16H, 17H (PIO-Konfiguration)
;
; 2) INTERRUPT-SERVICE-ROUTINE (1E88H):
;    Der ISR fuer den Index-Puls-Interrupt wird direkt installiert,
;    indem die Vektortabelle im RAM (adressiert ueber I-Register)
;    manipuliert wird. Der ISR modifiziert per Selbstmodifikation
;    den JR-Displacement-Wert in der CPU2-Schleife, um den Ausstieg
;    nach Abschluss der Formatierung zu signalisieren.
;
; 3) ISR-VEKTOR-VERWALTUNG (1E8EH-1EC7H):
;    Sichert die originalen ISR-Vektoren bei F7E8H/F7EAH (Index-Puls
;    und Daten-Markierung), installiert eigene Handler und stellt
;    die Originale nach der Formatierung wieder her.
;
; 4) PIO-STATUS-ABFRAGE (1E8EH):
;    Liest direkt Port 12H (PIO B Status), um den Schreibschutz-
;    status der Diskette zu pruefen (Bit 5 = /WP).
;
; 5) WARM-BOOT-VEKTOR-UMLEITUNG (1CE5H-1CE9H):
;    Waehrend der Formatierung wird der Warm-Boot-Vektor (0001H)
;    voruebergehend auf 0000H gesetzt, um zu verhindern, dass ein
;    versehentlicher Warm-Boot den Formatiervorgang stoert.
;
; 6) SELBSTMODIFIZIERENDER CODE:
;    - 016BH: CPA-Modus-Flag wird zur Laufzeit gepatcht
;    - 0B65H: Seiten-Flag wird zur Laufzeit gepatcht
;    - 1CEEH: Schreibt FEH als JR-Displacement nach 1D22H (erzeugt JR $)
;    - 1CF7H/1CFAH: Patcht JR-Opcodes an 1D50H und 1DE5H
;    - 1E88H: ISR schreibt 3EH (LD A,n Opcode) ueber den JR-Opcode,
;             wodurch CPU2 aus der Endlosschleife ausbricht
;
; DATENFLUSSPRINZIP
; ==================
; Normale Disk-I/O (Lesen/Schreiben/Seek) laeuft ueber:
;   Programm -> CDB (Command Descriptor Block) -> cpmx21 (BIOS-Extension)
; Die physische Formatierung laeuft direkt ueber:
;   CPU2-Code -> PIO-Ports -> FDC-Hardware -> Diskette
;
; ============================================================================

; --- CP/M Systemadressen ---
WBOOT		EQU	0000H	; CP/M Warm-Boot (JP an BIOS warm boot)
WBOOTV		EQU	0001H	; Warm-Boot-Vektor (Adresse der BIOS-Routine)
BDOS		EQU	0005H	; BDOS-Einsprung (JP an BDOS)
BDOSADDR	EQU	0006H	; BDOS-Adresse (Obergrenze des TPA)
CPMEXT		EQU	004EH	; CPA-Erweiterungstabelle (Zeiger auf cpmx-Routinen)
FCB1		EQU	005CH	; Standard-FCB (erstes Kommandozeilenargument)
DMAADDR		EQU	0080H	; Standard-DMA-Puffer / Kommandozeilenpuffer

; --- BDOS-Funktionsnummern ---
F_RAWIO		EQU	06H	; Direkte Konsolen-E/A (Zeichen lesen/schreiben)
F_PRINT		EQU	09H	; String ausgeben ($-terminiert)
F_RDBUF		EQU	0AH	; Konsolenpuffer einlesen (Zeile)
F_GETVER	EQU	0CH	; CP/M-Versionsnummer abfragen

; --- FDC/PIO-Portadressen (K5122 Floppydisk-Controllerkarte) ---
; Die K5122-Karte enthaelt zwei Z80-PIO-Bausteine:
;   Steuer-PIO (Ports 10H-13H): Steuert FDC-Signale und liest Status
;   Daten-PIO  (Ports 14H-17H): Uebertraegt Daten zum/vom FDC
; ACHTUNG: Diese Ports werden im CPU2-Formatierungscode DIREKT
;          angesprochen (am Betriebssystem vorbei)!
PIO_CTRL_A	EQU	10H	; Steuer-PIO Port A Daten: FDC-Steuersignale
				;   Bit 0: /WE  (Write Enable, aktiv low)
				;   Bit 2: /SIDE (Seitenanwahl: 0=Seite 1, 1=Seite 0)
				;   Bit 4: Motor-On
				;   Bit 5: SD   (Step Direction: 0=aussen, 1=innen)
				;   Bit 7: /ST  (Step-Puls, steigende Flanke)
PIO_CTRL_C	EQU	11H	; Steuer-PIO Port A Steuerregister
				;   83H = Interrupts aktivieren (fuer Index-Puls)
				;   03H = Interrupts deaktivieren
PIO_STAT_B	EQU	12H	; Steuer-PIO Port B Daten: FDC-Statussignale
				;   Bit 0: /RDY (0=Laufwerk bereit)
				;   Bit 5: /WP  (0=schreibgeschuetzt)
				;   Bit 7: /T0  (0=Spur 0 erreicht)
PIO_DATA_A	EQU	14H	; Daten-PIO Port A: Datenbytes zum/vom FDC
				;   Hierueber werden beim Formatieren die
				;   Gap-, Sync-, Adress- und Datenbytes gesendet
PIO_DATA_B	EQU	04H	; Daten-PIO Port B: Zusaetzlicher Datenkanal
PIO_DATA_C	EQU	16H	; Daten-PIO Steuerregister Port A
PIO_DATA_D	EQU	17H	; Daten-PIO Steuerregister Port B
DRV_SEL		EQU	18H	; Laufwerksauswahl-Latch

; --- Interruptvektoren (im RAM, adressiert ueber I-Register) ---
; Diese Vektoren liegen normalerweise bei F7E8H (I-Register * 256 + E8H)
; und werden vom CPU2-Formatierungscode temporaer umgebogen.
IV_INDEX	EQU	0F7E8H	; Index-Puls ISR-Vektor (1 Puls pro Umdrehung)
IV_MARK		EQU	0F7EAH	; Daten-Markierungs-ISR-Vektor

; ============================================================================

	ORG	0100H

; ============================================================================
; PROGRAMMSTART: Systemvalidierung
; Prueft ob das System ein CPA (nicht Standard-CP/M) ist und ob die
; Version mindestens CPAB5 (d.h. CP/A Version B, ab Dezember 1987) ist.
; Dies ist notwendig, weil FORMAT.COM CPA-spezifische BIOS-Extensions
; wie cpmx21 (diskio) und cpmx18 (delsps) benoetigt.
; ============================================================================
start:
	LD HL,(0001H)                           ; 0100: 2A 01 00 ; HL = BIOS Warm-Boot-Adresse
	LD DE,0030H                             ; 0103: 11 30 00 ; Offset +30H = Versionsstring im BIOS
	ADD HL,DE                               ; 0106: 19 ; HL -> BIOS-Versionskennung
	CALL check_CPA                          ; 0107: CD 22 01 ; Pruefe ob 'CPA' an dieser Stelle steht
	JR NZ,L011C                             ; 010A: 20 10 ; Kein CPA -> Fehlermeldung
	LD A,42H                                ; 010C: 3E 42 ; 'B' pruefen (CP/A Variante B)
	CPI                                     ; 010E: ED A1 ; Vergleiche und HL++
	JR NZ,L011C                             ; 0110: 20 0A ; Nicht Variante B -> Fehler
	LD A,39H                                ; 0112: 3E 39 ; Versionsziffer muss < '9' sein
	CP (HL)                                 ; 0114: BE
	JR C,L011C                              ; 0115: 38 05 ; Version zu hoch -> Fehler
	LD A,35H                                ; 0117: 3E 35 ; Versionsziffer muss >= '5' sein
	CP (HL)                                 ; 0119: BE
	JR C,check_TPA                          ; 011A: 38 15 ; Version OK -> TPA pruefen
L011C:
	LD DE,msg_version_error                 ; 011C: 11 BD 0F ; -> msg_version_error
	JP print_string                         ; 011F: C3 18 0E

; -----------------------------------------------
; Check for 'CPA' string at (HL)
; Uses CPI to compare and advance HL
; Returns: Z=match, NZ=no match
; -----------------------------------------------
check_CPA:
	LD A,43H                                ; 0122: 3E 43 ; 'C'
	CPI                                     ; 0124: ED A1
	RET NZ                                  ; 0126: C0
	LD A,50H                                ; 0127: 3E 50 ; 'P'
	CPI                                     ; 0129: ED A1
	RET NZ                                  ; 012B: C0
	LD A,41H                                ; 012C: 3E 41 ; 'A'
	CPI                                     ; 012E: ED A1
	RET                                     ; 0130: C9

; Pruefe ob genuegend TPA-Speicher vorhanden ist (mindestens 9660H = 38496 Bytes).
; Der TPA (Transient Program Area) reicht von 0100H bis zur BDOS-Adresse.
; FORMAT.COM benoetigt diesen Platz fuer Programm + Format-Tabellen + Puffer.
check_TPA:
	LD HL,(0006H)                           ; 0131: 2A 06 00 ; HL = BDOS-Einsprung = TPA-Obergrenze
	LD DE,9660H                             ; 0134: 11 60 96 ; Mindestens 38496 Bytes erforderlich
	OR A                                    ; 0137: B7 ; Carry loeschen fuer SBC
	SBC HL,DE                               ; 0138: ED 52 ; TPA gross genug?
	JR NC,check_cmdline                     ; 013A: 30 06 ; Ja -> weiter
	LD DE,msg_tpa_error                     ; 013C: 11 12 10 ; Nein -> Fehlermeldung
	JP print_string                         ; 013F: C3 18 0E

; Pruefe Kommandozeile auf 'CPA'-Parameter.
; Wenn der Benutzer "FORMAT CPA" eingibt, werden zusaetzliche CPA-spezifische
; Formattypen im Menue angeboten. Das Flag wird per Selbstmodifikation
; in die Adresse 016CH geschrieben (dort steht ein LD A,nn Operand).
check_cmdline:
	LD HL,005DH                             ; 0142: 21 5D 00 ; FCB1+1 = Kommandozeilenargument
	CALL check_CPA                          ; 0145: CD 22 01 ; Pruefe auf 'CPA'
	LD A,00H                                ; 0148: 3E 00 ; Default: CPA-Modus aus
	JR NZ,L0155                             ; 014A: 20 09 ; Kein CPA-Argument -> Flag=0
	LD B,03H                                ; 014C: 06 03 ; 3x Leerzeichen ueberspringen
L014E:
	PUSH BC                                 ; 014E: C5
	CALL call_cpmx18                        ; 014F: CD EE 0D ; cpmx18 = delsps (Leerzeichen entf.)
	POP BC                                  ; 0152: C1
	DJNZ L014E                              ; 0153: 10 F9
L0155:
	; SELBSTMODIFIKATION: Schreibt A (0 oder !=0) als Operand des
	; LD A,nn Befehls bei 016BH. So wird das CPA-Flag zur Laufzeit gesetzt.
	LD (016CH),A                            ; 0155: 32 6C 01 ; CPA-Modus-Flag speichern

; ============================================================================
; HAUPTPROGRAMMSCHLEIFE
; Zeigt das Formatierungsmenue an und verarbeitet Benutzerauswahlen.
; Der Stapelzeiger wird auf die BDOS-Adresse gesetzt (= TPA-Obergrenze),
; damit der gesamte Speicher darunter als Stack nutzbar ist.
; ============================================================================
main_init:
	LD SP,(0006H)                           ; 0158: ED 7B 06 00 ; Stack = TPA-Ende
	CALL save_isr_vectors                   ; 015C: CD 78 0C ; ISR-Vektoren sichern, Hardware init
	LD DE,msg_banner                        ; 015F: 11 5B 10 ; Programmtitel anzeigen
	CALL print_string                       ; 0162: CD 18 0E
; --- Formattyp-Menue anzeigen ---
; Das Menue bietet 4 Grundfunktionen:
;   0 = Formatieren (Diskette komplett neu anlegen)
;   1 = Kopieren (Spur fuer Spur von Quelle auf Ziel)
;   2 = Pruefen (Lesen aller Spuren, Fehler melden)
;   3 = Automatische Formaterkennung im BIOS einstellen
show_menu:
	LD DE,msg_menu                          ; 0165: 11 BE 10 ; Grundmenue
	CALL print_string                       ; 0168: CD 18 0E
	; SELBSTMODIFIKATION: Der Operand bei 016CH wurde beim Start
	; mit dem CPA-Modus-Flag ueberschrieben (siehe check_cmdline).
	LD A,00H                                ; 016B: 3E 00 ; CPA-Modus? (Operand selbstmodifiziert)
	OR A                                    ; 016D: B7
	JR Z,L0176                              ; 016E: 28 06 ; Kein CPA-Modus -> skip
	LD DE,msg_cpa_mode                      ; 0170: 11 E3 10 ; CPA-spezifische Optionen
	CALL print_string_inline                ; 0173: CD 1B 0E
L0176:
	LD DE,msg_format_info                   ; 0176: 11 1C 11 ; Formatauswahl-Prompt
	CALL print_string_inline                ; 0179: CD 1B 0E
	CALL read_char                          ; 017C: CD 37 0E ; Eingabe abwarten
	JR NZ,menu_input                        ; 017F: 20 02 ; Taste gedrueckt -> auswerten
	LD A,30H                                ; 0181: 3E 30 ; Default bei ENTER = '0' (Formatieren)
; --- Benutzereingabe auswerten ---
; Q/X = Programmende (Rueckkehr ins Betriebssystem)
; 0-3 = FORMAT-Funktion auswaehlen
menu_input:
	CP 51H                                  ; 0183: FE 51 ; 'Q' = Quit
	JP Z,select_drive_side                  ; 0185: CA 5D 0B
	CP 58H                                  ; 0188: FE 58 ; 'X' = Exit 
	JP Z,select_drive_side                  ; 018A: CA 5D 0B
	SUB 30H                                 ; 018D: D6 30 ; ASCII -> Zahl (0-3)
	JR C,show_menu                          ; 018F: 38 D4 ; Ungueltig -> nochmal
	CP 04H                                  ; 0191: FE 04 ; > 3 -> ungueltig
	JR NC,show_menu                         ; 0193: 30 D0
	CP 01H                                  ; 0195: FE 01 ; Funktion 1 (Kopieren)?
	JR NZ,L01A1                             ; 0197: 20 08
	LD A,(016CH)                            ; 0199: 3A 6C 01 ; Kopieren nur im CPA-Modus
	OR A                                    ; 019C: B7
	JR Z,show_menu                          ; 019D: 28 C6 ; Nicht verfuegbar -> Menue
	LD A,01H                                ; 019F: 3E 01
L01A1:
	LD (01C8H),A                            ; 01A1: 32 C8 01 ; store function number
	CP 01H                                  ; 01A4: FE 01
	LD DE,11CBH                             ; 01A6: 11 CB 11
	JP NZ,process_choice                    ; 01A9: C2 AF 01
	LD DE,11E5H                             ; 01AC: 11 E5 11
; --- Funktionsnummer speichern und Laufwerk/Format vorbereiten ---
; A = gewaehlte Funktion (0=Formatieren, 1=Kopieren, 2=Pruefen, 3=Autodetect)
; Der Funktionscode wird an mehrere Stellen im Code geschrieben,
; die spaeter per Selbstmodifikation abgefragt werden (01C8H etc.).
process_choice:
	PUSH DE                                 ; 01AF: D5
	CALL read_char_upper                    ; 01B0: CD 34 0E
	POP DE                                  ; 01B3: D1
	CP 41H                                  ; 01B4: FE 41
	JR C,process_choice                     ; 01B6: 38 F7
	CP 51H                                  ; 01B8: FE 51
	JR NC,process_choice                    ; 01BA: 30 F3
	LD (123FH),A                            ; 01BC: 32 3F 12
	LD (12B3H),A                            ; 01BF: 32 B3 12
	SUB 41H                                 ; 01C2: D6 41
	LD (1C1FH),A                            ; 01C4: 32 1F 1C
	LD A,FFH                                ; 01C7: 3E FF
	CP 03H                                  ; 01C9: FE 03
	JR Z,setup_format_params                ; 01CB: 28 2D
L01CD:
	LD DE,1224H                             ; 01CD: 11 24 12
	CALL read_char_upper                    ; 01D0: CD 34 0E
	JR NZ,L01CD                             ; 01D3: 20 F8
	LD IY,drive_a_params                    ; 01D5: FD 21 1E 1C
	CALL deselect_drive                     ; 01D9: CD 9E 0B
	JP C,L0B46                              ; 01DC: DA 46 0B
	LD A,(01C8H)                            ; 01DF: 3A C8 01
	CP 02H                                  ; 01E2: FE 02
	JR Z,setup_format_params                ; 01E4: 28 14
	CALL setup_isr                          ; 01E6: CD 8E 1E
	LD DE,141DH                             ; 01E9: 11 1D 14
	JP Z,L0B46                              ; 01EC: CA 46 0B
	LD DE,1263H                             ; 01EF: 11 63 12
	CALL read_char_upper                    ; 01F2: CD 34 0E
	SUB 4EH                                 ; 01F5: D6 4E
	LD (0AC7H),A                            ; 01F7: 32 C7 0A
; ============================================================================
; FORMATPARAMETER-EINRICHTUNG
; Laedt die aktiven Formatparameter (CDB = Command Descriptor Block) in
; die Arbeitsbereiche. Der CDB beschreibt ein komplettes Diskettenformat:
;   Offset  0: Sektoren pro Spur (SPT)
;   Offset  2: Block Shift Factor (BSH)
;   Offset  3: Block Mask (BLM)
;   Offset  4: Extent Mask (EXM)
;   Offset  5-6: Disk Size - 1 (DSM, in Bloecken)
;   Offset  7-8: Directory-Eintraege - 1 (DRM)
;   Offset  9-10: Directory Allocation Bitmap (AL0/AL1)
;   Offset 11-12: Checksum-Vektorgroesse (CKS)
;   Offset 13: Reservierte Systemspuren (OFF)
;   Offset 14: Track count
;   Offset 15: Flags (Bit-Feld fuer Formatierungsoptionen)
;   Offset 16: Sector Length Code (SLC: 0=128, 1=256, 2=512, 3=1024)
;   Offset 17: Letzte Sektornummer
;   Offset 18: Seitenanzahl/Konfiguration
;   Offset 19: Seitenoffset fuer Sektornummern auf Rueckseite
;   Offset 20: Anzahl Tracks gesamt
;   Offset 22: Physische Spur-Anzahl
;   Offset 24: Hardware-Feature-Flags (Bit 7: extended params etc.)
; ============================================================================
setup_format_params:
	LD IY,drive_a_params                    ; 01FA: FD 21 1E 1C
	CALL calc_track_capacity                ; 01FE: CD B4 0B
	JP C,L0B46                              ; 0201: DA 46 0B
	LD DE,active_cdb                        ; 0204: 11 D0 1B
	PUSH DE                                 ; 0207: D5
	POP IX                                  ; 0208: DD E1
	LD BC,0033H                             ; 020A: 01 33 00
	LDIR                                    ; 020D: ED B0
	BIT 7,(IX+24)                           ; 020F: DD CB 18 7E
	JR Z,L021A                              ; 0213: 28 05
	LD BC,001AH                             ; 0215: 01 1A 00
	LDIR                                    ; 0218: ED B0
L021A:
	BIT 4,(IX+24)                           ; 021A: DD CB 18 66
	JR NZ,L0233                             ; 021E: 20 13
	LD A,06H                                ; 0220: 3E 06
	LD (1B95H),A                            ; 0222: 32 95 1B
	LD HL,sector_table_2                    ; 0225: 21 92 1A
	BIT 3,(IX+24)                           ; 0228: DD CB 18 5E
	JR Z,L026D                              ; 022C: 28 3F
	LD HL,1AE8H                             ; 022E: 21 E8 1A
	JR L026D                                ; 0231: 18 3A

L0233:
	LD A,1EH                                ; 0233: 3E 1E
	LD (1B95H),A                            ; 0235: 32 95 1B
	LD A,(IX+22)                            ; 0238: DD 7E 16
	LD C,A                                  ; 023B: 4F
	LD HL,21DFH                             ; 023C: 21 DF 21
	LD DE,2637H                             ; 023F: 11 37 26
	CP 29H                                  ; 0242: FE 29
	JR C,L024C                              ; 0244: 38 06
	LD HL,fmt_5_25_80_ss                    ; 0246: 21 5A 29
	LD DE,2BE0H                             ; 0249: 11 E0 2B
L024C:
	BIT 0,(IX+24)                           ; 024C: DD CB 18 46
	JR Z,L0263                              ; 0250: 28 11
	LD HL,fmt_5_25_40_ds                    ; 0252: 21 AF 2D
	LD DE,30D9H                             ; 0255: 11 D9 30
setup_drive:
	LD A,C                                  ; 0258: 79
	CP 29H                                  ; 0259: FE 29
	JR C,L0263                              ; 025B: 38 06
	LD HL,fmt_5_25_80_ds                    ; 025D: 21 12 33
	LD DE,38A0H                             ; 0260: 11 A0 38
L0263:
	LD (1A3EH),HL                           ; 0263: 22 3E 1A
	LD (1A40H),DE                           ; 0266: ED 53 40 1A
	LD HL,default_params                    ; 026A: 21 3C 1A
L026D:
	LD DE,1B3EH                             ; 026D: 11 3E 1B
	LD BC,0056H                             ; 0270: 01 56 00
	LDIR                                    ; 0273: ED B0
L0275:
	LD DE,(1B3EH)                           ; 0275: ED 5B 3E 1B
	CALL print_string                       ; 0279: CD 18 0E
	LD DE,(1B40H)                           ; 027C: ED 5B 40 1B
	CALL print_string_inline                ; 0280: CD 1B 0E
	LD A,(01C8H)                            ; 0283: 3A C8 01
	CP 03H                                  ; 0286: FE 03
	LD DE,msg_auto_format                   ; 0288: 11 7C 14
	CALL Z,print_string                     ; 028B: CC 18 0E
	LD A,(01C8H)                            ; 028E: 3A C8 01
	CP 03H                                  ; 0291: FE 03
	JR NZ,L02A8                             ; 0293: 20 13
	LD IX,(1C29H)                           ; 0295: DD 2A 29 1C
	BIT 6,(IX+24)                           ; 0299: DD CB 18 76
	LD DE,msg_verify_yes                    ; 029D: 11 BA 14
	JR Z,L02A5                              ; 02A0: 28 03
	LD DE,msg_verify_no                     ; 02A2: 11 EC 14
L02A5:
	CALL print_string                       ; 02A5: CD 18 0E
L02A8:
	LD A,(01C8H)                            ; 02A8: 3A C8 01
	CP 02H                                  ; 02AB: FE 02
	LD DE,msg_source_drive                  ; 02AD: 11 1E 15
	CALL Z,print_string                     ; 02B0: CC 18 0E
	LD DE,msg_select_fmt                    ; 02B3: 11 3F 15
	CALL read_char_upper                    ; 02B6: CD 34 0E
	LD IX,active_cdb                        ; 02B9: DD 21 D0 1B
	JR NZ,L02C1                             ; 02BD: 20 02
	LD A,30H                                ; 02BF: 3E 30
L02C1:
	CP 42H                                  ; 02C1: FE 42
	JR NZ,L02EB                             ; 02C3: 20 26
	LD A,(01C8H)                            ; 02C5: 3A C8 01
	CP 02H                                  ; 02C8: FE 02
	JR NZ,L0275                             ; 02CA: 20 A9
	LD A,(IX+0)                             ; 02CC: DD 7E 00
	LD B,(IX+16)                            ; 02CF: DD 46 10
	INC B                                   ; 02D2: 04
	DEC B                                   ; 02D3: 05
	JR Z,L02DA                              ; 02D4: 28 04
; --- Sektorlaengencode aus SLC berechnen ---
; SLC (Sector Length Code): 0=128B, 1=256B, 2=512B, 3=1024B
; Die Sektorgroesse wird durch wiederholtes Halbieren berechnet.
begin_operation:
	SRL A                                   ; 02D6: CB 3F ; Halbieren pro SLC-Schritt
	DJNZ begin_operation                    ; 02D8: 10 FC ; B mal wiederholen
L02DA:
	LD (1B94H),A                            ; 02DA: 32 94 1B
	LD HL,format_buffer                     ; 02DD: 21 50 1B
	LD DE,1B96H                             ; 02E0: 11 96 1B
	LD BC,0034H                             ; 02E3: 01 34 00
	LDIR                                    ; 02E6: ED B0
	JP format_setup                         ; 02E8: C3 D4 03

L02EB:
