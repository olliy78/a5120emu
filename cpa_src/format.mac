; --- Arbeitsdaten-Bereich ---
; Laufwerksparameter-Bloecke fuer Laufwerk A und B:
;   Byte 0: Flags/Modus
;   Byte 1: aktuelle Spur
;   Byte 2: gewuenschte Spur
;   Byte 3-4: reserviert
;   Byte 5: Anzahl Sektoren
;   Byte 6: Funktion
;   Byte 7-8: DMA-Adresse
;   Byte 9-10: DPB-Zeiger
;   Byte 11-12: Spur-Tabellen-Zeiger
;   Byte 13+: formatspezifische Parameter
drive_a_params:
	DB	10H,FFH,FFH,FFH,FFH,03H,01H,B0H,6CH,00H,00H,00H,00H,00H; 1C1E | ........l.....
drive_b_params:
	DB	10H,FFH,FFH,FFH,FFH,03H,01H,00H,44H,00H,00H,00H,00H,00H,20H,00H; 1C2C | ........D..... .
	DB	00H,00H,00H,00H,00H,00H,00H,00H,00H,00H,00H,00H,00H,00H,00H,00H; 1C3C | ................
	DB	00H,00H,00H,00H,00H,00H,00H,00H,00H,00H,00H,00H,00H,00H,00H,00H; 1C4C | ................
	DB	00H,00H,00H,00H,00H,00H,00H,00H,00H,00H,00H,00H,00H,00H,00H,00H; 1C5C | ................
	DB	00H,00H,00H,00H,00H,00H,00H,00H,00H,00H,00H,00H,00H,00H,00H,00H; 1C6C | ................
	DB	00H,00H,00H,00H,00H,00H,4EH,13H,00H,00H,FEH,00H,00H,00H,00H,00H; 1C7C | ......N.........
	DB	00H,FBH                                           ; 1C8C | ..

; ============================================================================
;                 CPU2 (K2526) FORMAT CODE - DIREKTER HARDWARE-ZUGRIFF
; ============================================================================
;
; *** DIESER ABSCHNITT UMGEHT DAS BETRIEBSSYSTEM VOLLSTAENDIG! ***
;
; Die Karte K2526 besitzt ZWEI Z80/U880 CPUs auf einer Platine.
; CPU1 fuehrt das CPA-Betriebssystem aus.
; CPU2 ist normalerweise fuer Floppy-I/O ueber das BIOS zustaendig.
;
; FORMAT.COM nutzt CPU2 DIREKT fuer die Formatierung:
;   1. CPU1 bereitet die Sektor-Tabellen vor (cpu2_init)
;   2. sub_1E93 deaktiviert PIO-Interrupts und speichert alte ISR-Vektoren
;   3. Der Warmstart-Vektor (0001H) wird umgeleitet, damit das OS
;      waehrend der Formatierung nicht stoert
;   4. CPU2-Formatroutine-Zeiger werden aus der Routinen-Tabelle geladen
;   5. Die PIOs werden DIREKT konfiguriert (Port 10H-17H)
;   6. CPU1 geht in eine JR $-Schleife (Endlosschleife bei 1D21H)
;   7. CPU2 fuehrt die Formatierung durch (cpu2_format_5_sd/dd)
;   8. Der Index-Puls-Interrupt (ISR bei 1E88H) modifiziert den
;      JR-Operanden per Selbstmodifikation, um die Schleife zu beenden
;   9. Nach Abschluss werden ISR-Vektoren restauriert
;
; EINSPRUNGPUNKTE:
;   1C8EH: cpu2_init    - Einstieg 5.25" SD-Format
;   1C96H:              - Einstieg 5.25" DD-Format
;   1C9BH:              - Einstieg 8" Format
;
; Die ersten 3 Bytes (1C8E-1C90) werden als Laufzeit-Variablen benutzt:
;   1C8EH: CPU2 Seitenoffset (0 = Seite A, >0 = Seite B)
;   1C8FH: Aktueller Sektor-Zaehler
;   1C90H: Wiederholungszaehler fuer Fehler
; ============================================================================
cpu2_init:
	NOP                                     ; 1C8E: 00 ; Variable: Seitenoffset (wird zur Laufzeit beschrieben)
	NOP                                     ; 1C8F: 00 ; Variable: Sektor-Zaehler
	NOP                                     ; 1C90: 00 ; Variable: Wiederholungen

; --- Einstieg SD-Format (Single Density, FM-Kodierung) ---
	LD DE,1EEAH                             ; 1C91: 11 EA 1E ; DE -> SD-Format-Parametertabelle
	JR L1CA0                                ; 1C94: 18 0A

; --- Einstieg DD-Format (Double Density, MFM-Kodierung) ---
	LD DE,1EEFH                             ; 1C96: 11 EF 1E ; DE -> DD-Format-Parametertabelle
	JR L1CA0                                ; 1C99: 18 05

; --- Einstieg 8"-Laufwerk Format ---
	LD DE,1EF4H                             ; 1C9B: 11 F4 1E ; DE -> 8"-Format-Parametertabelle
	JR L1CA0                                ; 1C9E: 18 00

; --- Gemeinsame Initialisierung aller Formate ---
; Laedt Formatroutinen-Zeiger aus der cpu2_format_table,
; konfiguriert Gap-Fuellbytes und Sektorinterleave-Tabelle.
L1CA0:
	LD HL,cpu2_format_table                 ; 1CA0: 21 DF 1E ; HL -> Zeigertabelle der CPU2-Routinen
	CALL sub_1ED2                           ; 1CA3: CD D2 1E ; Kopiert Parameter aus (DE)-Tabelle nach (HL)-Zieladressen

; --- Gap-Fuellbyte-Tabelle je nach Dichte auswaehlen ---
; Die gap_fill_table (1F04H) enthaelt 8 Bytes pro Dichtestufe.
; 1C8AH enthaelt den Index des aktuellen Formats (SD/DD/HD).
	LD A,(1C8AH)                            ; 1CA6: 3A 8A 1C ; Formattyp-Index
	LD B,A                                  ; 1CA9: 47
	INC B                                   ; 1CAA: 04
	LD DE,0008H                             ; 1CAB: 11 08 00 ; 8 Bytes pro Tabelleneintrag
	LD HL,1F02H                             ; 1CAE: 21 02 1F ; Basis der Gap-Fill-Tabelle (vor gap_fill_table)
L1CB1:
	ADD HL,DE                               ; 1CB1: 19       ; HL += 8 * (Formattyp+1)
	DJNZ L1CB1                              ; 1CB2: 10 FD
	EX DE,HL                                ; 1CB4: EB       ; DE -> Gap-Parameter fuer dieses Format
	LD HL,1EF9H                             ; 1CB5: 21 F9 1E ; HL -> Zieladressen fuer Gap-Fill
	CALL sub_1ED2                           ; 1CB8: CD D2 1E ; Kopiert Gap-Parameter an Zieladressen

; --- Seitenwahl (Side Select) konfigurieren ---
; Bit 2 der FDC-Steuerbytes wird je nach Seite gesetzt/geloescht.
; 1C81H: 0=Seite A (Bit 2 setzen), >0=Seite B (Bit 2 loeschen)
; Die Zeigertabelle format_ptr_table (1F2AH) enthaelt Adressen
; der FDC-Steuerbytes, die entsprechend manipuliert werden.
	LD A,(1C81H)                            ; 1CBB: 3A 81 1C ; Seitenflag (0=A, 1=B)
	LD HL,1F2AH                             ; 1CBE: 21 2A 1F ; HL -> Zeigertabelle der Steuerbytes
	LD B,(HL)                               ; 1CC1: 46       ; B = Anzahl der zu aendernden Steuerbytes
L1CC2:
	INC HL                                  ; 1CC2: 23
	LD E,(HL)                               ; 1CC3: 5E       ; Lo-Byte der Zieladresse
	INC HL                                  ; 1CC4: 23
	LD D,(HL)                               ; 1CC5: 56       ; Hi-Byte der Zieladresse
	EX DE,HL                                ; 1CC6: EB       ; HL -> Ziel-Steuerbyte
	OR A                                    ; 1CC7: B7       ; Seite A (A=0)?
	JR Z,L1CCE                              ; 1CC8: 28 04    ; Ja -> Bit 2 setzen (/SIDE high)
	RES 2,(HL)                              ; 1CCA: CB 96    ; Seite B: Bit 2 loeschen (/SIDE low)
	JR cpu2_copy_data                       ; 1CCC: 18 02

L1CCE:
	SET 2,(HL)                              ; 1CCE: CB D6    ; Seite A: Bit 2 setzen (/SIDE high)
cpu2_copy_data:
	EX DE,HL                                ; 1CD0: EB
	DJNZ L1CC2                              ; 1CD1: 10 EF    ; Naechstes Steuerbyte
; ============================================================================
; HARDWARE-SETUP: DIREKTER PIO/FDC-ZUGRIFF (am OS vorbei!)
; ============================================================================
; Ab hier beginnt der kritische Abschnitt, in dem FORMAT.COM
; DIREKT auf die Hardware der K5122 Floppy-Controller-Karte zugreift.
; Das Betriebssystem (CPA) wird komplett umgangen.
; ============================================================================

	LD (1D29H),SP                           ; 1CD3: ED 73 29 1D ; Stack-Pointer sichern fuer spaetere Wiederherstellung

; --- Schreibschutz-Pruefung: DIREKTER PORT-ZUGRIFF! ---
; Liest PIO B Status-Port 12H direkt, um zu pruefen ob
; die Diskette schreibgeschuetzt ist (Bit 5 = /WP).
	CALL setup_isr                          ; 1CD7: CD 8E 1E ; -> IN A,(12H); BIT 5,A bei 1E8EH
	LD B,57H                                ; 1CDA: 06 57    ; Fehlercode 'W' (Write-protect) vorbereiten
	JP Z,L1D28                              ; 1CDC: CA 28 1D ; Wenn WP aktiv -> Abbruch mit Fehler

; --- ISR-Vektoren umbiegen: DIREKTER I-REGISTER ZUGRIFF! ---
; sub_1E93 macht Folgendes:
;   1. Deaktiviert PIO-Interrupts: OUT (11H),03H
;   2. Liest I-Register: LD A,I (Interrupt-Basisvektor)
;   3. Speichert alte ISR-Vektoren von I*256+E8H (4 Bytes)
;   4. Installiert eigene ISR-Vektoren (Index-Puls + Daten-Marke)
;   5. Aktiviert Interrupts: EI
	CALL sub_1E93                           ; 1CDF: CD 93 1E ; ISR-Vektoren umbiegen

; --- Warmstart-Vektor deaktivieren: OS-UMGEHUNG! ---
; Der Warmstart-Vektor bei 0001H wird auf 0000H gesetzt,
; damit das CPA waehrend der Formatierung nicht durch einen
; versehentlichen Warmstart die Hardware-Programmierung stoert.
; Der originale Vektor wird in BC gesichert und spaeter restauriert.
	LD HL,0000H                             ; 1CE2: 21 00 00
	LD BC,(0001H)                           ; 1CE5: ED 4B 01 00 ; BC = Original-Warmstart-Vektor sichern
	LD (0001H),HL                           ; 1CE9: 22 01 00    ; Warmstart deaktivieren (0000H)

; --- Selbstmodifikation: JR $-Endlosschleife vorbereiten ---
; Bei 1D22H (cpu2_format_end) wird FEH geschrieben, was zusammen
; mit dem Opcode 18H (JR) zu JR $-2 wird -> Endlosschleife.
; Wenn die Formatierung beendet ist, schreibt die ISR bei 1E88H
; den Wert 3EH dorthin, was die Schleife aufbricht.
	LD A,FEH                                ; 1CEC: 3E FE    ; FEH = JR-Displacement fuer "JR $" (-2)
	LD (cpu2_format_end),A                  ; 1CEE: 32 22 1D ; Endlosschleife bei 1D21H programmieren

; --- Selbstmodifikation der Format-Schleifen ---
; In den Formatroutinen cpu2_format_5_sd (bei 1D50H) und
; cpu2_format_5_dd_wr (bei 1DE5H) gibt es JR-Schleifen, die
; ebenfalls per ISR aufgebrochen werden. 18H = JR-Opcode.
	LD HL,1D50H                             ; 1CF1: 21 50 1D ; Adresse der SD-Formatschleife
	LD DE,1DE5H                             ; 1CF4: 11 E5 1D ; Adresse der DD-Formatschleife
	LD (HL),18H                             ; 1CF7: 36 18    ; 18H = JR Opcode einschreiben
	EX DE,HL                                ; 1CF9: EB
	LD (HL),18H                             ; 1CFA: 36 18    ; dto. fuer DD-Schleife
	EX DE,HL                                ; 1CFC: EB
; ============================================================================
; *** KRITISCHER HARDWARE-ZUGRIFF: PIO-KONFIGURATION ***
; Hier wird die K5122 Floppy-Controller-Karte DIREKT programmiert.
; Alle OUT-Befehle gehen OHNE OS-Vermittlung an die PIO-Ports.
; ============================================================================
;
; Port 14H = Daten-PIO Kanal A (Daten zum/vom FDC)
; Port 04H = Daten-PIO Kanal B (Steuer-/Statusdaten)
; Port 17H = Daten-PIO Steuerregister (Konfiguration Eingang/Ausgang)
; Port 10H = FDC Steuer-PIO Ausgabe (Steuersignale zum FDC):
;            Bit 0 = /WE (Write Enable, active low)
;            Bit 2 = /SIDE (Seitenauswahl, 0=B, 1=A)
;            Bit 3 = SD (Single Density, 1=FM, 0=MFM)
;            Bit 4 = /ST (Step, Schrittimpuls)
;            Bit 5 = DIR (Richtung, 1=innen, 0=aussen)
;            Bit 7 = Laufwerk Select
; Port 11H = FDC Steuer-PIO Interrupt-Steuerung:
;            83H = Interrupts freigeben (Index-Puls-Erkennung)
;            03H = Interrupts sperren
; Port 16H = Daten-PIO Steuerregister lesen
; ============================================================================

	XOR A                                   ; 1CFD: AF       ; A = 00H
	OUT (14H),A                             ; 1CFE: D3 14    ; *** HW-ZUGRIFF: Daten-PIO A auf 00H setzen
	OUT (04H),A                             ; 1D00: D3 04    ; *** HW-ZUGRIFF: Daten-PIO B auf 00H setzen
	DEC A                                   ; 1D02: 3D       ; A = FFH
	OUT (17H),A                             ; 1D03: D3 17    ; *** HW-ZUGRIFF: PIO Steuer-Reg: Eingabemodus konfigurieren
	OUT (17H),A                             ; 1D05: D3 17    ; *** HW-ZUGRIFF: Nochmals FFH -> alle Bits als Eingang

; --- FDC-Steuersignale setzen: Laufwerk vorbereiten ---
	LD A,B9H                                ; 1D07: 3E B9    ; B9H = 10111001b:
	                                        ;                ; Bit 0=1: /WE inaktiv (NICHT schreiben)
	                                        ;                ; Bit 3=1: SD=Single Density (FM)
	                                        ;                ; Bit 4=1: /ST inaktiv (kein Step)
	                                        ;                ; Bit 5=1: DIR=nach innen
	                                        ;                ; Bit 7=1: Laufwerk selektiert
	OUT (10H),A                             ; 1D09: D3 10    ; *** HW-ZUGRIFF: FDC-Steuersignale setzen

	LD A,A1H                                ; 1D0B: 3E A1    ; A1H = 10100001b:
	                                        ;                ; Bit 0=1: /WE inaktiv
	                                        ;                ; Bit 5=1: DIR nach innen
	                                        ;                ; Bit 7=1: Laufwerk selektiert
	                                        ;                ; (SD-Bit geloescht = MFM vorbereitet)
	OUT (10H),A                             ; 1D0D: D3 10    ; *** HW-ZUGRIFF: Steuersignale aktualisieren

; --- Daten-PIO als Eingang konfigurieren (Bitmaske lesen) ---
	LD A,7FH                                ; 1D0F: 3E 7F    ; 7FH = Bit-Maske fuer Eingangs-Konfiguration
	OUT (17H),A                             ; 1D11: D3 17    ; *** HW-ZUGRIFF: PIO-Konfiguration
	IN A,(16H)                              ; 1D13: DB 16    ; *** HW-ZUGRIFF: PIO-Status lesen (Handshake)

; --- Warmstart-Vektor restaurieren ---
	LD (0001H),BC                           ; 1D15: ED 43 01 00 ; Original-Warmstart-Vektor zurueckschreiben

; --- Schreibmodus aktivieren und Index-Interrupt einschalten ---
	LD A,B4H                                ; 1D19: 3E B4    ; B4H = 10110100b:
	                                        ;                ; Bit 0=0: /WE AKTIV -> SCHREIBEN ERLAUBT!
	                                        ;                ; Bit 2=1: /SIDE (Seite A)
	                                        ;                ; Bit 4=1: /ST inaktiv
	                                        ;                ; Bit 5=1: DIR nach innen
	                                        ;                ; Bit 7=1: Laufwerk selektiert
	OUT (10H),A                             ; 1D1B: D3 10    ; *** HW-ZUGRIFF: SCHREIBEN AKTIVIEREN!

	LD A,83H                                ; 1D1D: 3E 83    ; 83H = Interrupts freigeben
	                                        ;                ; Der Index-Puls am Laufwerk loest jetzt
	                                        ;                ; einen Interrupt aus, der die ISR bei 1E88H anspringt.
	OUT (11H),A                             ; 1D1F: D3 11    ; *** HW-ZUGRIFF: PIO-Interrupts EINSCHALTEN!

; ============================================================================
; *** ENDLOSSCHLEIFE - Warten auf Formatierung ***
; CPU1 wartet hier, waehrend CPU2 die eigentliche Formatierung ausfuehrt.
; Die ISR bei 1E88H wird beim Index-Puls am Ende der Spur ausgeloest
; und modifiziert den JR-Operanden bei 1D22H von FEH (JR $) auf 3EH,
; wodurch die Schleife aufgebrochen und die Ausfuehrung fortgesetzt wird.
; Aus JR FEH (= JR $, Endlosschleife) wird LD A,06H (= NOP-artig).
; ============================================================================
L1D21:
	JR L1D21                                ; 1D21: 18 FE    ; *** ENDLOSSCHLEIFE bis ISR sie aufbricht!
cpu2_format_end EQU 1D22H                               ; Operand des JR wird von ISR modifiziert

; --- Hierhin gelangt die Ausfuehrung nach ISR-Modifikation ---
	LD B,00H                                ; 1D23: 06 00    ; B=0: kein Fehler
	LD HL,0000H                             ; 1D25: 21 00 00 ; HL=0 (normal return)

; --- Cleanup nach Formatierung ---
L1D28:
	LD SP,0000H                             ; 1D28: 31 00 00 ; SP restaurieren (Operand bei 1CD3H gesichert)

; --- PIO-Interrupts wieder sperren ---
	LD A,03H                                ; 1D2B: 3E 03    ; 03H = Interrupts sperren
	OUT (11H),A                             ; 1D2D: D3 11    ; *** HW-ZUGRIFF: PIO-Interrupts ABSCHALTEN!

	LD A,B                                  ; 1D2F: 78       ; Fehlercode laden

; --- ISR-Vektoren restaurieren und zurueckkehren ---
cpu2_check_ready:
	PUSH HL                                 ; 1D30: E5
	PUSH AF                                 ; 1D31: F5
	CALL restore_isr_vecs                   ; 1D32: CD B6 1E ; Originale ISR-Vektoren wiederherstellen
	POP AF                                  ; 1D35: F1
	POP HL                                  ; 1D36: E1
	OR A                                    ; 1D37: B7       ; Z-Flag setzen wenn kein Fehler
	RET                                     ; 1D38: C9       ; Zurueck zum Hauptprogramm

; ============================================================================
; CPU2 FORMATIERROUTINE: SINGLE DENSITY (FM-KODIERUNG)
; ============================================================================
;
; *** DIREKTER HARDWARE-ZUGRIFF AUF ALLEN PORTS! ***
;
; Diese Routine wird von CPU2 ausgefuehrt und schreibt die physische
; Spur-Struktur im FM-Format (Single Density) direkt auf die Diskette.
; Alle Daten werden byteweise ueber die PIO an den FDC geschickt.
;
; FM-Spurs-Struktur pro Sektor:
;   1. GAP (4EH-Bytes via Port 14H/C=14H, B=Anzahl)
;   2. SYNC (00H-Bytes, 11 Stueck via Port 14H)
;   3. Index Address Mark (C2H) ueber Port 14H, Clock via Port 10H
;   4. Sector ID (Track, Side, Sector, Size) via OTIR
;   5. CRC (2 Bytes)
;   6. GAP2
;   7. Data Address Mark (A1H) und Data-Feld
;   8. CRC (2 Bytes)
;   9. GAP3
;
; Port-Zuordnung (DIREKT, ohne OS!):
;   Port 14H (C=14H) = Daten-PIO A: Datenbytes zum FDC
;   Port 10H (C=10H) = Steuer-PIO: Clock/Steuersignale
;   Port 04H (C=04H) = Daten-PIO B: Hilfsdaten
;
; Register-Belegung:
;   BC  = Port-Adresse und Zaehler fuer OUTI/OTIR
;   D   = Sektorzaehler (herunterzaehlend)
;   E   = Gap-Fuellbyte (4EH fuer SD)
;   HL  = Zeiger auf Sektor-Daten (ab 6CB0H)
;   HL' = Zeiger auf Sektor-Adress-Tabelle
;   DE' = CRC/Kontroll-Werte (alternativregister)
; ============================================================================
	EXX                                     ; 1D39: D9       ; Alternativregister aktivieren
cpu2_format_5_sd:
	LD HL,6CB0H                             ; 1D3A: 21 B0 6C ; HL' -> Sektor-Datenpuffer
	LD DE,B6B4H                             ; 1D3D: 11 B4 B6 ; DE' = CRC Initialwert fuer FM
	EXX                                     ; 1D40: D9       ; Zurueck zu Hauptregistern
	LD BC,5014H                             ; 1D41: 01 14 50 ; B=50H (80 Gap-Bytes), C=14H (Daten-Port)
	LD A,(1C45H)                            ; 1D44: 3A 45 1C ; Anzahl Sektoren pro Spur
	LD D,A                                  ; 1D47: 57       ; D = Sektorzaehler
	LD E,4EH                                ; 1D48: 1E 4E    ; E = Gap-Fuellbyte (4EH fuer FM)

; --- Warten auf Index-Puls (Spuranfang) ---
; Die ISR bei 1E88H bricht diese Schleife beim naechsten Index-Puls auf.
; Danach beginnt sofort die Formatierung am Spuranfang.
L1D4A:
	LD A,BDH                                ; 1D4A: 3E BD    ; BDH = Steuerwort mit /WE aktiv (Schreiben an)
	OUT (10H),A                             ; 1D4C: D3 10    ; *** HW: Schreibmodus aktivieren

; --- Endlosschleife: Gap-Bytes schreiben bis Index-Puls ---
; SELBSTMODIFIKATION: Die ISR aendert den JR-Operanden bei 1D50H+1
; von FCH (JR $-2, Schleife) auf 3EH -> Schleife wird verlassen.
L1D4E:
	OUT (C),E                               ; 1D4E: ED 59    ; *** HW: Gap-Fuellbyte 4EH an Port 14H
	JR L1D4E                                ; 1D50: 18 FC    ; Schleife bis ISR den Operanden aendert

; ============================================================================
; SEKTOR-GAP SCHREIBEN (Post-Index Gap / Gap 1)
; 50H (80) Gap-Bytes werden am Anfang der Spur geschrieben
; ============================================================================
L1D52:
	OUT (C),E                               ; 1D52: ED 59    ; *** HW: Gap-Byte schreiben
	DJNZ L1D52                              ; 1D54: 10 FC    ; B Bytes schreiben

; --- SYNC-Feld (11 Null-Bytes) ---
; Die Null-Bytes dienen zur Taktsynchronisation des Lesekopfes.
	XOR A                                   ; 1D56: AF       ; A = 00H (Sync-Byte)
	LD B,0BH                                ; 1D57: 06 0B    ; 11 Sync-Bytes
L1D59:
	OUT (14H),A                             ; 1D59: D3 14    ; *** HW: Sync-Byte 00H schreiben
	DJNZ L1D59                              ; 1D5B: 10 FC

; --- INDEX ADDRESS MARK (IAM) ---
; Spezielle Byte-Folge die dem Controller den Spuranfang signalisiert.
; Im FM-Format: C2H C2H C2H mit speziellem Clock-Pattern.
; Port 10H steuert die Clock-Bits des FDC.
	EXX                                     ; 1D5D: D9       ; Alt-Register: D=Clock-Wert
	LD C,10H                                ; 1D5E: 0E 10    ; C = Steuer-Port 10H
	OUT (14H),A                             ; 1D60: D3 14    ; *** HW: Letztes Sync-Byte
	OUT (C),D                               ; 1D62: ED 51    ; *** HW: Clock-Pattern fuer Address Mark
	LD A,C2H                                ; 1D64: 3E C2    ; C2H = Index Address Mark Byte
	OUT (14H),A                             ; 1D66: D3 14    ; *** HW: IAM Byte 1
	OUT (14H),A                             ; 1D68: D3 14    ; *** HW: IAM Byte 2
	OUT (14H),A                             ; 1D6A: D3 14    ; *** HW: IAM Byte 3
	OUT (C),E                               ; 1D6C: ED 59    ; *** HW: Steuer-Signal normal
	LD A,FCH                                ; 1D6E: 3E FC    ; FCH = Index Mark Schluss-Byte
	OUT (14H),A                             ; 1D70: D3 14    ; *** HW: Index Mark abschliessen
	EXX                                     ; 1D72: D9       ; Zurueck zu Hauptregistern

; ============================================================================
; SEKTOR-SCHLEIFE: Fuer jeden Sektor der Spur:
; ============================================================================
	LD B,32H                                ; 1D73: 06 32    ; 50 Gap-Bytes (Gap 2)
L1D75:
	OUT (C),E                               ; 1D75: ED 59    ; *** HW: Gap-Byte schreiben
	DJNZ L1D75                              ; 1D77: 10 FC

; --- SECTOR ID FIELD ---
L1D79:
; Sync-Feld vor Sektor-ID (11 Null-Bytes)
	XOR A                                   ; 1D79: AF
	LD B,0BH                                ; 1D7A: 06 0B    ; 11 Sync-Bytes
L1D7C:
	OUT (14H),A                             ; 1D7C: D3 14    ; *** HW: Sync-Byte
	DJNZ L1D7C                              ; 1D7E: 10 FC

; --- Address Mark fuer Sektor-ID ---
; A1H mit speziellem Clock = Sektor-ID-Kennung
	EXX                                     ; 1D80: D9       ; Alt-Register
	LD C,10H                                ; 1D81: 0E 10    ; Steuer-Port
	OUT (14H),A                             ; 1D83: D3 14    ; *** HW: Letztes Sync-Byte
	OUT (C),D                               ; 1D85: ED 51    ; *** HW: Clock-Pattern fuer Address Mark
	LD A,A1H                                ; 1D87: 3E A1    ; A1H = Sektor ID Address Mark
	OUT (14H),A                             ; 1D89: D3 14    ; *** HW: IDAM Byte 1
	OUT (14H),A                             ; 1D8B: D3 14    ; *** HW: IDAM Byte 2
	OUT (14H),A                             ; 1D8D: D3 14    ; *** HW: IDAM Byte 3
	OUT (C),E                               ; 1D8F: ED 59    ; *** HW: Steuer-Signal normal

; --- Sektor-Header: FEH + Track + Side + Sector + Size ---
	LD A,FEH                                ; 1D91: 3E FE    ; FEH = ID Address Mark
	OUT (14H),A                             ; 1D93: D3 14    ; *** HW: ID-Mark schreiben
	LD BC,0614H                             ; 1D95: 01 14 06 ; 6 Bytes an Port 14H (ID + CRC)
	OTIR                                    ; 1D98: ED B3    ; *** HW: Sektor-ID-Feld schreiben (HL->Port)
	EXX                                     ; 1D9A: D9       ; Hauptregister

; --- GAP 2 (zwischen ID und Daten) ---
	LD B,16H                                ; 1D9B: 06 16    ; 22 Gap-Bytes
L1D9D:
	OUT (C),E                               ; 1D9D: ED 59    ; *** HW: Gap-Byte
	DJNZ L1D9D                              ; 1D9F: 10 FC

; --- DATA FIELD ---
; Sync-Feld vor Daten (11 Null-Bytes)
	XOR A                                   ; 1DA1: AF
	LD B,0BH                                ; 1DA2: 06 0B
L1DA4:
	OUT (14H),A                             ; 1DA4: D3 14    ; *** HW: Sync-Byte
	DJNZ L1DA4                              ; 1DA6: 10 FC

; --- Data Address Mark ---
	EXX                                     ; 1DA8: D9       ; Alt-Register
	LD C,10H                                ; 1DA9: 0E 10
	OUT (14H),A                             ; 1DAB: D3 14    ; *** HW: Letztes Sync-Byte
	OUT (C),D                               ; 1DAD: ED 51    ; *** HW: Clock-Pattern
	LD A,A1H                                ; 1DAF: 3E A1    ; A1H = Data Address Mark
	OUT (14H),A                             ; 1DB1: D3 14    ; *** HW: DAM Byte 1
	OUT (14H),A                             ; 1DB3: D3 14    ; *** HW: DAM Byte 2
	OUT (14H),A                             ; 1DB5: D3 14    ; *** HW: DAM Byte 3
	OUT (C),E                               ; 1DB7: ED 59    ; *** HW: Steuer normal

; --- Daten-Mark + Sektor-Daten + CRC ---
	LD A,FBH                                ; 1DB9: 3E FB    ; FBH = Data Mark
	OUT (14H),A                             ; 1DBB: D3 14    ; *** HW: Data Mark schreiben
	LD BC,8014H                             ; 1DBD: 01 14 80 ; 128 Bytes an Port 14H (SD=128 Bytes/Sektor)
	OUTI                                    ; 1DC0: ED A3    ; *** HW: 1. Datenbyte
	OUTI                                    ; 1DC2: ED A3    ; *** HW: 2. Datenbyte  
	OUTI                                    ; 1DC4: ED A3    ; *** HW: 3. Datenbyte
	OTIR                                    ; 1DC6: ED B3    ; *** HW: restliche Datenbytes (Block-Transfer)
	OUTI                                    ; 1DC8: ED A3    ; *** HW: CRC Byte 1
	OUTI                                    ; 1DCA: ED A3    ; *** HW: CRC Byte 2
	EXX                                     ; 1DCC: D9       ; Hauptregister

; --- GAP 3 (zwischen Sektoren) ---
; Die Gap-Laenge wird aus 1C46H gelesen (formatspezifisch)
	LD A,(1C46H)                            ; 1DCD: 3A 46 1C ; Gap3-Laenge
	OUT (C),E                               ; 1DD0: ED 59    ; *** HW: 1. Gap-Byte
	LD B,A                                  ; 1DD2: 47       ; B = Gap-Laenge
	DEC B                                   ; 1DD3: 05       ; -2 (fuer die beiden OUT-Befehle davor/dahinter)
	DEC B                                   ; 1DD4: 05
L1DD5:
	OUT (C),E                               ; 1DD5: ED 59    ; *** HW: Gap-Byte
	DJNZ L1DD5                              ; 1DD7: 10 FC

; --- Naechster Sektor oder Spur-Ende ---
	DEC D                                   ; 1DD9: 15       ; Sektorzaehler verringern
	OUT (C),E                               ; 1DDA: ED 59    ; *** HW: letztes Gap-Byte
	JP NZ,L1D79                             ; 1DDC: C2 79 1D ; Wenn noch Sektoren -> naechster Sektor

; --- Spur-Ende: Gap-Fuellbytes bis zum naechsten Index-Puls ---
L1DDF:
	LD HL,0000H                             ; 1DDF: 21 00 00 ; Byte-Zaehler
L1DE2:
	OUT (C),E                               ; 1DE2: ED 59    ; *** HW: Fuellbytes schreiben
	INC HL                                  ; 1DE4: 23       ; Zaehler erhoehen
	JR L1DE2                                ; 1DE5: 18 FB    ; Schleife bis ISR sie aufbricht

; --- Seite umschalten fuer naechste Formatierung ---
; Wenn die aktuelle Seite fertig ist und Doppelseitig formatiert wird,
; wechselt dieser Code auf die andere Seite und startet erneut.
	OUT (C),E                               ; 1DE7: ED 59    ; *** HW: letztes Gap-Byte
	LD A,B1H                                ; 1DE9: 3E B1    ; B1H = Seitenwechsel-Steuerwort
	                                        ;                ; Bit 0=1: /WE inaktiv
	                                        ;                ; Bit 4=1: /ST inaktiv
	                                        ;                ; Bit 5=1: DIR
	                                        ;                ; Bit 7=1: Laufwerk selektiert
	OUT (10H),A                             ; 1DEB: D3 10    ; *** HW: FDC-Steuersignale fuer Seitenwechsel
	LD (1D26H),HL                           ; 1DED: 22 26 1D ; Byte-Zaehler dieser Seite merken
	XOR A                                   ; 1DF0: AF
	LD (cpu2_format_end),A                  ; 1DF1: 32 22 1D ; JR-Operand zuruecksetzen -> Schleife wieder aktiv
	JP L1D4A                                ; 1DF4: C3 4A 1D ; Zurueck zum Spur-Anfang (andere Seite)

; ============================================================================
; CPU2 FORMATIERROUTINE: DOUBLE DENSITY (MFM-KODIERUNG)
; ============================================================================
;
; *** DIREKTER HARDWARE-ZUGRIFF AUF ALLEN PORTS! ***
;
; Identische Struktur wie cpu2_format_5_sd (siehe oben), jedoch:
; - MFM-Kodierung (doppelte Bitdichte)
; - 256 Bytes pro Sektor statt 128 (bei DD-Formaten)
; - Andere Gap-Laengen und Sync-Byte-Anzahlen
; - Anderes Gap-Fuellbyte: FFH statt 4EH
; - Andere CRC-Initialwerte
;
; MFM-Sektorstruktur:
;   1. Gap (FFH-Bytes)
;   2. Sync (00H, 5 Stueck statt 11)
;   3. Address Mark (FCH mit Clock-Pattern)
;   4. Sektor-ID (Track, Side, Sector, Size, CRC)
;   5. Gap2 (1AH=26 Bytes)
;   6. Data Mark (FBH)
;   7. Sektor-Daten (256 Bytes)
;   8. CRC (2 Bytes)
;   9. Gap3
; ============================================================================
cpu2_format_5_dd_wr:
	EXX                                     ; 1DF7: D9       ; Alt-Register
	LD HL,6CB0H                             ; 1DF8: 21 B0 6C ; HL' -> Sektor-Datenpuffer
	LD DE,B6A4H                             ; 1DFB: 11 A4 B6 ; DE' = CRC Initialwert fuer MFM
	EXX                                     ; 1DFE: D9       ; Hauptregister
	LD BC,2814H                             ; 1DFF: 01 14 28 ; B=28H (40 Gap-Bytes), C=14H (Daten-Port)
	LD A,(1C45H)                            ; 1E02: 3A 45 1C ; Sektoren pro Spur
	LD D,A                                  ; 1E05: 57       ; Sektorzaehler
	LD E,FFH                                ; 1E06: 1E FF    ; Gap-Fuellbyte (FFH fuer MFM)

; --- Schreibmodus aktivieren ---
	LD A,B9H                                ; 1E08: 3E B9    ; B9H = Steuerwort (s. SD-Routine Erklaerung)
	OUT (10H),A                             ; 1E0A: D3 10    ; *** HW: FDC-Steuersignale setzen

; --- Warten auf Index-Puls (SELBSTMODIFIKATION!) ---
L1E0C:
	OUT (C),E                               ; 1E0C: ED 59    ; *** HW: Gap-Fuellbyte FFH
	JR L1E0C                                ; 1E0E: 18 FC    ; Endlosschleife bis ISR aufbricht

; --- Post-Index Gap ---
L1E10:
	OUT (C),E                               ; 1E10: ED 59    ; *** HW: Gap-Byte
	DJNZ L1E10                              ; 1E12: 10 FC

; --- Sync-Feld (5 Null-Bytes, weniger als bei FM) ---
	XOR A                                   ; 1E14: AF
	LD B,05H                                ; 1E15: 06 05    ; 5 Sync-Bytes (MFM braucht weniger)
L1E17:
	OUT (14H),A                             ; 1E17: D3 14    ; *** HW: Sync-Byte
	DJNZ L1E17                              ; 1E19: 10 FC

; --- Index Address Mark (MFM-Format) ---
	EXX                                     ; 1E1B: D9
	LD C,10H                                ; 1E1C: 0E 10
	OUT (14H),A                             ; 1E1E: D3 14    ; *** HW: Sync
	OUT (C),D                               ; 1E20: ED 51    ; *** HW: Clock-Pattern
	LD A,FCH                                ; 1E22: 3E FC    ; FCH = Index Mark (MFM)
	OUT (14H),A                             ; 1E24: D3 14    ; *** HW: Index Mark
	OUT (C),E                               ; 1E26: ED 59    ; *** HW: Steuer normal
	EXX                                     ; 1E28: D9

; --- Sektor-Schleife (DD) ---
	LD B,1AH                                ; 1E29: 06 1A    ; 26 Gap-Bytes (Gap 1/Gap 2)
L1E2B:
	OUT (C),E                               ; 1E2B: ED 59    ; *** HW: Gap-Byte
	DJNZ L1E2B                              ; 1E2D: 10 FC

; --- SEKTOR ID FIELD (MFM) ---
L1E2F:
	XOR A                                   ; 1E2F: AF
	LD B,05H                                ; 1E30: 06 05    ; 5 Sync-Bytes
L1E32:
	OUT (14H),A                             ; 1E32: D3 14    ; *** HW: Sync-Byte
	DJNZ L1E32                              ; 1E34: 10 FC

; --- Sektor ID Address Mark ---
	EXX                                     ; 1E36: D9
	LD C,10H                                ; 1E37: 0E 10
	OUT (14H),A                             ; 1E39: D3 14    ; *** HW: Sync
	OUT (C),D                               ; 1E3B: ED 51    ; *** HW: Clock-Pattern
	LD A,FEH                                ; 1E3D: 3E FE    ; FEH = ID Address Mark
	OUT (14H),A                             ; 1E3F: D3 14    ; *** HW: ID Mark
	OUT (C),E                               ; 1E41: ED 59    ; *** HW: Steuer normal

; --- Sektor-ID: Track/Side/Sector/Size + CRC (6 Bytes Block-Transfer) ---
	LD BC,0614H                             ; 1E43: 01 14 06
	OTIR                                    ; 1E46: ED B3    ; *** HW: 6 Bytes ID-Feld via Block-I/O
	EXX                                     ; 1E48: D9

; --- Gap 2 (zwischen ID und Daten) ---
	LD B,0BH                                ; 1E49: 06 0B    ; 11 Gap-Bytes
L1E4B:
	OUT (C),E                               ; 1E4B: ED 59    ; *** HW: Gap-Byte
	DJNZ L1E4B                              ; 1E4D: 10 FC

; --- Datenfeld-Sync ---
	XOR A                                   ; 1E4F: AF
	LD B,05H                                ; 1E50: 06 05    ; 5 Sync-Bytes
L1E52:
	OUT (14H),A                             ; 1E52: D3 14    ; *** HW: Sync-Byte
	DJNZ L1E52                              ; 1E54: 10 FC

; --- Data Address Mark ---
	EXX                                     ; 1E56: D9
	LD C,10H                                ; 1E57: 0E 10
	OUT (14H),A                             ; 1E59: D3 14    ; *** HW: Sync
	OUT (C),D                               ; 1E5B: ED 51    ; *** HW: Clock-Pattern
	LD A,FBH                                ; 1E5D: 3E FB    ; FBH = Data Mark
	OUT (14H),A                             ; 1E5F: D3 14    ; *** HW: Data Mark
	OUT (C),E                               ; 1E61: ED 59    ; *** HW: Steuer normal

; --- Sektor-Daten + CRC (Block-Transfer) ---
	LD BC,8014H                             ; 1E63: 01 14 80 ; 128 Bytes an Port 14H
	OUTI                                    ; 1E66: ED A3    ; *** HW: Datenbyte 1
	OUTI                                    ; 1E68: ED A3    ; *** HW: Datenbyte 2
	OUTI                                    ; 1E6A: ED A3    ; *** HW: Datenbyte 3
	OTIR                                    ; 1E6C: ED B3    ; *** HW: restliche Datenbytes
	OUTI                                    ; 1E6E: ED A3    ; *** HW: CRC Byte 1
	OUTI                                    ; 1E70: ED A3    ; *** HW: CRC Byte 2
	EXX                                     ; 1E72: D9

; --- Gap 3 (zwischen Sektoren) ---
	LD A,(1C46H)                            ; 1E73: 3A 46 1C ; Gap3-Laenge
	OUT (C),E                               ; 1E76: ED 59    ; *** HW: 1. Gap-Byte
	LD B,A                                  ; 1E78: 47
	DEC B                                   ; 1E79: 05       ; -2 Korrektur
	DEC B                                   ; 1E7A: 05
L1E7B:
	OUT (C),E                               ; 1E7B: ED 59    ; *** HW: Gap-Byte
	DJNZ L1E7B                              ; 1E7D: 10 FC

; --- Naechster Sektor oder Spur-Ende ---
	DEC D                                   ; 1E7F: 15       ; Sektorzaehler--
	OUT (C),E                               ; 1E80: ED 59    ; *** HW: letztes Gap-Byte
	JP NZ,L1E2F                             ; 1E82: C2 2F 1E ; Naechster Sektor
	JP L1DDF                                ; 1E85: C3 DF 1D ; Spur-Ende -> Fuellbytes

; ============================================================================
; INDEX-PULS ISR (Interrupt Service Routine)
; ============================================================================
;
; *** DIREKTER HARDWARE-ISR-HANDLER! ***
;
; Diese ISR wird vom Index-Puls des Diskettenlaufwerks ausgeloest.
; Sie signalisiert der CPU, dass eine komplette Umdrehung (= 1 Spur)
; geschrieben wurde.
;
; MECHANISMUS (Selbstmodifikation):
; Der ISR-Eintritt bekommt HL als Zeiger auf den JR-Operanden
; der aktiven Format-Schleife (z.B. 1D50H+1 oder 1DE5H+1).
; LD (HL),3EH schreibt den Wert 3EH an diese Stelle.
; Aus dem JR $-2 (18H FEH = Endlosschleife) wird dann:
;   18H 3EH -> JR $+3EH (springt weit nach vorne, bricht Schleife auf)
; Oder bei der Haupt-Warteschleife bei 1D21H:
;   (1D22H) wird von FEH auf 3EH gesetzt, Schleife verlassen.
;
; EI + RETI: Interrupts wieder zulassen und regulaer zurueckkehren.
; ============================================================================
isr_index_handler:
	LD (HL),3EH                             ; 1E88: 36 3E    ; *** SELBSTMODIFIKATION: JR-Operand aendern!
	EX DE,HL                                ; 1E8A: EB       ; HL <-> DE tauschen
	EI                                      ; 1E8B: FB       ; Interrupts wieder freigeben
	RETI                                    ; 1E8C: ED 4D    ; Interrupt-Rueckkehr

; ============================================================================
; SCHREIBSCHUTZ-PRUEFUNG: DIREKTER PORT-ZUGRIFF!
; ============================================================================
;
; *** UMGEHT DAS OS: Liest PIO B Status-Port direkt! ***
;
; Port 12H = PIO B Status (FDC-Statussignale vom Laufwerk):
;   Bit 0 = /INDEX   (Index-Puls, aktiv low)
;   Bit 2 = /T0      (Track 0 erreicht)
;   Bit 4 = /RDY     (Laufwerk bereit)
;   Bit 5 = /WP      (Write Protect, aktiv low = geschuetzt)
;   Bit 6 = /DP      (Data Present / Double Step)
;
; Wenn Bit 5 = 0 -> Diskette ist schreibgeschuetzt
; Rueckgabe: Z-Flag gesetzt wenn schreibgeschuetzt
; ============================================================================
setup_isr:
	IN A,(12H)                              ; 1E8E: DB 12    ; *** HW-ZUGRIFF: PIO B Status lesen!
	BIT 5,A                                 ; 1E90: CB 6F    ; Bit 5 = /WP testen
	RET                                     ; 1E92: C9       ; Z=1: geschuetzt, Z=0: nicht geschuetzt

; ============================================================================
; ISR-VEKTOR-INSTALLATION: DIREKTER I-REGISTER ZUGRIFF!
; ============================================================================
;
; *** UMGEHT DAS OS: Manipuliert die Interrupt-Vektortabelle direkt! ***
;
; Der Z80 Interrupt-Modus 2 verwendet eine Vektortabelle im RAM.
; Die Basisadresse steht im I-Register (z.B. I=F7H -> Tabelle bei F700H).
; Der Index-Puls-Interrupt des FDC verwendet Vektor-Offset E8H,
; also steht der ISR-Zeiger bei F7E8H (I*256 + E8H).
;
; Diese Routine:
;   1. Sperrt Interrupts (DI implizit durch vorherigen OUT 11H,03H)
;   2. Deaktiviert PIO-Interrupts: OUT (11H),03H
;   3. Liest I-Register: LD A,I -> Basisadresse der Vektortabelle
;   4. Speichert 4 Bytes (2 Vektor-Eintraege) von I*256+E8H
;      nach 1ECAH (Sicherungskopie)
;   5. Installiert eigene ISR-Vektoren von 1ECEH:
;      E8H -> isr_index_handler (1E88H) = Index-Puls
;      EAH -> sekundaerer Handler (1E8BH)
;   6. Gibt Interrupts wieder frei (EI)
; ============================================================================
sub_1E93:
	LD A,18H                                ; 1E93: 3E 18
	CALL delay_loop                         ; 1E95: CD AD 0F ; Kurze Verzoegerung

; --- PIO-Interrupts sperren ---
	DI                                      ; 1E98: F3       ; Interrupts global sperren
	LD A,03H                                ; 1E99: 3E 03    ; 03H = PIO-Interrupts aus
	OUT (11H),A                             ; 1E9B: D3 11    ; *** HW-ZUGRIFF: PIO-Interrupts sperren!

; --- I-Register lesen: Basis der Interrupt-Vektortabelle ---
	LD A,I                                  ; 1E9D: ED 57    ; *** HW-ZUGRIFF: I-Register lesen!
	LD H,A                                  ; 1E9F: 67       ; H = I (z.B. F7H)
	LD L,E8H                                ; 1EA0: 2E E8    ; L = E8H -> HL = F7E8H

; --- Alte ISR-Vektoren sichern (4 Bytes: 2 Adressen) ---
	LD DE,1ECAH                             ; 1EA2: 11 CA 1E ; Ziel: Sicherungskopie
	LD BC,0004H                             ; 1EA5: 01 04 00 ; 4 Bytes (2 Vektor-Adressen)
	LDIR                                    ; 1EA8: ED B0    ; Kopieren: (F7E8H..F7EBH) -> (1ECAH..1ECDH)

; --- Eigene ISR-Vektoren installieren ---
	LD L,E8H                                ; 1EAA: 2E E8    ; HL wieder auf F7E8H zuruecksetzen
	EX DE,HL                                ; 1EAC: EB       ; DE = F7E8H (Ziel)
	LD HL,1ECEH                             ; 1EAD: 21 CE 1E ; HL -> neue ISR-Vektoren:
	                                        ;                ; 1ECEH: 88H,1EH -> isr_index_handler (1E88H)
	                                        ;                ; 1ED0H: 8BH,1EH -> EI;RETI (1E8BH)
	LD C,04H                                ; 1EB0: 0E 04    ; 4 Bytes
	LDIR                                    ; 1EB2: ED B0    ; Installieren

; --- Interrupts wieder freigeben ---
	EI                                      ; 1EB4: FB       ; Interrupts global freigeben
	RET                                     ; 1EB5: C9

; ============================================================================
; ISR-VEKTOREN RESTAURIEREN: DIREKTER I-REGISTER ZUGRIFF!
; ============================================================================
;
; *** UMGEHT DAS OS: Stellt originale Interrupt-Vektoren wieder her! ***
;
; Kehrt den Vorgang von sub_1E93 um:
; Kopiert die gesicherten Original-Vektoren von 1ECAH
; zurueck an I*256+E8H.
; ============================================================================
restore_isr_vecs:
	DI                                      ; 1EB6: F3       ; Interrupts sperren
	LD A,I                                  ; 1EB7: ED 57    ; *** HW-ZUGRIFF: I-Register lesen!
	LD D,A                                  ; 1EB9: 57       ; D = I
	LD E,E8H                                ; 1EBA: 1E E8    ; DE = I*256+E8H (Vektortabellen-Adresse)
	LD HL,1ECAH                             ; 1EBC: 21 CA 1E ; HL -> gesicherte Original-Vektoren
	LD BC,0004H                             ; 1EBF: 01 04 00 ; 4 Bytes
	LDIR                                    ; 1EC2: ED B0    ; Restaurieren
	EI                                      ; 1EC4: FB       ; Interrupts wieder freigeben
	LD A,1BH                                ; 1EC5: 3E 1B
	JP delay_loop                           ; 1EC7: C3 AD 0F ; Kurze Verzoegerung und Rueckkehr

; --- Gesicherte/neue ISR-Vektoren ---
; 1ECAH-1ECDH: Platz fuer originale ISR-Vektoren (werden von sub_1E93 gesichert)
	NOP                                     ; 1ECA: 00       ; Gesicherter Vektor 1 (Lo)
	NOP                                     ; 1ECB: 00       ; Gesicherter Vektor 1 (Hi)
	NOP                                     ; 1ECC: 00       ; Gesicherter Vektor 2 (Lo)
	NOP                                     ; 1ECD: 00       ; Gesicherter Vektor 2 (Hi)
; 1ECEH-1ED1H: Neue ISR-Vektoren fuer die Formatierung
	ADC A,B                                 ; 1ECE: 88       ; -> 1E88H = isr_index_handler (Lo)
	LD E,8BH                                ; 1ECF: 1E 8B    ; -> 1E8BH (Hi, plus naechster Lo)
	LD E,46H                                ; 1ED1: 1E 46    ; Zweiter Vektor (1E46H? oder Fuellbyte)
; --- Parametertabellen-Kopierer ---
; Kopiert Parameter aus einer indirekten Tabelle (DE) an Zieladressen
; in einer Zeigertabelle (HL).
; Format der Zeigertabelle: 1 Byte Anzahl, dann Paare von:
;   2 Bytes: Zieladresse (Low/High)
; Fuer jeden Eintrag wird 1 Byte aus (DE) an die Zieladresse kopiert.
L1ED3:
	INC HL                                  ; 1ED3: 23
	PUSH BC                                 ; 1ED4: C5
	LD C,(HL)                               ; 1ED5: 4E       ; C = Lo-Byte der Zieladresse
	INC HL                                  ; 1ED6: 23
	LD B,(HL)                               ; 1ED7: 46       ; B = Hi-Byte der Zieladresse
	LD A,(DE)                               ; 1ED8: 1A       ; A = Parameterbyte aus Quelltabelle
	INC DE                                  ; 1ED9: 13
	LD (BC),A                               ; 1EDA: 02       ; An Zieladresse speichern
	POP BC                                  ; 1EDB: C1
	DJNZ L1ED3                              ; 1EDC: 10 F5    ; Naechster Parameter
	RET                                     ; 1EDE: C9
sub_1ED2 EQU L1ED3 - 1                                 ; Einstiegspunkt: liest erst Anzahl aus (HL)


; ============================================================================
; CPU2 Format-Routinen-Zeigertabelle
; Enthaelt indirekte Zeiger auf die verschiedenen Format-Parameter.
; Jeder Eintrag: 5 Bytes (Anzahl + 2 Zeiger-Paare) die auf die
; Adressen der Steuerbytes in den Formatroutinen verweisen.
; Die Parametertabellen (1EEAH, 1EEFH, 1EF4H) enthalten die
; konkreten Werte fuer SD, DD und 8" Formate.
; ============================================================================
cpu2_format_table:
	DB	05H,E3H,1CH,E4H,1CH,1AH,1DH,F2H,1CH,F3H,1CH,39H,1DH,B4H,50H,1DH; 1EDF | ...........9..P.
	DB	F7H,1DH,A4H,0EH,1EH,39H,1DH,B4H,50H,1DH,08H,BFH,1DH,C1H,1DH,C3H; 1EEF | .....9..P.......
	DB	1DH,C5H,1DH,65H,1EH                               ; 1EFF | ...e.
; ============================================================================
; Gap-Fuellbyte-Tabelle
; 8 Bytes pro Dichtestufe, definiert die GAP-Fuellwerte und OUTI/OTIR-
; Steuersequenzen fuer die verschiedenen Format-Typen.
; Die Zeiger in format_ptr_table verweisen auf Adressen in den
; Formatroutinen, deren Werte hiermit initialisiert werden.
; ============================================================================
gap_fill_table:
	DB	67H,1EH,69H,1EH,6BH,1EH,80H,A3H,A3H,A3H,80H,A3H,A3H,A3H,00H,A3H; 1F04 | g.i.k...........
	DB	A3H,A3H,00H,A3H,A3H,A3H,00H,A3H,A3H,B3H,00H,A3H,A3H,B3H,00H,B3H; 1F14 | ................
	DB	B3H,B3H,00H,B3H,B3H,B3H,07H                       ; 1F24 | .......

; ============================================================================
; Format Zeiger-/Parametertabellen
; ============================================================================
; format_ptr_table: Enthaelt Zeiger auf modifizierbare Stellen in den
; Formatroutinen, die je nach Seitenwahl (Bit 2) veraendert werden.
; Dient der Seitenwahl-Konfiguration (Side Select A/B).
; ============================================================================
format_ptr_table:
	DB	1AH,1DH,0CH,1DH,FDH,1DH,FCH,1DH,3EH,1DH,3FH,1DH,4BH,1DH,01H,00H; 1F2B | ........>.?.K...
	DB	04H                                               ; 1F3B | .
; ============================================================================
; DPB-aehnliche Parameterbloecke (Disk Parameter Blocks)
; Fuer jedes unterstuetzte Standard-Disketten-Format existiert ein
; DPB mit den CP/M-ueblichen Werten:
;   SPT (Sektoren/Spur), BSH (Block Shift), BLM (Block Mask),
;   EXM (Extent Mask), DSM (Disk Size-1), DRM (Directory Max-1),
;   AL0/AL1 (Allocation Bitmap), CKS (Check Area Size),
;   OFF (System-Spuren Offset)
; Diese werden bei bekannten Formaten in die aktive DPB-Struktur
; kopiert und beim Formatieren auf den Boot-Sektor geschrieben.
; ============================================================================
dpb_table:
	DB	00H,07H,00H,0EH,00H,01H,00H,03H,00H,05H,00H,09H,00H,00H,02H,01H; 1F3C | ................
	DB	01H,00H,02H,40H,00H,68H,01H,FCH,02H,00H,09H,00H,01H,00H,00H,00H; 1F4C | ...@.h..........
	DB	01H,00H,03H,00H,05H,00H,0CH,00H,00H,02H,02H,01H,00H,02H,70H,00H; 1F5C | ..............p.
	DB	D0H,02H,FDH,02H,00H,09H,00H,02H,00H,00H,00H,01H,00H,04H,00H,07H; 1F6C | ................
	DB	00H,0EH,00H,00H,02H,02H,01H,00H,02H,70H,00H,A0H,05H,F9H,03H,00H; 1F7C | .........p......
	DB	09H,00H,02H,00H,00H,00H,01H,00H,04H,00H,07H,00H,0FH,00H,00H,02H; 1F8C | ................
	DB	02H,01H,00H,02H,80H,00H,40H,06H,F9H,03H,00H,0AH,00H,02H,00H,00H; 1F9C | ......@.........
	DB	00H,05H,00H,06H,00H,07H,00H,0CH,00H,00H,04H,02H,05H,00H,02H,A0H; 1FAC | ................
	DB	00H,20H,03H,FFH,01H,00H,05H,00H,02H,00H,00H,00H,EBH,34H,90H; 1FBC | . ...........4.
; --- CPA-Versions-String zur Identifikation ---
; Wird beim Programmstart mit dem String an Adresse 004EH verglichen,
; um sicherzustellen, dass das richtige CPA-System laeuft.
cpa_version_str:
	DB	'CP/A1188'
dpb_default:
	DB	00H,02H,02H,01H,00H,02H,70H,00H,A0H,05H,F9H,03H,00H,09H,00H,02H; 1FD3 | ......p.........
	DB	00H,00H,00H,00H,00H,00H,00H,00H,00H,00H,00H,00H,00H,00H,00H,00H; 1FE3 | ................
	DB	00H,00H,00H,00H,0FH,00H,00H,00H,00H,01H,00H,FAH,33H; 1FF3 | ............3

; ============================================================================
; Boot-Sektor-Vorlage (512 Bytes)
; Wird auf Spur 0 formatierter Disketten geschrieben.
; Enthaelt x86-kompatiblen Bootstrap-Code fuer MSDOS/CPA Dual-Boot.
; Der Boot-Sektor laedt BIO.COM und DOS.COM vom Systembereich.
; Die Fehlermeldungen sind deutsch ("Kein System", "Fehler beim Laden").
; ============================================================================
boot_sector:
	DB	C0H,8EH,D0H,BCH,00H,7CH,16H,07H,BBH,78H,00H,36H,C5H,37H,1EH,56H; 2000 | .....|...x.6.7.V
	DB	16H,53H,BFH,2BH,7CH,B9H,0BH,00H,FCH,ACH,26H,80H,3DH,00H,74H,03H; 2010 | .S.+|.....&.=.t.
	DB	26H,8AH,05H,AAH,8AH,C4H,E2H,F1H,06H,1FH,89H,47H,02H,C7H,07H,2BH; 2020 | &..........G...+
	DB	7CH,FBH,CDH,13H,72H,67H,A0H,10H,7CH,98H,F7H,26H,16H,7CH,03H,06H; 2030 | |...rg..|..&.|..
	DB	1CH,7CH,03H,06H,0EH,7CH,A3H,3FH,7CH,A3H,37H,7CH,B8H,20H,00H,F7H; 2040 | .|...|.?|.7|. ..
	DB	26H,11H,7CH,8BH,1EH,0BH,7CH,03H,C3H,48H,F7H,F3H,01H,06H,37H,7CH; 2050 | &.|...|..H....7|
	DB	BBH,00H,05H,A1H,3FH,7CH,E8H,96H,00H,B8H,01H,02H,E8H,AAH,00H,72H; 2060 | ....?|.........r
	DB	19H,8BH,FBH,B9H,0BH,00H,BEH,E6H,7DH,F3H,A6H,75H,0DH,8DH,7FH,20H; 2070 | ........}..u... 
	DB	BEH,F1H,7DH,B9H,0BH,00H,F3H,A6H,74H,18H,BEH,7FH,7DH,E8H,61H,00H; 2080 | ..}.....t...}.a.
	DB	32H,E4H,CDH,16H,5EH,1FH,8FH,04H,8FH,44H,02H,CDH,19H,BEH,CFH,7DH; 2090 | 2...^....D.....}
	DB	EBH,EBH,A1H,1CH,05H,33H,D2H,F7H,36H,0BH,7CH,FEH,C0H,A2H,3CH,7CH; 20A0 | .....3..6.|...<|
	DB	A1H,37H,7CH,A3H,3DH,7CH,BBH,00H,07H,A1H,37H,7CH,E8H,40H,00H,A1H; 20B0 | .7|.=|....7|.@..
	DB	18H,7CH,2AH,06H,3BH,7CH,40H,50H,E8H,4EH,00H,58H,72H,CFH,28H,06H; 20C0 | .|*.;|@P.N.Xr.(.
	DB	3CH,7CH,76H,0CH,01H,06H,37H,7CH,F7H,26H,0BH,7CH,03H,D8H,EBH,D9H; 20D0 | <|v...7|.&.|....
	DB	8AH,2EH,15H,7CH,8AH,16H,FDH,7DH,8BH,1EH,3DH,7CH,EAH,00H,00H,70H; 20E0 | ...|...}..=|...p
	DB	00H,ACH,0AH,C0H,74H,22H,B4H,0EH,BBH,07H,00H,CDH,10H,EBH,F2H,33H; 20F0 | ....t".........3
	DB	D2H,F7H,36H,18H,7CH,FEH,C2H,88H,16H,3BH,7CH,33H,D2H,F7H,36H,1AH; 2100 | ..6.|....;|3..6.
	DB	7CH,88H,16H,2AH,7CH,A3H,39H,7CH,C3H,B9H,04H,00H,51H,B4H,02H,8BH; 2110 | |..*|.9|....Q...
	DB	16H,39H,7CH,B1H,06H,D2H,E6H,0AH,36H,3BH,7CH,8BH,CAH,86H,E9H,8AH; 2120 | .9|.....6;|.....
	DB	16H,FDH,7DH,8AH,36H,2AH,7CH,CDH,13H,59H,72H,01H,C3H,80H,FCH,11H; 2130 | ..}.6*|..Yr.....
	DB	75H,01H,C3H,E2H,D7H,F9H,C3H                       ; 2140 | u......
boot_msg_no_sys:
	DB	0DH,0AH
	DB	'Diskette: Kein System oder fehlerhaft',0DH,0AH
	DB	'Austauschen und eine Taste bet'
	DB	84H                                               ; 218E | .
	DB	'tigen',0DH,0AH
	DB	00H                                               ; 2196 | .
boot_msg_load_err:
	DB	0DH,0AH
	DB	'Fehler beim Laden ',0DH,0AH
	DB	00H                                               ; 21AD | .
boot_filenames:
	DB	'BIO     COMDOS     COM'
	DB	00H                                               ; 21C4 | .
boot_sector_end:
	DB	00H,55H,AAH,0CH                                   ; 21C5 | .U..

; ============================================================================
; Format-Definitionstabellen
; Jede Tabelle enthaelt:
;   1. Menue-Text (deutschsprachig, $-terminiert)
;   2. DPB-Parameter (Disk Parameter Block)
;   3. Sektor-Interleave-Tabelle (physische Sektorreihenfolge)
;
; Unterstuetzte Formate:
;   - 5.25" 40 Spuren einseitig (200KB-800KB)
;   - 5.25" 40 Spuren doppelseitig
;   - 5.25" 80 Spuren einseitig
;   - 5.25" 80 Spuren doppelseitig (bis 1.6MB)
;   - 8" einseitig und doppelseitig
;   - Verschiedene Sektorgroessen (128/256/512/1024 Bytes)
;   - SD (Single Density, FM) und DD (Double Density, MFM)
; ============================================================================
fmt_5_25_40_ss:
	DB	'Formate fuer 5 1/4", ','$'
	DB	'40 Sp., eins. ["A": autom. Formaterk.]',0AH
	DB	0DH,0AH
	DB	'0= 5*1024 Sp. 0-39                  ;0 System, 200k, CP/A   '
	DB	';A',0DH,0AH
	DB	'1= 26*128 Sp. 0-1; 5*1024 Sp. 2-39  ;2 System, 190k, CP/A S '
	DB	';A',0DH,0AH
	DB	'2= 26*128 Sp. 0-39;Sektorf. 1,7,13..;2 System, 123k         '
	DB	';A',0DH,0AH
	DB	'3= 26*128 Sp. 0-39;Sektorf. 1,7,13..;0 System, 130k         '
	DB	';A',0DH,0AH
	DB	'4= 16*256 Sp. 0-39;ohne ph. Sektorv.;3 System, 148k, SCP    '
	DB	';A',0DH,0AH
	DB	'5= 16*256 Sp. 0-39;mit  ph. Sektorv.;3 System, 148k         '
	DB	';A',0DH,0AH
	DB	'6= 15*256 Sp. 0-39;Sektorf. 1,4,7,..;3 System, 138k, BAP2001'
	DB	0DH,0AH
	DB	'7= 5*1024 Sp. 0-39;ohne ph. Sektorv.;3 System, 185k, Osborne'
	DB	0DH,0AH
	DB	'X= Menue #2','$'
	DB	'40 Sp., eins. ["A": autom. Formaterk.]',0AH
	DB	0DH,0AH
	DB	'E=  9*512 Sp. 0-39;Sektorf. 1,3,5,..;2 System, 170k, DEC VT '
	DB	0DH,0AH
	DB	'F=  9*512 Sp. 0-39; 1k BDOS-Bloecke ;2 System, 171k, VPPC   '
	DB	0DH,0AH
	DB	'G=  9*512 Sp. 0-39;Sektorf. 41,42,..;2 System, 171k, Schn. S'
	DB	0DH,0AH
	DB	'H=  9*512 Sp. 0-39;Sektorf. c1,c2,..;0 System, 180k, Schn. D'
	DB	0DH,0AH
	DB	'I=  8*512 Sp. 0-39; 2k BDOS-Bloecke ;1 System, 156k, CP/M 86'
	DB	0DH,0AH
	DB	'J=  9*512 Sp. 0-39;                            180k, {MSDOS}'
	DB	';A',0DH,0AH
	DB	'K=  8*512 Sp. 0-39; 1k BDOS-Bloecke ;1 System, 156k, IBM CPC'
	DB	0DH,0AH
	DB	'L= 10*512 Sp. 0-39; Sektorf. 0,1,.. ;1 System, 195k, KAYPRO '
	DB	0DH,0AH
	DB	'Z= Menue #1','$'
	DB	'0x&1'
	DB	99H,26H,32H,BAH,26H,33H,05H                       ; 263B | .&2.&3.
	DB	'''4P''5'
	DB	87H,27H,36H,BEH,27H,37H,F3H,27H,45H,14H           ; 2647 | .'6.'7.'E.
	DB	'(F=(Gf(H'
	DB	8FH,28H,49H,B8H,28H,4AH,DFH,28H,4BH,08H           ; 2659 | .(I.(J.(K.
	DB	')L/)Xn&Zs&'
	DB	FFH,01H,10H,24H,37H,26H,01H,DFH,21H,37H,26H,05H,64H,01H,05H,04H; 266D | ...$7&..!7&.d...
	DB	03H,02H,28H,00H,03H,07H,00H,C7H,00H,3FH,00H,C0H,00H,10H,00H,00H; 267D | ..(......?......
