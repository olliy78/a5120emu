	INC E                                   ; 0A7C: 1C
	INC HL                                  ; 0A7D: 23
	DJNZ L0A79                              ; 0A7E: 10 F9
	RST 38H                                 ; 0A80: FF
L0A81:
	LD D,00H                                ; 0A81: 16 00
L0A83:
	LD A,E                                  ; 0A83: 7B
	SUB D                                   ; 0A84: 92
	LD HL,1C81H                             ; 0A85: 21 81 1C
	BIT 0,(HL)                              ; 0A88: CB 46
	JR Z,L0A8F                              ; 0A8A: 28 03
	SUB (IX+19)                             ; 0A8C: DD 96 13
L0A8F:
	POP DE                                  ; 0A8F: D1
	POP BC                                  ; 0A90: C1
	POP IX                                  ; 0A91: DD E1
L0A93:
	LD HL,4400H                             ; 0A93: 21 00 44
display_status:
	INC A                                   ; 0A96: 3C
L0A97:
	DEC A                                   ; 0A97: 3D
	JR Z,L0A9D                              ; 0A98: 28 03
	ADD HL,BC                               ; 0A9A: 09
	JR L0A97                                ; 0A9B: 18 FA

L0A9D:
	LDIR                                    ; 0A9D: ED B0
	POP IY                                  ; 0A9F: FD E1
	PUSH DE                                 ; 0AA1: D5
	CALL write_sector_data                  ; 0AA2: CD 97 0D
	POP HL                                  ; 0AA5: E1
	LD (HL),B                               ; 0AA6: 70
	INC HL                                  ; 0AA7: 23
	LD (HL),C                               ; 0AA8: 71
	INC HL                                  ; 0AA9: 23
L0AAA:
	EX DE,HL                                ; 0AAA: EB
	LD HL,1C8FH                             ; 0AAB: 21 8F 1C
	INC (HL)                                ; 0AAE: 34
	LD A,(1C45H)                            ; 0AAF: 3A 45 1C
	CP (HL)                                 ; 0AB2: BE
	JP NZ,L0A03                             ; 0AB3: C2 03 0A
	XOR A                                   ; 0AB6: AF
	LD (0A3EH),A                            ; 0AB7: 32 3E 0A
	LD HL,(1C3BH)                           ; 0ABA: 2A 3B 1C
	CALL prompt_format_count                ; 0ABD: CD ED 0B
	OR A                                    ; 0AC0: B7
	JR NZ,L0B0E                             ; 0AC1: 20 4B
	LD (0B01H),HL                           ; 0AC3: 22 01 0B
	LD A,FFH                                ; 0AC6: 3E FF
	OR A                                    ; 0AC8: B7
	JR Z,L0AFA                              ; 0AC9: 28 2F
	LD (0A3EH),A                            ; 0ACB: 32 3E 0A
	LD A,(6CB0H)                            ; 0ACE: 3A B0 6C
	CPL                                     ; 0AD1: 2F
	LD (6CB0H),A                            ; 0AD2: 32 B0 6C
	LD IY,drive_a_params                    ; 0AD5: FD 21 1E 1C
	CALL do_multisector_io                  ; 0AD9: CD 03 0C
	JR NZ,L0B0E                             ; 0ADC: 20 30
	LD A,(1C45H)                            ; 0ADE: 3A 45 1C
	LD B,A                                  ; 0AE1: 47
	LD HL,6CB0H                             ; 0AE2: 21 B0 6C
	LD DE,4400H                             ; 0AE5: 11 00 44
L0AE8:
	PUSH BC                                 ; 0AE8: C5
	LD BC,(1C7DH)                           ; 0AE9: ED 4B 7D 1C
L0AED:
	LD A,(DE)                               ; 0AED: 1A
	INC DE                                  ; 0AEE: 13
	CPI                                     ; 0AEF: ED A1
	JP NZ,L0B0C                             ; 0AF1: C2 0C 0B
	JP PE,L0AED                             ; 0AF4: EA ED 0A
	POP BC                                  ; 0AF7: C1
	DJNZ L0AE8                              ; 0AF8: 10 EE
L0AFA:
	LD DE,144FH                             ; 0AFA: 11 4F 14
	CALL print_string_inline                ; 0AFD: CD 1B 0E
	LD DE,0000H                             ; 0B00: 11 00 00
	LD HL,(1C7BH)                           ; 0B03: 2A 7B 1C
	ADD HL,DE                               ; 0B06: 19
	CALL print_dec_HL                       ; 0B07: CD 70 0E
	JR L0B1E                                ; 0B0A: 18 12

L0B0C:
	LD A,56H                                ; 0B0C: 3E 56
L0B0E:
	LD (13B6H),A                            ; 0B0E: 32 B6 13
	LD HL,1C90H                             ; 0B11: 21 90 1C
	DEC (HL)                                ; 0B14: 35
	JP NZ,format_next_track                 ; 0B15: C2 F1 09
	LD DE,msg_track_error                   ; 0B18: 11 AB 13
	CALL print_string_inline                ; 0B1B: CD 1B 0E
L0B1E:
	LD HL,1C20H                             ; 0B1E: 21 20 1C
	LD A,(1C1DH)                            ; 0B21: 3A 1D 1C
	CP (HL)                                 ; 0B24: BE
	JR Z,L0B2F                              ; 0B25: 28 08
	INC (HL)                                ; 0B27: 34
	LD HL,1C2EH                             ; 0B28: 21 2E 1C
	INC (HL)                                ; 0B2B: 34
	JP L07EF                                ; 0B2C: C3 EF 07

; --- Programmende: Zurueck zum Menue oder warm boot ---
L0B2F:
	LD DE,(1C82H)                           ; 0B2F: ED 5B 82 1C
	CALL print_string                       ; 0B33: CD 18 0E
	LD DE,1371H                             ; 0B36: 11 71 13
	CALL print_string_inline                ; 0B39: CD 1B 0E
	CALL read_char                          ; 0B3C: CD 37 0E
	CP 4AH                                  ; 0B3F: FE 4A
	JP Z,do_format_main                     ; 0B41: CA 33 07
	JR L0B49                                ; 0B44: 18 03

L0B46:
	CALL print_string                       ; 0B46: CD 18 0E
L0B49:
	CALL save_isr_vectors                   ; 0B49: CD 78 0C
	LD DE,13C9H                             ; 0B4C: 11 C9 13
	CALL read_char_upper                    ; 0B4F: CD 34 0E
	CP 4AH                                  ; 0B52: FE 4A
	JP Z,main_init                          ; 0B54: CA 58 01
	CALL restore_isr                        ; 0B57: CD A8 0F
	CALL restore_isr_exit                   ; 0B5A: CD 90 0F
; --- Programmende: Disk-Reset und Warm-Boot zurueck ins CPA ---
select_drive_side:
	LD C,0DH                                ; 0B5D: 0E 0D ; BDOS Funktion 0DH = Disk-Reset
	CALL 0005H                              ; 0B5F: CD 05 00 ; Alle Laufwerke deselektieren
	JP 0000H                                ; 0B62: C3 00 00 ; Warm-Boot -> zurueck ins CPA

; --- Seitenflag bestimmen ---
; SELBSTMODIFIKATION: Der Operand bei 0B66H wird zur Laufzeit
; mit dem aktuellen Seitenflag (0 oder F6H) beschrieben.
; Gibt in A den Fuellbyte-Wert fuer die aktuelle Seite zurueck.
set_side_flag:
	LD A,00H                                ; 0B65: 3E 00
	OR A                                    ; 0B67: B7
	RET NZ                                  ; 0B68: C0
	LD A,(1C20H)                            ; 0B69: 3A 20 1C
	LD HL,1BDDH                             ; 0B6C: 21 DD 1B
	CP (HL)                                 ; 0B6F: BE
	LD A,E5H                                ; 0B70: 3E E5
	RET NC                                  ; 0B72: D0
	LD A,53H                                ; 0B73: 3E 53
	RET                                     ; 0B75: C9

check_valid_drive:
	LD (15F1H),A                            ; 0B76: 32 F1 15
	PUSH HL                                 ; 0B79: E5
	PUSH DE                                 ; 0B7A: D5
restore_drive:
	LD DE,15E2H                             ; 0B7B: 11 E2 15
	CALL print_string_inline                ; 0B7E: CD 1B 0E
	POP DE                                  ; 0B81: D1
	POP HL                                  ; 0B82: E1
	LD A,E                                  ; 0B83: 7B
	CALL save_drive_state                   ; 0B84: CD 96 0B
	LD A,D                                  ; 0B87: 7A
	CALL save_drive_state                   ; 0B88: CD 96 0B
	LD A,L                                  ; 0B8B: 7D
	CALL save_drive_state                   ; 0B8C: CD 96 0B
	LD A,H                                  ; 0B8F: 7C
	CALL save_drive_state                   ; 0B90: CD 96 0B
	JP print_char                           ; 0B93: C3 20 0E

save_drive_state:
	CALL print_hex_A                        ; 0B96: CD CC 0E
	LD A,20H                                ; 0B99: 3E 20
	JP print_char_bdos                      ; 0B9B: C3 27 0E

; --- Laufwerk validieren und Track-Kapazitaet berechnen ---
; Springt in den BIOS-Code, um DPB-Informationen fuer das
; angegebene Laufwerk zu holen. Verwendet calc_track_capacity.
deselect_drive:
	CALL calc_track_capacity                ; 0B9E: CD B4 0B
	RET C                                   ; 0BA1: D8
	LD (IY+2),00H                           ; 0BA2: FD 36 02 00
	CALL seek_only                          ; 0BA6: CD 00 0C
	OR A                                    ; 0BA9: B7
display_track_info:
	RET Z                                   ; 0BAA: C8
	LD (IY+1),00H                           ; 0BAB: FD 36 01 00
	LD DE,13FBH                             ; 0BAF: 11 FB 13
	SCF                                     ; 0BB2: 37
	RET                                     ; 0BB3: C9

; --- Track-Kapazitaet berechnen ---
; Ermittelt ueber den BIOS-Warmstart-Vektor die SELDSK-Routine
; des BIOS und liest daraus die DPB-Informationen.
; Dies ist ein INDIREKTER OS-Zugriff: Der Code berechnet die
; Adresse der BIOS-Sprungtabelle aus dem Warmstart-Vektor (0001H)
; und springt dann direkt in die BIOS SELDSK Routine.
calc_track_capacity:
	LD HL,(0001H)                           ; 0BB4: 2A 01 00
	LD BC,0018H                             ; 0BB7: 01 18 00
	ADD HL,BC                               ; 0BBA: 09
	LD E,01H                                ; 0BBB: 1E 01
	LD C,(IY+1)                             ; 0BBD: FD 4E 01
	PUSH IY                                 ; 0BC0: FD E5
	CALL prompt_format_count                ; 0BC2: CD ED 0B
	POP IY                                  ; 0BC5: FD E1
	LD A,H                                  ; 0BC7: 7C
	OR L                                    ; 0BC8: B5
	JR Z,L0BE8                              ; 0BC9: 28 1D
	LD (IY+9),L                             ; 0BCB: FD 75 09
	LD (IY+10),H                            ; 0BCE: FD 74 0A
	LD DE,000AH                             ; 0BD1: 11 0A 00
	ADD HL,DE                               ; 0BD4: 19
	LD E,(HL)                               ; 0BD5: 5E
	INC HL                                  ; 0BD6: 23
	LD D,(HL)                               ; 0BD7: 56
	EX DE,HL                                ; 0BD8: EB
	LD (IY+11),L                            ; 0BD9: FD 75 0B
	LD (IY+12),H                            ; 0BDC: FD 74 0C
	PUSH HL                                 ; 0BDF: E5
	POP IX                                  ; 0BE0: DD E1
	OR A                                    ; 0BE2: B7
	BIT 7,(IX+15)                           ; 0BE3: DD CB 0F 7E
	RET Z                                   ; 0BE7: C8
L0BE8:
	LD DE,13FBH                             ; 0BE8: 11 FB 13
	SCF                                     ; 0BEB: 37
	RET                                     ; 0BEC: C9

prompt_format_count:
	JP (HL)                                 ; 0BED: E9

input_format_count:
	LD IY,drive_b_params                    ; 0BEE: FD 21 2C 1C
	CALL do_multisector_io                  ; 0BF2: CD 03 0C
	RET Z                                   ; 0BF5: C8
	PUSH AF                                 ; 0BF6: F5
	CALL do_cdb_io_write                    ; 0BF7: CD 6A 0C
	POP AF                                  ; 0BFA: F1
	CALL check_valid_drive                  ; 0BFB: CD 76 0B
	SCF                                     ; 0BFE: 37
	RET                                     ; 0BFF: C9

; ============================================================================
; DISK I/O SUBROUTINEN
; ============================================================================
;
; Diese Routinen verwenden zwei verschiedene I/O-Wege:
;
; 1. CPA-BIOS-Extension cpmx21 (diskio):
;    Wird ueber call_diskio_cdb aufgerufen. Das ist der "offizielle" Weg
;    ueber das Betriebssystem. Verwendet einen CDB (Command Descriptor Block)
;    als Parameterblock.
;
; 2. DIREKTE PIO-Programmierung (CPU2-Code):
;    Wird fuer die eigentliche Formatierung verwendet (siehe oben).
;
; CDB-Aufbau (Command Descriptor Block) bei drive_a_params / drive_b_params:
;   Offset  0: Flags (Bit 1=Sekt-ID lesen, Bit 2=Schreiben, Bit 5=Kopf hoch)
;   Offset  1: Laufwerk-Nummer
;   Offset  2: Spur-Nummer (Track)
;   Offset  3: Seite
;   Offset  4: Sektor-Nummer (1-basiert)
;   Offset  5: Sektorlaengencode (0=128, 1=256, 2=512, 3=1024)
;   Offset  6: Anzahl phys. Sektoren (0=nur Seek)
;   Offset  7-8: DMA-Adresse (Datenpuffer)
;   Offset  9-10: DPB-Zeiger
;   Offset 11-12: Spur-Tabellen-Zeiger
; ============================================================================

; --- Seek-Only: Lesekopf auf Spur positionieren ---
; Funktion 0 im CDB = nur Seek, keine Daten lesen/schreiben.
seek_only:
	XOR A                                   ; 0C00: AF       ; A=0 = Seek-Funktion
	JR do_cdb_io                            ; 0C01: 18 5E    ; -> CDB-I/O ausfuehren

; --- Multi-Sektor I/O ---
; Liest oder schreibt mehrere aufeinanderfolgende Sektoren.
; Teilt grosse Transfers automatisch in kleinere Bloecke auf,
; da der FDC nur begrenzt viele Sektoren auf einmal verarbeiten kann.
do_multisector_io:
	LD A,(1C80H)                            ; 0C03: 3A 80 1C
	LD (IY+5),A                             ; 0C06: FD 77 05
	LD (IY+4),01H                           ; 0C09: FD 36 04 01
	LD E,09H                                ; 0C0D: 1E 09
	LD A,(cpu2_init)                        ; 0C0F: 3A 8E 1C
	LD C,A                                  ; 0C12: 4F
	LD B,00H                                ; 0C13: 06 00
	LD HL,1C47H                             ; 0C15: 21 47 1C
	ADD HL,BC                               ; 0C18: 09
	LD A,(HL)                               ; 0C19: 7E
L0C1A:
	INC B                                   ; 0C1A: 04
	DEC E                                   ; 0C1B: 1D
	JR Z,L0C23                              ; 0C1C: 28 05
	INC A                                   ; 0C1E: 3C
	INC HL                                  ; 0C1F: 23
	CP (HL)                                 ; 0C20: BE
	JR Z,L0C1A                              ; 0C21: 28 F7
L0C23:
	LD L,(IY+7)                             ; 0C23: FD 6E 07
	LD H,(IY+8)                             ; 0C26: FD 66 08
	PUSH HL                                 ; 0C29: E5
	LD A,(1C45H)                            ; 0C2A: 3A 45 1C
L0C2D:
	LD C,A                                  ; 0C2D: 4F
	CP B                                    ; 0C2E: B8
	JR C,L0C34                              ; 0C2F: 38 03
	LD A,B                                  ; 0C31: 78
	JR L0C35                                ; 0C32: 18 01

L0C34:
	LD B,A                                  ; 0C34: 47
L0C35:
	PUSH BC                                 ; 0C35: C5
	CALL do_cdb_io                          ; 0C36: CD 61 0C
	POP BC                                  ; 0C39: C1
	JR NZ,L0C58                             ; 0C3A: 20 1C
	LD A,B                                  ; 0C3C: 78
	LD DE,(1C7DH)                           ; 0C3D: ED 5B 7D 1C
	LD L,(IY+7)                             ; 0C41: FD 6E 07
	LD H,(IY+8)                             ; 0C44: FD 66 08
L0C47:
	ADD HL,DE                               ; 0C47: 19
	INC (IY+4)                              ; 0C48: FD 34 04
	DJNZ L0C47                              ; 0C4B: 10 FA
	LD (IY+7),L                             ; 0C4D: FD 75 07
	LD (IY+8),H                             ; 0C50: FD 74 08
	LD B,A                                  ; 0C53: 47
	LD A,C                                  ; 0C54: 79
	SUB B                                   ; 0C55: 90
	JR NZ,L0C2D                             ; 0C56: 20 D5
L0C58:
	POP HL                                  ; 0C58: E1
	LD (IY+7),L                             ; 0C59: FD 75 07
	LD (IY+8),H                             ; 0C5C: FD 74 08
	OR A                                    ; 0C5F: B7
	RET                                     ; 0C60: C9

; --- CDB I/O ausfuehren: Lese-Modus ---
; Setzt Funktion im CDB und ruft dann die CPA BIOS-Extension
; cpmx21 (diskio) auf, um die Disk-Operation auszufuehren.
do_cdb_io:
	LD (IY+6),A                             ; 0C61: FD 77 06 ; Funktion im CDB setzen
	RES 1,(IY+0)                            ; 0C64: FD CB 00 8E ; Bit 1 loeschen = Lese-Modus
	JR L0C6E                                ; 0C68: 18 04

; --- CDB I/O: Schreib-Modus ---
do_cdb_io_write:
	SET 1,(IY+0)                            ; 0C6A: FD CB 00 CE ; Bit 1 setzen = Schreib-Modus
L0C6E:
	PUSH IY                                 ; 0C6E: FD E5
	POP HL                                  ; 0C70: E1       ; HL -> CDB-Adresse
	PUSH HL                                 ; 0C71: E5
	CALL call_diskio_cdb                    ; 0C72: CD AB 0F ; CPA Extension cpmx21 aufrufen
	POP IY                                  ; 0C75: FD E1
	RET                                     ; 0C77: C9

; ============================================================================
; ISR-Vektoren sichern und Laufwerke deselektieren
; Wird vor dem Beenden oder Laufwerkswechsel aufgerufen.
; ============================================================================
save_isr_vectors:
	CALL restore_isr                        ; 0C78: CD A8 0F
	LD A,(1C1FH)                            ; 0C7B: 3A 1F 1C
	INC A                                   ; 0C7E: 3C
	JP Z,next_drive                         ; 0C7F: CA 8E 0C
	LD IY,drive_a_params                    ; 0C82: FD 21 1E 1C
	CALL deselect_drive                     ; 0C86: CD 9E 0B
	LD A,FFH                                ; 0C89: 3E FF
	LD (1C1FH),A                            ; 0C8B: 32 1F 1C
next_drive:
	LD A,(1C2DH)                            ; 0C8E: 3A 2D 1C
	INC A                                   ; 0C91: 3C
	JP Z,next_side                          ; 0C92: CA A1 0C
	LD IY,drive_b_params                    ; 0C95: FD 21 2C 1C
	CALL deselect_drive                     ; 0C99: CD 9E 0B
	LD A,FFH                                ; 0C9C: 3E FF
	LD (1C2DH),A                            ; 0C9E: 32 2D 1C
next_side:
	RET                                     ; 0CA1: C9

display_format_info:
	LD DE,msg_offset_prompt                 ; 0CA2: 11 2D 17
	CALL print_string                       ; 0CA5: CD 18 0E
	LD A,(1B95H)                            ; 0CA8: 3A 95 1B
	LD H,00H                                ; 0CAB: 26 00
	LD L,A                                  ; 0CAD: 6F
	CALL print_dec_HL                       ; 0CAE: CD 70 0E
	LD DE,msg_format_uses                   ; 0CB1: 11 5A 17
	CALL print_string_inline                ; 0CB4: CD 1B 0E
	LD HL,(1B90H)                           ; 0CB7: 2A 90 1B
	LD DE,(1B8CH)                           ; 0CBA: ED 5B 8C 1B
	XOR A                                   ; 0CBE: AF
	SBC HL,DE                               ; 0CBF: ED 52
	LD DE,0000H                             ; 0CC1: 11 00 00
	LD BC,(1B94H)                           ; 0CC4: ED 4B 94 1B
	LD B,D                                  ; 0CC8: 42
L0CC9:
	SBC HL,BC                               ; 0CC9: ED 42
	JR C,L0CD0                              ; 0CCB: 38 03
	INC DE                                  ; 0CCD: 13
	JR L0CC9                                ; 0CCE: 18 F9

L0CD0:
	LD HL,(1B8EH)                           ; 0CD0: 2A 8E 1B
	EX DE,HL                                ; 0CD3: EB
	XOR A                                   ; 0CD4: AF
	SBC HL,DE                               ; 0CD5: ED 52
	EX DE,HL                                ; 0CD7: EB
	LD A,(1BCFH)                            ; 0CD8: 3A CF 1B
	LD HL,0040H                             ; 0CDB: 21 40 00
	INC A                                   ; 0CDE: 3C
	LD B,A                                  ; 0CDF: 47
L0CE0:
	ADD HL,HL                               ; 0CE0: 29
	DJNZ L0CE0                              ; 0CE1: 10 FD
	EX DE,HL                                ; 0CE3: EB
	SBC HL,DE                               ; 0CE4: ED 52
	LD A,H                                  ; 0CE6: 7C
	OR A                                    ; 0CE7: B7
	JR Z,L0CED                              ; 0CE8: 28 03
	LD HL,00FFH                             ; 0CEA: 21 FF 00
L0CED:
	LD (0D06H),HL                           ; 0CED: 22 06 0D
	CALL print_dec_HL                       ; 0CF0: CD 70 0E
	LD DE,175DH                             ; 0CF3: 11 5D 17
	CALL print_string_inline                ; 0CF6: CD 1B 0E
	CALL parse_dec_input                    ; 0CF9: CD 63 0F
	LD HL,(1B95H)                           ; 0CFC: 2A 95 1B
	CP L                                    ; 0CFF: BD
	JR C,display_format_info                ; 0D00: 38 A0
	LD D,00H                                ; 0D02: 16 00
	LD E,A                                  ; 0D04: 5F
	LD HL,0000H                             ; 0D05: 21 00 00
	SBC HL,DE                               ; 0D08: ED 52
	JR C,display_format_info                ; 0D0A: 38 96
	LD (1B95H),A                            ; 0D0C: 32 95 1B
	RET                                     ; 0D0F: C9

; ============================================================================
; Disk I/O Setup und Spurkapazitaets-Berechnung
; ============================================================================
; Berechnet die Parameter fuer den physischen Disk-Zugriff:
; - Sektorgroesse (80H * 2^N Bytes basierend auf DPB)
; - Spurkapazitaet in Bytes
; - Ganzzahl-Division fuer Sektor-Interleave
; Nutzt CPA Extension cpmx21 fuer den eigentlichen Zugriff.
; ============================================================================
do_disk_io:
	LD A,(IX+16)                            ; 0D10: DD 7E 10
	LD (1BCFH),A                            ; 0D13: 32 CF 1B
	LD B,A                                  ; 0D16: 47
	INC B                                   ; 0D17: 04
	LD A,80H                                ; 0D18: 3E 80
L0D1A:
	RLCA                                    ; 0D1A: 07
	DJNZ L0D1A                              ; 0D1B: 10 FD
	LD (1BCEH),A                            ; 0D1D: 32 CE 1B
	LD HL,0000H                             ; 0D20: 21 00 00
	LD DE,0080H                             ; 0D23: 11 80 00
	LD B,A                                  ; 0D26: 47
L0D27:
	ADD HL,DE                               ; 0D27: 19
	DJNZ L0D27                              ; 0D28: 10 FD
	LD (1BCCH),HL                           ; 0D2A: 22 CC 1B
	LD BC,(1B8EH)                           ; 0D2D: ED 4B 8E 1B
	ADD HL,BC                               ; 0D31: 09
	LD A,(1B95H)                            ; 0D32: 3A 95 1B
	LD C,A                                  ; 0D35: 4F
	ADD HL,BC                               ; 0D36: 09
	EX DE,HL                                ; 0D37: EB
	LD A,(1B94H)                            ; 0D38: 3A 94 1B
	LD B,A                                  ; 0D3B: 47
	LD HL,0000H                             ; 0D3C: 21 00 00
L0D3F:
	ADD HL,DE                               ; 0D3F: 19
	DJNZ L0D3F                              ; 0D40: 10 FD
	LD BC,(1B8CH)                           ; 0D42: ED 4B 8C 1B
	ADD HL,BC                               ; 0D46: 09
	LD (1BCAH),HL                           ; 0D47: 22 CA 1B
	LD DE,(1B90H)                           ; 0D4A: ED 5B 90 1B
	XOR A                                   ; 0D4E: AF
	SBC HL,DE                               ; 0D4F: ED 52
	RET C                                   ; 0D51: D8
	LD DE,1761H                             ; 0D52: 11 61 17
	CALL print_string                       ; 0D55: CD 18 0E
	LD HL,(1B95H)                           ; 0D58: 2A 95 1B
	LD H,00H                                ; 0D5B: 26 00
do_format_write:
	CALL print_dec_HL                       ; 0D5D: CD 70 0E
	LD DE,1768H                             ; 0D60: 11 68 17
	CALL print_string_inline                ; 0D63: CD 1B 0E
	CALL display_format_info                ; 0D66: CD A2 0C
	JP do_disk_io                           ; 0D69: C3 10 0D

fill_format_buffer:
	LD HL,1B94H                             ; 0D6C: 21 94 1B
	LD B,(HL)                               ; 0D6F: 46
	LD A,(1BE3H)                            ; 0D70: 3A E3 1B
	OR A                                    ; 0D73: B7
	JR Z,L0D78                              ; 0D74: 28 02
	SLA B                                   ; 0D76: CB 20
L0D78:
	LD C,00H                                ; 0D78: 0E 00
L0D7A:
	PUSH DE                                 ; 0D7A: D5
	PUSH BC                                 ; 0D7B: C5
	LD DE,17F5H                             ; 0D7C: 11 F5 17
	CALL print_string                       ; 0D7F: CD 18 0E
	CALL parse_hex_input                    ; 0D82: CD 32 0F
	JR Z,L0D8F                              ; 0D85: 28 08
	POP BC                                  ; 0D87: C1
	POP DE                                  ; 0D88: D1
	LD (DE),A                               ; 0D89: 12
	INC DE                                  ; 0D8A: 13
	LD C,A                                  ; 0D8B: 4F
	DJNZ L0D7A                              ; 0D8C: 10 EC
	RET                                     ; 0D8E: C9

L0D8F:
	POP BC                                  ; 0D8F: C1
	POP HL                                  ; 0D90: E1
L0D91:
	INC C                                   ; 0D91: 0C
	LD (HL),C                               ; 0D92: 71
	INC HL                                  ; 0D93: 23
	DJNZ L0D91                              ; 0D94: 10 FB
	RET                                     ; 0D96: C9

; --- Sektor-Daten per CDB schreiben ---
; Schreibt die Sektordaten ueber die CPA BIOS-Extension.
; Der CDB wird mit der richtigen DMA-Adresse und Sektornummer
; konfiguriert, dann wird cpmx21 (diskio) aufgerufen.
write_sector_data:
	PUSH IY                                 ; 0D97: FD E5
	LD IY,1C8DH                             ; 0D99: FD 21 8D 1C
	LD E,01H                                ; 0D9D: 1E 01
	CALL save_de_to_iy                      ; 0D9F: CD C3 0D
	POP IY                                  ; 0DA2: FD E1
	LD A,(1C7FH)                            ; 0DA4: 3A 7F 1C
L0DA7:
	PUSH AF                                 ; 0DA7: F5
	LD E,80H                                ; 0DA8: 1E 80
	CALL advance_dma_ptr                    ; 0DAA: CD C7 0D
read_sector_data:
	POP AF                                  ; 0DAD: F1
	DEC A                                   ; 0DAE: 3D
	JR NZ,L0DA7                             ; 0DAF: 20 F6
	RET                                     ; 0DB1: C9

; --- Sektor verifizieren (Lesen ohne Datenvergleich) ---
; Liest den Sektor ueber CDB und prueft auf Lesefehler.
do_verify_read:
	PUSH IY                                 ; 0DB2: FD E5
	LD IY,1C86H                             ; 0DB4: FD 21 86 1C
	LD E,01H                                ; 0DB8: 1E 01
	CALL save_de_to_iy                      ; 0DBA: CD C3 0D
	POP IY                                  ; 0DBD: FD E1
	LD E,04H                                ; 0DBF: 1E 04
	JR advance_dma_ptr                      ; 0DC1: 18 04

; ============================================================================
; CRC-16 Berechnung
; ============================================================================
; Berechnet eine CRC-16 Pruefsumme ueber die Sektor-Daten.
; Wird fuer die Integritaetspruefung der formatierten Sektoren verwendet.
; Algorithmus: Standard CRC-16 mit Bit-Rotation und XOR.
; Register: BC = laufende CRC, E = Byte-Zaehler, IY -> Datenpuffer
; ============================================================================
save_de_to_iy:
	LD BC,(1C43H)                           ; 0DC3: ED 4B 43 1C
advance_dma_ptr:
	LD A,(IY+0)                             ; 0DC7: FD 7E 00
	XOR B                                   ; 0DCA: A8
	LD B,A                                  ; 0DCB: 47
	RRCA                                    ; 0DCC: 0F
	RRCA                                    ; 0DCD: 0F
	RRCA                                    ; 0DCE: 0F
	RRCA                                    ; 0DCF: 0F
	AND 0FH                                 ; 0DD0: E6 0F
	XOR B                                   ; 0DD2: A8
	LD B,A                                  ; 0DD3: 47
	RRCA                                    ; 0DD4: 0F
	RRCA                                    ; 0DD5: 0F
	RRCA                                    ; 0DD6: 0F
	LD D,A                                  ; 0DD7: 57
	AND 1FH                                 ; 0DD8: E6 1F
	XOR C                                   ; 0DDA: A9
	LD C,A                                  ; 0DDB: 4F
	LD A,D                                  ; 0DDC: 7A
	RRCA                                    ; 0DDD: 0F
	AND F0H                                 ; 0DDE: E6 F0
	XOR C                                   ; 0DE0: A9
	LD C,A                                  ; 0DE1: 4F
	LD A,D                                  ; 0DE2: 7A
	AND E0H                                 ; 0DE3: E6 E0
	XOR B                                   ; 0DE5: A8
	LD B,C                                  ; 0DE6: 41
	LD C,A                                  ; 0DE7: 4F
	INC IY                                  ; 0DE8: FD 23
	DEC E                                   ; 0DEA: 1D
	JR NZ,advance_dma_ptr                   ; 0DEB: 20 DA
	RET                                     ; 0DED: C9

; ============================================================================
; CPA Extension Aufrufe (Betriebssystem-Zugriff)
; ============================================================================
; Diese Routinen rufen die CPA-spezifischen BIOS-Erweiterungen auf.
; Der Zugriff erfolgt ueber die Extensionstabelle bei Adresse 004EH.
;
; cpmx18 (0DEE): "delsps" - Leerzeichen ueberlesen in der Kommandozeile
; cpmx21 (0FAB): "diskio" - Erweiterte Disk-I/O ueber CDB
;
; Die Extension-Tabelle wird per LD HL,(004EH) gelesen, dann wird
; der Funktions-Offset addiert. Dies ist der EINZIGE Weg wie
; FORMAT.COM regulaer auf die Disk-Hardware zugreift (ausser beim
; Formatieren selbst, wo direkte PIO-Programmierung noetig ist).
; ============================================================================

; --- CPA Extension cpmx18: Leerzeichen ueberlesen ---
; Liest Zeichen aus dem Kommandozeilen-Puffer (0080H)
; und ueberspringt Leerzeichen (20H).
; Rueckgabe: A=naechstes Nicht-Leerzeichen, CF=1 wenn Zeichen vorhanden
call_cpmx18:
	CALL resolve_cpmext                     ; 0DEE: CD F9 0D
	OR A                                    ; 0DF1: B7
	RET Z                                   ; 0DF2: C8
	CP 20H                                  ; 0DF3: FE 20
	JR Z,call_cpmx18                        ; 0DF5: 28 F7
	SCF                                     ; 0DF7: 37
	RET                                     ; 0DF8: C9

; --- Kommandozeilen-Puffer auslesen ---
; Liest ein Byte aus dem DMA-Puffer (0080H = Laenge, 0081H+ = Daten).
; Dekrementiert den Laengenzaehler. Konvertiert '/' in CR (0DH).
; Rueckgabe: A=Zeichen, Z wenn Puffer leer.
resolve_cpmext:
	LD A,(0080H)                            ; 0DF9: 3A 80 00
	OR A                                    ; 0DFC: B7
	RET Z                                   ; 0DFD: C8
	DEC A                                   ; 0DFE: 3D
	LD (0080H),A                            ; 0DFF: 32 80 00
	LD C,A                                  ; 0E02: 4F
	LD DE,0081H                             ; 0E03: 11 81 00
	LD A,(DE)                               ; 0E06: 1A
	CP 2FH                                  ; 0E07: FE 2F
	JR NZ,L0E0D                             ; 0E09: 20 02
	LD A,0DH                                ; 0E0B: 3E 0D
L0E0D:
	INC C                                   ; 0E0D: 0C
; --- CPA Extension per Nummer aufrufen ---
; C = Offset in der Kommandozeile, wird heruntergezaehlt.
; Verschiebt den restlichen Pufferinhalt nach vorne.
call_cpmext:
	DEC C                                   ; 0E0E: 0D
	RET Z                                   ; 0E0F: C8
	LD B,00H                                ; 0E10: 06 00
	LD HL,0082H                             ; 0E12: 21 82 00 ; HL -> Puffer ab 2. Byte
	LDIR                                    ; 0E15: ED B0    ; Restliche Bytes verschieben
	RET                                     ; 0E17: C9

; -----------------------------------------------
; Print $-terminated string
; DE = pointer to string
; -----------------------------------------------
print_string:
	CALL print_char                         ; 0E18: CD 20 0E ; BDOS function 9
; Print $-terminated string + CRLF
print_string_inline:
	LD C,09H                                ; 0E1B: 0E 09 ; BDOS function 9
	JP 0005H                                ; 0E1D: C3 05 00

; Print character in A
print_char:
	LD A,0DH                                ; 0E20: 3E 0D
	CALL print_char_bdos                    ; 0E22: CD 27 0E
	LD A,0AH                                ; 0E25: 3E 0A
; Print character via BDOS (E=char)
print_char_bdos:
	PUSH HL                                 ; 0E27: E5
	PUSH DE                                 ; 0E28: D5
	PUSH BC                                 ; 0E29: C5
	LD C,02H                                ; 0E2A: 0E 02
	LD E,A                                  ; 0E2C: 5F
	CALL 0005H                              ; 0E2D: CD 05 00
	POP BC                                  ; 0E30: C1
	POP DE                                  ; 0E31: D1
	POP HL                                  ; 0E32: E1
	RET                                     ; 0E33: C9

; Read char and convert to uppercase
read_char_upper:
	CALL print_string                       ; 0E34: CD 18 0E
; -----------------------------------------------
; Read character from console
; Returns: A = character, Z if no char
; -----------------------------------------------
read_char:
	CALL call_cpmx18                        ; 0E37: CD EE 0D ; BDOS direct console I/O
	JR C,L0E43                              ; 0E3A: 38 07
	LD E,FFH                                ; 0E3C: 1E FF
	LD C,06H                                ; 0E3E: 0E 06
	CALL 0005H                              ; 0E40: CD 05 00
L0E43:
	OR A                                    ; 0E43: B7
	JR Z,read_char                          ; 0E44: 28 F1
	CP 03H                                  ; 0E46: FE 03
	JR Z,L0E6A                              ; 0E48: 28 20
	CP 61H                                  ; 0E4A: FE 61
	JR C,L0E50                              ; 0E4C: 38 02
	AND 5FH                                 ; 0E4E: E6 5F
L0E50:
	CP 0DH                                  ; 0E50: FE 0D
	RET Z                                   ; 0E52: C8
	CP 21H                                  ; 0E53: FE 21
	JR C,L0E62                              ; 0E55: 38 0B
	PUSH AF                                 ; 0E57: F5
	LD E,A                                  ; 0E58: 5F
	LD C,02H                                ; 0E59: 0E 02
	CALL 0005H                              ; 0E5B: CD 05 00
	POP AF                                  ; 0E5E: F1
	CP 0DH                                  ; 0E5F: FE 0D
	RET                                     ; 0E61: C9

L0E62:
	LD DE,1462H                             ; 0E62: 11 62 14
	CALL print_string_inline                ; 0E65: CD 1B 0E
	JR read_char                            ; 0E68: 18 CD

L0E6A:
	LD DE,15D6H                             ; 0E6A: 11 D6 15
	JP L0B46                                ; 0E6D: C3 46 0B

; -----------------------------------------------
; Print HL as decimal number (signed)
; Uses successive subtraction by -10000,-1000,-100,-10
; -----------------------------------------------
print_dec_HL:
	PUSH DE                                 ; 0E70: D5
	PUSH BC                                 ; 0E71: C5
	LD A,H                                  ; 0E72: 7C
	AND 80H                                 ; 0E73: E6 80
	LD B,A                                  ; 0E75: 47
	JR Z,L0E7F                              ; 0E76: 28 07
	XOR H                                   ; 0E78: AC
	LD DE,0000H                             ; 0E79: 11 00 00
	EX DE,HL                                ; 0E7C: EB
	SBC HL,DE                               ; 0E7D: ED 52
L0E7F:
	INC H                                   ; 0E7F: 24
	DEC H                                   ; 0E80: 25
	JR Z,L0E8F                              ; 0E81: 28 0C
	LD DE,D8F0H                             ; 0E83: 11 F0 D8
	CALL dec_div_digit                      ; 0E86: CD A5 0E
	LD DE,FC18H                             ; 0E89: 11 18 FC
	CALL dec_div_digit                      ; 0E8C: CD A5 0E
L0E8F:
	LD DE,FF9CH                             ; 0E8F: 11 9C FF
	CALL dec_div_digit                      ; 0E92: CD A5 0E
	LD DE,FFF6H                             ; 0E95: 11 F6 FF
	CALL dec_div_digit                      ; 0E98: CD A5 0E
	LD A,L                                  ; 0E9B: 7D
	ADD A,30H                               ; 0E9C: C6 30
	LD C,A                                  ; 0E9E: 4F
	CALL dec_out_digit                      ; 0E9F: CD B0 0E
	POP BC                                  ; 0EA2: C1
	POP DE                                  ; 0EA3: D1
	RET                                     ; 0EA4: C9

dec_div_digit:
	LD C,2FH                                ; 0EA5: 0E 2F
L0EA7:
	INC C                                   ; 0EA7: 0C
	ADD HL,DE                               ; 0EA8: 19
	JR C,L0EA7                              ; 0EA9: 38 FC
	SBC HL,DE                               ; 0EAB: ED 52
dec_check_zero:
	LD A,C                                  ; 0EAD: 79
	CP 30H                                  ; 0EAE: FE 30
dec_out_digit:
	LD A,20H                                ; 0EB0: 3E 20
	JR Z,L0EB6                              ; 0EB2: 28 02
	SET 6,B                                 ; 0EB4: CB F0
L0EB6:
	BIT 6,B                                 ; 0EB6: CB 70
	JR Z,L0EC9                              ; 0EB8: 28 0F
	BIT 0,B                                 ; 0EBA: CB 40
	JR NZ,L0EC8                             ; 0EBC: 20 0A
	INC B                                   ; 0EBE: 04
	BIT 7,B                                 ; 0EBF: CB 78
	JR Z,L0EC5                              ; 0EC1: 28 02
	LD A,2DH                                ; 0EC3: 3E 2D
L0EC5:
	CALL print_char_bdos                    ; 0EC5: CD 27 0E
L0EC8:
	LD A,C                                  ; 0EC8: 79
L0EC9:
	JP print_char_bdos                      ; 0EC9: C3 27 0E

; -----------------------------------------------
; Print A register as 2-digit hex
; Rotates high nibble down, prints both nibbles
; -----------------------------------------------
print_hex_A:
	PUSH AF                                 ; 0ECC: F5
	RRCA                                    ; 0ECD: 0F
	RRCA                                    ; 0ECE: 0F
	RRCA                                    ; 0ECF: 0F
	RRCA                                    ; 0ED0: 0F
	CALL print_hex_nib                      ; 0ED1: CD D5 0E
	POP AF                                  ; 0ED4: F1
print_hex_nib:
	AND 0FH                                 ; 0ED5: E6 0F
	OR 30H                                  ; 0ED7: F6 30
	CP 3AH                                  ; 0ED9: FE 3A
	JR C,L0EDF                              ; 0EDB: 38 02
	ADD A,07H                               ; 0EDD: C6 07
L0EDF:
	JP print_char_bdos                      ; 0EDF: C3 27 0E

; -----------------------------------------------
; Read user input (from command tail or console)
; If (0080H)=0: uses BDOS read buffer function
; Otherwise: reads chars via cpmx18, echoing each
; Converts result to uppercase
; -----------------------------------------------
read_user_input:
	LD A,(0080H)                            ; 0EE2: 3A 80 00
	OR A                                    ; 0EE5: B7
	JR Z,read_line_bdos                     ; 0EE6: 28 27
	LD HL,format_data_area                  ; 0EE8: 21 30 1A
	LD B,(HL)                               ; 0EEB: 46
	INC HL                                  ; 0EEC: 23
read_chars_loop:
	LD C,00H                                ; 0EED: 0E 00
L0EEF:
	PUSH BC                                 ; 0EEF: C5
	PUSH HL                                 ; 0EF0: E5
	CALL call_cpmx18                        ; 0EF1: CD EE 0D
	POP HL                                  ; 0EF4: E1
	POP BC                                  ; 0EF5: C1
	JR NC,L0F04                             ; 0EF6: 30 0C
	CP 0DH                                  ; 0EF8: FE 0D
	JR Z,L0F04                              ; 0EFA: 28 08
	INC HL                                  ; 0EFC: 23
	LD (HL),A                               ; 0EFD: 77
	CALL print_char_bdos                    ; 0EFE: CD 27 0E
	INC C                                   ; 0F01: 0C
	DJNZ L0EEF                              ; 0F02: 10 EB
L0F04:
	LD A,0DH                                ; 0F04: 3E 0D
	CALL print_char_bdos                    ; 0F06: CD 27 0E
	LD A,C                                  ; 0F09: 79
	LD (1A31H),A                            ; 0F0A: 32 31 1A
	JR L0F17                                ; 0F0D: 18 08

; Read console line via BDOS function 0AH
read_line_bdos:
	LD DE,format_data_area                  ; 0F0F: 11 30 1A
	LD C,0AH                                ; 0F12: 0E 0A
	CALL 0005H                              ; 0F14: CD 05 00
L0F17:
	LD HL,1A31H                             ; 0F17: 21 31 1A
	LD A,(HL)                               ; 0F1A: 7E
	INC HL                                  ; 0F1B: 23
	OR A                                    ; 0F1C: B7
	RET Z                                   ; 0F1D: C8
	PUSH AF                                 ; 0F1E: F5
	PUSH HL                                 ; 0F1F: E5
	LD B,A                                  ; 0F20: 47
L0F21:
	LD A,(HL)                               ; 0F21: 7E
	CP 61H                                  ; 0F22: FE 61
	JR C,L0F2C                              ; 0F24: 38 06
	CP 7BH                                  ; 0F26: FE 7B
	JR NC,L0F2C                             ; 0F28: 30 02
	RES 5,(HL)                              ; 0F2A: CB AE
L0F2C:
	INC HL                                  ; 0F2C: 23
	DJNZ L0F21                              ; 0F2D: 10 F2
	POP HL                                  ; 0F2F: E1
	POP AF                                  ; 0F30: F1
	RET                                     ; 0F31: C9

; -----------------------------------------------
; Parse hex number from user input buffer
; Returns: E=value, Z if empty input
; -----------------------------------------------
parse_hex_input:
	CALL read_user_input                    ; 0F32: CD E2 0E
	RET Z                                   ; 0F35: C8
	LD B,A                                  ; 0F36: 47
	LD E,00H                                ; 0F37: 1E 00
L0F39:
	LD A,(HL)                               ; 0F39: 7E
	INC HL                                  ; 0F3A: 23
	CP 41H                                  ; 0F3B: FE 41
	JR C,L0F41                              ; 0F3D: 38 02
	SUB 07H                                 ; 0F3F: D6 07
L0F41:
	SUB 30H                                 ; 0F41: D6 30
	JR C,L0F5B                              ; 0F43: 38 16
	CP 10H                                  ; 0F45: FE 10
	JR NC,L0F5B                             ; 0F47: 30 12
	LD D,A                                  ; 0F49: 57
	LD A,E                                  ; 0F4A: 7B
	CP 11H                                  ; 0F4B: FE 11
	JR NC,L0F5B                             ; 0F4D: 30 0C
	ADD A,A                                 ; 0F4F: 87
	ADD A,A                                 ; 0F50: 87
	ADD A,A                                 ; 0F51: 87
	ADD A,A                                 ; 0F52: 87
	ADD A,D                                 ; 0F53: 82
	LD E,A                                  ; 0F54: 5F
	DJNZ L0F39                              ; 0F55: 10 E2
	XOR A                                   ; 0F57: AF
	INC A                                   ; 0F58: 3C
	LD A,E                                  ; 0F59: 7B
	RET                                     ; 0F5A: C9

L0F5B:
	LD DE,1462H                             ; 0F5B: 11 62 14
	CALL print_string_inline                ; 0F5E: CD 1B 0E
	JR parse_hex_input                      ; 0F61: 18 CF

parse_dec_input:
	CALL read_user_input                    ; 0F63: CD E2 0E
	RET Z                                   ; 0F66: C8
	LD B,A                                  ; 0F67: 47
	LD E,00H                                ; 0F68: 1E 00
L0F6A:
	LD A,(HL)                               ; 0F6A: 7E
	INC HL                                  ; 0F6B: 23
	SUB 30H                                 ; 0F6C: D6 30
	JR C,L0F88                              ; 0F6E: 38 18
print_decimal_HL:
	CP 0AH                                  ; 0F70: FE 0A
	JR NC,L0F88                             ; 0F72: 30 14
	LD D,A                                  ; 0F74: 57
	LD A,E                                  ; 0F75: 7B
	CP 1AH                                  ; 0F76: FE 1A
	JR NC,L0F88                             ; 0F78: 30 0E
	ADD A,A                                 ; 0F7A: 87
	ADD A,A                                 ; 0F7B: 87
	ADD A,E                                 ; 0F7C: 83
	ADD A,A                                 ; 0F7D: 87
	ADD A,D                                 ; 0F7E: 82
	JR C,L0F88                              ; 0F7F: 38 07
	LD E,A                                  ; 0F81: 5F
	DJNZ L0F6A                              ; 0F82: 10 E6
	XOR A                                   ; 0F84: AF
	INC A                                   ; 0F85: 3C
	LD A,E                                  ; 0F86: 7B
	RET                                     ; 0F87: C9

L0F88:
	LD DE,1462H                             ; 0F88: 11 62 14
	CALL print_string_inline                ; 0F8B: CD 1B 0E
	JR parse_dec_input                      ; 0F8E: 18 D3

; ============================================================================
; Programmende und Rueckkehr-Routinen
; ============================================================================

; --- ISR restaurieren und Verzoegerung ---
; Fuehrt eine Verzoegeurngsschleife aus (C8H = 200 Durchlaeufe),
; um dem FDC Zeit zu geben die letzte Operation abzuschliessen.
restore_isr_exit:
	LD C,C8H                                ; 0F90: 0E C8
L0F92:
	CALL exit_program                       ; 0F92: CD 99 0F
	DEC C                                   ; 0F95: 0D
	JR NZ,L0F92                             ; 0F96: 20 FA
	RET                                     ; 0F98: C9

; --- Software-Verzoegerungsschleife ---
; Zaehlt B von BDH (189) herunter bis 0.
; Wird fuer Hardware-Timing gebraucht (Motor-Hochlauf etc.).
exit_program:
	LD B,BDH                                ; 0F99: 06 BD
L0F9B:
	DJNZ L0F9B                              ; 0F9B: 10 FE
	RET                                     ; 0F9D: C9

; --- Direkter BIOS-Warmstart-Aufruf ---
; *** DIREKTER OS-ZUGRIFF: Berechnet BIOS-Adresse aus Warmstart-Vektor! ***
; Liest den Warmstart-Vektor (0001H), addiert 18H (Offset zur
; SELDSK-Routine in der BIOS-Sprungtabelle), und springt direkt
; in den BIOS-Code. Dies umgeht den normalen BDOS-Weg.
exit_warm_boot:
	LD HL,(0001H)                           ; 0F9E: 2A 01 00 ; BIOS-Warmstart-Adresse lesen
	LD DE,0018H                             ; 0FA1: 11 18 00 ; Offset +18H = SELDSK in BIOS-Tabelle
	ADD HL,DE                               ; 0FA4: 19       ; HL -> BIOS SELDSK Routine
	LD E,00H                                ; 0FA5: 1E 00    ; Parameter: Laufwerk 0
	JP (HL)                                 ; 0FA7: E9       ; *** Direkt in BIOS springen!

; --- ISR restaurieren ---
; Ruft die CPA Extension cpmx21 auf, um den Disk-Controller
; in den normalen Zustand zurueckzuversetzen.
restore_isr:
	LD HL,1C3AH                             ; 0FA8: 21 3A 1C ; HL -> CDB fuer Reset-Kommando

; --- CPA Extension cpmx21 (diskio) aufrufen ---
; Berechnet die Adresse der diskio-Funktion aus der CPA
; Extensionstabelle bei 004EH und springt dorthin.
; A = 21H = Funktionsnummer von diskio
; HL = Zeiger auf CDB (Command Descriptor Block)
call_diskio_cdb:
	LD A,21H                                ; 0FAB: 3E 21    ; cpmx21 = diskio

; --- Allgemeiner CPA-Extension-Aufruf ---
; Liest die CPA-Extensionstabelle von 004EH, addiert den
; Funktions-Offset (A) und springt indirekt dorthin.
; *** OS-ZUGRIFF: Nutzt CPA-spezifische Erweiterungstabelle! ***
delay_loop:
	PUSH HL                                 ; 0FAD: E5
	LD HL,(004EH)                           ; 0FAE: 2A 4E 00 ; HL -> CPA Extensionstabelle
	ADD A,L                                 ; 0FB1: 85       ; Offset addieren
	LD L,A                                  ; 0FB2: 6F
	JR NC,L0FB6                             ; 0FB3: 30 01
	INC H                                   ; 0FB5: 24
L0FB6:
	LD (0FBBH),HL                           ; 0FB6: 22 BB 0F ; SELBSTMODIFIKATION: JP-Zieladresse schreiben!
	POP HL                                  ; 0FB9: E1
	JP 0000H                                ; 0FBA: C3 00 00 ; *** SELBSTMODIFIKATION: Adresse wird ueberschrieben!


; ============================================================================
; String-Datenbereich
; Alle deutschsprachigen Meldungen des Programms.
; Strings sind mit '$' terminiert (fuer BDOS Funktion 9).
; ============================================================================
msg_version_error:
	DB	0AH
	DB	'Tut mir leid! System CP/A fuer Buerocomputer',0DH,0AH
	DB	'mit Version ab 12/87 erforderlich!',0DH,0AH
	DB	07H,'$'
	DB	0AH
	DB	'Tut mir leid! Zuwenig freier Hauptspeicherplatz (TPA-Ende >='
