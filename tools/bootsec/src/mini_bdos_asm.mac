; ======================================================================
; MINI_BDOS_ASM -- Mini-BDOS Modul (0100H-0CFFH)
; ======================================================================
; Assemblierbare Version, basierend auf der kommentierten Disassemblierung
; (mini_bdos.mac, erzeugt mit bdos_analyze.py).
;
; Adressbereich: 0100H-0CFFH (3072 Bytes, Track 0 Sektoren 2-25)
;
; Architektur:
;   Das BDOS-Modul wurde original mit ORG 0900H assembliert.
;   Alle internen Referenzen verwenden Laufzeit-Adressen (+0800H).
;   @OS.COM verschiebt den Code zur Laufzeit von 0100H nach 0900H.
;
;   Phys. 0100H = Laufzeit 0900H   (BDOS-Modul-Anfang)
;   Phys. 0106H = Laufzeit 0906H   (BDOS-Einstieg: JP bdose)
;   Phys. 0111H = Laufzeit 0911H   (bdose Einstiegspunkt)
;   Phys. 0CFFH = Laufzeit 14FFH   (BDOS-Modul-Ende)
;
; Dies ist ein READ-ONLY Mini-BDOS fuer den Boot-Vorgang:
;   - Schreib-Funktionen (func10/21/33/34/40) zeigen auf Stub (08AFH)
;   - Console-I/O ist vollstaendig (func1-9, func11)
;   - Disk-Lesen ist vollstaendig (func15/17/18/20)
;
; CP/M-Referenz: doc/CPM_2_2/OS3BDOS.ASM + OS3BDOS1.ASM
;
; Dieses Modul wird zusammen mit bootsec_syl.mac und boot_bios.mac
; assembliert, um die vollstaendige bootsec.bin zu erzeugen.
; ======================================================================

	.Z80
	ASEG
	ORG	0100H

; --- Padding (0100H-0105H) ---
	DS	6		; 0100-0105: Padding (Nullbytes)

BDOS_ENTRY:
	JP 0911H		; 0106H  JMP bdose (CP/M 2.2 Standard-Einstieg)
PERERR:
; --- Error-Handler-Zeiger (CP/M 2.2: pererr/selerr/roderr/roferr) ---
	DW	0999H		; 0109H: Eintrag 00 -> 0999H (OPEN_NEXT)
	DW	09A5H		; 010BH: Eintrag 01 -> 09A5H
	DW	09ABH		; 010DH: Eintrag 02 -> 09ABH
	DW	09B1H		; 010FH: Eintrag 03 -> 09B1H

; --- bdose: BDOS-Einstiegspunkt (CP/M 2.2: arrive here from user) ---
; Registerbelegung: C=Funktionsnummer, DE=Parameter
BDOSE:
	EX DE,HL		; 0111H  xchg (DE<->HL)
	LD (0B5CH),HL		; 0112H  shld info ; info = Parameter-Adresse
	EX DE,HL		; 0115H  xchg
	LD A,E		; 0116H  mov a,e
	LD (1429H),A		; 0117H  sta linfo ; low(info) merken
	LD HL,0000H		; 011AH  lxi h,0
	LD (0B5EH),HL		; 011DH  shld aret ; Rueckgabewert = 0000H
	ADD HL,SP		; 0120H  dad sp ; SP merken
	LD (0B28H),HL		; 0121H  shld entsp
	LD SP,0B5AH		; 0124H  lxi sp,lstack ; lokaler Stack
	XOR A		; 0127H  xra a
	LD (1433H),A		; 0128H  sta fcbdsk ; fcbdsk = false
BDOSE_RESEL:
	LD (1431H),A		; 012BH  sta resel  ; resel = false
BDOSE_DISP:
	LD HL,13E7H		; 012EH  lxi h,goback ; Ruecksprung-Adresse
	PUSH HL		; 0131H  push h ; -> Stack (funktioniert wie jmp goback bei RET)
	LD A,C		; 0132H  mov a,c ; Funktionsnummer
	CP 29H		; 0133H  cpi nfuncs (41) ; gueltige Funktion?
	RET NC		; 0135H  ret nc ; nein -> goback
	LD C,E		; 0136H  mov c,e ; Ausgabe-Zeichen nach C
	LD HL,0947H		; 0137H  lxi h,functab ; Adresse der Dispatch-Tabelle
	LD E,A		; 013AH  mov e,a ; DE = Funktionsnummer
	LD D,00H		; 013BH  mvi d,0
	ADD HL,DE		; 013DH  dad d
	ADD HL,DE		; 013EH  dad d ; HL = functab + func*2
	LD E,(HL)		; 013FH  mov e,m ; Low-Byte der Zieladresse
BDOSE_PCHL:
	INC HL		; 0140H  inx h
L0141:
	LD D,(HL)		; 0141H  mov d,m ; High-Byte der Zieladresse
	LD HL,(0B5CH)		; 0142H  lhld info ; HL = info (Parameter)
	EX DE,HL		; 0145H  xchg ; HL = Zieladresse, DE = info
	JP (HL)		; 0146H  pchl ; -> Funktions-Handler

; --- functab: 41 Dispatch-Eintraege (func00..func40) ---
; Eintraege zeigen auf Laufzeit-Adressen (nach Relokation auf 0900H).
; STUB-Eintraege (08AFH) verweisen auf mergezero (= Dummy-Ruecksprung).
FUNCTAB:
; --- functab: BDOS-Dispatch-Tabelle (41 DW-Eintraege) ---
	DW	1803H		; 0147H: func00: wbootf (BIOS Warmstart)
	DW	0AE1H		; 0149H: func01: conech (Konsoleingabe+Echo)
	DW	0A90H		; 014BH: func02: tabout (Konsolausgabe+Tab)
	DW	0AE7H		; 014DH: func03: readerf (Reader-Eingabe)
	DW	1812H		; 014FH: func04: punchf (Punch-Ausgabe)
	DW	180FH		; 0151H: func05: listf (List-Ausgabe)
	DW	0AEDH		; 0153H: func06: direct I/O
	DW	0B06H		; 0155H: func07: get IOBYTE
	DW	0B0CH		; 0157H: func08: set IOBYTE
	DW	0B11H		; 0159H: func09: print string
	DW	08AFH		; 015BH: func10: read line (STUB)
	DW	0B17H		; 015DH: func11: console status
	DW	12F0H		; 015FH: func12: version (2.2)
	DW	1441H		; 0161H: func13: reset disks
	DW	1449H		; 0163H: func14: select disk
	DW	1312H		; 0165H: func15: open file
	DW	131BH		; 0167H: func16: close file
	DW	1321H		; 0169H: func17: search first
	DW	133EH		; 016BH: func18: search next
	DW	134DH		; 016DH: func19: delete file
	DW	1356H		; 016FH: func20: read sequential
	DW	08AFH		; 0171H: func21: write seq (STUB)
	DW	135CH		; 0173H: func22: make file
	DW	1365H		; 0175H: func23: rename file
	DW	136EH		; 0177H: func24: login vector
	DW	1374H		; 0179H: func25: current disk
	DW	137AH		; 017BH: func26: set DMA
	DW	1381H		; 017DH: func27: alloc vector
	DW	0D45H		; 017FH: func28: write protect
	DW	1387H		; 0181H: func29: R/O vector
	DW	138DH		; 0183H: func30: set indicators
	DW	1396H		; 0185H: func31: DPB address
	DW	139DH		; 0187H: func32: user code
	DW	08AFH		; 0189H: func33: random read (STUB)
	DW	08AFH		; 018BH: func34: random write (STUB)
	DW	13B1H		; 018DH: func35: file size
	DW	1280H		; 018FH: func36: set random
	DW	13B7H		; 0191H: func37: reset drive
	DW	0B1DH		; 0193H: func38: (unused)
	DW	0B1DH		; 0195H: func39: (unused)
	DW	08AFH		; 0197H: func40: rand write+zero (STUB)
	LD HL,09CAH		; 0199H
	CALL 09E5H		; 019CH  call errflg
	CP 03H		; 019FH  cpi ctlc (03H)
	JP Z,0000H		; 01A1H  jz reboot ; Ctrl-C -> Neustart
	RET		; 01A4H  ret ; Fehler ignorieren
SELSUB:
	LD HL,09D5H		; 01A5H  lxi h,selmsg
	JP 09B4H		; 01A8H  jmp wait$err
RODSUB:
	LD HL,09E1H		; 01ABH  lxi h,rodmsg
	JP 09B4H		; 01AEH  jmp wait$err
ROFSUB:
	LD HL,09DCH		; 01B1H  lxi h,rofmsg
WAIT_ERR:
	CALL 09E5H		; 01B4H  call errflg
	JP 0000H		; 01B7H  jmp reboot ; Neustart nach R/O-Fehler

; --- Fehlermeldungen (ASCII, $-terminiert) ---
DSKMSG:
; --- ASCII: "Bdos Err On  : $" ---
	DB	'Bdos Err On  : $'	; 01BAH
PERMSG:
; --- ASCII: "Bad Sector$" ---
	DB	'Bad Sector$'	; 01CAH
SELMSG:
; --- ASCII: "Select$" ---
	DB	'Select$'	; 01D5H
ROFMSG:
; --- ASCII: "File R/O$" ---
	DB	'File R/O$'	; 01DCH

; --- Console-I/O-Routinen (CP/M 2.2: errflg..print) ---
; Identisch mit CP/M 2.2 BDOS, nur in Z80-Mnemonics.
ERRFLG:
	PUSH HL		; 01E5H  push h ; Fehlermeldung auf Stack
	CALL 0AC9H		; 01E6H  call crlf ; neue Zeile
	LD A,(0B5BH)		; 01E9H  lda curdsk ; aktuelles Laufwerk
	ADD A,41H		; 01ECH  adi 'A' ; -> Buchstabe
	LD (09C6H),A		; 01EEH  sta dskerr ; in Meldung einsetzen
	LD BC,09BAH		; 01F1H  lxi b,dskmsg
	CALL 0AD3H		; 01F4H  call print ; "Bdos Err On X : "
	POP BC		; 01F7H  pop b ; Fehlermeldung vom Stack
	CALL 0AD3H		; 01F8H  call print ; Fehlertext ausgeben
CONIN:
	LD HL,0B27H		; 01FBH  lxi h,kbchar ; gepuffertes Zeichen?
	LD A,(HL)		; 01FEH  mov a,m
	LD (HL),00H		; 01FFH  mvi m,0 ; Puffer loeschen
	OR A		; 0201H  ora a
	RET NZ		; 0202H  ret nz ; ja -> Zeichen zurueck
	JP 1809H		; 0203H  jmp coninf ; BIOS: Konsole lesen
CONECH:
	CALL 09FBH		; 0206H  call conin ; Zeichen von Konsole
	CALL 0A14H		; 0209H  call echoc ; Echo noetig?
	RET C		; 020CH  ret c ; Steuerzeichen -> kein Echo
	PUSH AF		; 020DH  push af
	LD C,A		; 020EH  mov c,a
	CALL 0A90H		; 020FH  call tabout ; Zeichen mit Tab-Expansion
	POP AF		; 0212H  pop af
L0213:
	RET		; 0213H
ECHOC:
	CP 0DH		; 0214H  cpi cr ; Wagenruecklauf?
	RET Z		; 0216H
	CP 0AH		; 0217H  cpi lf ; Zeilenvorschub?
	RET Z		; 0219H
	CP 09H		; 021AH  cpi tab ; Tabulator?
	RET Z		; 021CH
	CP 08H		; 021DH  cpi ctlh ; Backspace?
	RET Z		; 021FH
	CP 20H		; 0220H  cpi ' ' ; Carry gesetzt wenn nicht druckbar
L0222:
	RET		; 0222H
CONBRK:
	LD A,(0B27H)		; 0223H  lda kbchar ; gepuffertes Zeichen?
	OR A		; 0226H
	JP NZ,0A45H		; 0227H  jnz conb1 ; ja -> return true
	CALL 1806H		; 022AH  call constf ; BIOS: Status pruefen
	AND 01H		; 022DH  ani 1
	RET Z		; 022FH  ret z ; kein Zeichen bereit
	CALL 1809H		; 0230H  call coninf ; BIOS: Zeichen lesen
	CP 13H		; 0233H  cpi ctls (13H) ; Bildschirm-Stop?
	JP NZ,0A42H		; 0235H  jnz conb0 ; nein -> Zeichen merken
	CALL 1809H		; 0238H  call coninf ; naechstes Zeichen
	CP 03H		; 023BH  cpi ctlc (03H) ; Ctrl-C?
	JP Z,0000H		; 023DH  jz reboot ; ja -> Neustart
	XOR A		; 0240H  xra a ; nichts passiert
	RET		; 0241H
CONB0:
	LD (0B27H),A		; 0242H  sta kbchar ; Zeichen merken
CONB1:
	LD A,01H		; 0245H  mvi a,1 ; true zurueck
	RET		; 0247H
CONOUT:
	LD A,(0B23H)		; 0248H  lda compcol ; nur Spalte berechnen?
	OR A		; 024BH
	JP NZ,0A62H		; 024CH  jnz compout ; ja -> nur Position
	PUSH BC		; 024FH  push b ; Zeichen retten
	CALL 0A23H		; 0250H  call conbrk ; Bildschirm-Stop pruefen
	POP BC		; 0253H  pop b
	PUSH BC		; 0254H  push b
	CALL 180CH		; 0255H  call conoutf ; BIOS: Zeichen ausgeben
	POP BC		; 0258H  pop b
	PUSH BC		; 0259H  push b
	LD A,(0B26H)		; 025AH  lda listcp ; Drucker-Kopie aktiv?
	OR A		; 025DH
	CALL NZ,180FH		; 025EH  cnz listf ; ja -> auch an Drucker
	POP BC		; 0261H  pop b
COMPOUT:
	LD A,C		; 0262H  mov a,c ; Zeichen zurueck
	LD HL,0B25H		; 0263H  lxi h,column ; Spaltenposition
	CP 7FH		; 0266H  cpi rubout (7FH)
	RET Z		; 0268H  ret z ; DEL -> keine Spaltenveraenderung
	INC (HL)		; 0269H  inr m ; column++
	CP 20H		; 026AH  cpi ' '
	RET NC		; 026CH  ret nc ; druckbar -> fertig
	DEC (HL)		; 026DH  dcr m ; column-- (nicht druckbar)
	LD A,(HL)		; 026EH  mov a,m
	OR A		; 026FH
	RET Z		; 0270H  ret z ; Spalte 0 -> fertig
	LD A,C		; 0271H  mov a,c
	CP 08H		; 0272H  cpi ctlh (08H) ; Backspace?
	JP NZ,0A79H		; 0274H  jnz notbacksp
	DEC (HL)		; 0277H  dcr m ; column-- (Backspace)
	RET		; 0278H
	CP 0AH		; 0279H  cpi lf ; Zeilenende?
	RET NZ		; 027BH
	LD (HL),00H		; 027CH  mvi m,0 ; column = 0
	RET		; 027EH
CTLOUT:
	LD A,C		; 027FH  mov a,c
	CALL 0A14H		; 0280H  call echoc
	JP NC,0A90H		; 0283H  jnc tabout ; druckbar -> normal ausgeben
	PUSH AF		; 0286H  push af
	LD C,5EH		; 0287H  mvi c,'^' ; Pfeil-Praefix
	CALL 0A48H		; 0289H  call conout
	POP AF		; 028CH  pop af
	OR 40H		; 028DH  ori 40H ; Steuerzeichen -> Buchstabe
	LD C,A		; 028FH  mov c,a
TABOUT:
	LD A,C		; 0290H  mov a,c
	CP 09H		; 0291H  cpi tab (09H)
	JP NZ,0A48H		; 0293H  jnz conout ; kein Tab -> direkt ausgeben
TAB0:
	LD C,20H		; 0296H  mvi c,' ' ; Leerzeichen
	CALL 0A48H		; 0298H  call conout
	LD A,(0B25H)		; 029BH  lda column
	AND 07H		; 029EH  ani 7 ; column mod 8
	JP NZ,0A96H		; 02A0H  jnz tab0 ; weiter bis Tabstop
	RET		; 02A3H
BACKUP:
	CALL 0AACH		; 02A4H  call pctlh ; Backspace
	LD C,20H		; 02A7H  mvi c,' '
	CALL 180CH		; 02A9H  call conoutf ; Leerzeichen (BIOS direkt)
PCTLH:
	LD C,08H		; 02ACH  mvi c,ctlh (08H)
	JP 180CH		; 02AEH  jmp conoutf ; nochmal Backspace
CRLFP:
	LD C,23H		; 02B1H  mvi c,'#'
	CALL 0A48H		; 02B3H  call conout
	CALL 0AC9H		; 02B6H  call crlf
CRLFP0:
	LD A,(0B25H)		; 02B9H  lda column
	LD HL,0B24H		; 02BCH  lxi h,strtcol ; Startposition
	CP (HL)		; 02BFH  cmp m ; Ziel erreicht?
	RET NC		; 02C0H  ret nc
	LD C,20H		; 02C1H  mvi c,' '
	CALL 0A48H		; 02C3H  call conout
	JP 0AB9H		; 02C6H  jmp crlfp0 ; weiter auffuellen
CRLF:
	LD C,0DH		; 02C9H  mvi c,cr (0DH)
	CALL 0A48H		; 02CBH  call conout
	LD C,0AH		; 02CEH  mvi c,lf (0AH)
	JP 0A48H		; 02D0H  jmp conout
PRINT:
	LD A,(BC)		; 02D3H  ldax b ; Zeichen holen
	CP 24H		; 02D4H  cpi '$' ; Ende?
	RET Z		; 02D6H  ret z
	INC BC		; 02D7H  inx b
	PUSH BC		; 02D8H  push b
	LD C,A		; 02D9H  mov c,a
	CALL 0A90H		; 02DAH  call tabout ; Zeichen ausgeben
	POP BC		; 02DDH  pop b
	JP 0AD3H		; 02DEH  jmp print ; naechstes Zeichen

; --- Funktions-Handler (func1..func11, sta$ret, func$ret) ---
FUNC1:
	CALL 0A06H		; 02E1H  call conech ; Zeichen mit Echo
	JP 0B1AH		; 02E4H  jmp sta$ret ; -> Rueckgabe
FUNC3:
	CALL 1815H		; 02E7H  call readerf ; BIOS: Reader-Zeichen
	JP 0B1AH		; 02EAH  jmp sta$ret
FUNC6:
	LD A,C		; 02EDH  mov a,c ; Func 6: Direct I/O
	INC A		; 02EEH  inr a ; FFH -> 00 = Eingabe?
	JP Z,0AF9H		; 02EFH  jz dirinp
	INC A		; 02F2H  inr a ; FEH -> 00 = Status?
	JP Z,1806H		; 02F3H  jz constf ; BIOS: Status
	JP 180CH		; 02F6H  jmp conoutf ; direkte Ausgabe
DIRINP:
	CALL 1806H		; 02F9H  call constf ; Status pruefen
	OR A		; 02FCH  ora a
	JP Z,13F5H		; 02FDH  jz func$ret ; kein Zeichen -> 0 zurueck
	CALL 1809H		; 0300H  call coninf ; Zeichen holen
	JP 0B1AH		; 0303H  jmp sta$ret
FUNC7:
	LD A,(0003H)		; 0306H  lda ioloc (0003H)
	JP 0B1AH		; 0309H  jmp sta$ret
FUNC8:
	LD HL,0003H		; 030CH  lxi h,ioloc (0003H)
	LD (HL),C		; 030FH  mov m,c ; IOBYTE setzen
	RET		; 0310H
FUNC9:
	EX DE,HL		; 0311H  xchg ; HL = info
	LD C,L		; 0312H  mov c,l
	LD B,H		; 0313H  mov b,h ; BC = info
	JP 0AD3H		; 0314H  jmp print ; String ausgeben
FUNC11:
	CALL 0A23H		; 0317H  call conbrk ; Status pruefen
STA_RET:
	LD (0B5EH),A		; 031AH  sta aret ; Ergebnis speichern
FUNC_RET:
	RET		; 031DH
SETLRET1:
	LD A,01H		; 031EH  mvi a,1
	JP 0B1AH		; 0320H  jmp sta$ret

; --- BDOS-Variablenbereich + lokaler Stack ---
COMPCOL:
; --- BDOS-Variablen + lokaler Stack (compcol..lstack) ---
	DS	61		; 0323H-035FH: BDOS-Variablen + lokaler Stack (compcol..lstack)

; --- Disk-Routinen (CP/M 2.2: goerr..mergezero) ---
; Low-Level Disk-I/O mit DPB-Verwaltung, Verzeichnis-Zugriff,
; Allokations-Verwaltung und FCB-Operationen.
GOERR:
	LD HL,090BH		; 0360H  goerr: indirekte Fehleraufruf-Routine
	LD E,(HL)		; 0363H
	INC HL		; 0364H
	LD D,(HL)		; 0365H
	EX DE,HL		; 0366H
	JP (HL)		; 0367H
MOVE:
	INC C		; 0368H  move: Speicherblock kopieren (C Bytes, DE->HL)
	DEC C		; 0369H
	RET Z		; 036AH
	LD A,(DE)		; 036BH
	LD (HL),A		; 036CH
	INC DE		; 036DH
	INC HL		; 036EH
	JP 0B69H		; 036FH  -> L0B69
SELECTDISK:
	LD A,(0B5BH)		; 0372H  selectdisk: Laufwerk auswaehlen, DPB laden
	LD C,A		; 0375H
	CALL 181BH		; 0376H
	LD A,H		; 0379H
	OR L		; 037AH
	RET Z		; 037BH
	LD E,(HL)		; 037CH
	INC HL		; 037DH
	LD D,(HL)		; 037EH
	INC HL		; 037FH
	LD (1406H),HL		; 0380H
	INC HL		; 0383H
	INC HL		; 0384H
	LD (1408H),HL		; 0385H
	INC HL		; 0388H
	INC HL		; 0389H
	LD (140AH),HL		; 038AH
	INC HL		; 038DH
	INC HL		; 038EH
	EX DE,HL		; 038FH
	LD (1423H),HL		; 0390H
	LD HL,140CH		; 0393H
	LD C,08H		; 0396H
	CALL 0B68H		; 0398H  -> L0B68
	LD HL,(140EH)		; 039BH
	EX DE,HL		; 039EH
	LD HL,1414H		; 039FH
	LD C,0FH		; 03A2H
	CALL 0B68H		; 03A4H  -> L0B68
	LD HL,(1419H)		; 03A7H
	LD A,H		; 03AAH
	LD HL,1430H		; 03ABH
	LD (HL),0FFH		; 03AEH
	OR A		; 03B0H
	JP Z,0BB6H		; 03B1H
	LD (HL),00H		; 03B4H
	LD A,0FFH		; 03B6H
	OR A		; 03B8H
	RET		; 03B9H
HOME:
	CALL 1818H		; 03BAH  home: Kopf auf Spur 0
	XOR A		; 03BDH
	LD HL,(1408H)		; 03BEH
	LD (HL),A		; 03C1H
	INC HL		; 03C2H
	LD (HL),A		; 03C3H
	LD HL,(140AH)		; 03C4H
	LD (HL),A		; 03C7H
	INC HL		; 03C8H
	LD (HL),A		; 03C9H
	RET		; 03CAH
RDBUFF:
	CALL 1827H		; 03CBH  rdbuff: Sektor lesen mit Fehlerpruefung
	JP 0BD4H		; 03CEH  -> L0BD4
WRBUFF:
	CALL 182AH		; 03D1H  wrbuff: Sektor schreiben mit Fehlerpruefung
	OR A		; 03D4H
	RET Z		; 03D5H
	LD HL,0909H		; 03D6H
	JP 0B63H		; 03D9H  -> L0B63
SEEK:
	LD HL,(143DH)		; 03DCH  seek: Spur/Sektor aus Recordnummer berechnen
	LD C,02H		; 03DFH
	CALL 0D03H		; 03E1H
	LD (1438H),HL		; 03E4H
	LD (143FH),HL		; 03E7H
	LD HL,1438H		; 03EAH
	LD C,(HL)		; 03EDH
	INC HL		; 03EEH
	LD B,(HL)		; 03EFH
	LD HL,(140AH)		; 03F0H
	LD E,(HL)		; 03F3H
	INC HL		; 03F4H
	LD D,(HL)		; 03F5H
	LD HL,(1408H)		; 03F6H
