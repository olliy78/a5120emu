	DS	14		; 0C33H-0C40H: Arbeitsbereich
DISK_INIT_A:
	LD A,0FFH		; 0C41H
	LD (1432H),A		; 0C43H
	JP 12F5H		; 0C46H
DISK_INIT_B:
