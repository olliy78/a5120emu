L0BFD:
	LD B,H		; 0BFDH
	RET		; 0BFEH

; --- BDOS-Arbeitsbereich (Variablen, Disk-Parameter) ---
BDOS_WORKSPACE:
; --- BDOS-Arbeitsbereich (Variablen/Puffer) ---
	DB	0E5H		; 0BFFH: initialisierter Wert (E5H = CP/M empty flag)
	DS	4		; 0C00H-0C03H: Arbeitsbereich
	DB	80H		; 0C04H: initialisierter Wert
	DS	45		; 0C05H-0C31H: Arbeitsbereich
