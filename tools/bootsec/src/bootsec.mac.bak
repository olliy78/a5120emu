; --- FDC-Fehlermeldungs-Vorlage (13B8H-13CFH) ---
; Formatstring fuer FDC-Fehlerausgabe:
;   0DH,0AH = CR/LF
;   "XX;T,Si,Se=XXXXXX" = Fehlercode, Track, Side, Sector
;   07H = BEL (Piepston)
; Die 'X'-Platzhalter werden zur Laufzeit durch die aktuellen
; Werte aus 1EB3H-1EB5H (Track/Side/Sector) ersetzt.
	DB	0C1H,0C9H,0DH,0AH,58H,58H,3BH,54H	; 13B8: ....XX;T
	DB	2CH,53H,69H,2CH,53H,65H,3DH,58H	; 13C0: ,Si,Se=X
	DB	58H,58H,58H,58H,58H,07H,00H,00H	; 13C8: XXXXX...

; --- FDC-Konfigurationsdaten (13D0H-13EFH) ---
; 13D0H-13D5H: Laufwerks-Initialisierungswerte (6x 0FFH = kein LW)
; 13D6H-13DDH: Standardkonfiguration (Adressen, Flags)
; 13DEH-13E5H: LDIR-Code-Fragment (0EDH,0B0H = LDIR; 0C9H = RET)
;   Wird dynamisch ausgefuehrt: kopiert Sektor-Daten aus Puffer.
; 13E6H-13EFH: weitere Konfig-Slots (alle 0FFH = uninitialisiert)
	DB	0FFH,0FFH,0FFH,0FFH,0FFH,0FFH	; 13D0
	DB	0AEH,21H,00H,00H,0FFH,0FFH,0FFH,00H	; 13D6: .!......
	DB	01H,0FFH,0FFH,0FFH,0FFH,00H,0EDH,0B0H	; 13DE: ........
	DB	0C9H,0FFH,0FFH,0FFH,0FFH,0FFH,0FFH,0FFH	; 13E6: ........
	DB	0FFH,0FFH	; 13EE: ..

; ======================================================================
; FDC-Treiber Fortsetzung (13F0H-16AFH)
; ======================================================================
; Enthaelt die Low-Level-Routinen des Floppy-Treibers:
;
;  13F0H-141AH: Retry-Zaehler Initialisierung
;    - Setzt ED5H (physische Retries) und ED6H (logische Retries)
;    - Prueft Laufwerks-Verfuegbarkeit via ED8H (Bitmap)
;    - Bei ungueltigem LW: Fehler 44H ("D")
;
;  141BH-146DH: Motor-Start und Laufwerksauswahl
;    - Setzt Motor-Enable-Bit fuer Port 18H (Motor-Steuerung)
;    - Wartet auf Motorhochlauf (Polling E78H = Index-Zaehler)
;    - Bei Timeout: Fehler 52H ("R" = Ready)
;
;  146EH-14F1H: FDC-Kommandoaufbau und Seek-Vorbereitung
;    - Laedt Sektortabelle aus EEEH (FM) / EF5H (MFM) / EFCH (5.25")
;    - Kopiert Timing-Parameter in FDC-Steuerbereich
;    - Spur-Vergleich (EDAH = aktuelle Position)
;    - Seek bei Abweichung via Routine 14F2H (Step)
;
;  14F2H-1513H: Step-Routine
;    - Sendet Step-Impulse an FDC Port 10H (flcoad)
;    - DI waehrend Step-Puls (Bit 7 toggle)
;    - Wartet via Delay-Schleife (EB9H = Step-Rate)
;
;  1514H-1532H: Spur-0-Suche (Recalibrate)
;    - Prueft Track-0-Signal via IN 12H (AMF PIOB, Bit 0)
;    - Maximal 2 Versuche, danach Seek ab Spur 0
;
;  1533H-15B7H: Sektor-I/O (der eigentliche Lese/Schreib-Kern)
;    - Wartet auf Motor-Bereitschaft (Delay 32H)
;    - Setzt Sektornummer, Spuradresse und Seitenwahl
;    - Konfiguriert PIO-Port B (12H/16H) fuer Datenrichtung
;    - Modifiziert FDC-Befehlstabelle dynamisch (1F29H Eintraege)
;    - Ruft Format-spezifische I/O-Routine auf (FFD1H/1FE3H)
;    - Prueft Index-Signal und startet I/O bei naechster Umdrehung
;
;  15B8H-1606H: Fehler-Handler
;    - 15C4H: CRC-Pruefung (liest EB0H Checksumme)
;    - 15DAH: Retry-Schleife (ED5H physisch, ED6H logisch)
;    - Fehler 43H ("C" = CRC), 53H ("S" = Seek), 55H ("U" = Unknown)
;    - Bei Retry: Home (8FH) oder Step-In (AFH) + erneut lesen
;
;  1608H-1629H: Puffer-Kopierer und Adressfeld-Vergleich
;    - 1608H: Tabellen-gesteuerter Speicherkopierer
;    - 1620H: Prueft Adressfeld (Spur+Seite gegen 1EBA-Block)
;
;  162AH-1666H: CRC-16-Berechnung (CCITT-Polynom)
;    - Software-CRC16 mit XOR/Shift-Algorithmus
;    - DE = laufende CRC, B = Byte-Zaehler,  HL = Daten-Zeiger
;
;  1667H-168FH: SIO-Interrupt-Setup und IRQ-Handler
;    - 1667H: SIO-Baudrate setzen via Port 11H
;    - 166FH: FDC-ISR: Stack-Wechsel, Zaehler dekrementieren,
;      bei Timeout Motor-Stop + Flag setzen
;
;  1692H-16AEH: Cleanup nach I/O-Abschluss
;    - SIO A Reset (Port 11H), alle Motoren aus (Port 18H)
;    - Spur-Position in Laufwerkstabelle (EDBH[LW]) sichern
	LD	A,(1EAFH)		; 13F0
	AND	01H		; 13F3
	JR	NZ,13F9H		; 13F5
	LD	A,10H		; 13F7
	LD	(1ED5H),A		; 13F9
	JR	NZ,1400H		; 13FC
	LD	A,05H		; 13FE
	LD	(1ED6H),A		; 1400
	LD	A,(1EB2H)		; 1403
