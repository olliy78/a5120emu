	JR	C,14E8H		; 14E1
	LD	A,54H		; 14E3
	JP	1DABH		; 14E5
	LD	B,0AFH		; 14E8
	INC	(HL)		; 14EA
	INC	(HL)		; 14EB
	DEC	(HL)		; 14EC
	CALL	1CF2H		; 14ED
	JR	14D2H		; 14F0
	LD	A,(1EB8H)		; 14F2
	LD	C,10H		; 14F5
	OUT	(C),B		; 14F7
	PUSH	BC		; 14F9
	RES	7,B		; 14FA
	DI		; 14FC
	OUT	(C),B		; 14FD
	SET	7,B		; 14FF
	OUT	(C),B		; 1501
	EI		; 1503
	LD	BC,(1EB9H)		; 1504
	LD	B,13H		; 1508
	DJNZ	150AH		; 150A
	DEC	C		; 150C
	JR	NZ,1508H		; 150D
	POP	BC		; 150F
	DEC	A		; 1510
	JR	NZ,14F9H		; 1511
	RET		; 1513
	LD	B,02H		; 1514
	PUSH	BC		; 1516
	LD	B,0AFH		; 1517
	CALL	1CF2H		; 1519
	POP	BC		; 151C
	DJNZ	1516H		; 151D
	IN	A,(12H)		; 151F
	RLCA		; 1521
	JR	NC,152DH		; 1522
	LD	B,8FH		; 1524
	LD	A,01H		; 1526
	CALL	1CF5H		; 1528
	JR	151FH		; 152B
	XOR	A		; 152D
	LD	(1EDAH),A		; 152E
	JR	14D2H		; 1531
	LD	A,32H		; 1533
	LD	B,0BDH		; 1535
	DJNZ	1537H		; 1537
	DEC	A		; 1539
	JR	NZ,1535H		; 153A
	LD	A,(1EB7H)		; 153C
	LD	(1F85H),A		; 153F
	LD	(1E1AH),A		; 1542
	LD	A,(1EB3H)		; 1545
	LD	(1F8CH),A		; 1548
	LD	HL,1EB8H		; 154B
	BIT	0,(HL)		; 154E
	JR	Z,1553H		; 1550
	ADD	A,A		; 1552
	LD	BC,0412H		; 1553
	CP	19H		; 1556
	JR	C,155CH		; 1558
	SET	3,B		; 155A
	OUT	(C),B		; 155C
	LD	A,(1EB5H)		; 155E
	LD	(1F8FH),A		; 1561
	LD	A,(1EB4H)		; 1564
	LD	(1F8DH),A		; 1567
	LD	A,(1EAFH)		; 156A
	LD	HL,1F29H		; 156D
	LD	B,(HL)		; 1570
	INC	HL		; 1571
	LD	E,(HL)		; 1572
	INC	HL		; 1573
	LD	D,(HL)		; 1574
	EX	DE,HL		; 1575
	BIT	7,A		; 1576
	JR	Z,157EH		; 1578
	RES	2,(HL)		; 157A
	JR	1580H		; 157C
	SET	2,(HL)		; 157E
	EX	DE,HL		; 1580
	DJNZ	1571H		; 1581
	LD	A,(1EAFH)		; 1583
	BIT	1,A		; 1586
	LD	HL,1F7DH		; 1588
	JR	Z,1590H		; 158B
	LD	HL,1FE3H		; 158D
	LD	(1F3DH),HL		; 1590
	LD	HL,2038H		; 1593
	LD	(1FE1H),HL		; 1596
	IN	A,(12H)		; 1599
	RRA		; 159B
	JR	C,1599H		; 159C
	LD	A,05H		; 159E
	CALL	1E67H		; 15A0
	LD	A,(1EB7H)		; 15A3
	OR	A		; 15A6
	JP	NZ,1F36H		; 15A7
	XOR	A		; 15AA
	PUSH	AF		; 15AB
	LD	HL,1E80H		; 15AC
	LD	(HL),0BH		; 15AF
	LD	A,14H		; 15B1
	CALL	1E67H		; 15B3
	POP	AF		; 15B6
	RET		; 15B7
	LD	HL,1EAFH		; 15B8
	BIT	6,(HL)		; 15BB
	JR	Z,15AAH		; 15BD
	RES	2,(HL)		; 15BF
	JP	1D3CH		; 15C1
	LD	HL,(1EB0H)		; 15C4
	LD	IX,1EBAH		; 15C7
	CALL	1E2AH		; 15CB
	CALL	1E20H		; 15CE
	JR	NZ,15DAH		; 15D1
	CALL	1E15H		; 15D3
	JR	NZ,15CBH		; 15D6
	JR	15AAH		; 15D8
	LD	HL,1ED5H		; 15DA
	DEC	(HL)		; 15DD
	JP	NZ,1D3CH		; 15DE
	LD	A,43H		; 15E1
	JR	15ABH		; 15E3
	LD	HL,1ED6H		; 15E5
	DEC	(HL)		; 15E8
	JR	Z,1600H		; 15E9
	LD	A,02H		; 15EB
	CP	(HL)		; 15ED
	JP	C,1D14H		; 15EE
	LD	B,8FH		; 15F1
	JR	Z,15FAH		; 15F3
	LD	B,0AFH		; 15F5
	CALL	1CF2H		; 15F7
	CALL	1CF2H		; 15FA
	JP	1D33H		; 15FD
	LD	A,53H		; 1600
	JR	15ABH		; 1602
	LD	A,55H		; 1604
	JR	15ABH		; 1606
	LD	B,(HL)		; 1608
	INC	HL		; 1609
	PUSH	BC		; 160A
	LD	C,(HL)		; 160B
	INC	HL		; 160C
	LD	B,(HL)		; 160D
	LD	A,(DE)		; 160E
	INC	DE		; 160F
	LD	(BC),A		; 1610
	POP	BC		; 1611
	DJNZ	1609H		; 1612
	RET		; 1614
	INC	IX		; 1615
	INC	IX		; 1617
	LD	A,0FFH		; 1619
	DEC	A		; 161B
	LD	(1E1AH),A		; 161C
	RET		; 161F
	LD	A,(IX+0)		; 1620
	CP	D		; 1623
	RET	NZ		; 1624
	LD	A,(IX+1)		; 1625
	CP	E		; 1628
	RET		; 1629
	LD	DE,0CDB4H		; 162A
	PUSH	IX		; 162D
	EX	(SP),HL		; 162F
	LD	B,01H		; 1630
	CALL	1E44H		; 1632
	EX	(SP),HL		; 1635
	POP	IX		; 1636
	LD	B,01H		; 1638
	PUSH	BC		; 163A
	LD	B,80H		; 163B
	CALL	1E44H		; 163D
	POP	BC		; 1640
	DJNZ	163AH		; 1641
	RET		; 1643
; --- CRC-16-Berechnung (CCITT-Polynom 1021H) ---
; Eingabe: HL = Daten, B = Anzahl Bytes, DE = Start-CRC
; Ausgabe: DE = berechnete CRC-16
	LD	A,(HL)		; 1644: Datenbyte laden
	XOR	D		; 1645: XOR mit CRC High-Byte
	LD	D,A		; 1646
	RRCA		; 1647: 4x rotieren (Nibble-Swap)
	RRCA		; 1648
	RRCA		; 1649
	RRCA		; 164A
	AND	0FH		; 164B: unteres Nibble isolieren
	XOR	D		; 164D: XOR mit CRC
	LD	D,A		; 164E
	RRCA		; 164F: weitere Shifts
	RRCA		; 1650
	RRCA		; 1651
	LD	C,A		; 1652: Zwischenwert
	AND	1FH		; 1653
	XOR	E		; 1655: XOR mit CRC Low-Byte
	LD	E,A		; 1656
	LD	A,C		; 1657
	RRCA		; 1658
	AND	0F0H		; 1659
	XOR	E		; 165B
	LD	E,A		; 165C
	LD	A,C		; 165D
	AND	0E0H		; 165E
	XOR	D		; 1660
	LD	D,E		; 1661: CRC-Bytes tauschen
	LD	E,A		; 1662
	INC	HL		; 1663: naechstes Datenbyte
	DJNZ	1644H		; 1664: Schleife
	RET		; 1666
; --- SIO-Baudrate setzen (1667H) ---
	LD	(1E78H),A		; 1667: Baudrate speichern
	LD	A,83H		; 166A: SIO-Konfigurationswert
	OUT	(11H),A		; 166C: -> flcoac (SIO A Control)
	RET		; 166E
; --- FDC-Interrupt-Handler (166FH) ---
; Wird per IM 2 angesprungen. Dekrementiert Index-Zaehler,
; bei Timeout: Motor aus + Flag setzen.
	LD	(20B7H),SP		; 166F: SP auf FDC-Stack retten
	LD	SP,25D6H		; 1673: eigener ISR-Stack
	PUSH	AF		; 1676
	LD	A,00H		; 1677: (wird gepatcht: Index-Zaehler)
	DEC	A		; 1679: Zaehler -1
	LD	(1E78H),A		; 167A: zurueckspeichern
	JR	NZ,168FH		; 167D: noch nicht 0 -> RETI
	JR	168CH		; 167F: -> Timeout-Behandlung
; --- Motor-Stop bei Index-Timeout ---
	LD	A,0A9H		; 1681: FDC: Motor aus (Head unload)
	OUT	(10H),A		; 1683: -> flcoad
	LD	A,00H		; 1685: Timeout-Flag loeschen
	LD	(1F6DH),A		; 1687: -> FDC-Timeout-Status
	JR	168FH		; 168A
	CALL	1E92H		; 168C: -> Fehlerbehandlung
	JP	20B5H		; 168F: -> Stack restaurieren + RETI
; --- Cleanup: SIO Reset + Motor aus + Track speichern (1692H) ---
	LD	A,03H		; 1692: SIO-Reset
	OUT	(11H),A		; 1694: -> flcoac
	LD	A,0FFH		; 1696: alle Motoren aus
	OUT	(18H),A		; 1698: -> Motor-Port
	PUSH	HL		; 169A
	PUSH	BC		; 169B
	LD	HL,1ED9H		; 169C: aktuelles Laufwerk
	RES	3,(HL)		; 169F: Busy-Bit loeschen
	LD	C,(HL)		; 16A1: C = Laufwerksnummer
	LD	B,00H		; 16A2
	LD	HL,1EDBH		; 16A4: Track-Tabelle Basis
	ADD	HL,BC		; 16A7: + Laufwerksnummer
	LD	A,(1EDAH)		; 16A8: aktuelle Spurposition
	LD	(HL),A		; 16AB: in Track-Tabelle speichern
	POP	BC		; 16AC
	POP	HL		; 16AD
	RET		; 16AE
	NOP		; 16AF

; --- FDC-Konfigurations-Tabelle (16B0H-16DFH) ---
; 16B0H-16B9H: Fuellbereich (10 Bytes 00H)
; 16BAH-16D4H: Laufwerks-Status und Medientyp-Cache
;   (4x 7 Bytes: je ein Eintrag pro Laufwerk A:-D:)
;   FFh = nicht initialisiert/kein Medium
; 16D5H-16DFH: Weitere Fuellbytes + Konfigurationsbyte 07H
	DS	10,00H		; 16B0: Fuellbytes
	DB	0FFH,0FFH,0FFH,0FFH,0FFH,0FFH,0FFH,0FFH	; 16BA
	DB	0FFH,0FFH,0FFH,0FFH,0FFH,0FFH,0FFH,0FFH	; 16C2
	DB	0FFH,0FFH,0FFH,0FFH,0FFH,0FFH,0FFH,0FFH	; 16CA
	DB	0FFH,0FFH,0FFH	; 16D2
	DS	10,00H		; 16D5: Fuellbytes
	DB	07H	; 16DF: .

; --- Interrupt-Vektoren und Parameter (16E0H-1737H) ---
; 16E0H-16EFH: Interrupt-Vektor-Tabelle (8 Eintraege a 2 Bytes)
;   Zeigen auf ISR-Routinen im FDC-Treiber:
;   1FAEH, 1FD9H, 1E2BH, 1E2CH, 1D55H, 1D57H, 1D9DH, 1185H
; 16F0H-1709H: FDC-Initialisierungssequenz
;   Enthaelt PIO-Init-Bytes, SIO-Konfiguration,
;   Format-Erkennungsmuster (B4H,CDH Prefixes)
; 170AH-1737H: Sektortabelle und Timing-Parameter
;   - 170AH: JP-Adressen fuer Sektor-I/O-Dispatch
;     (1E39H, 2049H, 2055H, 2058H, 205BH)
;   - 1714H: Sektor-Interleave-Tabellen fuer FM und MFM
;     01H,80H = 128B/Sektor FM; 02H,00H = 256B/Sektor FM
;     04H,00H = 1024B/Sektor MFM; 08H,00H = 2048B (unused)
;   - 172EH: Zeiger auf Format-Deskriptoren (1FAEH, 1F5AH, ...)
	DB	0AEH,1FH,0D9H,1FH,2BH,1EH,2CH,1EH	; 16E0: ....+.,.
	DB	55H,1DH,57H,1DH,9DH,1DH,85H,11H	; 16E8: U.W.....
	DB	0B4H,0CDH,10H,0FFH,00H,85H,11H,0B4H	; 16F0: ........
	DB	0CDH,04H,19H,0FBH,87H,06H,0FFH,0FFH	; 16F8: ........
	DB	04H,0FFH,00H,87H,06H,0FFH,0FFH,00H	; 1700: ........
	DB	19H,0FBH,05H,39H,1EH,49H,20H,55H	; 1708: ...9.I U
	DB	20H,58H,20H,5BH,20H,01H,80H,0A2H	; 1710:  X [ ...
	DB	0A2H,0A2H,02H,00H,0A2H,0A2H,0A2H,04H	; 1718: ........
	DB	00H,0A2H,0A2H,0B2H,08H,00H,0B2H,0B2H	; 1720: ........
	DB	0B2H,06H,0AEH,1FH,5AH,1FH,0AAH,1FH	; 1728: ....Z...
	DB	9AH,1FH,41H,20H,64H,20H,2AH,0B0H	; 1730: ..A d *.

; --- FDC Low-Level: PIO-Init, Sync-Suche, DMA (1738H-17FFH) ---
; 1738H-176BH: PIO/SIO-Hardware-Initialisierung
;   - Setzt Port 14H (CTC), Port 04H (PIO Mode), Port 17H (PIO Data)
;   - Konfiguriert FDC-Steuerregister (B9H, A5H Kommandos)
;   - Sichert und restauriert Interrupt-Vektor bei (0001H)
;
; 176EH-177AH: Sprung-Tabelle (5 JP-Eintraege)
;   Dispatcher fuer verschiedene I/O-Modi:
;   JP 1E04H, JP 1DAAH, JP 1DE5H, JP 1DC4H, JP 1DB8H
;
; 177DH-17A3H: MFM-Sync-Suche (Format-Erkennung)
;   - Sucht nach MFM-Sync-Muster (A1H,FEH) auf der Spur
;   - Zaehlt Sync-Byte-Paare, vergleicht mit erwartetem Muster
;   - ED7H = Timeout-Zaehler (max. Umdrehungen)
;   - Bei Erfolg: Adressfeld lesen via INIR
;
; 17A4H-17FFH: FM-Sync-Suche und Sektor-Lesen
;   - Sendet FDC-Kommando B5H (Reset) + 85H (Read)
;   - Wartet auf Sync-Byte (A1H/FEH je nach FM/MFM)
;   - INIR fuer Daten-Transfer in 1EBA-Puffer
;   - EXX-basiertes Double-Buffering (wie bei Boot-Sektor-Leser)
	LD	E,22H		; 1738
	ADD	A,D		; 173A
	RRA		; 173B
	LD	HL,1F7DH		; 173C
	LD	BC,(0001H)		; 173F
	LD	(0001H),HL		; 1743
	LD	A,0FEH		; 1746
	LD	(1F6DH),A		; 1748
	XOR	A		; 174B
	OUT	(14H),A		; 174C
	OUT	(04H),A		; 174E
	DEC	A		; 1750
	OUT	(17H),A		; 1751
	OUT	(17H),A		; 1753
	LD	A,0B9H		; 1755
	OUT	(10H),A		; 1757
	LD	A,0A5H		; 1759
	OUT	(10H),A		; 175B
	LD	A,7FH		; 175D
	OUT	(17H),A		; 175F
	IN	A,(16H)		; 1761
	LD	(0001H),BC		; 1763
	LD	A,(1FAEH)		; 1767
	OUT	(10H),A		; 176A
	JR	176CH		; 176C
	JP	1E04H		; 176E
	JP	1DAAH		; 1771
	JP	1DE5H		; 1774
	JP	1DC4H		; 1777
	JP	1DB8H		; 177A
	XOR	A		; 177D
	LD	(1FB6H),A		; 177E
	LD	HL,0000H		; 1781
	LD	A,00H		; 1784
	EX	AF,AF'		; 1786
	LD	DE,1EBAH		; 1787
	EXX		; 178A
	LD	BC,00FFH		; 178B
	LD	HL,0FFFFH		; 178E
	LD	DE,0FEA1H		; 1791
	LD	A,3CH		; 1794
	LD	(1ED7H),A		; 1796
	LD	A,0BDH		; 1799
	OUT	(10H),A		; 179B
	JR	17B1H		; 179D
	LD	A,3CH		; 179F
	LD	(1ED7H),A		; 17A1
	LD	A,05H		; 17A4
	LD	(1E78H),A		; 17A6
	LD	A,0B5H		; 17A9
	OUT	(10H),A		; 17AB
	LD	A,85H		; 17AD
	OUT	(10H),A		; 17AF
	IN	A,(16H)		; 17B1
	OUT	(14H),A		; 17B3
	JR	17B7H		; 17B5
	IN	A,(16H)		; 17B7
	CP	E		; 17B9
	JR	Z,17B7H		; 17BA
	CP	D		; 17BC
	IN	A,(16H)		; 17BD
	JR	NZ,17A9H		; 17BF
	CP	C		; 17C1
	IN	A,(16H)		; 17C2
	JR	NZ,1823H		; 17C4
	CP	B		; 17C6
	IN	A,(16H)		; 17C7
	JR	NZ,1823H		; 17C9
	CP	L		; 17CB
	IN	A,(16H)		; 17CC
	JR	NZ,1823H		; 17CE
	CP	H		; 17D0
	IN	A,(16H)		; 17D1
	JR	NZ,1823H		; 17D3
	EXX		; 17D5
	IN	A,(16H)		; 17D6
	LD	B,11H		; 17D8
	IN	A,(16H)		; 17DA
	DJNZ	17DAH		; 17DC
	IN	A,(16H)		; 17DE
	JP	2038H		; 17E0
	LD	A,39H		; 17E3
	LD	(1FB6H),A		; 17E5
	LD	BC,0316H		; 17E8
	LD	HL,1EB4H		; 17EB
	JR	178AH		; 17EE
	IN	A,(16H)		; 17F0
	CP	E		; 17F2
	JR	Z,17F0H		; 17F3
	CP	D		; 17F5
	IN	A,(16H)		; 17F6
	JR	NZ,17A9H		; 17F8
	EXX		; 17FA
	INIR		; 17FB
	EXX		; 17FD
	LD	L,A		; 17FE
	DB	3AH		; 17FF: (unbekannter Opcode)

; ======================================================================
; WARM_BIOS: Warmstart- und Initialisierungs-Code (1800H-19BBH)
; ======================================================================
; Dieser Bereich enthaelt zwei funktionale Bloecke:
;
; --- Block 1: FDC Sektor-Lese-Fortsetzung (1800H-187BH) ---
; Wird als Teil der MFM/FM-Sektor-Leselogik erreicht (von 17xxH).
; Enthaelt:
;  1800H-1838H: Spurvergleich und Header-Verifikation
;    - Prueft ob gelesene Spur (EB3H/EB4H) mit Erwartung stimmt
;    - Bei Abweichung: Retry oder Abbruch mit Fehlercode
;  1838H-187BH: Sektor-Daten-Transfer
;    - Liest Gap-Bytes, wartet auf Datenmarke (A1H)
;    - INI/INIR fuer Datentransfer (Spur+Seite+Sektor+Daten)
;    - CRC-Bytes lesen (2x INI nach Datenblock)
;    - Dekrement Umdrehungszaehler, bei 0: naechste Spur
;
; --- Block 2: BIOS-Hilfsroutinen (187CH-19BBH) ---
;  187CH-1886H: String-Ausgabe (NUL-terminiert via CONOUT-Schleife)
;  1888H-1893H: Delay-Routine (verschachtelte Schleifen)
;  1894H-18AAH: Hex-Ausgabe (Byte in 2 ASCII-Hex-Ziffern wandeln)
;  18ABH-18B1H: Adressfeld-Setup (HL=1833H, IX=1843H fuer ISR-Vektoren)
;  18B2H-18B4H: CONOUT-Einstieg (prueft HL auf 0, RET wenn leer)
;  18B5H-18BBH: Stack-Wiederherstellung: POP AF, LD SP, EI, RETI
;
;  18BCH-18EEH: Hardware-Grundinitialisierung (WARM_INIT)
;    - DI + Suche nach dem eigenen Slot via Port 03FCH/0EEH
;    - Ergebnis in B -> wird als Laufwerksnummer gespeichert
;    - PIO Port B (0BH): Konfiguration FFH/E2H (Mode 3, Bitmaske)
;    - PIO Port A (0AH): Bits 1,3 zuruecksetzen (Motor aus)
;    - SIO A+B (09H-0FH): Reset-Kommando 03H an alle Kanaele
;    - CTC Kanal 0 (40H): Reset-Kommando 03H
;
;  18F0H-1905H: Stack und Interrupt-Setup
;    - SP = 0080H (CP/M-Standard TPA-Anfang)
;    - I = 26H -> Interrupt-Page bei 2600H (IM 2)
;    - Laufwerk A: = 0 in CDISK (0004H)
;    - Prueft AMF Port A Bit 6: wenn gesetzt -> ueberspringe Display-Init
;
;  1906H-1941H: A5120 Display-Konfiguration
;    - Setzt Memory-Mapped-Video-Adressen fuer CONOUT:
;      81H/FF30H/FF2FH (Alpha-Zeilen-Adressen)
;      F850H/F800H (Bildschirm-Basisadresse, 64x25 Zeichen)
;      0730H (Zeichensatz-ROM), FF7EH/004FH (Cursor-Grenzen)
;    - Selbstmodifizierender Code: LD (xxxxH),HL-Befehle patchen
;      die CONOUT-Routine mit diesen Hardware-Adressen
;
;  1942H-19A3H: FDC-Initialisierung und Laufwerks-Scan
;    - Setzt SIO-Interrupt-Vektor bei 26E8H -> 1E6FH (FDC-ISR)
;    - SIO A: Konfiguration E8H/7FH (Interrupt-Enable, Vektor)
;    - PIO Port B (17H): Output-Mode 7FH, dann IN 16H (Flush)
;    - FDC Reset: FDH -> Port 10H (flcoad)
;    - SIO A: 3FH an Port 11H + 15H (Error Reset + Init)
;    - SIO B: FFH/F3H an Port 13H (Reset + Rx Enable)
;    - Laufwerks-Scan: 4 Laufwerke (C=04H)
;      Rotiert Motor-Enable-Bit (Port 18H), testet Ready (Port 12H Bit 0)
;      Step-Pulse (5FH/DFH an Port 10H) mit Delay
;      Setzt Bit 6 in D wenn Laufwerk antwortet, dann RRC D
;      Ergebnis (1ED8H): Bitmap der erkannten Laufwerke
;    - Alle Motoren aus (FFH -> Port 18H)
;    - Track-Tabelle (EDBH..EDEH) auf 00H initialisieren
;
;  19ADH-19BBH: Warmstart-Abschluss
;    - LD (1801H),HL = 08AFH -> patcht BIOS WBOOT auf RET-Stub
;      (beim Warmstart genuegt der Stub, da OS bereits geladen)
;    - Gibt Boot-Meldung aus: \"CP/A-Bootsystem, Version 05.04.88 ...\"
;    - JP 1890H -> GOCPM (BDOS-Patch + CCP-Start)
	XOR	D		; 1800
	RRA		; 1801
	OUT	(10H),A		; 1802
	LD	A,L		; 1804
	CP	C		; 1805
	JR	Z,1811H		; 1806
	LD	A,(1EB4H)		; 1808
	SUB	B		; 180B
	JR	NZ,1819H		; 180C
	CP	C		; 180E
	JR	Z,1834H		; 180F
	LD	A,L		; 1811
	LD	(1EB3H),A		; 1812
	LD	A,03H		; 1815
	JR	1875H		; 1817
	EXX		; 1819
	LD	BC,0316H		; 181A
	LD	HL,1EB4H		; 181D
	EXX		; 1820
	JR	182AH		; 1821
	IN	A,(16H)		; 1823
	LD	A,(1FAAH)		; 1825
	OUT	(10H),A		; 1828
	LD	A,(1ED7H)		; 182A
	DEC	A		; 182D
	LD	(1ED7H),A		; 182E
	JP	NZ,1FA4H		; 1831
	LD	A,06H		; 1834
	JR	1875H		; 1836
	IN	A,(16H)		; 1838
	LD	B,06H		; 183A
	IN	A,(16H)		; 183C
	DJNZ	183CH		; 183E
	LD	A,0B5H		; 1840
	OUT	(10H),A		; 1842
	LD	A,(1FAEH)		; 1844
	LD	BC,8016H		; 1847
	OUT	(10H),A		; 184A
	IN	A,(16H)		; 184C
	IN	A,(16H)		; 184E
	CP	0A1H		; 1850
	JR	Z,184EH		; 1852
	INI		; 1854
	LD	(DE),A		; 1856
	INI		; 1857
	INC	DE		; 1859
	INI		; 185A
	INIR		; 185C
	EX	DE,HL		; 185E
	INI		; 185F
	INI		; 1861
	LD	A,0B5H		; 1863
	OUT	(10H),A		; 1865
	EX	DE,HL		; 1867
	LD	A,09H		; 1868
	EX	AF,AF'		; 186A
	DEC	A		; 186B
	JR	Z,1874H		; 186C
	EX	AF,AF'		; 186E
	EXX		; 186F
	INC	L		; 1870
	JP	1F9FH		; 1871
	EX	AF,AF'		; 1874
	LD	(1F6DH),A		; 1875
	JP	1F99H		; 1878
	RET		; 187B
; --- BIOS: String-Ausgabe (NUL-terminiert) ---
	LD	A,(HL)		; 187C: naechstes Zeichen
	OR	A		; 187D: NUL?
	RET	Z		; 187E: ja -> fertig
	PUSH	HL		; 187F
	LD	C,A		; 1880: C = Zeichen fuer CONOUT
	CALL	18B2H		; 1881: -> CONOUT
	POP	HL		; 1884
	INC	HL		; 1885: naechstes Zeichen
	JR	187CH		; 1886: Schleife
; --- BIOS: Delay-Routine ---
	PUSH	BC		; 1888
	LD	B,06H		; 1889: aeussere Schleife
	DEC	C		; 188B: innere Schleife
	JR	NZ,188BH		; 188C
	DJNZ	188BH		; 188E
	POP	BC		; 1890
	DJNZ	1888H		; 1891: bei B > 0 nochmal
	RET		; 1893
; --- BIOS: Byte in Hex-ASCII wandeln ---
	LD	A,(HL)		; 1894: Byte laden
	CALL	2098H		; 1895: oberes Nibble
	RRCA		; 1898: unteres Nibble
	RRCA		; 1899
	RRCA		; 189A
	RRCA		; 189B
	PUSH	AF		; 189C
	AND	0FH		; 189D: Nibble isolieren
	SUB	0AH		; 189F: >= A?
	JR	C,18A5H		; 18A1: nein -> '0'-'9'
	ADD	A,07H		; 18A3: ja -> 'A'-'F' (+ 7)
	ADD	A,3AH		; 18A5: + 3AH -> ASCII
	LD	(DE),A		; 18A7: im Puffer speichern
	INC	DE		; 18A8
	POP	AF		; 18A9
	RET		; 18AA
; --- BIOS: Adressfeld-Setup (ISR-Vektoren) ---
	LD	HL,1833H		; 18AB: ISR-Adresse 1
	LD	IX,1843H		; 18AE: ISR-Adresse 2
; --- BIOS: CONOUT-Einstieg (C=Zeichen) ---
	LD	A,H		; 18B2: H|L == 0?
	OR	L		; 18B3
	RET		; 18B4: RET wenn kein Zeichenpuffer
; --- Stack-Wiederherstellung (von ISR) ---
	POP	AF		; 18B5
	LD	SP,0000H		; 18B6: SP restaurieren (wird gepatcht)
	EI		; 18B9
	RETI		; 18BA
; --- WARM_INIT: Hardware-Grundinitialisierung (18BCH) ---
; Sucht eigenen I/O-Slot via Port 03FCH und Kennung 0EEH.
	DI		; 18BC
	LD	HL,03FCH		; 18BD: I/O-Slot-Adresse
	LD	A,0EEH		; 18C0: Slot-Kennbyte (A5120)
	LD	B,00H		; 18C2: Slot-Zaehler
	CP	(HL)		; 18C4: Kennbyte gefunden?
	JR	Z,18CBH		; 18C5: ja -> Slot erkannt
	RLCA		; 18C7: naechster Slot (EEH->DDH->BBH...)
	INC	B		; 18C8: Zaehler +1
	JR	18C4H		; 18C9: weiter suchen
	LD	A,B		; 18CB: B = Slot-Nummer
	LD	(1858H),A		; 18CC: fuer Sektor-Transfer (INI-Offset)
	LD	(20FCH),A		; 18CF: fuer BIOS-Disk-Routinen
; --- PIO Port B Konfiguration ---
	LD	A,0FFH		; 18D2
	OUT	(0BH),A		; 18D4: PIO B: Mode 3 (Bit-I/O)
	LD	A,0E2H		; 18D6: Bitmaske: Bit 0,2,3,4 = Input
	OUT	(0BH),A		; 18D8: -> PIO B Richtungsregister
; --- PIO Port A: Motor-Bits loeschen ---
	IN	A,(0AH)		; 18DA: PIO A lesen
	AND	0F6H		; 18DC: Bits 0,3 loeschen (Motor aus)
	OUT	(0AH),A		; 18DE: -> PIO A
; --- SIO + CTC Reset ---
	LD	A,03H		; 18E0: Reset-Kommando
	OUT	(0BH),A		; 18E2: -> PIO B
	OUT	(09H),A		; 18E4: -> PIO A
	OUT	(0CH),A		; 18E6: -> SIO A Data
	OUT	(0DH),A		; 18E8: -> SIO A Control
	OUT	(0EH),A		; 18EA: -> SIO B Data
	OUT	(0FH),A		; 18EC: -> SIO B Control
	LD	A,03H		; 18EE
	OUT	(40H),A		; 18F0: -> CTC Kanal 0 Reset
; --- Stack + Interrupt-Vektor Setup ---
	LD	SP,0080H		; 18F2: CP/M Standard-Stack
	LD	HL,2600H		; 18F5: Interrupt-Page
	LD	A,H		; 18F8
	LD	I,A		; 18F9: I = 26H (IM 2 Vektor-Page)
	LD	A,00H		; 18FB: Laufwerk A:
	LD	(0004H),A		; 18FD: -> CDISK (aktuelles Laufwerk)
; --- Pruefe A5120-Typ (Port A Bit 6) ---
	IN	A,(0AH)		; 1900: AMF PIO Port A
	BIT	6,A		; 1902: Bit 6: Display vorhanden?
	JR	NZ,1942H		; 1904: Bit gesetzt -> Display-Init ueberspringen
; --- A5120 Display-Konfiguration (selbstmodifizierend) ---
; Patcht CONOUT-Routine mit Hardware-Adressen des Alpha-Displays
	LD	HL,0081H		; 1906: Start Zeilen-Offset
	LD	(18CEH),HL		; 1909: -> CONOUT Zeilen-Basis
	LD	HL,0FF30H		; 190C: letzte Zeile Adresse
	LD	(18D5H),HL		; 190F: -> CONOUT Scroll-Grenze
	DEC	HL		; 1912: FF2FH
	LD	(1929H),HL		; 1913: -> CONOUT Scroll-Ziel
	LD	HL,0F850H		; 1916: Bildschirm-Basis (alpha)
	LD	(18D9H),HL		; 1919: -> CONOUT Screen-Start
	LD	HL,0F800H		; 191C: Video-RAM Anfang
	LD	(18DCH),HL		; 191F: -> CONOUT Screen-Anfang
	LD	(1947H),HL		; 1922: -> CONOUT Cursor-Basis
	LD	HL,0730H		; 1925: Zeichensatz-ROM Adresse
	LD	(18DFH),HL		; 1928: -> CONOUT Charset-Zeiger
	LD	HL,0FF7EH		; 192B: Cursor-Untergrenze
	LD	(18E7H),HL		; 192E: -> CONOUT Cursor-Limit unten
	INC	HL		; 1931: FF7FH
	LD	(191CH),HL		; 1932: -> CONOUT Cursor-Position
	LD	HL,004FH		; 1935: Cursor-Obergrenze (79=4FH)
	LD	(18EAH),HL		; 1938: -> CONOUT Cursor-Limit oben
	INC	HL		; 193B: 0050H (80 Spalten)
	LD	(1919H),HL		; 193C: -> CONOUT Spaltenbreite
	LD	(1931H),HL		; 193F: -> CONOUT Spaltenbreite (Kopie)
; --- FDC-Initialisierung und SIO-Setup ---
	LD	HL,1E6FH		; 1942: FDC-ISR Adresse
	LD	(26E8H),HL		; 1945: -> Interrupt-Vektor-Tabelle
	LD	A,0E8H		; 1948: SIO A: Interrupt-Enable
	OUT	(11H),A		; 194A: -> flcoac (SIO A Control)
	LD	A,7FH		; 194C: Interrupt-Vektor
	OUT	(11H),A		; 194E: -> flcoac
	OUT	(17H),A		; 1950: -> PIO B: Output-Modus
	IN	A,(16H)		; 1952: <- fldabd: Flush FDC-Daten
	LD	A,0FDH		; 1954: FDC-Reset-Kommando
	OUT	(10H),A		; 1956: -> flcoad
	LD	A,3FH		; 1958: SIO Error Reset + Rx Enable
	OUT	(11H),A		; 195A: -> flcoac
	OUT	(15H),A		; 195C: -> (unbekanntes Register?)
	LD	A,0FFH		; 195E: SIO B Reset
	OUT	(13H),A		; 1960: -> flcobc
	LD	A,0F3H		; 1962: SIO B: Rx Enable + Konfiguration
	OUT	(13H),A		; 1964: -> flcobc
; --- Laufwerks-Scan: bis zu 4 Laufwerke pruefen ---
	LD	C,04H		; 1966: 4 Laufwerke
	LD	D,00H		; 1968: Ergebnis-Bitmap (Bit pro LW)
	LD	A,0F7H		; 196A: Motor-Enable fuer LW 0
	RLCA		; 196C: naechstes Laufwerk (Bit rotieren)
	OUT	(18H),A		; 196D: -> Floppy-Motor-Port
	EX	AF,AF'		; 196F: Motor-Byte sichern
	LD	B,55H		; 1970: Timeout-Zaehler (85 Versuche)
	IN	A,(12H)		; 1972: <- AMF PIOB (Status)
	RLCA		; 1974: Bit 0 (Ready) -> Carry
	JR	NC,1989H		; 1975: nicht bereit -> naechstes LW
; --- Step-Test: Laufwerk verifizieren ---
	LD	A,5FH		; 1977: FDC Step-In (kein Head load)
	OUT	(10H),A		; 1979: -> flcoad
	LD	A,0DFH		; 197B: FDC Step-In (mit Head load)
	OUT	(10H),A		; 197D: -> flcoad
	LD	H,08H		; 197F: Delay-Zaehler (aeussere Schleife)
	DEC	L		; 1981: Delay innere Schleife
	JR	NZ,1981H		; 1982
	DEC	H		; 1984
	JR	NZ,1981H		; 1985
	DJNZ	1972H		; 1987: naechster Ready-Check
; --- Laufwerk erkannt: Bit in D setzen ---
	SET	6,D		; 1989: Bit 6 setzen (wird spaeter rotiert)
	DEC	C		; 198B: naechstes Laufwerk
	JR	Z,1995H		; 198C: alle 4 geprueft -> fertig
	RRC	D		; 198E: Ergebnis-Bitmap rotieren
	RRC	D		; 1990: (2 Bits pro Laufwerk)
	EX	AF,AF'		; 1992: Motor-Byte zurueck
	JR	196CH		; 1993: -> naechstes Laufwerk
; --- Scan-Ergebnis speichern ---
	LD	A,D		; 1995: Laufwerks-Bitmap
	LD	(1ED8H),A		; 1996: -> Laufwerks-Verfuegbarkeits-Register
	LD	A,0FFH		; 1999
	OUT	(18H),A		; 199B: alle Motoren aus
; --- Track-Tabelle initialisieren ---
	XOR	A		; 199D: A = 0
	LD	(1ED9H),A		; 199E: aktuelles Laufwerk = 0
	LD	(1EDAH),A		; 19A1: aktuelle Spur = 0
	LD	B,04H		; 19A4: 4 Laufwerke
	LD	HL,1EDBH		; 19A6: Track-Tabelle Basis
	LD	(HL),A		; 19A9: Spur = 0
	INC	HL		; 19AA
	DJNZ	19A9H		; 19AB: naechstes Laufwerk
; --- Warmstart-Abschluss: WBOOT patchen + Boot-Meldung ---
	LD	HL,08AFH		; 19AD: RET-Stub Adresse
	LD	(1801H),HL		; 19B0: -> XOUT+1 (patcht BIOS WBOOT auf Stub)
	LD	HL,21BCH		; 19B3: Boot-Meldungs-Adresse
	CALL	207CH		; 19B6: -> String-Ausgabe
	JP	1890H		; 19B9: -> GOCPM (BDOS-Patch + CCP-Start)

; --- Boot-Meldung (19BCH-19FFH) ---
	DB	04H,0AH		; 19BC: Steuerzeichen
	DB	'CP/A-Bootsystem, Version 05.04.88 laedt @OS.COM ...',0DH,0AH,0AH,00H	; 19BE
	DS	11,00H		; 19F5: Fuellbytes

	END
