	DB	000H,000H,000H,000H,000H,000H,000H,000H	; 0C39: ........
	DB	03EH,0FFH,032H,032H,014H,0C3H,0F5H,012H	; 0C41: >.22....
	DB	03EH,0FFH,032H,032H,014H,0C3H,0B7H,012H	; 0C49: >.22....
	DB	03AH,032H,014H,03CH,028H,002H,03DH,0C9H	; 0C51: :2.<(.=.
	DB	03AH,05BH,00BH,0C9H,021H,032H,014H,07EH	; 0C59: :[..!2.~
	DB	03CH,0C8H,036H,0FFH,03DH,032H,029H,014H	; 0C61: <.6.=2).
	DB	0CDH,0B7H,012H,0C3H,0E7H,012H,000H,000H	; 0C69: ........
	DB	000H,000H,000H,000H,000H,000H,000H,000H	; 0C71: ........
	DB	000H,000H,000H,000H,000H,000H,000H,000H	; 0C79: ........
	DB	000H,000H,000H,000H,000H,000H,000H,000H	; 0C81: ........
	DB	000H,000H,000H,000H,000H,000H,000H,000H	; 0C89: ........
	DB	000H,000H,000H,000H,000H,000H,000H,000H	; 0C91: ........
	DB	000H,000H,000H,000H,000H,000H,000H,000H	; 0C99: ........
	DB	000H,000H,000H,000H,000H,000H,000H,000H	; 0CA1: ........
	DB	000H,000H,000H,000H,000H,000H,000H,000H	; 0CA9: ........
	DB	000H,000H,000H,000H,000H,000H,000H,000H	; 0CB1: ........
	DB	000H,000H,000H,000H,000H,000H,000H,000H	; 0CB9: ........
	DB	000H,000H,000H,000H,000H,000H,000H,000H	; 0CC1: ........
	DB	000H,000H,000H,000H,000H,000H,000H,000H	; 0CC9: ........
	DB	000H,000H,000H,000H,000H,000H,000H,000H	; 0CD1: ........
	DB	000H,000H,000H,000H,000H,000H,000H,000H	; 0CD9: ........
	DB	000H,000H,000H,000H,000H,000H,000H,000H	; 0CE1: ........
	DB	000H,000H,000H,000H,000H,000H,000H,000H	; 0CE9: ........
	DB	000H,000H,000H,000H,000H,000H,000H,000H	; 0CF1: ........
	DB	000H,000H,000H,000H,000H,000H,000H	; 0CF9: .......

; ======================================================================
; ABSCHNITT 3: STAGE-2 / BOOT-BIOS (Track2 Sektoren 0-25, ORG 0D00H)
; Enthaelt: FDC-Treiber, CRC-Decoder, @OS.COM-Lader, BIOS-Einstieg
; ======================================================================
	ORG	0D00H

; --- T2 SYL-Kennung + Padding (0D00H-0D06H) ---
T2_SYL_HDR:
	DB	'SYL'		; 0D00: zweiter SYL-Kopf (Spur 2)
	DS	4		; 0D03-0D06: Padding

; --- FDC_ADRDEC: FDC Adressen-/CRC-Decoder (0D07H-0D2DH) ---
; Funktion: CRC-Berechnung / Dekodierung von FDC-Adressfeld-Bytes.
;           XOR+RRCA-Kette extrahiert Spur (B) und Sektor (C) aus dem
;           kompakten AMF-Bitstrom (Address Mark Field des K5600-FDC).
; Eingabe:  IY = Zeiger auf FDC-Adressfeld-Puffer (PARAM_TAB 0400H)
;           E  = Anzahl der zu verarbeitenden Bytes
;           BC = laufende CRC / vorheriger Dekodierungszustand
; Ausgabe:  BC = dekodiertes Ergebnis (B=Spurbyte, C=Sektorbyte)
; Identischer Algorithmus in format.mac (advance_dma_ptr, 0DC7H).
FDC_ADRDEC:
	LD	A,(IY+0)	; 0D07: IY[0] = kompaktes Spur/Sektor-Byte
	XOR	B		; 0D0A: XOR mit B (vorangehendem Wert)
	LD	B,A		; 0D0B: B = XOR-Ergebnis
	RRCA			; 0D0C: \
	RRCA			; 0D0D:  | 4 Rechts-Rotationen
	RRCA			; 0D0E:  | -> Bits 7-4 nach 3-0
	RRCA			; 0D0F: /
	AND	0FH		; 0D10: maskiere nur Bits 3-0
	XOR	B		; 0D12: Paritaet korrigieren
	LD	B,A		; 0D13: B = dekodierter Spur-High
	RRCA			; 0D14: \
	RRCA			; 0D15:  | 3 Rechts-Rotationen
	RRCA			; 0D16: /
	LD	D,A		; 0D17: D = Zwischenergebnis
	AND	1FH		; 0D18: Sektor-Teil (5 Bits)
	XOR	C		; 0D1A: XOR mit aktuellem C-Wert
	LD	C,A		; 0D1B: C = Sektor-Nummer
	LD	A,D		; 0D1C: zurueck zu D
	RRCA			; 0D1D: ein weiterer Shift
	AND	0F0H		; 0D1E: maskiere Bits 7-4 (Spur-Low)
	XOR	C		; 0D20
	LD	C,A		; 0D21: C = kombinierter Sektor/Spur
	LD	A,D		; 0D22
	AND	0E0H		; 0D23: Bits 7-5 = Seitenkennung
	XOR	B		; 0D25
	LD	B,C		; 0D26: BC aufbereitet
	LD	C,A		; 0D27: C = Seiten-/High-Bits
	INC	IY		; 0D28: naechster Parameterblock
	DEC	E		; 0D2A: Zaehler
	JR	NZ,FDC_ADRDEC	; 0D2B: weiter wenn nicht fertig
	RET			; 0D2D

; ======================================================================
; BOOT_MAIN: Boot-BIOS Hauptroutine (0D2EH-0E6FH)
; ======================================================================
; Initialisiert FDC, liest @OS.COM vom Dateisystem, laedt es in den
; RAM und springt dorthin.
; Aufruf: Direkt vom SYL-Header oder vom Warmstart-Vektor.
BOOT_MAIN:
	LD	IY,0400H	; 0D2E: IY -> PARAM_TAB (FDC-Parameterblock)
	LD	E,0FEH		; 0D32: E = Wiederholzaehler
	LD	BC,0FFFFH	; 0D34: BC = Vergleichswert (Disketten-ID)

; --- Laufwerks-Selektion ---
	LD	A,00H		; 0D37: Laufwerk 0 (Floppy A:)
	OUT	(0EEH),A	; 0D39: -> Geraete-Selektor

; --- FDC Lese-Sequenz: 3 Versuche ---
	LD	A,03H		; 0D3B: Versuchszaehler = 3
BOOT_RETRY:
	PUSH	AF		; 0D3D
	CALL	0407H		; 0D3E: READ_SEC: lese ersten Sektor
	POP	AF		; 0D41
	DEC	A		; 0D42: Zaehler minus 1
	JR	NZ,BOOT_RETRY	; 0D43: nochmal versuchen

; --- Disketten-Kennung pruefen ---
	LD	A,B		; 0D45
	CP	(IY+0)		; 0D46: prueffe Sektor-High-Byte
	JP	NZ,0605H	; 0D49: -> ERR_HANDLER wenn Fehler
	LD	A,C		; 0D4C
	CP	(IY+1)		; 0D4D: prueffe Sektor-Low-Byte
	JP	NZ,0605H	; 0D50: -> ERR_HANDLER

; --- RAM-Nullung (2 KByte Pufferbereich) ---
	LD	HL,0000H	; 0D53: Start RAM
	LD	BC,0800H	; 0D56: 2 KByte
CLEAR_RAM:
	IN	A,(0AH)		; 0D59: FDC-Status lesen
	BIT	6,A		; 0D5B: Bit 6 gesetzt? (Daten bereit)
	JR	Z,CLEAR_LOOP	; 0D5D: wenn nicht: Skip
	LD	B,04H		; 0D5F: B = 4 (Wiederholung bei Ready)
CLEAR_LOOP:
	DEC	HL		; 0D61: HL rueckwaerts
	LD	(HL),00H	; 0D62: setze Byte auf 0
	DEC	BC		; 0D64
	LD	A,B		; 0D65
	OR	C		; 0D66: BC != 0?
	JR	NZ,CLEAR_LOOP	; 0D67: weiter bis BC=0

; --- Interrupt-Vektor-Tabellen-Setup (Z80 IM2) ---
	EX	DE,HL		; 0D69
	LD	HL,06C1H	; 0D6A: Quelladresse der IV-Tabelle
	LD	C,1DH		; 0D6D: 29 Bytes kopieren
	LDIR			; 0D6F: Interrupt-Vektortabelle kopieren

; --- Sprung-Vektor-Patches ---
	LD	HL,0624H	; 0D71: Disketten-IRQ-Handler-Adresse
	LD	(0760H),HL	; 0D74: patch IV-Eintrag 0760H
	LD	HL,060EH	; 0D77: zweiter Handler
	LD	(0762H),HL	; 0D7A: patch IV-Eintrag 0762H

; --- Z80 Interrupt Mode 2 via I-Register ---
	LD	A,07H		; 0D7D: Vektortabelle high-Byte = 07xxH
	LD	I,A		; 0D7F: I-Register fuer IM2 setzen

; --- SIO / USART-Init ---
	LD	A,62H		; 0D81: SIO A Steuerwort
	OUT	(11H),A		; 0D83: -> flcoac
	LD	A,60H		; 0D85: SIO A Reset
	OUT	(13H),A		; 0D87: -> flcobc

; --- BDOS Einstiegspunkt Patch bei RAM[0001H] ---
	LD	HL,062EH	; 0D89: Adresse des BDOS-Dispatch-Jumps
	LD	(0001H),HL	; 0D8C: patch JP-Ziel bei 0001H

; --- Stack- und DMA-Zeiger setzen ---
	LD	HL,0034H	; 0D8F
	LD	(07FCH),HL	; 0D92: DMA-Zeiger = 0034H
	LD	HL,0800H	; 0D95
	LD	(07FAH),HL	; 0D98: Lesepuffer-Adresse = 0800H

; --- @OS.COM-Ladepuffer initialisieren ---
	LD	HL,07E9H	; 0D9B
	LD	(HL),00H	; 0D9E: 07E9H = 0 (kein Motorstart-Pending)
	INC	L		; 0DA0
	LD	(HL),01H	; 0DA1: 07EAH = 1 (Kaltstart-Typ)
	LD	DE,018DH	; 0DA3: Ziel fuer @OS.COM-Lade
	LD	HL,0770H	; 0DA6: Quellbereich (OS-Image)
	LD	(07F4H),HL	; 0DA9: Datei-Suchstart-Adresse

; --- Motorstart / FDC-Bereitschaft ---
	INC	D		; 0DAC: Null-Test fuer D
	DEC	D		; 0DAD
	JR	Z,OS_SEARCH	; 0DAE: kein Motor-Anlauf noetig

; --- FDC Laufwerks-Steuerung via Port 10H ---
MOTOR_START:
	LD	A,E		; 0DB0
	OUT	(10H),A		; 0DB1: -> flcoad: Motor ON
MOTOR_CHK:
	IN	A,(12H)		; 0DB3: <- flcobd: FDC-Status lesen
	RLCA			; 0DB5: Bit 7 nach Carry
	JR	NC,ALT_MOTOR	; 0DB6: kein Index -> alternativer Pfad
STEP_IN:
	LD	A,E		; 0DB8
	AND	7FH		; 0DB9: Bit 7 loeschen (Richtung Step-In)
	OUT	(10H),A		; 0DBB: Schritt-Kommando
	OR	80H		; 0DBD: Bit 7 setzen (Schritt-Impuls)
	OUT	(10H),A		; 0DBF: Schritt-Puls senden
	LD	BC,0800H	; 0DC1: 2K Warte-Iterationen
STEP_WAIT:
	DEC	C		; 0DC4: innere Schleife
	JR	NZ,STEP_WAIT	; 0DC5
	DJNZ	STEP_WAIT	; 0DC7: aeussere Schleife
	DEC	D		; 0DC9: Track-Zaehler
	JR	NZ,MOTOR_CHK	; 0DCA: noch mehr Steps?
	JR	OS_SEARCH	; 0DCC: -> weiter mit OS-Lader

; --- Alternativer Motorstart (wenn Index-Puls vorhanden) ---
ALT_MOTOR:
	LD	A,(07E9H)	; 0DCE: Motor-Zustand lesen
	OR	A		; 0DD1
	JR	Z,OS_SEARCH	; 0DD2: schon an?
	LD	D,A		; 0DD4
	LD	E,0ADH		; 0DD5: FDC-Motor-Kommando
	LD	A,E		; 0DD7
	OUT	(10H),A		; 0DD8: -> flcoad
	JR	STEP_IN		; 0DDA: -> zurueck in Stepping-Sequenz

; --- @OS.COM Dateisystem-Suche und FDC-Konfiguration ---
OS_SEARCH:
	LD	L,0F0H		; 0DDC
	LD	(HL),03H	; 0DDE: Sektor-Typ
	INC	L		; 0DE0
	LD	A,05H		; 0DE1
	LD	(HL),A		; 0DE3: Sektorzahl
	INC	L		; 0DE4
	LD	(HL),A		; 0DE5
	INC	L		; 0DE6
	LD	(HL),A		; 0DE7
	LD	L,0EDH		; 0DE8
	LD	(HL),0B5H	; 0DEA: Zaehlwert
	LD	B,00H		; 0DEC: Sektorzaehler
	LD	HL,07E0H	; 0DEE: Puffer fuer Verz.-Sektor
	LD	(HL),0FEH	; 0DF1: Sektor-Kennung (MFM-ID-Feld)
	INC	L		; 0DF3
	LD	A,(07E9H)	; 0DF4: Laufwerk-Nummer
	LD	(HL),A		; 0DF7
	INC	L		; 0DF8
	LD	(HL),B		; 0DF9: Sektor Low-Byte (0)
	INC	L		; 0DFA
	LD	A,(07EAH)	; 0DFB: Sektor High-Byte
	LD	(HL),A		; 0DFE
	INC	L		; 0DFF
	LD	(HL),00H	; 0E00: Ende-Marker
	LD	L,0ECH		; 0E02: Sektor-Kommando
	LD	(HL),05H	; 0E04
	LD	L,0F7H		; 0E06
	LD	(HL),B		; 0E08
	OUT	(14H),A		; 0E09: -> fldaad: Schreib-Daten Port A
	OUT	(04H),A		; 0E0B: -> alternativer Port
	LD	A,0FFH		; 0E0D
	OUT	(17H),A		; 0E0F: -> fldabc: Port B Steuerung reset
	OUT	(17H),A		; 0E11: zweites Reset
	LD	A,0A1H		; 0E13: Seek-Kommando
	OUT	(10H),A		; 0E15: -> flcoad
	LD	A,7FH		; 0E17: Interrupt-Enable-Maske
	OUT	(17H),A		; 0E19: -> fldabc: IRQ freigeben
	LD	A,97H		; 0E1B: SIO A: Empfaenger freigeben
	OUT	(13H),A		; 0E1D: -> flcobc
	LD	A,0AFH		; 0E1F: SIO A: volle Konfiguration
	OUT	(13H),A		; 0E21: -> flcobc
	IN	A,(16H)		; 0E23: <- fldabd: Lese-Status
	LD	A,(03FDH)	; 0E25: Ladeadresse-Low
	OUT	(10H),A		; 0E28: -> flcoad
	LD	A,(07F7H)	; 0E2A: Datei-Suchzeiger
	LD	B,A		; 0E2D

; --- Verzeichnis-Eintrag pruefen (Name @OS.COM suchen) ---
	RRC	B		; 0E2E
	JR	NZ,0E9BH	; 0E30: -> Sprung wenn B ungerade
	LD	L,0EAH		; 0E32
	LD	A,(07E3H)	; 0E34: aktuelles Byte aus Verz.-Puffer
	CP	(HL)		; 0E37
	JR	Z,0E2AH	; 0E38: zurueck wenn gleich (Schleife)
	LD	A,(03FDH)	; 0E3A
	LD	BC,0BF84H	; 0E3D: Sektor/Spur-Parameter
	BIT	1,A		; 0E40
	JR	NZ,0E47H	; 0E42: einseitig
	LD	BC,0E295H	; 0E44: anderer Parameter-Satz

; --- @OS.COM gefunden, Lade-Adresse berechnen ---
	LD	IY,(07FAH)	; 0E47: IY = Lese-Puffer-Adresse
	LD	A,(0677H)	; 0E4B: Startsektor des OS-Image
	LD	E,A		; 0E4E
	CALL	0407H		; 0E4F: -> READ_SEC: Sektor lesen

; --- Verzeichniseintrag-Vergleich mit "@OS.COM" ---
	LD	HL,(07F4H)	; 0E52: Zeiger auf Such-FCB
	LD	A,(HL)		; 0E55
	CP	B		; 0E56: Vergleich Byte 0
	JR	NZ,0EBFH	; 0E57: nicht gefunden
	INC	L		; 0E59
	LD	A,(HL)		; 0E5A
	CP	C		; 0E5B: Vergleich Byte 1
	JR	NZ,0EBFH	; 0E5C: nicht gefunden

; --- Gefunden! Naechste Station in Lade-Tabelle ---
	INC	L		; 0E5E
	LD	(07F4H),HL	; 0E5F: Such-Zeiger vorschieben
	LD	(07FAH),IY	; 0E62: Puffer-Zeiger aktualisieren
	LD	HL,07F6H	; 0E66
	LD	(HL),00H	; 0E69: Block-Zaehler init
	LD	HL,(07FCH)	; 0E6B
	DEC	HL		; 0E6E
	LD	(07FCH),HL	; 0E6F: Zaehler dekrementiert zurueckspeichern

; ======================================================================
; Boot-BIOS Fortsetzung: OS-Lade-Logik (0E72H-0FC0H)
; ======================================================================
; Fortsetzung des @OS.COM-Ladeprozesses nach gefundenem Verzeichnis-
; eintrag. Enthaelt:
;  - Sektor-Zaehler-Pruefung und Neustart der FDC-Lese-Sequenz
;  - Spur-/Seiten-Wechsel bei Sektorueberlauf
;  - FDC-Interrupt-Service-Routinen (RETI bei 0F22H, 0F24H)
;  - Low-Level-Sektor-Lese-Schleife mit IN/OUT auf fldabd (16H)
;  - Schleife: Warte auf Adressmarke (0A1H), lese Daten-Marke (0FBH),
;    dann INIR fuer 128-Byte-Block-Transfer in RAM
;  - CRC-Pruefung (Sektorzaehler bei 0F8BH-0F92H: max 1AH Sektoren)
;  - SIO-Reset (OUT 11H/13H) nach erfolgreichem Lesen
;
; Kontrollflusss:
;  0E72H: Pruefe ob alle Bloecke geladen (HL=0 -> fertig)
;  0E76H: Wenn fertig: SIO-Reset, JP 0880H (= Sprung zu @OS.COM)
;  0E87H: Sektor-Zaehler inkrementieren, bei Ueberlauf Spur wechseln
;  0E95H: Naechsten Sektor anfordern via PARAM_TAB
;  0EC7H-0EDFH: FDC-Adressfeld lesen + CRC pruefen (CALL 0407H)
;  0F05H: Fehler: LED-Code 88H, DI+HALT (CALL 057AH = ERR_HANDLER)
;  0F0EH: ISR: FDC-Interrupt (Sektor-Zaehler, RETI)
;  0F24H: ISR: FDC-Fehler-Interrupt (Flag setzen, RETI)
;  0F2EH-0FC0H: Sektor-Lese-Kern (MFM-Sync, INIR, CRC-Check)
; ======================================================================
	LD	A,L		; 0E72: Pruefe Block-Zaehler
	OR	H		; 0E73: HL == 0? (alle Bloecke geladen?)
	JR	NZ,0E87H		; 0E74: nein -> weiter laden
; --- Laden abgeschlossen: SIO-Reset und Sprung zu @OS.COM ---
	LD	HL,0880H		; 0E76: Ruecksprungadresse (-> @OS.COM Einstieg)
	PUSH	HL		; 0E79: auf Stack fuer RET
	LD	A,03H		; 0E7A: SIO-Reset-Kommando
	OUT	(11H),A		; 0E7C: -> flcoac: SIO A zuruecksetzen
	OUT	(13H),A		; 0E7E: -> flcobc: SIO B zuruecksetzen
	LD	A,0FFH		; 0E80: alle Bits setzen
	OUT	(10H),A		; 0E82: -> flcoad: FDC deaktivieren
	OUT	(18H),A		; 0E84: -> Motor-Steuerung: alle aus
	RET		; 0E86: -> 0880H (= Sprung zu geladenem @OS.COM)
; --- Naechsten Sektor anfordern ---
	LD	HL,07EAH		; 0E87: Sektor-Zaehler-Adresse
	INC	(HL)		; 0E8A: Sektornummer +1
	LD	A,(0690H)		; 0E8B: max. Sektorzahl (aus Konfig.)
	CP	(HL)		; 0E8E: Ueberlauf?
	JR	NC,0E32H		; 0E8F: nein -> naechsten Sektor lesen
; --- Spur-Wechsel bei Sektorueberlauf ---
	LD	(HL),01H		; 0E91: Sektorzaehler zuruecksetzen auf 1
	DEC	L		; 0E93: -> 07E9H (Spur-Zaehler)
	INC	(HL)		; 0E94: Spurnummer +1
	LD	DE,01ADH		; 0E95: Motor/Step-Kommando fuer naechste Spur
	JP	04A6H		; 0E98: -> PARAM_TAB-Update im Mini-BDOS auf Stack fuer RET
; --- FDC-Verzeichnis-Sektor pruefen ---
	LD	L,0E3H		; 0E9B: Zeiger auf gelesenes Verzeichnis-Byte
	LD	A,(07EAH)		; 0E9D: erwartete Sektornummer
	CP	(HL)		; 0EA0: stimmt Sektor ueberein?
	JR	NZ,0E32H		; 0EA1: nein -> naechsten Eintrag pruefen
	BIT	7,B		; 0EA3: Bit 7 gesetzt = Sektor bereits bearbeitet?
	JR	Z,0EC7H		; 0EA5: nein -> Adressfeld pruefen
; --- Step-Kommando an FDC senden ---
	LD	L,0F3H		; 0EA7: Zeiger auf Retry-Zaehler
	LD	A,0ADH		; 0EA9: FDC-Kommando (Step + Head load)
	OUT	(10H),A		; 0EAB: -> flcoad: Step-Impuls
	DEC	(HL)		; 0EAD: Retry-Zaehler verringern
	JP	NZ,04ECH		; 0EAE: noch Versuche -> weiter
	LD	L,0F6H		; 0EB1: Zeiger auf Status-Flags
	BIT	0,(HL)		; 0EB3: Flag: erste Seite fertig?
	JR	NZ,0F05H		; 0EB5: ja -> Fehler (Sektor nicht gefunden)
	SET	0,(HL)		; 0EB7: Flag setzen: erste Seite bearbeitet
	LD	DE,508DH		; 0EB9: Seiten-Wechsel-Parameter
	JP	04ACH		; 0EBC: -> PARAM_TAB-Update (Seitenwechsel): Spurnummer +1
; --- Nicht-gefunden: naechsten Verzeichniseintrag pruefen ---
	LD	L,0F2H		; 0EBF: Retry-Zaehler Offset
	JR	0EA9H		; 0EC1: -> Step + neuen Sektor lesen
	LD	L,0F1H		; 0EC3: alternativer Retry-Zaehler
	JR	0EA9H		; 0EC5: -> Step + neuen Sektor lesen
; --- FDC-Adressfeld lesen und Disk-ID verifizieren ---
	RRC	B		; 0EC7: B ungerade? (Adressfeld-Typ)
	JR	C,0EFDH		; 0EC9: ja -> anderer Pfad
	LD	L,0EDH		; 0ECB: Zaehler fuer Adressfeld-Bytes
	LD	(HL),0B5H		; 0ECD: Warte-Zaehler = B5H
	LD	IY,07E0H		; 0ECF: IY -> FDC-Puffer
	LD	E,05H		; 0ED3: 5 Bytes dekodieren
	LD	BC,0FFFFH		; 0ED5: BC = Init-CRC
	LD	A,(03FDH)		; 0ED8: Format-Parameter
	BIT	1,A		; 0EDB: FM oder MFM?
	JR	NZ,0EE2H		; 0EDD: MFM -> skip
	LD	BC,0CDB4H		; 0EDF: FM-CRC Startwert
	CALL	0407H		; 0EE2: -> READ_SEC: Adressfeld lesen
; --- Disk-ID Vergleich ---
	LD	A,(IY+0)		; 0EE5: gelesene ID Byte 0
	CP	B		; 0EE8: mit erwartetem Wert
	JR	NZ,0EC3H		; 0EE9: ungleich -> Retry
	LD	A,(IY+1)		; 0EEB: gelesene ID Byte 1
	CP	C		; 0EEE: vergleiche
	JR	NZ,0EC3H		; 0EEF: ungleich -> Retry: naechsten Verzeichniseintrag pruefen ---
; --- Spur-Vergleich und Seiten-Logik ---
	LD	L,0E9H		; 0EF1: Offset zur Spur-Info
	LD	A,(07E1H)		; 0EF3: aktuelle Spur aus Puffer
	CP	(HL)		; 0EF6: stimmt Spur ueberein?
	JR	Z,0EC3H		; 0EF7: gleich -> Retry (falscher Sektor)
	JR	NC,0EB1H		; 0EF9: groesser -> Step (Spur wechseln)
	JR	0E95H		; 0EFB: kleiner -> Neupositionierung
; --- Alternativer Pfad: Sektorzaehler zuruecksetzen ---
	LD	L,0EDH		; 0EFD: Zaehler-Offset
	LD	(HL),00H		; 0EFF: Zaehler = 0
	LD	L,0F0H		; 0F01: Sektor-Typ-Offset
	JR	0EA9H		; 0F03: -> Step-Kommando
; --- Fataler Fehler: Sektor nicht gefunden ---
	CALL	057AH		; 0F05: -> ERR_HANDLER (BDOS-Fehlermeldung)
	LD	A,88H		; 0F08: LED-Fehlercode
	OUT	(03H),A		; 0F0A: -> Tastatur-LED-Port
	JR	0F0CH		; 0F0C: (DI+HALT folgt im ERR_HANDLER) FM oder MFM?
; --- ISR 1: FDC-Sektor-Zaehler-Interrupt (0F0EH) ---
; Wird vom FDC ausgeloest wenn ein Sektor komplett gelesen wurde.
; Dekrementiert Sektorzaehler, setzt Flag bei Abschluss.
	EI		; 0F0E: Interrupts wieder freigeben
	PUSH	AF		; 0F0F
	PUSH	HL		; 0F10
	LD	HL,07ECH		; 0F11: Sektor-Zaehler
	DEC	(HL)		; 0F14: ein Sektor weniger
	JR	NZ,0F20H		; 0F15: noch nicht fertig -> POP+RETI
	LD	HL,07F7H		; 0F17: Status-Flags
	SET	1,(HL)		; 0F1A: Flag: alle Sektoren gelesen
	LD	A,0ADH		; 0F1C: FDC: Step+Head load (Motor stoppen)
	OUT	(10H),A		; 0F1E: -> flcoad
	POP	HL		; 0F20
	POP	AF		; 0F21
	RETI		; 0F22: Interrupt-Rueckkehr
; --- ISR 2: FDC-Fehler-Interrupt (0F24H) ---
; Wird bei FDC-Fehler ausgeloest, setzt Fehler-Flag.
	EI		; 0F24
	PUSH	AF		; 0F25
	PUSH	HL		; 0F26
	LD	HL,07F7H		; 0F27: Status-Flags
	SET	0,(HL)		; 0F2A: Flag: FDC-Fehler aufgetreten
	JR	0F1CH		; 0F2C: -> FDC deaktivieren + RETI
; --- Sektor-Lese-Kern: MFM-Sync + DMA-Transfer (0F2EH-0FC0H) ---
; Diese Routine liest Sektoren direkt vom FDC ueber PIO-Port B (16H).
; Ablauf: (1) Initialisiere Puffer-Zeiger und Register-Saetze (EXX)
;         (2) FDC-Lese-Modus aktivieren (OUT 10H, 0BDH)
;         (3) Warte auf MFM-Sync-Byte 0A1H (Adressmarke)
;         (4) Pruefe auf Daten-Marke 0FEH (ID) oder 0FBH (Data)
;         (5) INIR: Block-Transfer 128 Bytes in RAM
;         (6) CRC-Bytes lesen, Sektor-Zaehler pruefen
;         (7) Bei Fehler: Retry via 0F45H
	LD	HL,(07FAH)		; 0F2E: HL = Lese-Puffer-Adresse
	LD	DE,(07F4H)		; 0F31: DE = Datei-Suchzeiger
	EXX		; 0F35: -> Schattenregister
	LD	BC,0310H		; 0F36: B=3 (Retry), C=10H (flcoad Port)
	LD	A,(07EDH)		; 0F39: FDC-Steuerbyte
	LD	D,A		; 0F3C: D' = Steuerbyte
	LD	A,(03FDH)		; 0F3D: Format-Parameter
	LD	E,A		; 0F40: E' = Format
	LD	A,0BDH		; 0F41: FDC: Lese-Modus (Head load + Read)
	OUT	(10H),A		; 0F43: -> flcoad
; --- Warte auf MFM-Adressmarke (0A1H) ---
	LD	HL,07E1H		; 0F45: Adressfeld-Puffer
	IN	A,(16H)		; 0F48: <- fldabd: FDC-Datenbyte lesen
	CP	0A1H		; 0F4A: Sync-Byte 0A1H?
	JR	Z,0F48H		; 0F4C: ja -> weiter warten (mehrere 0A1H)
	CP	0FEH		; 0F4E: ID-Adressmarke (0FEH)?
	JR	NZ,0FB2H		; 0F50: nein -> Fehler, Retry
; --- Adressfeld lesen (Spur, Seite, Sektor, Laenge) ---
	IN	A,(16H)		; 0F52: erstes Adressfeld-Byte
	BIT	2,D		; 0F54: Pruefe Steuerbyte Bit 2
	JR	Z,0FA4H		; 0F56: -> Adressfeld speichern (Schreib-Pfad)
	CP	(HL)		; 0F58: Vergleich mit erwartetem Wert
	JR	NZ,0FB2H		; 0F59: ungleich -> Retry
	IN	A,(16H)		; 0F5B: naechstes Byte
	INC	L		; 0F5D: Puffer-Zeiger++
	DJNZ	0F58H		; 0F5E: B Bytes vergleichen
; --- Gap-Bytes ueberspringen (zwischen Adressfeld und Datenfeld) ---
	LD	B,0BH		; 0F60: 11 Gap-Bytes bei FM
	IN	A,(16H)		; 0F62
	BIT	1,E		; 0F64: MFM-Modus? (ft.kom Bit 1)
	JR	NZ,0F6AH		; 0F66: ja -> weniger Gap
	LD	B,16H		; 0F68: 22 Gap-Bytes bei MFM
	IN	A,(16H)		; 0F6A: Gap-Byte lesen und verwerfen
	DJNZ	0F6AH		; 0F6C: alle Gap-Bytes ueberspringen
; --- FDC-Steuerung: Datenmarke erwartet ---
	OUT	(C),D		; 0F6E: Steuerbyte an Port C (10H)
	OUT	(C),E		; 0F70: Format-Byte an Port C
	IN	A,(16H)		; 0F72: naechstes Byte nach Gap
	EXX		; 0F74: -> Hauptregister
; --- Warte auf Datenmarke (0FBH) ---
	LD	BC,8016H		; 0F75: B=80H (128 Bytes), C=16H (fldabd Port)
	IN	A,(16H)		; 0F78: FDC-Datenbyte lesen
	CP	0A1H		; 0F7A: noch ein Sync-Byte?
	JR	Z,0F78H		; 0F7C: ja -> weiter warten
	CP	0FBH		; 0F7E: Daten-Adressmarke (0FBH)?
	JR	NZ,0FB1H		; 0F80: nein -> Fehler
; --- Block-Transfer: 128 Bytes vom FDC in RAM ---
	INIR		; 0F82: IN (C)->HL, B mal (128 Bytes)
	EX	DE,HL		; 0F84: DE <-> HL (Datei-Zeiger)
	INI		; 0F85: CRC Byte 1 lesen
	INI		; 0F87: CRC Byte 2 lesen
	EX	DE,HL		; 0F89: zurueck
	EXX		; 0F8A: -> Schattenregister
; --- Sektorzaehler pruefen ---
	DEC	L		; 0F8B: Zaehler im Puffer
	INC	(HL)		; 0F8C: Sektor-Zaehler +1
	IN	A,(16H)		; 0F8D: naechstes Byte (nach CRC)
	LD	A,1AH		; 0F8F: max. 26 Sektoren pro Spur
	CP	(HL)		; 0F91: alle gelesen?
	JR	NC,0FB2H		; 0F92: nein -> Retry/naechster Sektor
; --- Sektor erfolgreich: SIO-Reset und Motor-Kommando ---
	IN	A,(16H)		; 0F94: Rest-Byte verwerfen
	IN	A,(16H)		; 0F96: dto.
	LD	A,03H		; 0F98: SIO-Reset
	OUT	(11H),A		; 0F9A: -> flcoac
	OUT	(13H),A		; 0F9C: -> flcobc
	IN	A,(16H)		; 0F9E: letztes Byte verwerfen
	LD	A,0ADH		; 0FA0: FDC: Head load + Step
	OUT	(10H),A		; 0FA2: -> flcoad
; --- Adressfeld speichern (fuer Schreib-Pfad) ---
	LD	(HL),A		; 0FA4: Adressfeld-Byte speichern
	INC	L		; 0FA5: Puffer weiter
	LD	BC,0516H		; 0FA6: B=5 Bytes, C=16H (Port)
	INIR		; 0FA9: restliche Adressfeld-Bytes lesen
	LD	L,0F7H		; 0FAB: Status-Flags
	SET	2,(HL)		; 0FAD: Flag: Adressfeld gelesen
	JR	0F96H		; 0FAF: -> SIO-Reset
; --- Fehler-Pfad: Registersatz restaurieren ---
	EXX		; 0FB1: -> Hauptregister
; --- Retry: FDC zuruecksetzen und neuen Versuch starten ---
	IN	A,(16H)		; 0FB2: aktuelles Byte verwerfen
	LD	BC,0310H		; 0FB4: B=3 (Retry), C=10H (Port)
	IN	A,(16H)		; 0FB7: noch ein Byte verwerfen
	OUT	(C),D		; 0FB9: Steuerbyte an FDC
	OUT	(C),E		; 0FBB: Format-Byte an FDC
	IN	A,(16H)		; 0FBD: Sync verwerfen
	JR	0F45H		; 0FBF: -> zurueck zum Sektor-Lese-Start

; --- Bootloader-Versionsstring (0FC1H-0FFFH) ---
	DB	06H		; 0FC1: Header-Byte
	DB	'Bootloader, Version 24.02.87',00H	; 0FC2
	DS	31,00H		; 0FDF: Fuellbytes
	DB	02H,11H		; 0FFE

; ======================================================================
; BIOS-Sprungtabelle (CP/M 2.2 Standard, 17 Eintraege)
; ======================================================================
; Standard-CP/M-2.2-Schnittstelle. Jeder Eintrag ist ein JP xxxx.
; Die meisten Eintraege zeigen auf Stub-Adressen (08AFH = RET) oder
; auf die Boot-BIOS-Routinen in Stage-2 (1800H+).
; BOOT (1000H) -> JP 20BCH: Sprung ins geladene @OS.COM.
; CONOUT (100CH) -> JP 18B2H: Bildschirmtreiber-Einstieg in Stage-2.
	JP	20BCH		; 1000: BOOT - Kaltstart (Jump ins geladene OS)
	JP	08AFH		; 1003: WBOOT - Warmstart
	JP	08AFH		; 1006: CONST - Konsol-Status (Stub)
	JP	08AFH		; 1009: CONIN - Konsol-Eingabe (Stub)
	JP	18B2H		; 100C: CONOUT - Konsol-Ausgabe
	JP	08AFH		; 100F: LIST - Drucker-Ausgabe (Stub)
	LD	A,C		; 1012: PUNCH - Lochstreifen (Stub)
	RET			; 1013
	NOP			; 1014: (Fuellbyte)
	LD	A,1AH		; 1015: READER - Leser (Stub, gibt EOF)
	RET			; 1016
	JP	1964H		; 1017: HOME - Kopf auf Spur 0
	JP	1949H		; 101A: SELDSK - Laufwerk waehlen
	JP	1972H		; 101D: SETTRK - Spur setzen
	JP	1977H		; 1020: SETSEC - Sektor setzen
	JP	197CH		; 1023: SETDMA - DMA-Adresse setzen
	JP	1988H		; 1026: READ - Sektor lesen
	JP	08AFH		; 1029: WRITE - Sektor schreiben (Stub)
	JP	08AFH		; 102C: LISTST - Drucker-Status (Stub)
	JP	1981H		; 102F: SECTRN - Sektor-Uebersetzung
	DS	5,00H		; 1033: Fuellbytes

; --- DPH/DPB Disk-Parameter-Tabellen (1038H-108FH) ---
; DPH (Disk Parameter Header): Zeiger auf Translations-Tabelle,
;   Scratch-Bereiche, DPB-Zeiger. Eine DPH pro Laufwerk.
; DPB (Disk Parameter Block): Beschreibt Disketten-Geometrie:
;   SPT (Sectors Per Track), BSH/BLM (Block Shift/Mask),
;   EXM (Extent Mask), DSM (max. Blocknr.), DRM (max. Dir-Eintrag),
;   AL0/AL1 (Allokationsbitmap), CKS (Dir-Check-Groesse),
;   OFF (System-Spur-Offset).
; Ab 1058H: Sektor-Uebersetzungstabelle (Skew-Tabelle) fuer 26 Sektoren.
; Ab 1078H: Zweiter DPB (fuer alternative Geometrie/Datenspuren).
	DB	00H,00H,00H,0BCH,20H,43H,18H,6EH	; 1038: .... C.n
	DB	21H,3CH,21H,28H,00H,04H,0FH,00H	; 1040: !<!(....
	DB	85H,01H,7FH,00H,0C0H,00H,20H,00H	; 1048: ...... .
	DB	04H,00H,63H,03H,07H,01H,00H,0A0H	; 1050: ..c.....
	DB	01H,50H,28H,39H,01H,02H,03H,04H	; 1058: .P(9....
	DB	05H,06H,07H,08H,09H,0AH,0BH,0CH	; 1060: ........
	DB	0DH,0EH,0FH,10H,11H,12H,13H,14H	; 1068: ........
	DB	15H,16H,17H,18H,19H,1AH,28H,00H	; 1070: ......(.
	DB	03H,07H,00H,0BDH,00H,3FH,00H,0C0H	; 1078: .....?..
	DB	00H,10H,00H,02H,00H,02H,03H,07H	; 1080: ........
	DB	01H,00H,28H,02H,28H,82H,18H,01H	; 1088: ..(.(...

; ======================================================================
; GOCPM: CP/M-Kaltstart-Initialisierung (1090H-10B1H)
; ======================================================================
; Wird nach erfolgreichem Laden von @OS.COM aufgerufen.
; Patcht die drei Standard-JP-Befehle des CP/M-Systems:
;   0000H: JP 1803H  (BIOS WBOOT Vektor)
;   0005H: JP 0906H  (BDOS Einstieg)
; Setzt DMA-Adresse auf Standard 0080H, aktiviert Interrupts
; und springt zum CCP (Command Console Processor) bei 0883H.
	LD	A,0C3H		; 1090: 0C3H = JP-Opcode
	LD	(0000H),A		; 1092: JP bei Adresse 0000H
	LD	HL,1803H		; 1095: Ziel: BIOS WBOOT (1803H)
	LD	(0001H),HL		; 1098: -> 0001H/0002H = Warmstart-Adresse
	LD	(0005H),A		; 109B: JP bei Adresse 0005H
	LD	HL,0906H		; 109E: Ziel: BDOS Einstieg
	LD	(0006H),HL		; 10A1: -> 0006H/0007H = BDOS-Adresse
	LD	BC,0080H		; 10A4: Standard-DMA = 0080H
	CALL	197CH		; 10A7: -> SETDMA (BIOS-Funktion)
	EI		; 10AA: Interrupts freigeben
	LD	A,(0004H)		; 10AB: CDISK (aktuelle Disknummer)
	LD	C,A		; 10AE: C = Disknummer fuer CCP
	JP	0883H		; 10AF: -> CCP (Command Console Processor)

; --- CONOUT-Verarbeitung / Bildschirmtreiber (10B2H-1134H) ---
; Verarbeitet Zeichen fuer die Konsol-Ausgabe.
; - 10B2H: Zeichenpuffer-Position berechnen (Memory-Mapped Video)
; - 10C2H: Druckbare Zeichen (20H-7EH) direkt in Video-RAM schreiben
; - 10D4H-10EFH: Bildschirm scrollen (LDIR/LDDR fuer Zeilen-Verschiebung)
; - 10F0H: Cursor-Position aktualisieren, Cursor-Marker setzen (Bit 7)
; - 10F9H: Steuerzeichen-Handler: prueft Tabelle bei 1135H
;          (BS, LF, CR, TAB, FF, BEL) und springt zu Handlern
; - 1118H-1134H: Cursor-Begrenzung und Zeilen-Berechnung
	PUSH	BC		; 10B2: Register sichern
	LD	HL,18F0H		; 10B3: Ruecksprungadresse auf Stack
	PUSH	HL		; 10B6
	LD	HL,(1947H)		; 10B7: aktuelle Cursor-Position
	RES	7,(HL)		; 10BA: Cursor-Marker loeschen
	LD	A,C		; 10BC: C = auszugebendes Zeichen
	LD	(18CBH),A		; 10BD: Zeichen speichern
	AND	7FH		; 10C0: Bit 7 maskieren
; --- Druckbares Zeichen (20H-7EH)? ---
	CP	20H		; 10C2: < SPACE?
	JR	C,10F9H		; 10C4: ja -> Steuerzeichen-Handler
	CP	7FH		; 10C6: > 7EH (DEL)?
	JR	NC,10F9H		; 10C8: ja -> Steuerzeichen-Handler
; --- Zeichen in Video-RAM schreiben ---
	LD	(HL),00H		; 10CA: alte Position loeschen
	EX	DE,HL		; 10CC: DE = Cursor-Position
	LD	HL,0001H		; 10CD: Offset +1
	ADD	HL,DE		; 10D0: naechste Position
	EX	DE,HL		; 10D1: DE = naechste Position
	INC	HL		; 10D2: HL weiter
	RET	NC		; 10D3: kein Ueberlauf -> fertig
; --- Bildschirm scrollen ---
	LD	DE,0FFC0H		; 10D4: Scroll-Offset (-64 Bytes)
	PUSH	DE		; 10D7
	LD	HL,0FC40H		; 10D8: Quell-Adresse (2. Zeile)
	LD	DE,0FC00H		; 10DB: Ziel-Adresse (1. Zeile)
	LD	BC,03C0H		; 10DE: 960 Bytes (= 15 Zeilen a 64 Zeichen)
	LDIR		; 10E1: Zeilen nach oben kopieren
	DEC	HL		; 10E3
	LD	(HL),00H		; 10E4: letzte Zeile loeschen
	LD	DE,0FFFEH		; 10E6: Loeschrichtung rueckwaerts
	LD	BC,003FH		; 10E9: 63 Bytes (Rest der letzten Zeile)
	LDDR		; 10EC: letzte Zeile komplett loeschen
	POP	HL		; 10EE
	RET		; 10EF
; --- Cursor-Position aktualisieren ---
	LD	(1947H),HL		; 10F0: neue Cursor-Position speichern
	LD	A,80H		; 10F3: Cursor-Marker (Bit 7)
	OR	(HL)		; 10F5: mit Zeichen ver-ODERn
	LD	(HL),A		; 10F6: -> Video-RAM (Cursor sichtbar)
	POP	BC		; 10F7
	RET		; 10F8
; --- Steuerzeichen-Handler: Tabelle durchsuchen ---
	EX	DE,HL		; 10F9
	LD	HL,1935H		; 10FA: Steuerzeichen-Tabelle (6 Eintraege)
	LD	BC,0006H		; 10FD: 6 Zeichen pruefen
	CPIR		; 1100: A in Tabelle suchen
	JR	Z,1109H		; 1102: gefunden -> Handler aufrufen
	LD	C,5EH		; 1104: '^'-Zeichen (unbekanntes Ctrl)
	EX	DE,HL		; 1106
	JR	10BCH		; 1107: -> als '^' + Zeichen ausgeben
; --- Handler-Adresse aus Tabelle laden ---
	LD	HL,1946H		; 1109: Ende der Handler-Tabelle
	XOR	A		; 110C
	SBC	HL,BC		; 110D: HL-BC = Tabellen-Index
	SBC	HL,BC		; 110F: nochmal (2 Bytes pro Eintrag)
	LD	B,(HL)		; 1111: High-Byte der Handler-Adresse
	DEC	HL		; 1112
	LD	C,(HL)		; 1113: Low-Byte
	PUSH	BC		; 1114: Handler-Adresse auf Stack
	LD	L,E		; 1115: Cursor-Position zurueck
	LD	H,D		; 1116
	RET		; 1117: -> Handler aufrufen (via PUSH+RET)
; --- Cursor nach rechts begrenzen ---
	LD	BC,0040H		; 1118: 64 Zeichen pro Zeile
	LD	HL,0FFFFH		; 111B: -1
	SBC	HL,BC		; 111E: Zeilen-Ende berechnen
	PUSH	HL		; 1120
	SBC	HL,DE		; 1121: noch Platz?
	POP	HL		; 1123
	JR	NC,111EH		; 1124: ja -> weiter
	INC	HL		; 1126
	RET		; 1127
; --- Cursor nach unten begrenzen (Scroll-Pruefung) ---
	LD	HL,0FFBFH		; 1128: letzte Bildschirmposition-1
	SBC	HL,DE		; 112B: Cursor > Ende?
	JP	C,18D7H		; 112D: ja -> Scroll-Routine
	LD	HL,0040H		; 1130: eine Zeile weiter
	ADD	HL,DE		; 1133: neue Position
	RET		; 1134

; --- Steuerzeichen-Tabelle + Handler-Adressen (1135H-1147H) ---
; 1135H: 6 Steuerzeichen-Codes: 04H(EOT), 05H(ENQ), 06H(ACK),
;        07H(BEL), 0AH(LF), 0DH(CR)
; 113BH: 6 zugehoerige Handler-Adressen (16-Bit, je 2 Bytes):
;        18CAH, 18CAH, 18CAH, 18CCH, 1928H, 1918H
; 1145H: 3 Parameter-Bytes (18H, 19H, 00H)
	DB	04H,05H,06H,07H,0AH,0DH,0CAH,18H	; 1135: ........
	DB	0CAH,18H,0CAH,18H,0CCH,18H,28H,19H	; 113D: ......(.
	DB	18H,19H,00H	; 1145: ...

; ======================================================================
; FDC-Treiber: Disk-Read/Write/Seek (1148H-13B7H)
; ======================================================================
; Vollstaendiger FDC-Treiber fuer die K5122-Floppy-Controller-Karte.
; Implementiert Sektor-Lesen, -Schreiben und Kopf-Positionierung.
;
; Wesentliche Funktionen:
;  1148H: Laufwerk-Auswahl (prueft ob LW existiert, initialisiert)
;  1164H: Laufwerk-Parameter laden (Spurtabelle, Seiteninfo)
;  1177H: Spur setzen (LD (1BDCH),A)
;  117CH: DMA-Adresse setzen (LD (1BDFH),BC)
;  1181H: Sektor-Uebersetzung (Skew-Table Lookup)
;  1185H: Fehler-Rueckgabe (LD A,01H ; RET)
;  1188H: Sektor-Lesen/Schreiben (Hauptzugang)
;         - Prueft Laufwerk-Bereitschaft via CALL 20ABH
;         - Berechnet physische Spur aus logischer Sektor-Nr.
;         - Behandelt doppelseitige Disketten (IX+15 Bits)
;         - Ruft Seek (1A71H/1A77H) und Transfer (1BF0H) auf
;  1271H: Cache-Flush (schreibt gepufferte Sektoren)
;  1286H: Multi-Sektor-Transfer (Block-Lesen/-Schreiben)
;
; Register-Konventionen:
;  IX = Zeiger auf Laufwerks-Deskriptor (DPH-Erweiterung)
;  IY = ft.*-Parameterblock (bei PARAM_TAB, 0400H)
;  (1BCFH-1BE3H) = FDC-Arbeitsbereich (Flags, Zaehler, Cache)
;
; Entspricht biosdskt.mac (K5122 physischer Floppy-Treiber),
; allerdings als kompakte Boot-Version ohne Format-/Verify-Code.
; --- FDC-Treiber: Laufwerk-Auswahl (1148H) ---
	CALL	M,0ABCDH		; 1148: (Patch-Adresse fuer Self-Modifying Code)
	JR	NZ,1115H		; 114B: wenn Z nicht gesetzt -> Fehler
	LD	A,C		; 114D: C = Laufwerksnummer (0-3)
	LD	(1BD9H),A		; 114E: -> aktuelles Laufwerk speichern
	BIT	0,E		; 1151: E Bit 0: nur Auswahl, kein Init?
	RET	NZ		; 1153: ja -> zurueck
	PUSH	HL		; 1154
