; ============================================================================
; zre.prn  -  ZRE/K2526 Boot-EPROM (Lade-ROM A26), 1 KB, 0000H-03FFH
;
; Kommentiertes MACRO-80-kompatibles Listing fuer k1520dbg / boot_trace (-l).
; Erzeugt von tools/gen_zre_prn.py aus zre.rom (Bytes) + zre_rom.asm (Kommentare).
; Bytes byte-bestaetigt gegen den realen Chip (Hauptteil 0100H-03FFH ==
; A5120_ZRE_rom.bin[0000:0300], dem realen EPROM-Dump).
;
; Speicher:  0000-00FF Reset/Init-Prolog (loescht 2 KB RAM, IM2, PIO, ISR-Vekt.)
;            0100-03FF Hauptteil (Drive-Probe, ZVE2-DMA-Bootloader, ISRs)
;
; CPU-Zuordnung (jede Code-Zeile traegt [ZVE1]/[ZVE2] im Kommentar;
; empirisch via boot_trace --coverage cpu,pc + Kontrollfluss bestaetigt):
;   ZVE2 (DMA-CPU):  0x01DD-0x027D  = die EINE STROBE_LOOP-Sektorlade-Routine
;        (IDAM-Suche, INI/INIR-Transfer, DONE [03F8]=3, Mehrsektor-Reentry),
;        betreten nur ueber RAM[0000]=C3 DD 01 = JP 01DD.
;   ZVE1 (Haupt-CPU): 0x0000-0x01DC + 0x027E-0x03FF = alles andere
;        (Reset/Init, Seek/Retry, Drive-Init das ZVE2 startet @0194,
;        IM2-Index-ISR @01C7, Signatur-Check @01B6, Alt-Boot @027E, RAM-Vars).
; IM2-ISRs (auf ZVE1): Vektor 0xB8 -> 007A (BS-PIO),  0xBA -> 01C7 (Index-Puls)
;
; FM/MFM:  [0x03FD] bit1 = FM(1)/MFM(0)-Modus des K5122-Datenseparators.
;          Default 0x87=FM @0137; Retry toggelt via XOR 02h @0151 zu 0x85=MFM;
;          @01AD -> Port 0x10; ZVE2 testet BIT 1 @022B u. @025A. bit7=Step-Unterdr.
; CRC:     Das Boot-ROM PRUEFT KEINE CRC. ZVE2 validiert nur das IDAM-Feld
;          (cyl/head/sec/size) + Boot-Signatur @01B6; CRC-Bytes @0245/0247 werden
;          nur gelesen. Echte CRC-Pruefung (sub_0407, Dual-Seed 0xBF84 FM/0xE295
;          MFM via [0x03FD] bit1) liegt im GELADENEN Lader (RAM 0x04xx), nicht hier.
; RAM-Vars:  03F0 Ladeadr | 03F3 Zyl | 03F5 Kopf/Sektor | 03F7 Index-Zaehler
;            03F8 Done-Flag(0/1/3) | 03FA Retry | 03FC Port10-Ctrl | 03FD FM/MFM-Pfad
; ============================================================================

	ORG	0000H

0000  00            RESET_ENTRY:	NOP		;[ZVE1] [RESET ENTRY POINT]
0001  01 00 08      	LD BC,0800h		;[ZVE1] BC=0x0800=2048: Byte-Zähler für LDI-Schleife (löscht 2 KB RAM)
0004  51            	LD D,C		;[ZVE1] DE=HL=0x0000: Quelle und Ziel zeigen beide auf Adresse 0
0005  59            	LD E,C		;[ZVE1]
0006  61            	LD H,C		;[ZVE1]
0007  69            	LD L,C		;[ZVE1]
0008  ED A0         CLEAR_LOOP:	LDI		;[ZVE1] LDI-Trick: ROM[0x0000]=NOP=0x00 wird nach RAM[DE++] geschrieben. | DEC HL haelt HL=0x0000 (Quelle bleibt immer bei NOP). | JP PE: PV-Flag von LDI zeigt BC!=0 (noch Bytes uebrig).
000A  2B            	DEC HL		;[ZVE1]
000B  EA 08 00      	JP PE,0008h		;[ZVE1]
000E  AF            INIT_PORTS:	XOR A		;[ZVE1] [HARDWARE-GRUNDINITIALISIERUNG]
000F  D3 02         	OUT (02h),A		;[ZVE1] Port 0x02 = Bank-Select: 0 → Bank 0 aktiv
0011  31 E0 07      	LD SP,07E0h		;[ZVE1] SP = 0x07E0: Stack unterhalb des 2 KB RAM-Bereichs
0014  ED 5E         	IM 2		;[ZVE1] IM 2: ISR-Adresse = memory[(I<<8) | device_vector]
0016  3E 00         	LD A,00h		;[ZVE1] I = 0x00 → Vektor-Tabelle beginnt bei RAM[0x0000]
0018  ED 47         	LD I,A		;[ZVE1]
001A  3E 7F         INIT_BS_PIO:	LD A,7Fh		;[ZVE1] [BS-PIO (K2526-interne PIO, Ports 0x08/09/0A/0B) INIT] | BS-PIO steuert RAM-Banken, ROM-Enable und Drive-Select. | Port 0x08=Port-A-Daten, 0x09=Port-A-Ctrl | Port 0x0A=Port-B-Daten, 0x0B=Port-B-Ctrl
001C  D3 09         	OUT (09h),A		;[ZVE1] Port A ctrl: 0x7F = Modus 1 (Input)
001E  D3 0B         	OUT (0Bh),A		;[ZVE1] Port B ctrl: 0x7F = Modus 1 (Input)
0020  3E FF         	LD A,FFh		;[ZVE1]
0022  D3 08         	OUT (08h),A		;[ZVE1] Port A Daten = 0xFF (alle Leitungen high)
0024  D3 0A         	OUT (0Ah),A		;[ZVE1] Port B Daten = 0xFF (alle Leitungen high)
0026  3E B8         	LD A,B8h		;[ZVE1]
0028  D3 09         	OUT (09h),A		;[ZVE1] Port A: Interrupt-Vektor = 0xB8 → ISR-Adresse aus RAM[0xB8,0xB9]
002A  3E FF         	LD A,FFh		;[ZVE1]
002C  D3 09         	OUT (09h),A		;[ZVE1] Port A: Modus 3 (Bit-Control: einzelne Bits konfigurierbar)
002E  3E 7F         	LD A,7Fh		;[ZVE1]
0030  D3 09         	OUT (09h),A		;[ZVE1] Modus-3 I/O-Maske: Bit7=Output (ROM-Disable/Drive-Ctrl), Bits6..0=Input
0032  DD 21 00 08   RAM_TEST:	LD IX,0800h		;[ZVE1] [RAM-TEST / BANK-WALK (62 Durchlaeufe, je 1 KB)] | Testet 62 x 1KB-Bloecke (IX=0x0800, 0x0C00, ..., 0xFC00). | Waehrend EI/DI-Fenster: falls /ASTB feuert → ISR_BS_PIO_A (0x007A).
0036  DD 22 62 04   	LD (0462h),IX		;[ZVE1] IX (Startadresse erste RAM-Bank) in RAM[0x0462] sichern
003A  21 4E 04      	LD HL,044Eh		;[ZVE1] HL → Config-Flag bei 0x044E (nach RAM-Clear = 0x00)
003D  11 00 04      	LD DE,0400h		;[ZVE1] DE = 0x0400 = IX-Inkrement (1 KB pro Bankschritt)
0040  06 3E         	LD B,3Eh		;[ZVE1] B = 62 Iterationen (0x3E)
0042  DD 4E 00      RAM_TEST_LOOP:	LD C,(IX+0)		;[ZVE1] C = aktueller RAM-Inhalt (wird nach ISR-Aufruf wiederhergestellt)
0045  3E D7         	LD A,D7h		;[ZVE1] BS-PIO Port A Int-Ctrl: 0xD7 = INTENA=1, OR-Modus, H-Level, Maske folgt
0047  D3 09         	OUT (09h),A		;[ZVE1]
0049  3E 9F         	LD A,9Fh		;[ZVE1] Interrupt-Maske = 0x9F
004B  D3 09         	OUT (09h),A		;[ZVE1]
004D  FB            	EI		;[ZVE1] EI: Interrupt-Fenster oeffnen
004E  DD 36 00 FF   	LD (IX+0),FFh		;[ZVE1] Schreibe 0xFF → RAM[IX+0]: RAM-Test-Markierung; ISR prueft ob Schreiben geklappt
0052  00            	NOP		;[ZVE1]
0053  F3            	DI		;[ZVE1] DI: Interrupt-Fenster schliessen
0054  3E 47         	LD A,47h		;[ZVE1] BS-PIO Port A: INTENA=0 (kein weiterer Interrupt von Port A)
0056  D3 09         	OUT (09h),A		;[ZVE1]
0058  DD 19         	ADD IX,DE		;[ZVE1] IX += 0x0400 → naechster 1 KB-Block
005A  10 E6         	DJNZ 0042h		;[ZVE1]
005C  21 6F 04      COPY_DISK_TBL:	LD HL,046Fh		;[ZVE1] [DISK-PARAMETER-TABELLE KOPIEREN (ROM → RAM)] | Quelle 0x046F liegt ausserhalb des 1 KB ROM (endet bei 0x03FF), | daher wird tatsaechlich RAM[0x046F..] gelesen (= 0x00 nach Clear).
005F  11 6F 00      	LD DE,006Fh		;[ZVE1]
0062  01 24 00      	LD BC,0024h		;[ZVE1] 36 Byte rueckwaerts kopieren (LDDR)
0065  ED B8         	LDDR		;[ZVE1]
0067  21 4E 04      CHECK_BOOT_FLAG:	LD HL,044Eh		;[ZVE1] [BOOT-FLAG PRUEFEN] | RAM[0x044E] Bit0: 0=erster Boot (ROM aktiv), 1=ROM bereits deaktiviert
006A  CB 46         	BIT 0,(HL)		;[ZVE1] Bit0 testen
006C  28 4E         	JR Z,00BCh		;[ZVE1] Z (Bit0=0): erster Boot → springe zu ROM_COPY (0x00BC)
006E  21 00 08      SKIP_ROM_COPY:	LD HL,0800h		;[ZVE1] Bit0=1: ROM-Inhalt liegt bereits in RAM → direkt zum Hauptprogramm
0071  22 4C 00      	LD (004Ch),HL		;[ZVE1] [0x004C] = 0x0800 (Ladeadresse fuer naechste Stufe)
0074  2A 62 04      	LD HL,(0462h)		;[ZVE1] HL = gesicherter IX-Wert (erste gueltige RAM-Bank aus RAM-Test)
0077  2E 9D         	LD L,9Dh		;[ZVE1] L = 0x9D: Offset innerhalb der Bank → Sprung zu HL|0x9D
0079  E9            	JP (HL)		;[ZVE1]
007A  3E 47         ISR_BS_PIO_A:	LD A,47h		;[ZVE1] [ISR: BS-PIO PORT A (Vektor 0xB8 → ISR-Adresse RAM[0xB8,0xB9]={0x7A,0x00}=0x007A)] | Aufgerufen wenn /ASTB waehrend RAM-Test feuert. | Prueft ob RAM-Block korrekt beschrieben ist und protokolliert | erste/letzte gueltige RAM-Bank in RAM[0x0460]/RAM[0x0464].
007C  D3 09         	OUT (09h),A		;[ZVE1] BS-PIO Port A: INTENA=0 (kein weiterer Interrupt waehrend ISR)
007E  3E FF         	LD A,FFh		;[ZVE1]
0080  DD BE 00      	CP (IX+0)		;[ZVE1] CP (IX+0): ist RAM-Block korrekt mit 0xFF beschrieben?
0083  20 22         	JR NZ,00A7h		;[ZVE1] NZ: RAM nicht beschreibbar → Fehler-Pfad bei 0x00A7
0085  DD 71 00      	LD (IX+0),C		;[ZVE1] Originalwert (C) wiederherstellen
0088  CB 46         	BIT 0,(HL)		;[ZVE1] HL zeigt auf Config-Flag 0x044E; Bit0='erste Bank bereits gefunden'
008A  20 06         	JR NZ,0092h		;[ZVE1] Bit0 gesetzt → nicht erste gueltige Bank → bei 0x0092
008C  DD 22 60 04   	LD (0460h),IX		;[ZVE1] Erste gueltige Bank: speichere IX in RAM[0x0460]
0090  ED 4D         	RETI		;[ZVE1]
0092  DD 22 64 04   	LD (0464h),IX		;[ZVE1] Nicht erste Bank: speichere IX als letzte valide Bank in RAM[0x0464]
0096  CB 76         	BIT 6,(HL)		;[ZVE1] Bit6: 'bevorzugte Boot-Bank bereits gefunden'?
0098  20 0B         	JR NZ,00A5h		;[ZVE1]
009A  CB F6         	SET 6,(HL)		;[ZVE1] Bit6 noch nicht gesetzt: markiere diese Bank als Boot-Bank
009C  DD 22 6C 04   	LD (046Ch),IX		;[ZVE1] Speichere IX in RAM[0x046C] (Boot-Bank-Adresse)
00A0  3E 05         	LD A,05h		;[ZVE1]
00A2  32 6C 04      	LD (046Ch),A		;[ZVE1] [0x046C] = 5 (Bank-Qualitaets-Code / Retry-Zaehler)
00A5  ED 4D         	RETI		;[ZVE1]
00A7  CB 46         	BIT 0,(HL)		;[ZVE1] Fehler-Pfad: RAM-Block nicht beschreibbar
00A9  20 06         	JR NZ,00B1h		;[ZVE1]
00AB  CB C6         	SET 0,(HL)		;[ZVE1] Erster Fehler: Bit0 setzen, IX als erste Fehler-Bank sichern
00AD  DD 22 62 04   	LD (0462h),IX		;[ZVE1]
00B1  DD 22 64 04   	LD (0464h),IX		;[ZVE1] Immer: IX als letzte gesehene Bank sichern
00B5  ED 4D         	RETI		;[ZVE1]
00B7  00            ROM_DATA_BA_BB:	NOP		;[ZVE1] [ROM-DATEN: ISR-VEKTOR-EINTRAEGE (kein ausfuehrbarer Code!)] | Diese Bytes werden durch LDIR (bei 0x00C4) 1:1 in RAM kopiert | und bilden Eintraege in der IM-2-Vektor-Tabelle: | RAM[0xB8,0xB9] = {0x7A, 0x00} → Vektor 0xB8 → ISR 0x007A (BS-PIO) | RAM[0xBA,0xBB] = {0xC7, 0x01} → Vektor 0xBA → ISR 0x01C7 (K5122!) | ACHTUNG: Disassembler-Fehlausrichtung! ROM[0xBB]=0x01 (ISR-High-Byte) | wird als Beginn von 'LD BC,nn' fehlinterpretiert. ROM[0xBC]=0x21 ist | tatsaechlich der 'LD HL'-Opcode des ROM_COPY-Einstiegs (JR Z,00BCh).
00B8  7A            	LD A,D		;[ZVE1] [DATA] ROM[0xB8]=0x7A → ISR-Adresse-Low fuer Vektor 0xB8
00B9  00            	NOP		;[ZVE1] [DATA] ROM[0xB9]=0x00 → ISR-Adresse-High → ISR=0x007A (BS-PIO)
00BA  C7            	RST 00h		;[ZVE1] [DATA] ROM[0xBA]=0xC7 → ISR-Adresse-Low fuer Vektor 0xBA
00BB  01 21 BA      	LD BC,BA21h		;[ZVE1] [DATA+CODE] ROM[0xBB]=0x01 (ISR-High) | ROM[0xBC]=0x21 (LD HL Opcode) | Disassembler liest 0x01,0x21,0xBA faelschlich als 'LD BC,0xBA21' | Echter ROM_COPY-Einstieg: 0xBC=LD HL, 0xBD=0xBA, 0xBE=0x00 → HL=0x00BA
00BE  00            	NOP		;[ZVE1] [LD HL operand high = 0x00]; ROM_COPY-Code beginnt hier korrekt geparst
00BF  54            	LD D,H		;[ZVE1] [ROM → RAM KOPIEREN (erster Boot, Einstieg via JR Z von 0x006C)] | Kopiert 838 Byte ROM[0x00BA..0x03FF] → RAM[0x00BA..0x03FF]: | Enthaelt ISR-Vektor-Daten (0xBA/0xBB) und alle Laufzeit-Routinen. | DE = HL = 0x00BA: Quelle und Ziel identisch (ROM und RAM gleiche Adresse)
00C0  5D            	LD E,L		;[ZVE1]
00C1  01 46 03      	LD BC,0346h		;[ZVE1] BC = 0x0346 = 838 Byte (0x00BA bis 0x03FF inkl.)
00C4  ED B0         	LDIR		;[ZVE1] Nach LDIR: RAM[0xBA]=0xC7, RAM[0xBB]=0x01 → ISR-Vektor 0xBA fertig
00C6  3E FF         POST_COPY_INIT:	LD A,FFh		;[ZVE1] [POST-COPY HARDWARE-INITIALISIERUNG] | ROM-Kopie abgeschlossen. Alle Laufzeit-Routinen jetzt in RAM. | Naechster Schritt: ROM deaktivieren, K5122 (Floppy-Controller) konfigurieren.
00C8  D3 0B         	OUT (0Bh),A		;[ZVE1] BS-PIO Port B ctrl (0x0B): 0xFF = Modus 3 (Bit-Control)
00CA  D3 13         	OUT (13h),A		;[ZVE1] K5122 ctrl PIO Port B ctrl (Port 0x13): 0xFF = Modus 3
00CC  3E E2         	LD A,E2h		;[ZVE1]
00CE  D3 0B         	OUT (0Bh),A		;[ZVE1] BS-PIO Port B: Interrupt-Vektor = 0xE2 (nicht weiter genutzt)
00D0  DB 0A         	IN A,(0Ah)		;[ZVE1] Lese BS-PIO Port B Daten (Hardware-Konfigurations-Bits)
00D2  E6 F6         	AND F6h		;[ZVE1] AND 0xF6 = ~0x09: loescht Bit0 (ROM-Enable) und Bit3
00D4  D3 0A         	OUT (0Ah),A		;[ZVE1] Schreibe zurueck: Bit0=0 → ROM DEAKTIVIERT (laeuft jetzt aus RAM)
00D6  FB            ENABLE_INTS_INIT:	EI		;[ZVE1] EI: Interrupts freigeben (ROM aus, ISR-Vektoren in RAM bereit)
00D7  3E F3         	LD A,F3h		;[ZVE1]
00D9  D3 13         	OUT (13h),A		;[ZVE1] K5122 ctrl PIO Port B ctrl (Port 0x13): 0xF3 = E/A-Richtungsmaske (nach Modus 3): b2=/HF, b3=PRE = Ausgang
00DB  3E 7F         	LD A,7Fh		;[ZVE1]
00DD  D3 12         	OUT (12h),A		;[ZVE1] K5122 ctrl PIO Port B Daten (Port 0x12): 0x7F || DATENRATE: Tor B (Port 0x12) = 0x7F -> bit2=/HF=1 = NIEDRIGE Frequenz. Laut K5122-Doku deckt /HF=1 sowohl FM-8"-Laufwerke (MF3200/6400) ALS AUCH MFM-5,25" (MFS) ab -> derselbe Takt fuer beide; nur die Markenart (MK, FM/MFM) wird per Trial-and-Error variiert. /HF wird hier FEST gesetzt, NICHT mitgetoggelt (MFM-8", das /HF=0/hohe Frequenz braeuchte, liefe damit NICHT).
00DF  D3 11         	OUT (11h),A		;[ZVE1] K5122 ctrl PIO Port A ctrl (Port 0x11): 0x7F = Modus 1 (Input)
00E1  3E A9         	LD A,A9h		;[ZVE1]
00E3  D3 10         	OUT (10h),A		;[ZVE1] K5122 ctrl PIO Port A Daten (Port 0x10): 0xA9 = Drive-Steuer-Byte | Bit7=1 (kein Step), Bit3=1 (/STR high)
00E5  3E 3F         	LD A,3Fh		;[ZVE1]
00E7  D3 11         	OUT (11h),A		;[ZVE1] K5122 ctrl PIO Port A ctrl: 0x3F = MODUS 0 (Output)! | In Modus 0 loest /ASTB-Flanke (=Indexpuls) Interrupt aus.
00E9  D3 15         	OUT (15h),A		;[ZVE1] K5122 data PIO Port A ctrl (Port 0x15): 0x3F = Modus 0 (Output)
00EB  3E BA         	LD A,BAh		;[ZVE1] *** K5122 ctrl PIO Port A: INTERRUPT-VEKTOR = 0xBA *** | Indexpuls (/ASTB fallend) → CPU-Interrupt → ISR = RAM[0xBA,0xBB] = 0x01C7
00ED  D3 11         	OUT (11h),A		;[ZVE1]
00EF  3E 04         	LD A,04h		;[ZVE1] [0x07F2] = 4: Seek-Retry-Zaehler
00F1  32 F2 07      	LD (07F2h),A		;[ZVE1]
00F4  3E C3         	LD A,C3h		;[ZVE1] RAM[0x0000] = 0xC3 (JP-Opcode): ueberschreibt die geloopten NOPs
00F6  32 00 00      	LD (0000h),A		;[ZVE1]
00F9  21 DD 01      	LD HL,01DDh		;[ZVE1] RAM[0x0001,0x0002] = 0x01DD → JP 0x01DDh (STROBE_LOOP-Einstieg) | ZVE2 startet bei PC=0x0000 und springt damit sofort zu STROBE_LOOP
00FC  22 01 00      	LD (0001h),HL		;[ZVE1]
00FF  3E EE         	LD A,EEh		;[ZVE1] [0x03FC] = 0xEE: initialer Ctrl-Wert fuer Port 0x10 | 0xEE: Bit0=0 (Read-Modus), Bit3=1 (/STR high), kein Drive aktiv
0101  32 FC 03      	LD (03FCh),A		;[ZVE1]
0104  D3 18         	OUT (18h),A		;[ZVE1] Port 0x18 (8212-Latch Drive-Select): 0xEE → kein Drive selektiert
0106  21 00 04      	LD HL,0400h		;[ZVE1] HL = 0x0400: Ladeadresse fuer Bootsektor-Daten
0109  45            	LD B,L		;[ZVE1] B = 0x00 (= Low-Byte von HL)
010A  22 F0 03      	LD (03F0h),HL		;[ZVE1] [0x03F0] = 0x0400: Ladeadresse sichern
010D  11 06 50      	LD DE,5006h		;[ZVE1] D=0x50 (Outer-Retry-Zaehler), E=0x06
0110  DB 12         DRIVE_DETECT_LOOP:	IN A,(12h)		;[ZVE1] [LAUFWERK-ERKENNUNG] | Liest Drive-Status aus K5122 ctrl PIO Port B (Port 0x12). | RLCA rotiert Bit7 in Carry: Carry=0 → Bit7 war 0 → Drive bereit.
0112  07            	RLCA		;[ZVE1] altes Bit7 → Carry
0113  30 13         	JR NC,0128h		;[ZVE1] Carry=0 (Bit7=0) → Drive bereit → WAIT_INDEX_SETUP
0115  15            	DEC D		;[ZVE1] kein Drive bereit: Outer-Retry--
0116  28 28         	JR Z,0140h		;[ZVE1] Retry erschoepft → BOOT_FAIL
0118  3E 09         SEND_SEEK_TRACK0:	LD A,09h		;[ZVE1] Seek-to-Track-0: Step-Pulse senden um Kopf auf Track 0 zu setzen
011A  47            	LD B,A		;[ZVE1]
011B  D3 10         	OUT (10h),A		;[ZVE1] Port 0x10 Ctrl: Step-Puls ausloesen (Bit3 faellt)
011D  3E 89         	LD A,89h		;[ZVE1]
011F  D3 10         	OUT (10h),A		;[ZVE1]
0121  0D            	DEC C		;[ZVE1] Delay-Schleife (innerer Zaehler C)
0122  20 FD         	JR NZ,0121h		;[ZVE1]
0124  10 FB         	DJNZ 0121h		;[ZVE1] Delay-Schleife (aeusserer Zaehler B)
0126  18 E8         	JR 0110h		;[ZVE1]
0128  21 F7 03      WAIT_INDEX_SETUP:	LD HL,03F7h		;[ZVE1] [4 INDEX-PULSE ABWARTEN] | Jeder Indexpuls → ISR 0x01C7 → [0x03F7]--. | Nach 4 Pulsen (= 4 Umdrehungen x 200 ms = 800 ms) → STORE_03FD.
012B  36 04         	LD (HL),04h		;[ZVE1] [0x03F7] = 4: Puls-Zaehler (ISR dekrementiert auf 0)
012D  3E 97         	LD A,97h		;[ZVE1] Port 0x11 Int-Ctrl: 0x97 = INTENA=1, OR-Modus, H-Level, Maske folgt
012F  D3 11         	OUT (11h),A		;[ZVE1]
0131  3E FF         	LD A,FFh		;[ZVE1] Interrupt-Maske = 0xFF (in Modus 0 ignoriert; IE wird durch 0x97 gesetzt)
0133  D3 11         	OUT (11h),A		;[ZVE1]
0135  7E            WAIT_INDEX_LOOP:	LD A,(HL)		;[ZVE1] A = [0x03F7] lesen; A=0x87 vorladen fuer [0x03FD] (NZ-Pfad + kein Step)
0136  B7            	OR A		;[ZVE1] Z-Flag setzen wenn [0x03F7]=0
0137  3E 87         	LD A,87h		;[ZVE1] A = 0x87 vorladen: Bit7=1 (kein Step), Bit1=1 (NZ-Pfad) || FM/MFM: A=0x87 = Default-FM-Pfadbyte (Trial-and-Error-Startwert). [0x03FD] bit1 geht @01AD nach Port 0x10 = Signal MK des K5122 (Tor A bit1) und waehlt FM(1)/MFM(0). bit7=1 unterdrueckt Step-Puls. Abgelegt auf der Index-OK-Erfolgsstrecke (JR Z @0139 -> STORE_03FD @0153).
0139  28 18         	JR Z,0153h		;[ZVE1] [0x03F7]=0 → 4 Pulse empfangen → springe zu STORE_03FD
013B  0D            	DEC C		;[ZVE1] Timeout-Zaehler dekrementieren
013C  20 F7         WAIT_INDEX_INNER:	JR NZ,0135h		;[ZVE1]
013E  10 F5         	DJNZ 0135h		;[ZVE1]
