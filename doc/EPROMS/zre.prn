02A0  3E 03         	LD A,03h		;[ZVE1]
02A2  D3 34         	OUT (34h),A		;[ZVE1]
02A4  3C            	INC A		;[ZVE1]
02A5  D3 35         	OUT (35h),A		;[ZVE1] A = 4
02A7  3E FF         	LD A,FFh		;[ZVE1]
02A9  D3 37         	OUT (37h),A		;[ZVE1]
02AB  3E FD         	LD A,FDh		;[ZVE1]
02AD  D3 37         	OUT (37h),A		;[ZVE1]
02AF  3E FF         	LD A,FFh		;[ZVE1]
02B1  D3 36         	OUT (36h),A		;[ZVE1]
02B3  3E 80         	LD A,80h		;[ZVE1]
02B5  D3 36         	OUT (36h),A		;[ZVE1]
02B7  DB 34         	IN A,(34h)		;[ZVE1] Status lesen und pruefen ob Controller bereit
02B9  E6 7C         	AND 7Ch		;[ZVE1] Maske Bits 6..2: Fehler-Bits
02BB  C2 B0 03      	JP NZ,03B0h		;[ZVE1] Fehler → HALT-Schleife (0x03B0)
02BE  1E 09         	LD E,09h		;[ZVE1]
02C0  3E F2         	LD A,F2h		;[ZVE1]
02C2  D3 0C         INIT_CTC:	OUT (0Ch),A		;[ZVE1] [K2526 CTC-INITIALISIERUNG (nur im alternativen Boot-Pfad)] | Port 0x0C = K2526 CTC Kanal 0, Port 0x0D = CTC Kanal 1
02C4  3E 05         	LD A,05h		;[ZVE1] CTC Kanal 0: 0xF2 konfigurieren (Timer-Modus, Prescaler 16)
02C6  32 FA 03      	LD (03FAh),A		;[ZVE1] [0x03FA] = 5 (Retry-Counter fuer Sekundaer-Boot)
02C9  7B            	LD A,E		;[ZVE1]
02CA  D3 34         	OUT (34h),A		;[ZVE1] Port 0x34: Sekundaer-Controller Cmd-Register
02CC  06 00         	LD B,00h		;[ZVE1] BC=0: maximale Delay-Schleife
02CE  CD B6 03      	CALL 03B6h		;[ZVE1]
02D1  CD B6 03      	CALL 03B6h		;[ZVE1]
02D4  21 00 04      	LD HL,0400h		;[ZVE1] HL = 0x0400: Ladeadresse fuer Sekundaer-Boot
02D7  22 F8 03      	LD (03F8h),HL		;[ZVE1]
02DA  16 10         	LD D,10h		;[ZVE1]
02DC  DB 35         	IN A,(35h)		;[ZVE1] Status Port 0x35 lesen
02DE  CB 43         	BIT 0,E		;[ZVE1] E Bit0: Laufwerks-Typ-Unterscheidung
02E0  20 02         	JR NZ,02E4h		;[ZVE1]
02E2  16 08         	LD D,08h		;[ZVE1]
02E4  A2            	AND D		;[ZVE1]
02E5  CA 97 03      	JP Z,0397h		;[ZVE1] Status-Bit fehlt → HALT bei 0x0397
02E8  AF            	XOR A		;[ZVE1]
02E9  32 F6 03      	LD (03F6h),A		;[ZVE1] [0x03F6] = 0 (Byte-Zaehler reset)
02EC  3E 14         	LD A,14h		;[ZVE1]
02EE  32 F7 03      	LD (03F7h),A		;[ZVE1] [0x03F7] = 0x14 = 20 (Block-Zaehler)
02F1  3E A7         	LD A,A7h		;[ZVE1]
02F3  D3 0D         INIT_CTC2:	OUT (0Dh),A		;[ZVE1] CTC Kanal 1: 0xA7 = Timer-Modus, Prescaler 16, kein Interrupt
02F5  3E FF         	LD A,FFh		;[ZVE1] Zeitkonstante = 0xFF (maximaler Timeout)
02F7  D3 0D         	OUT (0Dh),A		;[ZVE1]
02F9  DB 34         	IN A,(34h)		;[ZVE1] Sekundaer-Controller Status pruefen (Bit7 = Bereit-Signal)
02FB  CB 7F         	BIT 7,A		;[ZVE1]
02FD  20 18         	JR NZ,0317h		;[ZVE1] Bit7=1: bereit → Konfiguration abschliessen
02FF  F6 20         	OR 20h		;[ZVE1] Bit7=0: noch nicht bereit → Bit5 setzen und warten
0301  D3 34         	OUT (34h),A		;[ZVE1]
0303  2E 03         	LD L,03h		;[ZVE1]
0305  CD B6 03      	CALL 03B6h		;[ZVE1]
0308  DB 34         	IN A,(34h)		;[ZVE1]
030A  CB 7F         	BIT 7,A		;[ZVE1]
030C  20 09         	JR NZ,0317h		;[ZVE1]
030E  2D            	DEC L		;[ZVE1]
030F  20 F4         	JR NZ,0305h		;[ZVE1]
0311  E6 DF         	AND DFh		;[ZVE1] Bit5 ruecksetzen
0313  D3 34         	OUT (34h),A		;[ZVE1]
0315  18 24         	JR 033Bh		;[ZVE1]
0317  E6 DF         	AND DFh		;[ZVE1] Bit7=1 Pfad: Konfiguration abschliessen
0319  D3 34         	OUT (34h),A		;[ZVE1]
031B  CD B6 03      	CALL 03B6h		;[ZVE1]
031E  F6 30         	OR 30h		;[ZVE1] Transfer-Modus: Bits 5 und 4 setzen
0320  D3 34         	OUT (34h),A		;[ZVE1]
0322  E6 C3         	AND C3h		;[ZVE1] Nur Bits 7,6 behalten
0324  D3 34         	OUT (34h),A		;[ZVE1]
0326  DB 35         	IN A,(35h)		;[ZVE1] warte auf Status-Bit
0328  A2            	AND D		;[ZVE1]
0329  28 FB         	JR Z,0326h		;[ZVE1]
032B  DB 34         	IN A,(34h)		;[ZVE1]
032D  CB 47         	BIT 0,A		;[ZVE1] Bit0: Laufwerks-Typ-Unterscheidung
032F  20 04         	JR NZ,0335h		;[ZVE1]
0331  C6 04         	ADD A,04h		;[ZVE1] Typ A: +4
0333  18 02         	JR 0337h		;[ZVE1]
0335  C6 08         	ADD A,08h		;[ZVE1] Typ B: +8
0337  D3 34         	OUT (34h),A		;[ZVE1]
0339  18 BE         	JR 02F9h		;[ZVE1]
033B  4F            	LD C,A		;[ZVE1] Bereit: Transfer-Parameter einstellen
033C  E6 F3         	AND F3h		;[ZVE1] Bits 1,0 loeschen, Bit6 setzen
033E  F6 40         	OR 40h		;[ZVE1]
0340  D3 34         	OUT (34h),A		;[ZVE1]
0342  79            	LD A,C		;[ZVE1]
0343  D3 34         	OUT (34h),A		;[ZVE1]
0345  F6 10         	OR 10h		;[ZVE1] Bit4 setzen (Transfer Start)
0347  D3 34         	OUT (34h),A		;[ZVE1]
0349  DB 34         	IN A,(34h)		;[ZVE1] warte bis Bit7 gesetzt (Transfer laeuft)
034B  17            	RLA		;[ZVE1]
034C  30 FB         	JR NC,0349h		;[ZVE1]
034E  06 00         	LD B,00h		;[ZVE1]
0350  CD B6 03      	CALL 03B6h		;[ZVE1]
0353  16 04         	LD D,04h		;[ZVE1]
0355  3E F0         	LD A,F0h		;[ZVE1]
0357  D3 33         	OUT (33h),A		;[ZVE1] Port 0x33: Reset/Init-Sequenz fuer Sekundaer-Controller
0359  01 31 83      	LD BC,8331h		;[ZVE1]
035C  3E 97         	LD A,97h		;[ZVE1]
035E  D3 33         	OUT (33h),A		;[ZVE1]
0360  D3 33         	OUT (33h),A		;[ZVE1]
0362  DB 31         	IN A,(31h)		;[ZVE1] warte auf Sync-Byte von Port 0x31
0364  AF            	XOR A		;[ZVE1]
0365  B8            	CP B		;[ZVE1] warte bis B-Zaehler 0 (Sync)
0366  20 FD         	JR NZ,0365h		;[ZVE1]
0368  3E 03         	LD A,03h		;[ZVE1] Reset Port 0x33
036A  D3 33         	OUT (33h),A		;[ZVE1]
036C  2A F8 03      	LD HL,(03F8h)		;[ZVE1] Ladeadresse um 3 dekrementieren (je Sync-Schleife)
036F  2B            	DEC HL		;[ZVE1]
0370  2B            	DEC HL		;[ZVE1]
0371  2B            	DEC HL		;[ZVE1]
0372  22 F8 03      	LD (03F8h),HL		;[ZVE1]
0375  15            	DEC D		;[ZVE1]
0376  20 DD         	JR NZ,0355h		;[ZVE1] D Zyklen wiederholen
0378  01 00 0D      	LD BC,0D00h		;[ZVE1]
037B  CD B6 03      	CALL 03B6h		;[ZVE1]
037E  DB 34         	IN A,(34h)		;[ZVE1] Bit4 ruecksetzen (Transfer Ende)
0380  E6 EF         	AND EFh		;[ZVE1]
0382  D3 34         	OUT (34h),A		;[ZVE1]
0384  3E 21         	LD A,21h		;[ZVE1] CTC Kanal 1: 0x21 = Timer-Stop
0386  D3 0D         	OUT (0Dh),A		;[ZVE1]
0388  CD B6 01      	CALL 01B6h		;[ZVE1] Bootsektor-Signatur pruefen (wie bei Floppy-Boot)
038B  20 0B         	JR NZ,0398h		;[ZVE1] NZ: Signatur falsch → Fehler-Pfad
038D  CD 34 04      	CALL 0434h		;[ZVE1] Signatur OK: Bootsektor-Code ausfuehren
0390  C3 77 01      	JP 0177h		;[ZVE1]
0393  3E 03         	LD A,03h		;[ZVE1] Hilfs-Reset Port 0x33 (Rueckkehr-Ziel von ISR 0x03D4 via Stack-Trick)
0395  D3 33         	OUT (33h),A		;[ZVE1]
0397  00            	NOP		;[ZVE1]
0398  3E 21         	LD A,21h		;[ZVE1] Fehler: Signature-Mismatch oder Transfer-Fehler → Retry
039A  D3 0D         	OUT (0Dh),A		;[ZVE1]
039C  21 FA 03      	LD HL,03FAh		;[ZVE1] [0x03FA]-- (Retry-Counter)
039F  35            	DEC (HL)		;[ZVE1]
03A0  3E 03         	LD A,03h		;[ZVE1]
03A2  D3 34         	OUT (34h),A		;[ZVE1]
03A4  C2 C9 02      	JP NZ,02C9h		;[ZVE1] NZ: noch Retries uebrig → von vorn
03A7  CB 43         	BIT 0,E		;[ZVE1] Bit0 von E: weiteren Laufwerks-Typ versuchen
03A9  28 05         	JR Z,03B0h		;[ZVE1]
03AB  1E 06         	LD E,06h		;[ZVE1]
03AD  C3 C4 02      	JP 02C4h		;[ZVE1]
03B0  3E 9F         	LD A,9Fh		;[ZVE1] [HALT-SCHLEIFE (kein Boot moeglich)] | Alle Boot-Versuche erschoepft: Fehler-Code ausgeben und anhalten.
03B2  D3 03         	OUT (03h),A		;[ZVE1] Port 0x03: Fehler-/Status-Ausgabe (evtl. Frontplatten-LED oder Panel)
03B4  18 FE         	JR 03B4h		;[ZVE1] Endlosschleife: System bleibt stehen
03B6  0D            	DEC C		;[ZVE1] [DELAY-SUBROUTINE (CALL-Ziel von vielen Stellen)] | Zaehlt C runter, dann B x C - Dauer: ca. (B+1)x(C+1)x13 Takte
03B7  20 FD         	JR NZ,03B6h		;[ZVE1]
03B9  10 FB         	DJNZ 03B6h		;[ZVE1]
03BB  C9            	RET		;[ZVE1]
03BC  FB            	EI		;[ZVE1] [ISR: SEKUNDAERER CONTROLLER KANAL 0] | Liest Byte von Port 0x31, bestaetigt Empfang via Port 0x33. | Adresse in [0x03F0] (gesetzt bei 0x0285).
03BD  F5            	PUSH AF		;[ZVE1]
03BE  DB 31         	IN A,(31h)		;[ZVE1] Daten-Byte vom Sekundaer-Controller lesen
03C0  3E F4         	LD A,F4h		;[ZVE1]
03C2  D3 33         	OUT (33h),A		;[ZVE1] Empfangs-Bestaetigung an Port 0x33
03C4  F1            	POP AF		;[ZVE1]
03C5  ED 4D         	RETI		;[ZVE1]
03C7  FB            	EI		;[ZVE1] [ISR: BYTE-TRANSFER (Software-DMA via INI)] | Schreibt ein Byte vom Sekundaer-Controller (Port C) in RAM bei [0x03F8]. | Adresse in [0x03F4] (gesetzt bei 0x0291).
03C8  F5            	PUSH AF		;[ZVE1]
03C9  E5            	PUSH HL		;[ZVE1]
03CA  2A F8 03      	LD HL,(03F8h)		;[ZVE1] HL = aktuelle Schreib-Adresse im RAM
03CD  ED A2         	DB EDh,A2h		;[ZVE1] INI (ED A2): 1 Byte aus Port C → (HL++), B--
03CF  22 F8 03      	LD (03F8h),HL		;[ZVE1] neue Schreib-Adresse sichern
03D2  18 0D         	JR 03E1h		;[ZVE1]
03D4  FB            	EI		;[ZVE1] [ISR: SEKUNDAERER CONTROLLER KANAL 1 (Block-Zaehler)] | Dekrementiert Byte-Zaehler [0x03F6] und Block-Zaehler [0x03F7]. | Wenn beide 0: Bootvorgang abgeschlossen → springe zu 0x0393. | Adresse in [0x03F2] (gesetzt bei 0x028B).
03D5  F5            	PUSH AF		;[ZVE1]
03D6  E5            	PUSH HL		;[ZVE1]
03D7  21 F6 03      	LD HL,03F6h		;[ZVE1] HL → [0x03F6] = Byte-Zaehler
03DA  35            	DEC (HL)		;[ZVE1] Byte-Zaehler--
03DB  20 04         	JR NZ,03E1h		;[ZVE1] noch Bytes im Block → normal RETI
03DD  2C            	INC L		;[ZVE1] INC L: HL → [0x03F7] = Block-Zaehler
03DE  35            	DEC (HL)		;[ZVE1] Block-Zaehler--
03DF  28 04         	JR Z,03E5h		;[ZVE1] alle Bloecke geladen → Abschluss-Pfad
03E1  E1            	POP HL		;[ZVE1]
03E2  F1            	POP AF		;[ZVE1]
03E3  ED 4D         	RETI		;[ZVE1]
03E5  E1            	POP HL		;[ZVE1] [BOOT-ABSCHLUSS: Ruecksprung-Adresse manipulieren] | Ersetzt normale RETI-Ruecksprung-Adresse durch 0x0393 (Reset Port 0x33). | EX (SP),HL tauscht Ruecksprung-Adresse auf dem Stack.
03E6  F1            	POP AF		;[ZVE1]
03E7  F1            	POP AF		;[ZVE1] zweites POP AF: rauemt zusaetzlichen Stack-Frame ab
03E8  21 93 03      	LD HL,0393h		;[ZVE1] neues Sprungziel: 0x0393 (Reset-Code nach erfolgreichem Transfer)
03EB  E3            	EX (SP),HL		;[ZVE1] tausche [SP] mit HL: Ruecksprung geht jetzt nach 0x0393
03EC  F5            	PUSH AF		;[ZVE1]
03ED  ED 4D         	RETI		;[ZVE1]
03EF  00            	NOP		;[ZVE1] [RAM-VARIABLEN-BEREICH (0x03EF-0x03FF)] | Diese Adressen enthalten zur Laufzeit Boot-Variablen. | Der Disassembler zeigt zufaellige Opcodes, da die Bytes | nach dem Booten ueberschrieben werden.
03F0  00            	NOP		;[ZVE1] 0x03F0-0x03F1: Ladeadresse Sektor-Daten (2 Byte, init: 0x0400)
03F1  04            	INC B		;[ZVE1]
03F2  FE 00         	CP 00h		;[ZVE1] 0x03F2-0x03F3: ISR-Zeiger Kanal 1 (2 Byte) / erwarteter Zylinder
03F4  00            	NOP		;[ZVE1] 0x03F4-0x03F5: ISR-Zeiger Kanal 2 (2 Byte) / erwarteter Kopf + Sektor-ID
03F5  00            	NOP		;[ZVE1]
03F6  00            	NOP		;[ZVE1] 0x03F6: Byte-Zaehler (Sek.-Boot) / Size-Code (Floppy)
03F7  00            	NOP		;[ZVE1] 0x03F7: Indexpuls-Zaehler (4→0) / Block-Zaehler (Sek.-Boot)
03F8  00            	NOP		;[ZVE1] 0x03F8-0x03F9: Abschluss-Flag (0/1/3) oder Schreib-Adresse (2 Byte)
03F9  00            	NOP		;[ZVE1]
03FA  00            	NOP		;[ZVE1] 0x03FA: Seek-/Retry-Counter (init: 5)
03FB  08            	EX AF,AF'		;[ZVE1] 0x03FB: (unbenutzt)
03FC  00            	NOP		;[ZVE1] 0x03FC: Ctrl-Wert fuer Port 0x10 (init: 0xEE, rotiert bei Retry)
03FD  00            	NOP		;[ZVE1] 0x03FD: FM/MFM-Pfad (MK, Port 0x10 bit1): 0x87=FM, 0x85=MFM; bit7=Step-Unterdr.
03FE  F7            	RST 30h		;[ZVE1] 0x03FE-0x03FF: Puffer-Ende / unbenutzt
03FF  6B            	LD L,E		;[ZVE1]

	END
